---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sayfa Bulunamadı - Laflaf" isAdmin={true}>
  <div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center">
      <div class="text-9xl font-bold text-gray-300 dark:text-gray-700 mb-4">404</div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Sayfa Bulunamadı</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-8">Aradığınız sayfa mevcut değil veya taşınmış olabilir.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition">Ana Sayfaya Dön</a>
        <a href="/admin" class="px-6 py-3 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">Admin Paneli</a>
      </div>
    </div>
  </div>
</BaseLayout>