---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Upps Kayboldun galiba">
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-12 relative overflow-hidden">
    <!-- Decorative background blobs -->
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl pointer-events-none"></div>
    
    <div class="relative z-10 max-w-lg w-full bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl border border-gray-150 dark:border-gray-700 p-8 md:p-12 rounded-3xl shadow-2xl text-center transition-all duration-300 hover:shadow-orange-500/10">
      
      <!-- Icon with pulse animation -->
      <div class="w-24 h-24 mx-auto bg-gradient-to-tr from-orange-500 to-purple-600 rounded-3xl flex items-center justify-center text-white text-4xl shadow-lg mb-8 animate-bounce">
        <i class="fas fa-compass"></i>
      </div>
      
      <!-- Big styled 404 text -->
      <div class="text-7xl md:text-8xl font-black bg-gradient-to-r from-orange-500 to-purple-600 bg-clip-text text-transparent tracking-tighter mb-4 font-outfit select-none">
        404
      </div>
      
      <!-- Heading -->
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white mb-4 leading-tight font-outfit tracking-tight">
        Upps Kayboldun galiba
      </h1>
      
      <!-- Description -->
      <p class="text-gray-500 dark:text-gray-400 mb-10 leading-relaxed text-sm md:text-base">
        Aradığınız sayfa mevcut değil, silinmiş veya adresi değişmiş olabilir. Keşfetmeye ana sayfamızdan devam edebilirsiniz.
      </p>
      
      <!-- Action button with premium styling -->
      <div class="flex justify-center">
        <a href="/" class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-orange-500 to-purple-600 hover:from-orange-600 hover:to-purple-700 text-white font-bold rounded-2xl shadow-lg hover:shadow-xl hover:shadow-orange-500/20 transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 group uppercase tracking-wider text-xs">
          <i class="fas fa-home mr-2.5 group-hover:scale-110 transition-transform"></i>
          Ana Sayfaya Dön
        </a>
      </div>
      
    </div>
  </div>
</BaseLayout>