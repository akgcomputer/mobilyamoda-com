---
import BaseLayout from '../layouts/BaseLayout.astro';

// Mock içerik verisi (geçici)
const posts: Record<string, any> = {
  'icerik-1': {
    title: 'Meraklı İçerik 1',
    content: '<p>Bu bir test içeriğidir. Lorem ipsum dolor sit amet.</p><p>İkinci paragraf.</p>',
    date: '2024-01-01',
    category: 'Keşfet',
    viewCount: 1250,
    likeCount: 89
  },
  'icerik-2': {
    title: 'Meraklı İçerik 2',
    content: '<p>İkinci test içeriği.</p>',
    date: '2024-01-02',
    category: 'Trend',
    viewCount: 890,
    likeCount: 45
  }
};

const slug = Astro.params.slug;
const post = posts[slug as string];

if (!post) {
  return Astro.redirect('/');
}
---

<BaseLayout title={post.title}>
  <article class="max-w-3xl mx-auto px-4 py-8">
    <!-- Kategori -->
    <div class="mb-4">
      <span class="inline-block px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm">
        {post.category}
      </span>
    </div>

    <!-- Başlık -->
    <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.title}</h1>

    <!-- Meta -->
    <div class="flex items-center gap-4 text-sm text-gray-500 mb-8 pb-4 border-b">
      <span>📅 {post.date}</span>
      <span>👁️ {post.viewCount}</span>
      <span>❤️ {post.likeCount}</span>
    </div>

    <!-- İçerik -->
    <div class="prose prose-lg max-w-none dark:prose-invert" set:html={post.content} />

    <!-- Beğeni Butonu -->
    <div class="mt-8 pt-4 border-t">
      <button id="likeBtn" class="flex items-center gap-2 px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition">
        <span>❤️</span>
        <span>Beğen ({post.likeCount})</span>
      </button>
    </div>
  </article>
</BaseLayout>

<script>
  document.getElementById('likeBtn')?.addEventListener('click', () => {
    alert('Beğeni eklendi! (Demo)');
  });
</script>