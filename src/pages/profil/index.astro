          <div class="flex items-center gap-6 mb-10 pb-8 border-b dark:border-gray-700">
            <div class="w-24 h-24 bg-gradient-to-tr from-purple-500 to-orange-500 rounded-full flex items-center justify-center text-white text-4xl font-bold">
