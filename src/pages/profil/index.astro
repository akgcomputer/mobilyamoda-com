                    </div>
                    <div class="flex gap-2 justify-end">
                      <button type="button" id="cancelAddressBtn" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-[11px] font-bold rounded-lg transition text-gray-500">İptal</button>
                      <button type="button" id="saveAddressBtn" class="px-3 py-1.5 bg-orange-600 hover:bg-orange-700 text-[11px] font-bold text-white rounded-lg transition shadow">Kaydet</button>
                    </div>
                  </div>

                  <!-- Adresler Listesi -->
                  <div id="addressesList" class="space-y-2 max-h-[160px] overflow-y-auto pr-1">
                    <!-- Dinamik doldurulacak -->
                  </div>
                </div>

                <!-- Fatura Adreslerim (Seçim Alanı) -->
                <div class="border-t dark:border-gray-800 pt-6">
                  <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">Fatura Adresim</label>
                  <p class="text-[11px] text-gray-500 mb-3">Yukarıda eklediğiniz kargo adreslerinden birini fatura adresi olarak seçebilirsiniz.</p>
                  <select id="billingAddressSelect" class="w-full px-4 py-2.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-sm focus:border-orange-500 focus:outline-none transition shadow-sm text-gray-900 dark:text-white">
                    <option value="">Lütfen seçin...</option>
                  </select>
                </div>

                <!-- Telefon Numaralarım -->
                <div class="border-t dark:border-gray-800 pt-6">
                  <div class="flex justify-between items-center mb-3">
                    <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Telefon Numaralarım</label>
                    <button type="button" id="toggleAddPhoneBtn" class="text-xs font-bold text-orange-600 hover:text-orange-700 flex items-center gap-1">
                      <i class="fas fa-plus-circle"></i> Ekle
                    </button>
                  </div>
                  
                  <!-- Telefon Ekle Formu -->
                  <div id="addPhoneForm" class="hidden bg-white dark:bg-gray-800 border border-gray-250 dark:border-gray-700 p-4 rounded-xl mb-4 space-y-3 shadow-md">
                    <div>
                      <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-1">Telefon Tanımı</label>
                      <input type="text" id="newPhoneName" class="w-full px-3 py-2 text-xs bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-white" placeholder="örn. Cep Telefonum" />
                    </div>
                    <div>
                      <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-1">Telefon Numarası</label>
                      <input type="tel" id="newPhoneNumber" class="w-full px-3 py-2 text-xs bg-gray-50 dark:bg-gray-950 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-white" placeholder="05XX XXX XX XX" />
                    </div>
                    <div class="flex gap-2 justify-end">
                      <button type="button" id="cancelPhoneBtn" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-[11px] font-bold rounded-lg transition text-gray-500">İptal</button>
                      <button type="button" id="savePhoneBtn" class="px-3 py-1.5 bg-orange-600 hover:bg-orange-700 text-[11px] font-bold text-white rounded-lg transition shadow">Kaydet</button>
                    </div>
                  </div>

                  <!-- Telefonlar Listesi -->
                  <div id="phonesList" class="space-y-2 max-h-[160px] overflow-y-auto pr-1">
                    <!-- Dinamik doldurulacak -->
                  </div>
                </div>
                
                <!-- Web Bildirimleri -->
                <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm border-t">
                  <div class="flex items-center gap-3">
                    <i class="fas fa-bell text-orange-500 text-xl"></i>
                    <div>
                      <div class="font-bold text-gray-800 dark:text-gray-200 text-sm">Web Bildirimleri</div>
                      <div class="text-xs text-gray-500">Önemli duyurulardan ve fırsatlardan haberdar olun</div>
                    </div>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" value="" class="sr-only peer" checked>
                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
                  </label>
                </div>

                <!-- Çıkış Yap Butonu -->
                <div class="pt-4 border-t dark:border-gray-800">
                  <form method="POST">
                    <input type="hidden" name="action" value="logout" />
                    <button type="submit" class="flex items-center justify-center gap-2 w-full p-3.5 bg-red-50 hover:bg-red-100 dark:bg-red-950/20 dark:hover:bg-red-950/40 text-red-600 dark:text-red-400 rounded-xl transition font-bold text-sm shadow-sm">
                      <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                    </button>
                  </form>
                </div>

              </div>
            </div>

            <!-- Sağ Kolon: Siparişlerim -->
            <div class="lg:col-span-6 space-y-6">
              <div class="bg-gray-50 dark:bg-gray-900/50 p-6 rounded-2xl border border-gray-150 dark:border-gray-700 space-y-6">
                <h2 class="text-xl font-bold flex items-center gap-2 font-outfit border-b dark:border-gray-800 pb-3">
                  <i class="fas fa-shopping-bag text-orange-500"></i> Siparişlerim
                </h2>

                <!-- Sipariş Detay Paneli (Dinamik Gösterim) -->
