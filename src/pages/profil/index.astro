---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUsers, createUser } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

// Basit Cookie tabanlı Mock Authentication
const sessionData = Astro.cookies.has('user_session') ? Astro.cookies.get('user_session')?.json() : null;
const isLoggedIn = sessionData !== null && sessionData.id !== undefined;
let userRole = 'Abone';
let userName = 'Misafir';
let errorMessage = '';
let successMessage = '';
const actionParam = Astro.url.searchParams.get('action') || 'register';
const redirectParam = Astro.url.searchParams.get('redirect') || '';

let userData: any = null;
let userOrders: any[] = [];
let userCommentCount = 0;

if (isLoggedIn && sessionData) {
  userRole = sessionData.role === 'abone' ? 'Müşteri / Abone' : sessionData.role;
  userName = sessionData.name;
  const users = await getUsers(dbBinding);
  userData = users.find(u => u.id === sessionData.id);
  
  // Siparişleri Çek
  try {
    if (dbBinding) {
      const stmt = await dbBinding.prepare('SELECT * FROM orders WHERE user_id = ? ORDER BY createdAt DESC').bind(sessionData.id).all();
      if (stmt.results) userOrders = stmt.results;

      // Yorum Sayısını Çek
      if (userData && userData.email) {
        const cStmt = await dbBinding.prepare('SELECT COUNT(*) as c FROM comments WHERE author_email = ?').bind(userData.email).first();
        userCommentCount = cStmt ? (cStmt.c as number) : 0;
      }
    }
  } catch (e) {
    console.error(e);
  }
}

// Form Post İşlemleri
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const redirect = (formData.get('redirect') as string) || redirectParam || '';

  if (action === 'login') {
    const usernameInput = formData.get('username') as string;
    const password = formData.get('password') as string;
    
    if (!usernameInput || !password) {
      errorMessage = 'E-posta/Telefon ve şifre zorunludur.';
    } else {
      const users = await getUsers(dbBinding);
      const existingUser = users.find(u => u.email === usernameInput || u.phone === usernameInput);
      
      if (existingUser) {
        if (existingUser.password === password) {
          if (existingUser.status !== 'aktif') {
            errorMessage = 'Hesabınız henüz onaylanmamıştır. Lütfen yöneticinin onaylamasını bekleyin.';
          } else {
            Astro.cookies.set('user_session', { id: existingUser.id, name: existingUser.name, role: existingUser.role }, { path: '/' });
            if (existingUser.role !== 'abone') {
              return Astro.redirect('/admin');
            }
            if (redirect === 'checkout') {
              return Astro.redirect('/checkout');
            }
            return Astro.redirect('/profil');
          }
        } else {
          errorMessage = 'Şifre hatalı.';
        }
      } else {
        errorMessage = 'Bu kullanıcı adı (E-posta / Telefon) ile kayıtlı üye bulunamadı.';
      }
    }
  }

  if (action === 'register') {
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const name = formData.get('name') as string || 'Yeni Kullanıcı';
    const phone = formData.get('phone') as string || '';
    const role = formData.get('role') as string || 'abone';
    const password_confirm = formData.get('password_confirm') as string;
    
    if (!email || !password) {
      errorMessage = 'E-posta ve şifre zorunludur.';
    } else if (password !== password_confirm) {
      errorMessage = 'Şifreler eşleşmiyor.';
    } else {
      const users = await getUsers(dbBinding);
      const existingUser = users.find(u => u.email === email);
      
      if (existingUser) {
        errorMessage = 'Bu e-posta adresi zaten kullanımda.';
      } else {
        const clientIp = Astro.clientAddress || 'Bilinmiyor';
        const isAbone = role.toLowerCase() === 'abone';
        const userStatus = isAbone ? 'aktif' : 'pasif';
        
        const newUser = await createUser({
          name, email, password, phone, role: role.toLowerCase(), status: userStatus, ip: clientIp
        }, dbBinding);
        
        if (newUser) {
          if (isAbone) {
            Astro.cookies.set('user_session', { id: newUser.id, name: newUser.name, role: newUser.role }, { path: '/' });
            if (redirect === 'checkout') {
              return Astro.redirect('/checkout');
            }
            return Astro.redirect('/profil?registration_success=true');
          } else {
            successMessage = 'Kayıt başarılı! Yöneticinin onayından sonra giriş yapabilirsiniz.';
          }
        } else {
          errorMessage = 'Kayıt sırasında bir hata oluştu.';
        }
      }
    }
  }

  if (action === 'update_profile') {
    const sessionData = Astro.cookies.get('user_session')?.json();
    if (sessionData) {
      const phone = formData.get('phone') as string;
      const address = formData.get('address') as string;
      try {
        await dbBinding.prepare('UPDATE users SET phone = ?, address = ? WHERE id = ?').bind(phone, address, sessionData.id).run();
        successMessage = 'Profil bilgileriniz başarıyla güncellendi.';
        const users = await getUsers(dbBinding);
        userData = users.find(u => u.id === sessionData.id);
      } catch (e) {
        errorMessage = 'Profil güncellenirken bir hata oluştu.';
      }
    }
  }

  if (action === 'logout') {
    Astro.cookies.delete('user_session', { path: '/' });
    return Astro.redirect('/profil');
  }
}
---

<BaseLayout title={isLoggedIn ? "Profilim" : "Giriş / Kayıt"} description="Laflaf kullanıcı işlemleri sayfası.">
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    
    {isLoggedIn ? (
      <!-- PROFİL (GİRİŞ YAPILMIŞ DURUM) -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="p-8 sm:p-12">
          <div class="flex items-center gap-6 mb-10 pb-8 border-b dark:border-gray-700">
            <div class="w-24 h-24 bg-gradient-to-tr from-purple-500 to-orange-500 rounded-full flex items-center justify-center text-white text-4xl font-bold">
              {userName.charAt(0).toUpperCase()}
            </div>
            <div>
              <h1 class="text-3xl font-bold mb-1">{userName}</h1>
              <div class="flex items-center gap-3">
                <span class="inline-block px-3 py-1 bg-purple-100 dark:bg-purple-900/50 text-purple-700 dark:text-purple-300 rounded-full text-sm font-medium">
                  {userRole}
                </span>
                <span class="text-sm text-gray-500 flex items-center gap-1">
                  <i class="far fa-comment-dots"></i> {userCommentCount} İçeriğe Yorum Yaptınız
                </span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Adres ve İletişim Bilgileri (Müşteri) -->
            <div>
              <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i class="fas fa-map-marker-alt text-orange-500"></i> İletişim & Adres Bilgilerim
              </h2>
              <form method="POST" class="space-y-4">
                <input type="hidden" name="action" value="update_profile" />
                <div>
                  <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Telefon Numarası</label>
                  <input type="tel" name="phone" value={userData?.phone || ''} class="w-full px-4 py-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700 focus:border-purple-500 focus:outline-none transition" placeholder="05XX XXX XX XX" />
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Teslimat / Fatura Adresi</label>
                  <textarea name="address" rows="3" class="w-full px-4 py-3 border rounded-xl dark:bg-gray-900 dark:border-gray-700 focus:border-purple-500 focus:outline-none transition" placeholder="Açık adresiniz...">{userData?.address || ''}</textarea>
                </div>
                <button type="submit" class="w-full px-6 py-3 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition font-bold shadow-md">Bilgilerimi Kaydet</button>
              </form>
            </div>

            <!-- Aksiyonlar -->
            <div>
              <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                <i class="fas fa-bolt text-orange-500"></i> Hızlı İşlemler
              </h2>
              <div class="space-y-4">
                {userRole !== 'abone' && (
                  <a href="/admin" class="flex items-center gap-3 w-full p-4 bg-gradient-to-r from-orange-500 to-purple-600 text-white rounded-xl hover:shadow-lg transition font-medium">
                    <i class="fas fa-tachometer-alt text-xl"></i> Yönetim Paneline Git
                  </a>
                )}
                <form method="POST">
                  <input type="hidden" name="action" value="logout" />
                  <button type="submit" class="flex items-center gap-3 w-full p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/40 transition font-medium text-left">
                    <i class="fas fa-sign-out-alt text-xl"></i> Çıkış Yap
                  </button>
                </form>

                <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-700">
                  <div class="flex items-center gap-3">
                    <i class="fas fa-bell text-orange-500 text-xl"></i>
                    <div>
                      <div class="font-bold text-gray-800 dark:text-gray-200">Web Bildirimleri</div>
                      <div class="text-xs text-gray-500">Önemli duyurulardan ve fırsatlardan haberdar olun</div>
                    </div>
                  </div>
                  <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" value="" class="sr-only peer" checked>
                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-purple-600"></div>
                  </label>
                </div>
              </div>
            </div>

            <!-- Siparişlerim -->
            <div class="md:col-span-2 mt-6 border-t dark:border-gray-700 pt-10">
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
                <i class="fas fa-shopping-bag text-orange-500"></i> Son Siparişlerim
              </h2>
              {userOrders.length > 0 ? (
                <div class="space-y-4">
                  {userOrders.map(order => (
                    <div class="border dark:border-gray-700 p-4 rounded-xl flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-gray-50 dark:bg-gray-900/50 hover:bg-gray-100 dark:hover:bg-gray-800 transition">
                      <div>
                        <div class="font-bold text-lg text-purple-600 dark:text-purple-400">Sipariş #{order.id}</div>
                        <div class="text-sm text-gray-500">{new Date(order.createdAt).toLocaleDateString('tr-TR')}</div>
                      </div>
                      <div class="flex-1 md:text-center">
                        <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${
                          order.status === 'onaylandi' ? 'bg-blue-100 text-blue-700' :
                          order.status === 'kargolandi' ? 'bg-indigo-100 text-indigo-700' :
                          order.status === 'tamamlandi' ? 'bg-green-100 text-green-700' :
                          order.status === 'iptal' ? 'bg-red-100 text-red-700' :
                          'bg-orange-100 text-orange-700'
                        }`}>
                          {order.status === 'bekliyor' ? 'Bekliyor' : order.status}
                        </span>
                      </div>
                      <div class="font-bold text-xl">
                        {order.total_amount.toLocaleString('tr-TR', {style:'currency', currency:'TRY', minimumFractionDigits: 0, maximumFractionDigits: 0})}
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="text-center py-12 bg-gray-50 dark:bg-gray-900/50 rounded-xl border dark:border-gray-700 border-dashed">
                  <i class="fas fa-box-open text-4xl text-gray-400 mb-3"></i>
                  <p class="text-gray-500">Henüz siparişiniz bulunmuyor.</p>
                  <a href="/urunler" class="inline-block mt-4 text-orange-600 font-bold hover:underline">Alışverişe Başla</a>
                </div>
              )}
            </div>
          </div>

        </div>
      </div>
    ) : (
      <!-- GİRİŞ / KAYIT SEÇENEKLERİ (KART TASARIMI) -->
      <div class="space-y-10">
        
        <!-- Hata & Başarı Mesajları -->
        {errorMessage && (
          <div class="p-4 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-xl border border-red-200 dark:border-red-800 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-xl"></i>
            <span>{errorMessage}</span>
          </div>
        )}
        {successMessage && (
          <div class="p-4 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-xl border border-green-200 dark:border-green-800 flex items-center gap-3">
            <i class="fas fa-check-circle text-xl"></i>
            <span>{successMessage}</span>
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <!-- Kart 1: Ziyaretçi Olarak Devam Et -->
          <div id="cardGuest" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-orange-100 dark:bg-orange-950/30 text-orange-600 dark:text-orange-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-user-secret"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Ziyaretçi Olarak Devam Et</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Üye olmadan içeriklere yorum yazabilir veya doğrudan ödeme adımına geçerek hızlıca alışverişinizi tamamlayabilirsiniz.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-orange-600 dark:text-orange-400 group-hover:translate-x-1 transition-transform">
                Devam Et <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

          <!-- Kart 2: Üye Ol -->
          <div id="cardRegister" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-purple-500 dark:hover:border-purple-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-purple-100 dark:bg-purple-950/30 text-purple-600 dark:text-purple-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-user-plus"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Yeni Üyelik Oluştur</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Fırsatları kaçırmamak, sipariş takibi yapmak ve yorum eklemek için üye olun.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-purple-600 dark:text-purple-400 group-hover:translate-x-1 transition-transform">
                Kaydol <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

          <!-- Kart 3: Giriş Yap -->
          <div id="cardLogin" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-key"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Üye Girişi Yap</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Zaten hesabınız var mı? Güvenli şekilde giriş yapın ve alışverişe devam edin.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-blue-600 dark:text-blue-400 group-hover:translate-x-1 transition-transform">
                Giriş Yap <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

        </div>

        <!-- YENİ ÜYE FORMU BÖLÜMÜ -->
        <div id="sectionRegister" class="hidden bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-700 p-8 sm:p-12 max-w-2xl mx-auto transform transition-all duration-300">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white font-outfit">Yeni Üyelik Oluştur</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Aramıza katılarak avantajlı alışverişin keyfini çıkarın.</p>
          </div>

          <form method="POST" id="registerForm" class="space-y-6">
            <input type="hidden" name="action" value="register" />
            <input type="hidden" name="redirect" value={redirectParam} />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Ad Soyad *</label>
                <input type="text" name="name" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="Ahmet Yılmaz">
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Cep Telefonu</label>
                <input type="tel" name="phone" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="05XX XXX XX XX">
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">E-posta *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="ornek@email.com">
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre *</label>
                <input type="password" name="password" id="regPassword" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="••••••••">
                <div class="mt-2 text-xs text-gray-500 space-y-1" id="pwRequirements">
                  <p class="req-length text-red-500">❌ En az 8 karakter</p>
                  <p class="req-upper text-red-500">❌ Büyük harf içermeli</p>
                  <p class="req-lower text-red-500">❌ Küçük harf içermeli</p>
                  <p class="req-number text-red-500">❌ Rakam içermeli</p>
                  <p class="req-symbol text-red-500">❌ Sembol içermeli (@$!%*?& vb.)</p>
                </div>
                <div id="pwSuccess" class="hidden mt-2 text-sm font-bold text-green-600">✅ Şifre zorluk seviyesi uygun</div>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre (Tekrar) *</label>
                <input type="password" name="password_confirm" id="regPasswordConfirm" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="••••••••">
                <div id="pwMatchError" class="hidden mt-2 text-xs text-red-500">Şifreler eşleşmiyor</div>
              </div>
            </div>

            <div class="p-5 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-700">
              <label class="block text-sm font-bold mb-3">Hesap Türü Seçimi</label>
              <div class="flex flex-wrap gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Abone" checked class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Müşteri / Abone</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Yazar" class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Yazar</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Editör" class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Editör</span>
                </label>
              </div>
            </div>

            <button type="submit" id="registerSubmitBtn" disabled class="w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed">
              Lütfen Şifre Kriterlerini Sağlayın
            </button>
          </form>
        </div>

        <!-- ÜYE GİRİŞ FORMU BÖLÜMÜ -->
        <div id="sectionLogin" class="hidden bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-700 p-8 sm:p-12 max-w-2xl mx-auto transform transition-all duration-300">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white font-outfit">Üye Girişi Yap</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Hesabınıza güvenli şekilde giriş yapın.</p>
          </div>

          <form method="POST" class="space-y-6" id="loginForm">
            <input type="hidden" name="action" value="login" />
            <input type="hidden" name="redirect" value={redirectParam} />
            
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Kullanıcı Adı (E-posta veya Telefon)</label>
              <input type="text" name="username" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="ornek@email.com veya 05XXXXXXXXX">
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre</label>
              <input type="password" name="password" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="••••••••">
            </div>

            <!-- Ben Robot Değilim Custom Widget -->
            <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl my-4 select-none shadow-sm">
              <div class="flex items-center gap-3">
                <div class="relative w-8 h-8 flex items-center justify-center">
                  <input type="checkbox" id="recaptchaCheck" class="sr-only" />
                  <div id="recaptchaBox" class="w-6 h-6 border-2 border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 cursor-pointer transition-all flex items-center justify-center hover:border-gray-400">
                    <span id="recaptchaSpinner" class="hidden w-4 h-4 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></span>
                    <i id="recaptchaCheckIcon" class="hidden fas fa-check text-green-500 text-sm"></i>
                  </div>
                </div>
                <label id="recaptchaLabel" class="text-sm font-semibold text-gray-700 dark:text-gray-300 cursor-pointer">Ben robot değilim</label>
              </div>
              <div class="flex flex-col items-center opacity-70">
                <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" alt="reCAPTCHA" class="w-6 h-6 object-contain" />
                <span class="text-[8px] text-gray-400 mt-0.5">reCAPTCHA</span>
              </div>
            </div>

            <button type="submit" id="loginSubmitBtn" disabled class="w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed">
              Giriş Yapmak İçin Doğrulayın
            </button>
          </form>
        </div>

      </div>
    )}

  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Elements
      const cardGuest = document.getElementById('cardGuest');
      const cardRegister = document.getElementById('cardRegister');
      const cardLogin = document.getElementById('cardLogin');
      
      const sectionRegister = document.getElementById('sectionRegister');
      const sectionLogin = document.getElementById('sectionLogin');
      
      // Guest Checkout Card Click handler
      cardGuest?.addEventListener('click', () => {
        window.location.href = '/checkout';
      });

      // Toggling Active States
      const resetCards = () => {
        [cardRegister, cardLogin].forEach(card => {
          card?.classList.remove('border-purple-500', 'border-blue-500', 'shadow-2xl', 'scale-[1.02]');
          card?.classList.add('border-gray-200', 'dark:border-gray-700');
        });
      };

      const selectRegister = () => {
        resetCards();
        cardRegister?.classList.remove('border-gray-200', 'dark:border-gray-700');
        cardRegister?.classList.add('border-purple-500', 'shadow-2xl', 'scale-[1.02]');
        
        sectionLogin?.classList.add('hidden');
        sectionRegister?.classList.remove('hidden');
        sectionRegister?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      };

      const selectLogin = () => {
        resetCards();
        cardLogin?.classList.remove('border-gray-200', 'dark:border-gray-700');
        cardLogin?.classList.add('border-blue-500', 'shadow-2xl', 'scale-[1.02]');
        
        sectionRegister?.classList.add('hidden');
        sectionLogin?.classList.remove('hidden');
        sectionLogin?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      };

      cardRegister?.addEventListener('click', selectRegister);
      cardLogin?.addEventListener('click', selectLogin);

      // Deep Linking trigger via URL Parameter
      const urlParams = new URLSearchParams(window.location.search);
      const action = urlParams.get('action');
      if (action === 'register') {
        selectRegister();
      } else if (action === 'login') {
        selectLogin();
      } else {
        // Default to showing register if error/success exists for register, login if login
        const errorMsg = document.querySelector('.bg-red-100')?.textContent || '';
        const successMsg = document.querySelector('.bg-green-100')?.textContent || '';
        if (errorMsg.includes('Şifre') || errorMsg.includes('kullanıcı adı') || successMsg.includes('onay')) {
          selectLogin();
        } else if (errorMsg || successMsg) {
          selectRegister();
        }
      }

      // --- Custom reCAPTCHA Widget Logic ---
      const recaptchaBox = document.getElementById('recaptchaBox');
      const recaptchaCheck = document.getElementById('recaptchaCheck') as HTMLInputElement | null;
      const recaptchaSpinner = document.getElementById('recaptchaSpinner');
      const recaptchaCheckIcon = document.getElementById('recaptchaCheckIcon');
      const recaptchaLabel = document.getElementById('recaptchaLabel');
      const loginSubmitBtn = document.getElementById('loginSubmitBtn') as HTMLButtonElement | null;
      
      let recaptchaVerified = false;

      const triggerRecaptcha = () => {
        if (recaptchaVerified) return;
        recaptchaVerified = true;

        if (recaptchaBox && recaptchaSpinner && recaptchaCheckIcon && loginSubmitBtn && recaptchaLabel) {
          // Disable clicking recaptcha
          recaptchaBox.style.pointerEvents = 'none';
          if (recaptchaCheck) recaptchaCheck.checked = true;

          // Play interactive spinner animation
          recaptchaSpinner.classList.remove('hidden');
          recaptchaLabel.textContent = 'Doğrulanıyor...';

          setTimeout(() => {
            recaptchaSpinner.classList.add('hidden');
            recaptchaCheckIcon.classList.remove('hidden');
            recaptchaBox.classList.add('bg-green-50', 'border-green-500', 'dark:bg-green-950/20');
            recaptchaLabel.textContent = 'Doğrulandı!';
            recaptchaLabel.className = 'text-sm font-bold text-green-600 dark:text-green-400';

            // Unlock Login Submit Button with Premium styles
            loginSubmitBtn.disabled = false;
            loginSubmitBtn.className = 'w-full py-4 bg-gradient-to-r from-orange-500 to-purple-600 text-white rounded-xl hover:shadow-lg hover:opacity-90 transition font-bold text-lg cursor-pointer transform hover:-translate-y-0.5 active:scale-95 duration-200';
            loginSubmitBtn.textContent = 'Giriş Yap';
          }, 900);
        }
      };

      recaptchaBox?.addEventListener('click', triggerRecaptcha);
      recaptchaLabel?.addEventListener('click', triggerRecaptcha);

      // --- Password Strength Requirements Validation ---
      const pwInput = document.getElementById('regPassword') as HTMLInputElement | null;
      const pwConfirm = document.getElementById('regPasswordConfirm') as HTMLInputElement | null;
      const registerSubmitBtn = document.getElementById('registerSubmitBtn') as HTMLButtonElement | null;
      const reqList = document.getElementById('pwRequirements');
      const pwSuccess = document.getElementById('pwSuccess');
      const matchError = document.getElementById('pwMatchError');

      if (pwInput && registerSubmitBtn && reqList && pwSuccess && matchError && pwConfirm) {
        const validatePassword = () => {
          const val = pwInput.value;
          const confVal = pwConfirm.value;
          
          let isValid = true;

          const rules = [
            { regex: /.{8,}/, el: document.querySelector('.req-length') as HTMLElement | null },
            { regex: /[A-Z]/, el: document.querySelector('.req-upper') as HTMLElement | null },
            { regex: /[a-z]/, el: document.querySelector('.req-lower') as HTMLElement | null },
            { regex: /[0-9]/, el: document.querySelector('.req-number') as HTMLElement | null },
            { regex: /[^A-Za-z0-9]/, el: document.querySelector('.req-symbol') as HTMLElement | null }
          ];

          rules.forEach(rule => {
            if (rule.el) {
              if (rule.regex.test(val)) {
                rule.el.classList.remove('text-red-500');
                rule.el.classList.add('text-green-500');
                rule.el.innerText = rule.el.innerText.replace('❌', '✅');
              } else {
                rule.el.classList.remove('text-green-500');
                rule.el.classList.add('text-red-500');
                rule.el.innerText = rule.el.innerText.replace('✅', '❌');
                isValid = false;
              }
            }
          });

          let isMatch = false;
          if (confVal.length > 0) {
            if (val === confVal) {
              matchError.classList.add('hidden');
              isMatch = true;
            } else {
              matchError.classList.remove('hidden');
            }
          }

          if (isValid) {
            reqList.classList.add('hidden');
            pwSuccess.classList.remove('hidden');
          } else {
            reqList.classList.remove('hidden');
            pwSuccess.classList.add('hidden');
          }

          if (isValid && isMatch) {
            registerSubmitBtn.disabled = false;
            registerSubmitBtn.className = 'w-full py-4 bg-gradient-to-r from-orange-500 to-purple-600 text-white rounded-xl hover:shadow-lg hover:opacity-90 transition font-bold text-lg cursor-pointer transform hover:-translate-y-0.5 active:scale-95 duration-200';
            registerSubmitBtn.innerText = 'Aramıza Katıl';
          } else {
            registerSubmitBtn.disabled = true;
            registerSubmitBtn.className = 'w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed';
            registerSubmitBtn.innerText = 'Lütfen Kriterleri Sağlayın';
          }
        };

        pwInput.addEventListener('input', validatePassword);
        pwConfirm.addEventListener('input', validatePassword);
      }
    });
  </script>
</BaseLayout>
