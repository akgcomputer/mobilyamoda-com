                  {userRole}
                </span>
                <span class="text-sm text-gray-500 flex items-center gap-1">
                  <i class="far fa-comment-dots"></i> {userCommentCount} İçeriğe Yorum Yaptınız
                </span>
              </div>
            </div>
          </div>

          <!-- İki Kolonlu Panel -->
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
            
            <!-- Sol Kolon: Bilgilerim -->
            <div class="lg:col-span-6 space-y-6">
              <div class="bg-gray-50 dark:bg-gray-900/50 p-6 rounded-2xl border border-gray-150 dark:border-gray-700 space-y-6">
                <h2 class="text-xl font-bold flex items-center gap-2 font-outfit border-b dark:border-gray-800 pb-3">
                  <i class="fas fa-user-cog text-orange-500"></i> Bilgilerim
                </h2>
                
                <!-- Bireysel / Kurumsal Seçimi -->
                <div>
                  <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2">Hesap Türü</label>
                  <div class="flex gap-4">
                    <label class="flex items-center gap-2 cursor-pointer bg-white dark:bg-gray-800 px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm flex-1 justify-center">
                      <input type="radio" name="profile_type" value="bireysel" id="profileTypeBireysel" checked class="text-orange-600 focus:ring-orange-500">
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">Bireysel</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer bg-white dark:bg-gray-800 px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm flex-1 justify-center">
                      <input type="radio" name="profile_type" value="kurumsal" id="profileTypeKurumsal" class="text-orange-600 focus:ring-orange-500">
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">Kurumsal</span>
                    </label>
                  </div>
                </div>

                <!-- TC / VKN -->
                <div>
                  <label class="block text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-2" id="tcvknLabel">TC Kimlik Numarası</label>
                  <input type="text" id="profileTcvkn" maxlength="11" class="w-full px-4 py-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-sm focus:border-orange-500 focus:outline-none transition shadow-sm text-gray-900 dark:text-white" placeholder="11 Haneli TC Kimlik No" />
                </div>

                <!-- Kargo Adreslerim -->
                <div class="border-t dark:border-gray-800 pt-6">
