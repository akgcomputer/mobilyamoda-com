---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUsers, createUser } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

// Basit Cookie tabanlı Mock Authentication
const sessionData = Astro.cookies.has('user_session') ? Astro.cookies.get('user_session')?.json() : null;
const isLoggedIn = sessionData !== null && sessionData.id !== undefined;
let userRole = 'Abone';
let userName = 'Misafir';
let errorMessage = '';
let successMessage = '';
const actionParam = Astro.url.searchParams.get('action') || 'register';
const redirectParam = Astro.url.searchParams.get('redirect') || '';

let userData: any = null;
let userOrders: any[] = [];
let userCommentCount = 0;

if (isLoggedIn && sessionData) {
  userRole = sessionData.role === 'abone' ? 'Müşteri / Abone' : sessionData.role;
  userName = sessionData.name;
  const users = await getUsers(dbBinding);
  userData = users.find(u => u.id === sessionData.id);
  
  // Siparişleri Çek
  try {
    if (dbBinding) {
      const stmt = await dbBinding.prepare('SELECT * FROM orders WHERE user_id = ? ORDER BY createdAt DESC').bind(sessionData.id).all();
      if (stmt.results) userOrders = stmt.results;

      // Sipariş Kalemlerini Çek
      if (userOrders.length > 0) {
        const itemsStmt = await dbBinding.prepare(`
          SELECT oi.*, p.slug as product_slug 
          FROM order_items oi 
          LEFT JOIN products p ON oi.product_id = p.id 
          WHERE oi.order_id IN (SELECT id FROM orders WHERE user_id = ?)
        `).bind(sessionData.id).all();
        
        const itemsList = itemsStmt.results || [];
        
        // Group items inside userOrders
        userOrders = userOrders.map((order: any) => {
          return {
            ...order,
            items: itemsList.filter((item: any) => item.order_id === order.id)
          };
        });
      }

      // Yorum Sayısını Çek
      if (userData && userData.email) {
        const cStmt = await dbBinding.prepare('SELECT COUNT(*) as c FROM comments WHERE author_email = ?').bind(userData.email).first();
        userCommentCount = cStmt ? (cStmt.c as number) : 0;
      }
    }
  } catch (e) {
    console.error("Profile SQL query error:", e);
  }
}

// Form Post İşlemleri
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const redirect = (formData.get('redirect') as string) || redirectParam || '';

  if (action === 'login') {
    const usernameInput = formData.get('username') as string;
    const password = formData.get('password') as string;
    
    if (!usernameInput || !password) {
      errorMessage = 'E-posta/Telefon ve şifre zorunludur.';
    } else {
      const users = await getUsers(dbBinding);
      const existingUser = users.find(u => u.email === usernameInput || u.phone === usernameInput);
      
      if (existingUser) {
        if (existingUser.password === password) {
          if (existingUser.status !== 'aktif') {
            errorMessage = 'Hesabınız henüz onaylanmamıştır. Lütfen yöneticinin onaylamasını bekleyin.';
          } else {
            Astro.cookies.set('user_session', { id: existingUser.id, name: existingUser.name, role: existingUser.role }, { path: '/' });
            if (existingUser.role !== 'abone') {
              return Astro.redirect('/admin');
            }
            if (redirect === 'checkout') {
              return Astro.redirect('/checkout');
            }
            return Astro.redirect('/profil');
          }
        } else {
          errorMessage = 'Şifre hatalı.';
        }
      } else {
        errorMessage = 'Bu kullanıcı adı (E-posta / Telefon) ile kayıtlı üye bulunamadı.';
      }
    }
  }

  if (action === 'register') {
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const name = formData.get('name') as string || 'Yeni Kullanıcı';
    const phone = formData.get('phone') as string || '';
    const role = formData.get('role') as string || 'abone';
    const password_confirm = formData.get('password_confirm') as string;
    
    if (!email || !password) {
      errorMessage = 'E-posta ve şifre zorunludur.';
    } else if (password !== password_confirm) {
      errorMessage = 'Şifreler eşleşmiyor.';
    } else {
      const users = await getUsers(dbBinding);
      const existingUser = users.find(u => u.email === email);
      
      if (existingUser) {
        errorMessage = 'Bu e-posta adresi zaten kullanımda.';
      } else {
        const clientIp = Astro.clientAddress || 'Bilinmiyor';
        const isAbone = role.toLowerCase() === 'abone';
        const userStatus = isAbone ? 'aktif' : 'pasif';
        
        const newUser = await createUser({
          name, email, password, phone, role: role.toLowerCase(), status: userStatus, ip: clientIp
        }, dbBinding);
        
        if (newUser) {
          if (isAbone) {
            Astro.cookies.set('user_session', { id: newUser.id, name: newUser.name, role: newUser.role }, { path: '/' });
            if (redirect === 'checkout') {
              return Astro.redirect('/checkout');
            }
            return Astro.redirect('/profil?registration_success=true');
          } else {
            successMessage = 'Kayıt başarılı! Yöneticinin onayından sonra giriş yapabilirsiniz.';
          }
        } else {
          errorMessage = 'Kayıt sırasında bir hata oluştu.';
        }
      }
    }
  }

  if (action === 'update_profile') {
    const sessionData = Astro.cookies.get('user_session')?.json();
    if (sessionData) {
      const phone = formData.get('phone') as string;
      const address = formData.get('address') as string;
      try {
        await dbBinding.prepare('UPDATE users SET phone = ?, address = ? WHERE id = ?').bind(phone, address, sessionData.id).run();
        successMessage = 'Profil bilgileriniz başarıyla güncellendi.';
        const users = await getUsers(dbBinding);
        userData = users.find(u => u.id === sessionData.id);
      } catch (e) {
        errorMessage = 'Profil güncellenirken bir hata oluştu.';
      }
    }
  }

  if (action === 'logout') {
    Astro.cookies.delete('user_session', { path: '/' });
    return Astro.redirect('/profil');
  }
}
---

<BaseLayout title={isLoggedIn ? "Profilim" : "Giriş / Kayıt"} description="Laflaf kullanıcı işlemleri sayfası.">
  <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Yenileme Bilgi Paneli -->
    <div class="mb-8 p-3 bg-orange-50 dark:bg-orange-950/20 border border-orange-200 dark:border-orange-900/50 rounded-xl text-xs text-orange-800 dark:text-orange-300 flex flex-wrap items-center justify-between gap-3 shadow-sm">
      <div class="flex items-center gap-2">
        <i class="fas fa-info-circle text-sm animate-bounce text-orange-500"></i>
        <span>Eğer sayfayı göremiyorsanız sayfayı yenileyebilirsiniz veya sağdaki butona basabilirsiniz:</span>
      </div>
