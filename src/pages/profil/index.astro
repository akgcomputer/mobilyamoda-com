                  <div class="flex justify-between items-center border-b dark:border-gray-700 pb-3">
                    <h3 class="font-extrabold text-sm text-purple-600 dark:text-purple-400 uppercase tracking-wider" id="detailsOrderId">Sipariş Detayı</h3>
                    <button type="button" id="closeDetailsBtn" class="text-gray-400 hover:text-gray-600 text-lg"><i class="fas fa-times"></i></button>
                  </div>
                  
                  <div class="text-xs text-gray-500 space-y-1">
                    <p><strong>Tarih:</strong> <span id="detailsOrderDate"></span></p>
                    <p><strong>Ödeme Tipi:</strong> <span id="detailsOrderPayment"></span></p>
                    <p><strong>Durum:</strong> <span id="detailsOrderStatus" class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider"></span></p>
                  </div>

                  <div class="border-t border-b dark:border-gray-700 py-3">
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Ürünler</label>
                    <ul id="detailsProductsList" class="space-y-3">
                      <!-- Dinamik doldurulacak -->
                    </ul>
                  </div>

                  <!-- İade / Değişim Talebi Bölümü -->
                  <div class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-gray-200 dark:border-gray-700 space-y-3">
                    <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider"><i class="fas fa-undo mr-1"></i> Kolay İade & Değişim</label>
                    <p class="text-[10px] text-gray-400 leading-normal">İade veya değişim yapmak istediğiniz ürünün yanındaki kutucuğa adeti girip işleminizi seçiniz.</p>
                    
                    <div class="grid grid-cols-2 gap-3 text-xs">
                      <div>
                        <label class="block mb-1 font-semibold">Miktar</label>
                        <input type="number" id="returnQtyInput" min="1" value="1" class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-250 dark:border-gray-700 rounded-lg" />
                      </div>
                      <div>
                        <label class="block mb-1 font-semibold">Talep Tipi</label>
                        <select id="returnTypeSelect" class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-250 dark:border-gray-700 rounded-lg">
                          <option value="iade">Ürün İadesi</option>
                          <option value="degisim">Beden/Renk Değişimi</option>
                        </select>
                      </div>
                    </div>

                    <button type="button" id="startReturnProcessBtn" class="w-full py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-lg text-xs font-bold transition shadow">Süreci Başlat</button>
                  </div>
                </div>

                <!-- Siparişler Listesi -->
                <div id="ordersList" class="space-y-3">
                  {userOrders.length > 0 ? (
                    userOrders.map((order: any) => (
                      <div class="order-item-card border dark:border-gray-700 p-4 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white dark:bg-gray-800 hover:border-orange-500 dark:hover:border-orange-500 shadow-sm transition cursor-pointer" 
                           data-order-id={order.id} 
                           data-order-date={new Date(order.createdAt).toLocaleDateString('tr-TR')}
                           data-order-payment={order.payment_method}
                           data-order-status={order.status}
                           data-order-total={order.total_amount}
                           data-order-items={JSON.stringify(order.items)}>
                        <div>
                          <div class="font-bold text-sm text-purple-600 dark:text-purple-400">Sipariş #LAF{order.id}</div>
                          <div class="text-[11px] text-gray-500">{new Date(order.createdAt).toLocaleDateString('tr-TR')}</div>
                        </div>
                        <div class="flex items-center gap-3 w-full sm:w-auto justify-between sm:justify-end">
                          <span class={`inline-block px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${
                            order.status === 'onaylandi' ? 'bg-blue-100 text-blue-700' :
                            order.status === 'kargolandi' ? 'bg-indigo-100 text-indigo-700' :
                            order.status === 'tamamlandi' ? 'bg-green-100 text-green-700' :
                            order.status === 'iptal' ? 'bg-red-100 text-red-700' :
                            'bg-orange-100 text-orange-700'
                          }`}>
                            {order.status === 'bekliyor' ? 'Bekliyor' : (order.status === 'onaylandi' ? 'Onaylandı' : (order.status === 'kargolandi' ? 'Kargoda' : (order.status === 'tamamlandi' ? 'Tamamlandı' : 'İptal')))}
                          </span>
                          <div class="font-extrabold text-base text-gray-900 dark:text-white">
                            {order.total_amount.toLocaleString('tr-TR', {style:'currency', currency:'TRY', minimumFractionDigits: 0, maximumFractionDigits: 0})}
                          </div>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-xl border dark:border-gray-700 border-dashed">
                      <i class="fas fa-box-open text-4xl text-gray-400 mb-3"></i>
                      <p class="text-gray-500 text-sm">Henüz siparişiniz bulunmuyor.</p>
                      <a href="/urunler" class="inline-block mt-4 text-orange-600 font-bold hover:underline text-sm">Alışverişe Başla</a>
                    </div>
                  )}
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>
    ) : (
      <!-- GİRİŞ / KAYIT SEÇENEKLERİ (KART TASARIMI) -->
      <div class="space-y-10">
        
        <!-- Hata & Başarı Mesajları -->
        {errorMessage && (
          <div class="p-4 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-xl border border-red-200 dark:border-red-800 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-xl"></i>
            <span>{errorMessage}</span>
          </div>
        )}
        {successMessage && (
          <div class="p-4 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-xl border border-green-200 dark:border-green-800 flex items-center gap-3">
            <i class="fas fa-check-circle text-xl"></i>
            <span>{successMessage}</span>
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <!-- Kart 1: Ziyaretçi Olarak Devam Et -->
          <div id="cardGuest" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-orange-100 dark:bg-orange-950/30 text-orange-600 dark:text-orange-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-user-secret"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Ziyaretçi Olarak Devam Et</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Üye olmadan içeriklere yorum yazabilir veya doğrudan ödeme adımına geçerek hızlıca alışverişinizi tamamlayabilirsiniz.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-orange-600 dark:text-orange-400 group-hover:translate-x-1 transition-transform">
                Devam Et <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

          <!-- Kart 2: Üye Ol -->
          <div id="cardRegister" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-purple-500 dark:hover:border-purple-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-purple-100 dark:bg-purple-950/30 text-purple-600 dark:text-purple-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-user-plus"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Yeni Üyelik Oluştur</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Fırsatları kaçırmamak, sipariş takibi yapmak ve yorum eklemek için üye olun.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-purple-600 dark:text-purple-400 group-hover:translate-x-1 transition-transform">
                Kaydol <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

          <!-- Kart 3: Giriş Yap -->
          <div id="cardLogin" class="cursor-pointer bg-white dark:bg-gray-800 rounded-2xl p-6 border-2 border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-xl transition-all duration-300 flex flex-col items-center justify-between text-center group h-full">
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">
                <i class="fas fa-key"></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Üye Girişi Yap</h2>
              <p class="text-sm text-gray-500 dark:text-gray-400">Zaten hesabınız var mı? Güvenli şekilde giriş yapın ve alışverişe devam edin.</p>
            </div>
            <div class="mt-6 w-full">
              <span class="inline-flex items-center gap-1 text-sm font-bold text-blue-600 dark:text-blue-400 group-hover:translate-x-1 transition-transform">
                Giriş Yap <i class="fas fa-arrow-right text-xs"></i>
              </span>
            </div>
          </div>

        </div>

        <!-- YENİ ÜYE FORMU BÖLÜMÜ -->
        <div id="sectionRegister" class="hidden bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-700 p-8 sm:p-12 max-w-2xl mx-auto transform transition-all duration-300">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white font-outfit">Yeni Üyelik Oluştur</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Aramıza katılarak avantajlı alışverişin keyfini çıkarın.</p>
          </div>

          <form method="POST" id="registerForm" class="space-y-6">
            <input type="hidden" name="action" value="register" />
            <input type="hidden" name="redirect" value={redirectParam} />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Ad Soyad *</label>
                <input type="text" name="name" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="Ahmet Yılmaz">
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Cep Telefonu</label>
                <input type="tel" name="phone" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="05XX XXX XX XX">
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">E-posta *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="ornek@email.com">
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre *</label>
                <input type="password" name="password" id="regPassword" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="••••••••">
                <div class="mt-2 text-xs text-gray-500 space-y-1" id="pwRequirements">
                  <p class="req-length text-red-500">❌ En az 8 karakter</p>
                  <p class="req-upper text-red-500">❌ Büyük harf içermeli</p>
                  <p class="req-lower text-red-500">❌ Küçük harf içermeli</p>
                  <p class="req-number text-red-500">❌ Rakam içermeli</p>
                  <p class="req-symbol text-red-500">❌ Sembol içermeli (@$!%*?& vb.)</p>
                </div>
                <div id="pwSuccess" class="hidden mt-2 text-sm font-bold text-green-600">✅ Şifre zorluk seviyesi uygun</div>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre (Tekrar) *</label>
                <input type="password" name="password_confirm" id="regPasswordConfirm" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" placeholder="••••••••">
                <div id="pwMatchError" class="hidden mt-2 text-xs text-red-500">Şifreler eşleşmiyor</div>
              </div>
            </div>

            <div class="p-5 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-100 dark:border-gray-700">
              <label class="block text-sm font-bold mb-3">Hesap Türü Seçimi</label>
              <div class="flex flex-wrap gap-6">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Abone" checked class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Müşteri / Abone</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Yazar" class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Yazar</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="role" value="Editör" class="text-purple-600 focus:ring-purple-500">
                  <span class="text-sm">Editör</span>
                </label>
              </div>
            </div>

            <button type="submit" id="registerSubmitBtn" disabled class="w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed">
              Lütfen Şifre Kriterlerini Sağlayın
            </button>
          </form>
        </div>

        <!-- ÜYE GİRİŞ FORMU BÖLÜMÜ -->
        <div id="sectionLogin" class="hidden bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-700 p-8 sm:p-12 max-w-2xl mx-auto transform transition-all duration-300">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white font-outfit">Üye Girişi Yap</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Hesabınıza güvenli şekilde giriş yapın.</p>
          </div>

          <form method="POST" class="space-y-6" id="loginForm">
            <input type="hidden" name="action" value="login" />
            <input type="hidden" name="redirect" value={redirectParam} />
            
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Kullanıcı Adı (E-posta veya Telefon)</label>
              <input type="text" name="username" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="ornek@email.com veya 05XXXXXXXXX">
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Şifre</label>
              <input type="password" name="password" required class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition" placeholder="••••••••">
            </div>

            <!-- Ben Robot Değilim Custom Widget -->
            <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl my-4 select-none shadow-sm">
              <div class="flex items-center gap-3">
                <div class="relative w-8 h-8 flex items-center justify-center">
                  <input type="checkbox" id="recaptchaCheck" class="sr-only" />
                  <div id="recaptchaBox" class="w-6 h-6 border-2 border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-800 cursor-pointer transition-all flex items-center justify-center hover:border-gray-400">
                    <span id="recaptchaSpinner" class="hidden w-4 h-4 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></span>
                    <i id="recaptchaCheckIcon" class="hidden fas fa-check text-green-500 text-sm"></i>
                  </div>
                </div>
                <label id="recaptchaLabel" class="text-sm font-semibold text-gray-700 dark:text-gray-300 cursor-pointer">Ben robot değilim</label>
              </div>
              <div class="flex flex-col items-center opacity-70">
                <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" alt="reCAPTCHA" class="w-6 h-6 object-contain" />
                <span class="text-[8px] text-gray-400 mt-0.5">reCAPTCHA</span>
              </div>
            </div>

            <button type="submit" id="loginSubmitBtn" disabled class="w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed">
              Giriş Yapmak İçin Doğrulayın
            </button>
          </form>
        </div>

      </div>
    )}

  </div>

  <script is:inline>
    function initProfilePage() {
      const dashboardContainer = document.getElementById('profileTcvkn');
      
      if (dashboardContainer) {
        const tcvknInput = document.getElementById('profileTcvkn');
        const tcvknLabel = document.getElementById('tcvknLabel');
        const typeBireysel = document.getElementById('profileTypeBireysel');
        const typeKurumsal = document.getElementById('profileTypeKurumsal');
        
        const toggleAddAddressBtn = document.getElementById('toggleAddAddressBtn');
        const addAddressForm = document.getElementById('addAddressForm');
        const newAddressName = document.getElementById('newAddressName');
        const newAddressText = document.getElementById('newAddressText');
        const cancelAddressBtn = document.getElementById('cancelAddressBtn');
        const saveAddressBtn = document.getElementById('saveAddressBtn');
        const addressesList = document.getElementById('addressesList');
        const billingAddressSelect = document.getElementById('billingAddressSelect');

        const toggleAddPhoneBtn = document.getElementById('toggleAddPhoneBtn');
        const addPhoneForm = document.getElementById('addPhoneForm');
        const newPhoneName = document.getElementById('newPhoneName');
        const newPhoneNumber = document.getElementById('newPhoneNumber');
        const cancelPhoneBtn = document.getElementById('cancelPhoneBtn');
        const savePhoneBtn = document.getElementById('savePhoneBtn');
        const phonesList = document.getElementById('phonesList');

        const orderDetailsPanel = document.getElementById('orderDetailsPanel');
        const closeDetailsBtn = document.getElementById('closeDetailsBtn');
        const detailsOrderId = document.getElementById('detailsOrderId');
        const detailsOrderDate = document.getElementById('detailsOrderDate');
        const detailsOrderPayment = document.getElementById('detailsOrderPayment');
        const detailsOrderStatus = document.getElementById('detailsOrderStatus');
        const detailsProductsList = document.getElementById('detailsProductsList');
        const returnQtyInput = document.getElementById('returnQtyInput');
        const returnTypeSelect = document.getElementById('returnTypeSelect');
        const startReturnProcessBtn = document.getElementById('startReturnProcessBtn');
        const orderCards = document.querySelectorAll('.order-item-card');

        let activeOrderId = null;

        const initUserType = () => {
          let userType = localStorage.getItem('laflaf_profile_user_type') || 'bireysel';
          let tcvkn = localStorage.getItem('laflaf_profile_tcvkn') || '';

          if (userType === 'kurumsal') {
            if (typeKurumsal) typeKurumsal.checked = true;
            if (tcvknLabel) tcvknLabel.textContent = 'Vergi Kimlik Numarası (VKN)';
            if (tcvknInput) {
              tcvknInput.placeholder = '10 Haneli Vergi No (VKN)';
              tcvknInput.maxLength = 10;
            }
          } else {
            if (typeBireysel) typeBireysel.checked = true;
            if (tcvknLabel) tcvknLabel.textContent = 'TC Kimlik Numarası';
            if (tcvknInput) {
              tcvknInput.placeholder = '11 Haneli TC Kimlik No';
              tcvknInput.maxLength = 11;
            }
          }

          if (tcvknInput) tcvknInput.value = tcvkn;
        };

        const handleTypeChange = (val) => {
          localStorage.setItem('laflaf_profile_user_type', val);
          if (val === 'kurumsal') {
            if (tcvknLabel) tcvknLabel.textContent = 'Vergi Kimlik Numarası (VKN)';
            if (tcvknInput) {
              tcvknInput.placeholder = '10 Haneli Vergi No (VKN)';
              tcvknInput.maxLength = 10;
              tcvknInput.value = tcvknInput.value.substring(0, 10);
              localStorage.setItem('laflaf_profile_tcvkn', tcvknInput.value);
            }
          } else {
            if (tcvknLabel) tcvknLabel.textContent = 'TC Kimlik Numarası';
            if (tcvknInput) {
              tcvknInput.placeholder = '11 Haneli TC Kimlik No';
              tcvknInput.maxLength = 11;
            }
          }
        };

        typeBireysel?.addEventListener('change', () => handleTypeChange('bireysel'));
        typeKurumsal?.addEventListener('change', () => handleTypeChange('kurumsal'));

        tcvknInput?.addEventListener('input', (e) => {
          let cleanVal = e.target.value.replace(/[^0-9]/g, '');
          e.target.value = cleanVal;
          localStorage.setItem('laflaf_profile_tcvkn', cleanVal);
        });

        const getAddresses = () => {
          try { return JSON.parse(localStorage.getItem('laflaf_profile_addresses') || '[]'); } catch(e) { return []; }
        };

        const saveAddresses = (arr) => { localStorage.setItem('laflaf_profile_addresses', JSON.stringify(arr)); };

        const renderAddresses = () => {
          const list = getAddresses();
          if (!addressesList || !billingAddressSelect) return;

          addressesList.innerHTML = '';
          billingAddressSelect.innerHTML = '<option value="">Lütfen seçin...</option>';

          if (list.length === 0) {
            addressesList.innerHTML = '<p class="text-xs text-gray-400 italic">Kayıtlı adres bulunmuyor.</p>';
          } else {
            list.forEach((addr, idx) => {
              const div = document.createElement('div');
              div.className = 'flex justify-between items-start p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm gap-4 text-xs';
              div.innerHTML = `
                <div class="flex-1">
                  <div class="font-bold text-gray-800 dark:text-gray-250 flex items-center gap-1.5">
                    <i class="fas fa-home text-orange-500"></i> ${addr.name} 
                    ${idx === 0 ? '<span class="text-[9px] uppercase font-extrabold tracking-wider bg-orange-100 dark:bg-orange-950/30 text-orange-600 dark:text-orange-400 px-1.5 py-0.5 rounded">Ana Adres</span>' : ''}
                  </div>
                  <div class="text-gray-500 dark:text-gray-400 mt-1">${addr.text}</div>
                </div>
                <button type="button" class="delete-address-btn text-red-500 hover:text-red-700 p-1" data-id="${addr.id}">
                  <i class="fas fa-trash-alt"></i>
                </button>
              `;
              addressesList.appendChild(div);
              const opt = document.createElement('option');
              opt.value = addr.id.toString();
              opt.textContent = addr.name;
              billingAddressSelect.appendChild(opt);
            });
          }
          let billingId = localStorage.getItem('laflaf_profile_billing_address_id') || '';
          billingAddressSelect.value = billingId;
        };

        toggleAddAddressBtn?.addEventListener('click', () => { addAddressForm?.classList.toggle('hidden'); });
        cancelAddressBtn?.addEventListener('click', () => { addAddressForm?.classList.add('hidden'); });
        saveAddressBtn?.addEventListener('click', () => {
          const name = newAddressName?.value.trim();
          const text = newAddressText?.value.trim();
          if (!name || !text) { alert('Lütfen tüm adres alanlarını doldurun.'); return; }
          const list = getAddresses();
          const newAddr = { id: Date.now(), name, text };
          list.push(newAddr);
          saveAddresses(list);
          if (list.length === 1) localStorage.setItem('laflaf_profile_billing_address_id', newAddr.id.toString());
          if (newAddressName) newAddressName.value = '';
          if (newAddressText) newAddressText.value = '';
          addAddressForm?.classList.add('hidden');
          renderAddresses();
        });

        addressesList?.addEventListener('click', (e) => {
          const btn = e.target.closest('.delete-address-btn');
          if (!btn) return;
          const id = parseInt(btn.getAttribute('data-id'));
          let list = getAddresses().filter((a) => a.id !== id);
          saveAddresses(list);
          let billingId = localStorage.getItem('laflaf_profile_billing_address_id') || '';
          if (billingId === id.toString()) localStorage.setItem('laflaf_profile_billing_address_id', list[0] ? list[0].id.toString() : '');
          renderAddresses();
        });

        billingAddressSelect?.addEventListener('change', (e) => { localStorage.setItem('laflaf_profile_billing_address_id', e.target.value); });

        const getPhones = () => { try { return JSON.parse(localStorage.getItem('laflaf_profile_phones') || '[]'); } catch(e) { return []; } };
        const savePhones = (arr) => { localStorage.setItem('laflaf_profile_phones', JSON.stringify(arr)); };
        const renderPhones = () => {
          const list = getPhones();
          if (!phonesList) return;
          phonesList.innerHTML = '';
          if (list.length === 0) {
            phonesList.innerHTML = '<p class="text-xs text-gray-400 italic">Kayıtlı telefon bulunmuyor.</p>';
          } else {
            list.forEach((p, idx) => {
              const div = document.createElement('div');
              div.className = 'flex justify-between items-center p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm gap-4 text-xs';
              div.innerHTML = `
                <div>
                  <div class="font-bold text-gray-800 dark:text-gray-250 flex items-center gap-1.5">
                    <i class="fas fa-mobile-alt text-orange-500"></i> ${p.name}
                    ${idx === 0 ? '<span class="text-[9px] uppercase font-extrabold tracking-wider bg-orange-100 dark:bg-orange-950/30 text-orange-600 dark:text-orange-400 px-1.5 py-0.5 rounded">Ana Telefon</span>' : ''}
                  </div>
                  <div class="text-gray-500 dark:text-gray-400 mt-1">${p.number}</div>
                </div>
                <button type="button" class="delete-phone-btn text-red-500 hover:text-red-700 p-1" data-id="${p.id}">
                  <i class="fas fa-trash-alt"></i>
                </button>
              `;
              phonesList.appendChild(div);
            });
          }
        };

        toggleAddPhoneBtn?.addEventListener('click', () => { addPhoneForm?.classList.toggle('hidden'); });
        cancelPhoneBtn?.addEventListener('click', () => { addPhoneForm?.classList.add('hidden'); });
        savePhoneBtn?.addEventListener('click', () => {
          const name = newPhoneName?.value.trim();
          const number = newPhoneNumber?.value.trim();
          if (!name || !number) { alert('Lütfen tüm telefon alanlarını doldurun.'); return; }
          const list = getPhones();
          list.push({ id: Date.now(), name, number });
          savePhones(list);
          if (newPhoneName) newPhoneName.value = '';
          if (newPhoneNumber) newPhoneNumber.value = '';
          addPhoneForm?.classList.add('hidden');
          renderPhones();
        });

        phonesList?.addEventListener('click', (e) => {
          const btn = e.target.closest('.delete-phone-btn');
          if (!btn) return;
          const id = parseInt(btn.getAttribute('data-id'));
          savePhones(getPhones().filter((p) => p.id !== id));
          renderPhones();
        });

        const getPaymentMethodTitle = (method) => ({ 'havale': 'Havale / EFT', 'kapida_nakit': 'Kapıda Nakit', 'kapida_pos': 'Kapıda Kredi Kartı (POS)', 'kredi_karti': 'Kredi Kartı', 'banka_kredisi': 'Alışveriş Kredisi' }[method] || method);
        const getStatusTitle = (status) => ({ 'bekliyor': 'Bekliyor', 'onaylandi': 'Onaylandı', 'kargolandi': 'Kargoda', 'tamamlandi': 'Tamamlandı', 'iptal': 'İptal' }[status] || status);

        orderCards.forEach((card) => {
          card.addEventListener('click', () => {
            const orderId = card.getAttribute('data-order-id');
            const date = card.getAttribute('data-order-date');
            const payment = card.getAttribute('data-order-payment');
            const status = card.getAttribute('data-order-status');
            const items = JSON.parse(card.getAttribute('data-order-items') || '[]');
            activeOrderId = orderId;
            if (detailsOrderId) detailsOrderId.textContent = `Sipariş #LAF${orderId}`;
            if (detailsOrderDate) detailsOrderDate.textContent = date;
            if (detailsOrderPayment) detailsOrderPayment.textContent = getPaymentMethodTitle(payment);
            if (detailsOrderStatus) {
              detailsOrderStatus.textContent = getStatusTitle(status);
              detailsOrderStatus.className = `px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${ status === 'onaylandi' ? 'bg-blue-100 text-blue-700' : status === 'kargolandi' ? 'bg-indigo-100 text-indigo-700' : status === 'tamamlandi' ? 'bg-green-100 text-green-700' : status === 'iptal' ? 'bg-red-100 text-red-700' : 'bg-orange-100 text-orange-700' }`;
            }
            if (detailsProductsList) {
              detailsProductsList.innerHTML = '';
              items.forEach((item) => {
                const li = document.createElement('li');
                li.className = 'border-b dark:border-gray-800 pb-2 text-xs';
                li.innerHTML = `<label class="flex items-start gap-3 cursor-pointer"><input type="radio" name="return_item_select" value="${item.id}" data-max-qty="${item.quantity}" data-product-name="${item.product_name}" class="text-orange-600 mt-1 focus:ring-orange-500" /><div class="flex-1"><div class="font-semibold text-sm hover:underline hover:text-orange-500"><a href="/urunler/${item.product_slug}">${item.product_name}</a></div><div class="text-[10px] text-gray-500 flex justify-between mt-1"><span>Adet: <strong class="text-gray-700 dark:text-gray-250">${item.quantity}</strong></span><a href="/urunler/${item.product_slug}#reviews" class="text-blue-500 hover:underline"><i class="far fa-star"></i> Değerlendir & Yorum Yaz</a></div></div></label>`;
                detailsProductsList.appendChild(li);
              });
            }
            orderDetailsPanel?.classList.remove('hidden');
          });
        });

        closeDetailsBtn?.addEventListener('click', () => { orderDetailsPanel?.classList.add('hidden'); });
        startReturnProcessBtn?.addEventListener('click', () => {
          const selectedRadio = document.querySelector('input[name="return_item_select"]:checked');
          if (!selectedRadio) { alert('Lütfen iade veya değişim yapmak istediğiniz ürünü yukarıdan seçin!'); return; }
          const maxQty = parseInt(selectedRadio.getAttribute('data-max-qty') || '1');
          const productName = selectedRadio.getAttribute('data-product-name') || '';
          const qty = parseInt(returnQtyInput?.value || '1');
          const type = returnTypeSelect?.value || 'iade';
          if (isNaN(qty) || qty <= 0) { alert('Lütfen geçerli bir adet girin.'); return; }
          if (qty > maxQty) { alert(`İade veya değişim adeti siparişteki miktardan (${maxQty}) fazla olamaz!`); return; }
          alert(`Tebrikler! İade/Değişim talebiniz başarıyla alınmıştır.\n\nÜrün: ${productName}\nİşlem: ${type === 'iade' ? 'Ürün İadesi' : 'Beden/Renk Değişimi'}\nMiktar: ${qty} Adet\n\nSüreç başlatıldı!`);
          let returnList = []; try { returnList = JSON.parse(localStorage.getItem('laflaf_profile_returns') || '[]'); } catch(e){}
          returnList.push({ order_id: activeOrderId, ref_code: `LAF-REF-${activeOrderId}-${Date.now().toString().slice(-4)}`, product_name: productName, qty, type, status: 'başlatıldı', createdAt: new Date().toISOString() });
          localStorage.setItem('laflaf_profile_returns', JSON.stringify(returnList));
          orderDetailsPanel?.classList.add('hidden');
        });
        initUserType(); renderAddresses(); renderPhones();
      } else {
        const cardGuest = document.getElementById('cardGuest');
        const cardRegister = document.getElementById('cardRegister');
        const cardLogin = document.getElementById('cardLogin');
        const sectionRegister = document.getElementById('sectionRegister');
        const sectionLogin = document.getElementById('sectionLogin');
        cardGuest?.addEventListener('click', () => { window.location.href = '/sepet'; });
        const resetCards = () => { [cardRegister, cardLogin].forEach(card => { card?.classList.remove('border-purple-500', 'border-blue-500', 'shadow-2xl', 'scale-[1.02]'); card?.classList.add('border-gray-200', 'dark:border-gray-700'); }); };
        const selectRegister = () => { resetCards(); cardRegister?.classList.remove('border-gray-200', 'dark:border-gray-700'); cardRegister?.classList.add('border-purple-500', 'shadow-2xl', 'scale-[1.02]'); sectionLogin?.classList.add('hidden'); sectionRegister?.classList.remove('hidden'); sectionRegister?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); };
        const selectLogin = () => { resetCards(); cardLogin?.classList.remove('border-gray-200', 'dark:border-gray-700'); cardLogin?.classList.add('border-blue-500', 'shadow-2xl', 'scale-[1.02]'); sectionRegister?.classList.add('hidden'); sectionLogin?.classList.remove('hidden'); sectionLogin?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); };
        cardRegister?.addEventListener('click', selectRegister);
        cardLogin?.addEventListener('click', selectLogin);
        const urlParams = new URLSearchParams(window.location.search);
        const action = urlParams.get('action');
        if (action === 'register') selectRegister(); else if (action === 'login') selectLogin();
        else {
          const errorMsg = document.querySelector('.bg-red-100')?.textContent || '';
          const successMsg = document.querySelector('.bg-green-100')?.textContent || '';
          if (errorMsg.includes('Şifre') || errorMsg.includes('kullanıcı adı') || successMsg.includes('onay')) selectLogin(); else if (errorMsg || successMsg) selectRegister();
        }
        const recaptchaBox = document.getElementById('recaptchaBox');
        const recaptchaCheck = document.getElementById('recaptchaCheck');
        const recaptchaSpinner = document.getElementById('recaptchaSpinner');
        const recaptchaCheckIcon = document.getElementById('recaptchaCheckIcon');
        const recaptchaLabel = document.getElementById('recaptchaLabel');
        const loginSubmitBtn = document.getElementById('loginSubmitBtn');
        let recaptchaVerified = false;
        const triggerRecaptcha = () => {
          if (recaptchaVerified) return;
          recaptchaVerified = true;
          if (recaptchaBox && recaptchaSpinner && recaptchaCheckIcon && loginSubmitBtn && recaptchaLabel) {
            recaptchaBox.style.pointerEvents = 'none';
            if (recaptchaCheck) recaptchaCheck.checked = true;
            recaptchaSpinner.classList.remove('hidden');
            recaptchaLabel.textContent = 'Doğrulanıyor...';
            setTimeout(() => {
              recaptchaSpinner.classList.add('hidden');
              recaptchaCheckIcon.classList.remove('hidden');
              recaptchaBox.classList.add('bg-green-50', 'border-green-500', 'dark:bg-green-950/20');
              recaptchaLabel.textContent = 'Doğrulandı!';
              recaptchaLabel.className = 'text-sm font-bold text-green-600 dark:text-green-400';
              loginSubmitBtn.disabled = false;
              loginSubmitBtn.className = 'w-full py-4 bg-gradient-to-r from-orange-500 to-purple-600 text-white rounded-xl hover:shadow-lg hover:opacity-90 transition font-bold text-lg cursor-pointer transform hover:-translate-y-0.5 active:scale-95 duration-200';
              loginSubmitBtn.textContent = 'Giriş Yap';
            }, 900);
          }
        };
        recaptchaBox?.addEventListener('click', triggerRecaptcha);
        recaptchaLabel?.addEventListener('click', triggerRecaptcha);
        const pwInput = document.getElementById('regPassword');
        const pwConfirm = document.getElementById('regPasswordConfirm');
        const registerSubmitBtn = document.getElementById('registerSubmitBtn');
        const reqList = document.getElementById('pwRequirements');
        const pwSuccess = document.getElementById('pwSuccess');
        const matchError = document.getElementById('pwMatchError');
        if (pwInput && registerSubmitBtn && reqList && pwSuccess && matchError && pwConfirm) {
          const validatePassword = () => {
            const val = pwInput.value;
            const confVal = pwConfirm.value;
            let isValid = true;
            const rules = [{ regex: /.{8,}/, el: document.querySelector('.req-length') }, { regex: /[A-Z]/, el: document.querySelector('.req-upper') }, { regex: /[a-z]/, el: document.querySelector('.req-lower') }, { regex: /[0-9]/, el: document.querySelector('.req-number') }, { regex: /[^A-Za-z0-9]/, el: document.querySelector('.req-symbol') }];
            rules.forEach(rule => {
              if (rule.el) {
                if (rule.regex.test(val)) { rule.el.classList.remove('text-red-500'); rule.el.classList.add('text-green-500'); rule.el.innerText = rule.el.innerText.replace('❌', '✅'); }
                else { rule.el.classList.remove('text-green-500'); rule.el.classList.add('text-red-500'); rule.el.innerText = rule.el.innerText.replace('✅', '❌'); isValid = false; }
              }
            });
            let isMatch = (confVal.length > 0 && val === confVal);
            if (isMatch) matchError.classList.add('hidden'); else if (confVal.length > 0) matchError.classList.remove('hidden');
            if (isValid) { reqList.classList.add('hidden'); pwSuccess.classList.remove('hidden'); } else { reqList.classList.remove('hidden'); pwSuccess.classList.add('hidden'); }
            if (isValid && isMatch) { registerSubmitBtn.disabled = false; registerSubmitBtn.className = 'w-full py-4 bg-gradient-to-r from-orange-500 to-purple-600 text-white rounded-xl hover:shadow-lg hover:opacity-90 transition font-bold text-lg cursor-pointer transform hover:-translate-y-0.5 active:scale-95 duration-200'; registerSubmitBtn.innerText = 'Aramıza Katıl'; }
            else { registerSubmitBtn.disabled = true; registerSubmitBtn.className = 'w-full py-4 bg-gray-400 text-white rounded-xl transition font-bold text-lg cursor-not-allowed'; registerSubmitBtn.innerText = 'Lütfen Kriterleri Sağlayın'; }
          };
          pwInput.addEventListener('input', validatePassword);
          pwConfirm.addEventListener('input', validatePassword);
        }
      }
    }
    
    // Bind securely to both view transitions and immediate DOM ready
    document.addEventListener('astro:page-load', initProfilePage);
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(initProfilePage, 50);
    } else {
      document.addEventListener('DOMContentLoaded', initProfilePage);
    }
  </script>
</BaseLayout>
