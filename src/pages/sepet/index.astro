---
// src/pages/sepet/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSettings } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
const settings = (await getSettings(dbBinding)) || {};

const isLoggedIn = Astro.cookies.has('user_session');
const checkoutUrl = isLoggedIn ? '/checkout' : '/profil?redirect=checkout';
---

<BaseLayout title="Sepetim | Laflaf E-Ticaret">
  <div id="cart-campaign-data" 
       class="hidden" 
       data-campaign={settings.campaign_settings || '{}'}>
  </div>
  
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white">Alışveriş Sepetim</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">Siparişinizi tamamlamadan önce sepetinizi inceleyin.</p>
    </div>

    <div id="emptyCartMessage" class="hidden text-center py-20 bg-gray-50 dark:bg-gray-800/50 rounded-2xl border border-gray-200 dark:border-gray-700">
      <i class="fas fa-shopping-cart text-6xl text-gray-300 dark:text-gray-600 mb-6 block"></i>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Sepetiniz Boş</h2>
      <p class="text-gray-500 mb-6">Şu an sepetinizde hiç ürün bulunmuyor.</p>
      <a href="/urunler" class="inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg transition-transform hover:-translate-y-0.5">Alışverişe Başla</a>
    </div>

    <div id="cartContent" class="hidden flex flex-col lg:flex-row gap-8">
      
      <!-- Sol: Sepet Ürünleri -->
      <div class="lg:w-2/3">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
          <ul id="cartItemsList" class="divide-y divide-gray-200 dark:divide-gray-700">
            <!-- JS tarafından doldurulacak -->
          </ul>
        </div>
      </div>

      <!-- Sağ: Sipariş Özeti -->
      <div class="lg:w-1/3">
        <div class="bg-gray-50 dark:bg-gray-800/80 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 sticky top-24">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Sipariş Özeti</h2>
          
          <!-- Kampanya Bildirimi -->
          <div id="cartCampaignAlert" class="hidden mb-4 p-3 bg-rose-50 dark:bg-rose-950/20 text-rose-700 dark:text-rose-350 border border-rose-200 dark:border-rose-900/50 rounded-xl text-xs font-semibold flex items-start gap-2">
            <i class="fas fa-bullhorn mt-0.5 text-sm animate-bounce"></i>
            <div>
              <div id="cartCampaignAlertName" class="font-bold">Aktif Kampanya</div>
              <div id="cartCampaignAlertDesc" class="opacity-95 text-[11px] mt-0.5"></div>
            </div>
          </div>

          <div class="space-y-4 mb-6 text-gray-600 dark:text-gray-300">
            <div class="flex justify-between">
              <span>Ara Toplam</span>
              <span id="subtotalDisplay" class="font-medium text-gray-900 dark:text-white">0,00 ₺</span>
            </div>
            <div id="campaignDiscountRow" class="flex justify-between hidden text-rose-600 font-semibold">
              <span id="campaignNameDisplay">Kampanya İndirimi</span>
              <span id="campaignDiscountDisplay">-0 ₺</span>
            </div>
            <div class="flex justify-between">
              <span>Kargo Ücreti</span>
              <span id="shippingDisplay" class="font-medium text-gray-900 dark:text-white">Ücretsiz</span>
            </div>
          </div>
          <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mb-4">
            <div class="flex gap-2 mb-2">
              <input type="text" id="couponInput" class="w-full bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-orange-500 focus:border-orange-500 p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="İndirim Kodu">
              <button type="button" id="applyCouponBtn" class="bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium transition dark:bg-gray-600 dark:hover:bg-gray-500">Uygula</button>
            </div>
            <div id="couponMessage" class="text-xs hidden mb-4"></div>
            
            <div id="discountRow" class="flex justify-between hidden text-green-600 font-medium text-sm mt-4">
              <span>İndirim (<span id="couponCodeDisplay"></span>)</span>
              <span id="discountDisplay">-0,00 ₺</span>
            </div>
          </div>
          
          <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mb-8">
            <div class="flex justify-between items-center">
              <span class="text-lg font-bold text-gray-900 dark:text-white">Toplam</span>
              <span id="totalDisplay" class="text-2xl font-extrabold text-orange-600">0,00 ₺</span>
            </div>
          </div>
          
          <a href={checkoutUrl} class="block w-full bg-orange-600 hover:bg-orange-700 text-white text-center font-bold py-4 px-6 rounded-xl shadow-lg transition-transform hover:-translate-y-0.5 text-lg">
            Siparişi Tamamla <i class="fas fa-arrow-right ml-2"></i>
          </a>
          
          <div class="mt-4 flex items-center justify-center gap-4 text-gray-400">
            <i class="fab fa-cc-visa text-2xl"></i>
            <i class="fab fa-cc-mastercard text-2xl"></i>
            <i class="fas fa-truck text-xl"></i>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const formatMoney = (amount: number, currency = '₺') => {
        return new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount) + ' ' + currency;
      };

      const safeParseFloat = (val: any) => {
        if (typeof val === 'number') return val;
        if (!val) return 0;
        let str = val.toString().replace(/[₺$€\s]/g, '');
        if (str.includes('.') && str.includes(',')) {
          str = str.replace(/\./g, '').replace(',', '.');
        } else if (str.includes(',')) {
          const parts = str.split(',');
          if (parts[1] && parts[1].length === 3) {
            str = str.replace(/,/g, '');
          } else {
            str = str.replace(',', '.');
          }
        } else if (str.includes('.')) {
          const parts = str.split('.');
          if (parts[1] && parts[1].length === 3) {
            str = str.replace(/\./g, '');
          }
        }
        const num = parseFloat(str);
        return isNaN(num) ? 0 : num;
      };

      let cart: any[] = [];
      try {
        cart = JSON.parse(localStorage.getItem('laflaf_cart') || '[]');
      } catch(e) {}

      // Parse campaign settings
      let campaignSettings: any = null;
      try {
        const campaignEl = document.getElementById('cart-campaign-data');
        if (campaignEl) {
          const rawSettings = JSON.parse(campaignEl.getAttribute('data-campaign') || '{}');
          if (rawSettings.campaign_settings) {
            campaignSettings = JSON.parse(rawSettings.campaign_settings);
          }
        }
      } catch (e) {
        console.error("Cart Campaign parse error:", e);
      }

      const emptyCartMessage = document.getElementById('emptyCartMessage');
      const cartContent = document.getElementById('cartContent');
      const cartItemsList = document.getElementById('cartItemsList');
      const subtotalDisplay = document.getElementById('subtotalDisplay');
      const totalDisplay = document.getElementById('totalDisplay');

      if (!cartItemsList || !emptyCartMessage || !cartContent || !subtotalDisplay || !totalDisplay) return;

      function renderCart() {
        if (!cartItemsList || !emptyCartMessage || !cartContent || !subtotalDisplay || !totalDisplay) return;
        if (cart.length === 0) {
          emptyCartMessage.classList.remove('hidden');
          cartContent.classList.add('hidden');
          cartContent.classList.remove('flex');
          return;
        }

        emptyCartMessage.classList.add('hidden');
        cartContent.classList.remove('hidden');
        cartContent.classList.add('flex');

        cartItemsList.innerHTML = '';
        let subtotal = 0;
        let totalItemsQty = 0;
        const cartCurrency = cart[0]?.currency || '₺';

        cart.forEach((item, index) => {
          const itemPrice = safeParseFloat(item.price);
          const itemTotal = itemPrice * item.qty;
          subtotal += itemTotal;
          totalItemsQty += item.qty;
          const itemCurrency = item.currency || '₺';

          const li = document.createElement('li');
          li.className = 'p-6 flex flex-col sm:flex-row items-start sm:items-center gap-6 hover:bg-gray-50 dark:hover:bg-gray-700/30 transition';
          
          // Product Image
          const imgHtml = item.image 
            ? `<img src="${item.image}" class="w-24 h-24 object-cover rounded-lg shadow-sm" alt="${item.name}" />`
            : `<div class="w-24 h-24 bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center text-gray-400"><i class="fas fa-image text-2xl"></i></div>`;

          // Variant Info
          const variantHtml = item.variant_name ? `<div class="text-sm text-gray-500 mt-1">Seçenek: <span class="font-medium text-gray-700 dark:text-gray-300">${item.variant_name}</span></div>` : '';

          li.innerHTML = `
            ${imgHtml}
            <div class="flex-1">
              <h3 class="text-lg font-bold text-gray-900 dark:text-white line-clamp-2">${item.name}</h3>
              ${variantHtml}
              <div class="text-orange-600 font-bold mt-2">${formatMoney(itemPrice, itemCurrency)} <span class="text-xs text-gray-400 font-normal">/ ${item.unit}</span></div>
            </div>
            <div class="flex items-center gap-4 w-full sm:w-auto justify-between sm:justify-start">
              <div class="flex items-center border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden bg-white dark:bg-gray-800">
                <button type="button" class="qty-btn minus w-8 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700 transition" data-index="${index}"><i class="fas fa-minus text-xs"></i></button>
                <input type="number" value="${item.qty}" min="1" readonly class="w-12 h-10 text-center font-bold border-0 bg-transparent focus:ring-0 p-0 text-sm dark:text-white" />
                <button type="button" class="qty-btn plus w-8 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700 transition" data-index="${index}"><i class="fas fa-plus text-xs"></i></button>
              </div>
              <div class="text-right sm:w-28">
                <div class="font-extrabold text-gray-900 dark:text-white">${formatMoney(itemTotal, itemCurrency)}</div>
              </div>
              <button class="remove-btn text-red-500 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/30 p-2 rounded-lg transition" data-index="${index}" title="Kaldır">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          `;
          cartItemsList.appendChild(li);
        });

        subtotalDisplay.textContent = formatMoney(subtotal, cartCurrency);

        // --- Campaign Discount Calculation ---
        let campaignDiscount = 0;
        const cartCampaignAlert = document.getElementById('cartCampaignAlert');
        const cartCampaignAlertName = document.getElementById('cartCampaignAlertName');
        const cartCampaignAlertDesc = document.getElementById('cartCampaignAlertDesc');
        const campaignDiscountRow = document.getElementById('campaignDiscountRow');
        const campaignNameDisplay = document.getElementById('campaignNameDisplay');
        const campaignDiscountDisplay = document.getElementById('campaignDiscountDisplay');

        if (campaignSettings && campaignSettings.active) {
          // Display Alert Banner
          if (cartCampaignAlert && cartCampaignAlertName && cartCampaignAlertDesc) {
            cartCampaignAlert.classList.remove('hidden');
            cartCampaignAlertName.textContent = campaignSettings.name || 'Aktif Kampanya!';
            let desc = '';
            if (campaignSettings.type === 'percentage') {
              desc = `Tüm alışverişlerinizde anında %${campaignSettings.value} indirim fırsatı!`;
            } else if (campaignSettings.type === 'fixed') {
              desc = `Tüm alışverişlerinizde anında ${campaignSettings.value} ₺ indirim fırsatı!`;
            } else if (campaignSettings.type === 'bogo') {
              desc = `${campaignSettings.bogo_buy_qty} Alana ${campaignSettings.bogo_get_qty} Bedava! (Sepetteki en ucuz ürün(ler) ücretsiz sayılacaktır)`;
            }
            cartCampaignAlertDesc.textContent = desc;
          }

          // Calculate Discount Value
          if (campaignSettings.type === 'percentage') {
            const pct = parseFloat(campaignSettings.value) || 0;
            campaignDiscount = subtotal * (pct / 100);
          } else if (campaignSettings.type === 'fixed') {
            const amount = parseFloat(campaignSettings.value) || 0;
            campaignDiscount = Math.min(subtotal, amount);
          } else if (campaignSettings.type === 'bogo') {
            const buyQty = parseInt(campaignSettings.bogo_buy_qty) || 3;
            const getQty = parseInt(campaignSettings.bogo_get_qty) || 1;
            if (totalItemsQty >= buyQty) {
              const flatPrices = [];
              cart.forEach(item => {
                const price = safeParseFloat(item.price);
                for (let i = 0; i < item.qty; i++) {
                  flatPrices.push(price);
                }
              });
              flatPrices.sort((a, b) => a - b);
              const freeCount = Math.floor(totalItemsQty / buyQty) * getQty;
              for (let i = 0; i < Math.min(freeCount, flatPrices.length); i++) {
                campaignDiscount += flatPrices[i];
              }
            }
          }

          // Render Row
          if (campaignDiscount > 0 && campaignDiscountRow && campaignNameDisplay && campaignDiscountDisplay) {
            campaignDiscountRow.classList.remove('hidden');
            campaignNameDisplay.textContent = campaignSettings.name || 'Kampanya İndirimi';
            campaignDiscountDisplay.textContent = '-' + formatMoney(campaignDiscount, cartCurrency);
          } else if (campaignDiscountRow) {
            campaignDiscountRow.classList.add('hidden');
          }
        } else {
          if (cartCampaignAlert) cartCampaignAlert.classList.add('hidden');
          if (campaignDiscountRow) campaignDiscountRow.classList.add('hidden');
        }
        
        // --- Coupon Discount Calculation (Applied on remaining total or subtotal) ---
        let couponDiscount = 0;
        let appliedCoupon: any = null;
        try { appliedCoupon = JSON.parse(localStorage.getItem('laflaf_coupon') || 'null'); } catch(e){}

        const discountRow = document.getElementById('discountRow');
        const couponCodeDisplay = document.getElementById('couponCodeDisplay');
        const discountDisplay = document.getElementById('discountDisplay');

        const remainingAfterCampaign = Math.max(0, subtotal - campaignDiscount);

        if (appliedCoupon && discountRow && couponCodeDisplay && discountDisplay) {
          if (appliedCoupon.type === 'percentage') {
            couponDiscount = remainingAfterCampaign * (appliedCoupon.value / 100);
          } else {
            couponDiscount = appliedCoupon.value;
          }
          if (couponDiscount > remainingAfterCampaign) couponDiscount = remainingAfterCampaign;
          
          discountRow.classList.remove('hidden');
          couponCodeDisplay.textContent = appliedCoupon.code;
          discountDisplay.textContent = '-' + formatMoney(couponDiscount, cartCurrency);
        } else if (discountRow) {
          discountRow.classList.add('hidden');
        }

        const total = remainingAfterCampaign - couponDiscount;
        totalDisplay.textContent = formatMoney(total > 0 ? total : 0, cartCurrency);
        
        // Update badge if any
        window.dispatchEvent(new Event('cart_updated'));
      }

      // Event Delegation for Qty and Remove Buttons
      cartItemsList.addEventListener('click', (e: any) => {
        const btn = e.target.closest('button');
        if (!btn) return;

        const index = parseInt(btn.getAttribute('data-index'));
        
        if (btn.classList.contains('remove-btn')) {
          cart.splice(index, 1);
          localStorage.setItem('laflaf_cart', JSON.stringify(cart));
          renderCart();
        } 
        else if (btn.classList.contains('qty-btn')) {
          const item = cart[index];
          if (btn.classList.contains('minus') && item.qty > 1) {
            item.qty--;
          } else if (btn.classList.contains('plus')) {
            item.qty++;
          }
          
          // Dynamic wholesale discount calculation if base_price and wholesale_prices exist
          if (item.base_price !== undefined) {
            const basePrice = safeParseFloat(item.base_price);
            const wholesaleRules = item.wholesale_prices || [];
            let discount = 0;
            if (wholesaleRules && wholesaleRules.length > 0) {
              const sortedWP = [...wholesaleRules].sort((a,b) => parseInt(b.min_qty) - parseInt(a.min_qty));
              for(let wp of sortedWP) {
                if (item.qty >= parseInt(wp.min_qty)) { 
                  discount = parseFloat(wp.discount_percentage); 
                  break; 
                }
              }
            }
            item.price = basePrice * (1 - discount / 100);
          }
          
          localStorage.setItem('laflaf_cart', JSON.stringify(cart));
          renderCart();
        }
      });

      // Coupon Logic
      const applyCouponBtn = document.getElementById('applyCouponBtn');
      const couponInput = document.getElementById('couponInput') as HTMLInputElement | null;
      const couponMessage = document.getElementById('couponMessage');

      if (applyCouponBtn && couponInput && couponMessage) {
        applyCouponBtn.addEventListener('click', async () => {
          const code = couponInput.value.trim();
          if (!code) return;

          applyCouponBtn.setAttribute('disabled', 'true');
          applyCouponBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
          couponMessage.classList.add('hidden');

          let subtotal = 0;
          cart.forEach(item => subtotal += (safeParseFloat(item.price) * item.qty));

          // Compute remaining subtotal for coupon limit check
          let campaignDiscount = 0;
          if (campaignSettings && campaignSettings.active) {
            if (campaignSettings.type === 'percentage') {
              campaignDiscount = subtotal * (parseFloat(campaignSettings.value) || 0) / 100;
            } else if (campaignSettings.type === 'fixed') {
              campaignDiscount = Math.min(subtotal, parseFloat(campaignSettings.value) || 0);
            } else if (campaignSettings.type === 'bogo') {
              const buyQty = parseInt(campaignSettings.bogo_buy_qty) || 3;
              const getQty = parseInt(campaignSettings.bogo_get_qty) || 1;
              let totalItemsQty = cart.reduce((sum, item) => sum + item.qty, 0);
              if (totalItemsQty >= buyQty) {
                const flatPrices = [];
                cart.forEach(item => {
                  const price = safeParseFloat(item.price);
                  for (let i = 0; i < item.qty; i++) flatPrices.push(price);
                });
                flatPrices.sort((a, b) => a - b);
                const freeCount = Math.floor(totalItemsQty / buyQty) * getQty;
                for (let i = 0; i < Math.min(freeCount, flatPrices.length); i++) {
                  campaignDiscount += flatPrices[i];
                }
              }
            }
          }
          const remainingSubtotal = Math.max(0, subtotal - campaignDiscount);

          try {
            const res = await fetch('/api/validate-coupon', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ code, cart_amount: remainingSubtotal })
            });
            const data = await res.json();

            if (res.ok && data.success) {
              localStorage.setItem('laflaf_coupon', JSON.stringify(data.coupon));
              couponMessage.textContent = 'Kupon başarıyla uygulandı!';
              couponMessage.className = 'text-xs mb-4 text-green-600 block font-bold';
              renderCart();
            } else {
              localStorage.removeItem('laflaf_coupon');
              couponMessage.textContent = data.error || 'Hata oluştu.';
              couponMessage.className = 'text-xs mb-4 text-red-600 block font-bold';
              renderCart();
            }
          } catch (e) {
            couponMessage.textContent = 'Bağlantı hatası.';
            couponMessage.className = 'text-xs mb-4 text-red-600 block font-bold';
          }

          applyCouponBtn.removeAttribute('disabled');
          applyCouponBtn.innerHTML = 'Uygula';
        });
      }

      // If coupon exists, show message
      try { 
        const existing = JSON.parse(localStorage.getItem('laflaf_coupon') || 'null');
        if(existing && couponInput && couponMessage) {
          couponInput.value = existing.code;
          couponMessage.textContent = 'Kupon devrede.';
          couponMessage.className = 'text-xs mb-4 text-green-600 block font-bold';
        }
      } catch(e){}

      // Initial render
      renderCart();
    });
  </script>
</BaseLayout>
