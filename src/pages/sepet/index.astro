---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProducts } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
const allProducts = await getProducts(dbBinding);

// Sadece aktif ürünleri al
const activeProducts = allProducts.filter(p => p.status === 'aktif');

// Client-side için ürün referans verilerini (Toptan fiyatlar ve Varyasyon fiyatları için) hazırla
const productRefs = activeProducts.map(p => ({
  id: p.id,
  price: p.price,
  min_order_qty: p.min_order_qty || 1,
  variants: p.variants || [],
  wholesalePrices: p.wholesalePrices || []
}));
const productRefsJson = JSON.stringify(productRefs);
---

<BaseLayout title="Sepetim | Laflaf E-Ticaret">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 min-h-[60vh]">
    
    <div class="flex items-center gap-3 mb-8 pb-4 border-b border-gray-200 dark:border-gray-800">
      <i class="fas fa-shopping-cart text-3xl text-gray-800 dark:text-gray-200"></i>
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Alışveriş Sepetim</h1>
    </div>

    <!-- Yükleniyor Durumu -->
    <div id="cartLoading" class="flex flex-col items-center justify-center py-20 text-gray-500">
      <i class="fas fa-circle-notch fa-spin text-4xl text-orange-500 mb-4"></i>
      <p>Sepetiniz yükleniyor...</p>
    </div>

    <!-- Boş Sepet -->
    <div id="emptyCartMessage" class="hidden flex-col items-center justify-center py-16 px-4 bg-gray-50 dark:bg-gray-800/30 rounded-2xl border border-dashed border-gray-300 dark:border-gray-700">
      <div class="w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mb-6">
        <i class="fas fa-shopping-basket text-4xl text-gray-400 dark:text-gray-500"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Sepetiniz şu an boş.</h2>
      <p class="text-gray-500 dark:text-gray-400 mb-8 text-center max-w-md">E-ticaret mağazamızdaki harika ürünleri inceleyip hemen alışverişe başlayabilirsiniz.</p>
      <a href="/urunler" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition transform hover:-translate-y-1">
        Alışverişe Başla
      </a>
    </div>

    <!-- Sepet İçeriği -->
    <div id="cartContent" class="hidden flex-col lg:flex-row gap-8">
      
      <!-- Sol: Ürün Listesi -->
      <div class="lg:w-2/3">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
          
          <div class="p-6 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/80 flex justify-between items-center">
            <h3 class="font-bold text-gray-700 dark:text-gray-300">Sepetteki Ürünler (<span id="cartItemCount">0</span>)</h3>
            <button id="clearCartBtn" class="text-sm text-red-500 hover:text-red-700 flex items-center gap-1 transition">
              <i class="fas fa-trash-alt"></i> Sepeti Boşalt
            </button>
          </div>
          
          <ul id="cartItemList" class="divide-y divide-gray-200 dark:divide-gray-700">
            <!-- JS ile doldurulacak -->
          </ul>
          
        </div>
      </div>

      <!-- Sağ: Sipariş Özeti -->
      <div class="lg:w-1/3">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sticky top-24">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 border-b border-gray-200 dark:border-gray-700 pb-4">Sipariş Özeti</h3>
          
          <div class="space-y-4 text-sm mb-6">
            <div class="flex justify-between items-center text-gray-600 dark:text-gray-400">
              <span>Ara Toplam</span>
              <span id="subTotalAmount" class="font-medium text-gray-900 dark:text-white">0,00 ₺</span>
            </div>
            
            <!-- İleride eklenebilecek kargo vb. için yer -->
            <div class="flex justify-between items-center text-gray-500 text-xs">
              <span>Kargo Ücreti</span>
              <span>Sonraki adımda hesaplanacak</span>
            </div>
          </div>
          
          <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mb-8">
            <div class="flex justify-between items-center">
              <span class="text-lg font-bold text-gray-900 dark:text-white">Genel Toplam</span>
              <span id="totalAmount" class="text-2xl font-extrabold text-orange-600">0,00 ₺</span>
            </div>
            <p class="text-xs text-gray-500 text-right mt-1">Vergiler Dahildir</p>
          </div>
          
          <a href="/checkout" class="w-full block text-center bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 px-6 rounded-xl shadow-lg hover:shadow-orange-500/30 transition transform hover:-translate-y-1">
            Alışverişi Tamamla <i class="fas fa-arrow-right ml-2"></i>
          </a>
          
          <div class="mt-6 flex items-center justify-center gap-2 text-gray-400 text-xl">
            <i class="fab fa-cc-visa"></i>
            <i class="fab fa-cc-mastercard"></i>
            <i class="fab fa-cc-amex"></i>
          </div>
          <p class="text-center text-xs text-gray-400 mt-2"><i class="fas fa-lock"></i> 256-bit Güvenli Ödeme</p>
        </div>
      </div>
      
    </div>
  </div>

  <script is:inline define:vars={{ productsData: productRefsJson }}>
    document.addEventListener('DOMContentLoaded', () => {
      const dbProducts = JSON.parse(productsData);
      
      const cartLoading = document.getElementById('cartLoading');
      const emptyCartMessage = document.getElementById('emptyCartMessage');
      const cartContent = document.getElementById('cartContent');
      const cartItemList = document.getElementById('cartItemList');
      const cartItemCount = document.getElementById('cartItemCount');
      const subTotalAmount = document.getElementById('subTotalAmount');
      const totalAmount = document.getElementById('totalAmount');
      const clearCartBtn = document.getElementById('clearCartBtn');
      
      const formatMoney = (amount) => {
        return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
      };

      const getCart = () => {
        try {
          return JSON.parse(localStorage.getItem('laflaf_cart') || '[]');
        } catch(e) { return []; }
      };

      const saveCart = (cart) => {
        localStorage.setItem('laflaf_cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart_updated'));
      };

      // Recalculate price dynamically based on DB rules
      const calculateItemPrice = (cartItem, dbProd) => {
        if (!dbProd) return cartItem.price; // fallback
        
        let price = dbProd.price;
        
        // 1. Toptan kuralları
        if (dbProd.wholesalePrices && dbProd.wholesalePrices.length > 0) {
          const sortedWP = [...dbProd.wholesalePrices].sort((a,b) => b.min_qty - a.min_qty);
          for(let wp of sortedWP) {
            if (cartItem.qty >= wp.min_qty) {
              price = wp.price_per_unit;
              break;
            }
          }
        }
        
        // 2. Varyasyon override
        if (cartItem.variant_id) {
          const v = dbProd.variants.find(v => v.id === cartItem.variant_id);
          if (v && v.price) {
            price = v.price; // Varyasyonların toptan fiyattan üstün olduğunu varsayıyoruz (basitlik için).
          }
        }
        
        return price;
      };

      const renderCart = () => {
        const cart = getCart();
        
        cartLoading.classList.add('hidden');
        
        if (cart.length === 0) {
          cartContent.classList.add('hidden');
          emptyCartMessage.classList.remove('hidden');
          emptyCartMessage.classList.add('flex');
          return;
        }
        
        emptyCartMessage.classList.add('hidden');
        emptyCartMessage.classList.remove('flex');
        cartContent.classList.remove('hidden');
        cartContent.classList.add('flex');
        
        let html = '';
        let subTotal = 0;
        let totalItems = 0;
        
        cart.forEach((item, index) => {
          // DB'deki güncel kuralları çek
          const dbProd = dbProducts.find(p => p.id === item.product_id);
          
          // Miktarı minimumun altına düşürme
          let minQty = dbProd ? dbProd.min_order_qty : 1;
          if (item.qty < minQty) item.qty = minQty;
          
          // Stok kontrolü varyasyon
          let maxStock = 9999;
          if (dbProd && item.variant_id) {
            const v = dbProd.variants.find(v => v.id === item.variant_id);
            if (v) maxStock = v.stock;
          }
          if (item.qty > maxStock) item.qty = maxStock;
          
          // Gerçek fiyatı hesapla
          item.price = calculateItemPrice(item, dbProd);
          
          const itemTotal = item.price * item.qty;
          subTotal += itemTotal;
          totalItems += item.qty;
          
          const imageHtml = item.image 
            ? `<img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover" />` 
            : `<div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-400"><i class="fas fa-image text-2xl"></i></div>`;
          
          const variantHtml = item.variant_name 
            ? `<div class="text-xs text-gray-500 mt-1 bg-gray-100 dark:bg-gray-700 inline-block px-2 py-0.5 rounded">Seçim: ${item.variant_name}</div>` 
            : '';
            
          html += `
            <li class="p-6 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
              <div class="flex flex-col sm:flex-row items-center gap-6">
                <!-- Ürün Görseli -->
                <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 flex-shrink-0 relative bg-white">
                  ${imageHtml}
                </div>
                
                <!-- Ürün Bilgileri -->
                <div class="flex-1 w-full flex flex-col justify-between">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <h4 class="text-lg font-bold text-gray-900 dark:text-white line-clamp-2">${item.name}</h4>
                      ${variantHtml}
                    </div>
                    <!-- Çöp Kutusu -->
                    <button class="remove-item text-gray-400 hover:text-red-500 transition p-2" data-id="${item.id}" title="Sepetten Çıkar">
                      <i class="fas fa-trash-alt text-lg"></i>
                    </button>
                  </div>
                  
                  <div class="flex flex-wrap justify-between items-end mt-4 gap-4">
                    <!-- Fiyat -->
                    <div class="text-gray-500 text-sm">
                      Birim Fiyatı: <strong class="text-gray-900 dark:text-white">${formatMoney(item.price)}</strong>
                    </div>
                    
                    <!-- Adet Kontrolü -->
                    <div class="flex items-center gap-4">
                      <div class="flex items-center border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden bg-white dark:bg-gray-800">
                        <button class="qty-btn qty-minus w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700" data-id="${item.id}">
                          <i class="fas fa-minus text-xs"></i>
                        </button>
                        <input type="text" class="w-12 h-8 sm:h-10 text-center text-sm font-bold border-0 bg-transparent focus:ring-0 p-0 pointer-events-none dark:text-white" value="${item.qty}" readonly />
                        <button class="qty-btn qty-plus w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700" data-id="${item.id}">
                          <i class="fas fa-plus text-xs"></i>
                        </button>
                      </div>
                      
                      <!-- Toplam Fiyat -->
                      <div class="text-lg sm:text-xl font-extrabold text-orange-600 w-24 text-right">
                        ${formatMoney(itemTotal)}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          `;
        });
        
        // Update DOM
        cartItemList.innerHTML = html;
        cartItemCount.textContent = totalItems.toString();
        subTotalAmount.textContent = formatMoney(subTotal);
        totalAmount.textContent = formatMoney(subTotal); // Vergiler dahil varsayımı
        
        // Adet azaltma/arttırma eventleri bağla
        bindEvents();
      };
      
      const bindEvents = () => {
        document.querySelectorAll('.remove-item').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const id = e.currentTarget.getAttribute('data-id');
            let cart = getCart();
            cart = cart.filter(item => item.id !== id);
            saveCart(cart);
            renderCart();
          });
        });
        
        document.querySelectorAll('.qty-minus').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const id = e.currentTarget.getAttribute('data-id');
            let cart = getCart();
            const item = cart.find(i => i.id === id);
            if (item) {
              const dbProd = dbProducts.find(p => p.id === item.product_id);
              const minQty = dbProd ? dbProd.min_order_qty : 1;
              if (item.qty > minQty) {
                item.qty--;
                saveCart(cart);
                renderCart();
              }
            }
          });
        });

        document.querySelectorAll('.qty-plus').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const id = e.currentTarget.getAttribute('data-id');
            let cart = getCart();
            const item = cart.find(i => i.id === id);
            if (item) {
              const dbProd = dbProducts.find(p => p.id === item.product_id);
              let maxStock = 9999;
              if (dbProd && item.variant_id) {
                const v = dbProd.variants.find(v => v.id === item.variant_id);
                if (v) maxStock = v.stock;
              }
              
              if (item.qty < maxStock) {
                item.qty++;
                saveCart(cart);
                renderCart();
              } else {
                alert('Maksimum stok sınırına ulaştınız.');
              }
            }
          });
        });
      };
      
      if (clearCartBtn) {
        clearCartBtn.addEventListener('click', () => {
          if (confirm('Sepetinizdeki tüm ürünleri silmek istediğinize emin misiniz?')) {
            saveCart([]);
            renderCart();
          }
        });
      }

      // İlk yükleme
      setTimeout(renderCart, 200); // Küçük bir gecikme UI loading hissiyatı için
      
      // Başka sayfadan güncellenirse
      window.addEventListener('storage', (e) => {
        if (e.key === 'laflaf_cart') {
          renderCart();
        }
      });
    });
  </script>
</BaseLayout>
