---

<BaseLayout title="Sosyal Medya Hesaplarımız">
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight bg-gradient-to-r from-orange-500 to-purple-600 bg-clip-text text-transparent sm:text-5xl">
        Sosyal Medya Hesaplarımız
      </h1>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
        Bizimle sosyal ağlar üzerinden iletişime geçin ve en güncel paylaşımlarımızı takip edin.
      </p>
    </div>

    {activeSocials.length === 0 ? (
      <div class="text-center py-12 bg-gray-50 dark:bg-gray-800 rounded-2xl border border-dashed border-gray-300 dark:border-gray-700">
        <p class="text-gray-500 dark:text-gray-400">Aktif sosyal medya hesabı bulunamadı.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {activeSocials.map((social: any) => {
          const bgClasses = {
            x: 'bg-black text-white hover:shadow-black/20',
            facebook: 'bg-[#1877F2] text-white hover:shadow-[#1877F2]/20',
            instagram: 'bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] text-white hover:shadow-pink-500/20',
            linkedin: 'bg-[#0A66C2] text-white hover:shadow-[#0A66C2]/20',
            pinterest: 'bg-[#BD081C] text-white hover:shadow-[#BD081C]/20',
            youtube: 'bg-[#FF0000] text-white hover:shadow-[#FF0000]/20',
            tiktok: 'bg-black text-white hover:shadow-black/20',
            medium: 'bg-black text-white hover:shadow-black/20',
            whatsapp: 'bg-[#25D366] text-white hover:shadow-[#25D366]/20',
            telegram: 'bg-[#0088cc] text-white hover:shadow-[#0088cc]/20',
            phone: 'bg-emerald-500 text-white hover:shadow-emerald-500/20',
            email: 'bg-red-500 text-white hover:shadow-red-500/20'
          };

          const colors = {
            x: '#000000',
            facebook: '#1877F2',
            instagram: '#E1306C',
            linkedin: '#0A66C2',
            pinterest: '#BD081C',
            youtube: '#FF0000',
            tiktok: '#010101',
            medium: '#000000',
            whatsapp: '#25D366',
            telegram: '#0088cc',
            phone: '#25D366',
            email: '#ea4335'
          };

          return (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-card group relative overflow-hidden bg-white dark:bg-gray-800 p-6 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col items-center text-center justify-between min-h-[180px]"
              data-color={colors[social.id]}
            >
              <div class="flex-1 flex flex-col items-center justify-center">
                <div class={`w-14 h-14 rounded-2xl flex items-center justify-center transition-all duration-300 ${bgClasses[social.id] || 'bg-gray-500 text-white'}`}>
                  <Fragment set:html={getSvgForPlatform(social.id)} />
                </div>
                <h3 class="mt-4 font-bold text-xl text-gray-900 dark:text-white transition-colors duration-300 target-name">
                  {social.name}
                </h3>
              </div>
              <div class="mt-4 w-full">
                <span class="action-btn inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-xl text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 transition-all duration-300 w-full">
                  Git / Bağlan
                </span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .social-card {
    --hover-color: #f97316;
  }
  .social-card[data-color="#000000"] { --hover-color: #000000; }
  .social-card[data-color="#1877F2"] { --hover-color: #1877F2; }
  .social-card[data-color="#E1306C"] { --hover-color: #E1306C; }
  .social-card[data-color="#0A66C2"] { --hover-color: #0A66C2; }
  .social-card[data-color="#BD081C"] { --hover-color: #BD081C; }
  .social-card[data-color="#FF0000"] { --hover-color: #FF0000; }
  .social-card[data-color="#010101"] { --hover-color: #010101; }
  .social-card[data-color="#25D366"] { --hover-color: #25D366; }
  .social-card[data-color="#0088cc"] { --hover-color: #0088cc; }
  .social-card[data-color="#ea4335"] { --hover-color: #ea4335; }

  .social-card:hover .target-name {
    color: var(--hover-color);
  }
  .social-card:hover .action-btn {
    background-color: var(--hover-color);
    color: white;
  }
</style>
