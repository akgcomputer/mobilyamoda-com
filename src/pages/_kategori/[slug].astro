---
// src/pages/kategori/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = ['kesfet', 'en-populer', 'en-yeni', 'en-begenilenler', 'trend'];
  return categories.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Mock içerikler
const allPosts = [
  { id: 1, title: 'Meraklı İçerik 1', excerpt: 'İçerik özeti...', date: '2024-01-01', slug: 'icerik-1', category: 'kesfet' },
  { id: 2, title: 'Meraklı İçerik 2', excerpt: 'İçerik özeti...', date: '2024-01-02', slug: 'icerik-2', category: 'trend' },
  { id: 3, title: 'Meraklı İçerik 3', excerpt: 'İçerik özeti...', date: '2024-01-03', slug: 'icerik-3', category: 'en-populer' },
  { id: 4, title: 'Meraklı İçerik 4', excerpt: 'İçerik özeti...', date: '2024-01-04', slug: 'icerik-4', category: 'kesfet' },
];

const categoryMap: Record<string, string> = {
  'kesfet': 'Keşfet',
  'en-populer': 'En Popüler',
  'en-yeni': 'En Yeni',
  'en-begenilenler': 'En Beğenilenler',
  'trend': 'Trend'
};

const categoryName = categoryMap[slug];
const filteredPosts = allPosts.filter(p => p.category === slug);

if (!categoryName) {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${categoryName} - Laflaf`}>
  <!-- Header -->
  <div class="bg-gradient-to-r from-orange-500 to-purple-600 text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold">{categoryName}</h1>
      <p class="text-lg opacity-90 mt-2">{filteredPosts.length} içerik bulundu</p>
    </div>
  </div>

  <!-- Grid -->
  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {filteredPosts.map(post => (
        <a href={`/${post.slug}`} class="group bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow hover:shadow-lg transition">
          <div class="aspect-square bg-gradient-to-br from-orange-400 to-purple-500 flex items-center justify-center">
            <span class="text-white text-4xl">📄</span>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-lg group-hover:text-orange-500 transition">{post.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{post.date}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>