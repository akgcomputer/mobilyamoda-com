---
// src/pages/checkout/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createOrder, getCouponByCode } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let basari = '';
let hata = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const cartDataStr = formData.get('cart_data') as string;
    
    if (!cartDataStr) {
      throw new Error("Sepet verisi bulunamadı.");
    }
    
    const cartData = JSON.parse(cartDataStr);
    if (!Array.isArray(cartData) || cartData.length === 0) {
      throw new Error("Sepetiniz boş.");
    }

    const customer_name = formData.get('customer_name') as string;
    const customer_email = formData.get('customer_email') as string;
    const customer_phone = formData.get('customer_phone') as string;
    const shipping_address = formData.get('shipping_address') as string;
    const payment_method = formData.get('payment_method') as string; // havale, kapida, kredi_karti, banka_kredisi
    
    if (!customer_name || !customer_email || !shipping_address || !payment_method) {
      throw new Error("Lütfen zorunlu alanları doldurun.");
    }

    let subtotal = 0;
    const orderItems = cartData.map(item => {
      const itemTotal = item.qty * item.price;
      subtotal += itemTotal;
      return {
        product_id: item.product_id,
        variant_id: item.variant_id || null,
        product_name: item.name,
        variant_name: item.variant_name || null,
        quantity: item.qty,
        unit_price: item.price,
        total_price: itemTotal
      };
    });

    const coupon_code = formData.get('coupon_code') as string;
    let discount_amount = 0;
    let final_coupon_code = null;

    if (coupon_code) {
      const coupon = await getCouponByCode(coupon_code, dbBinding);
      if (coupon && coupon.status === 'aktif' && (!coupon.min_cart_amount || subtotal >= coupon.min_cart_amount)) {
        if (coupon.discount_type === 'percentage') {
          discount_amount = subtotal * (coupon.discount_value / 100);
        } else {
          discount_amount = coupon.discount_value;
        }
        if (discount_amount > subtotal) discount_amount = subtotal;
        final_coupon_code = coupon.code;
      }
    }

    const total_amount = subtotal - discount_amount;

    const orderData = {
      user_id: null, // Şimdilik hep ziyaretçi siparişi olarak varsayıyoruz
      customer_name,
      customer_email,
      customer_phone,
      shipping_address,
      billing_address: shipping_address, // MVP için aynı
      subtotal,
      shipping_fee: 0,
      tax: 0,
      discount_amount,
      coupon_code: final_coupon_code,
      total_amount,
      payment_method,
      status: 'bekliyor',
      notes: null
    };

    const newOrder = await createOrder(orderData, orderItems, dbBinding);
    
    if (newOrder) {
      basari = `Siparişiniz #LAF${newOrder.id} numarası ile başarıyla alınmıştır. Bizi tercih ettiğiniz için teşekkür ederiz!`;
    } else {
      throw new Error("Sipariş oluşturulamadı.");
    }

  } catch (err: any) {
    console.error("Checkout Error:", err);
    hata = err.message || "İşlem sırasında bir hata oluştu.";
  }
}
---

<BaseLayout title="Ödeme ve Teslimat | Laflaf E-Ticaret">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    
    {basari ? (
      <div class="max-w-2xl mx-auto text-center py-20">
        <div class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
          <i class="fas fa-check"></i>
        </div>
        <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white mb-4">Siparişiniz Alındı!</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">{basari}</p>
        <div class="p-6 bg-gray-50 dark:bg-gray-800/50 rounded-2xl border border-gray-200 dark:border-gray-700 mb-8 text-left">
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Sonraki Adımlar</h3>
          <ul class="list-disc list-inside text-gray-600 dark:text-gray-400 space-y-2">
            <li>Sipariş detaylarınız e-posta adresinize gönderilecektir.</li>
            <li>Siparişiniz onaylandığında ve kargoya verildiğinde sizi bilgilendireceğiz.</li>
            <li>Havale/EFT seçtiyseniz lütfen ödemenizi açıklama kısmına sipariş numaranızı yazarak gerçekleştirin.</li>
          </ul>
        </div>
        <a href="/" class="inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg transition-transform hover:-translate-y-0.5">Alışverişe Dön</a>
        
        <!-- LocalStorage temizleme ve sipariş kaydetme scripti -->
        <script is:inline define:vars={{ newOrderId: newOrder.id }}>
          localStorage.removeItem('laflaf_cart');
          localStorage.removeItem('laflaf_coupon');
          window.dispatchEvent(new Event('cart_updated'));

          // Siparişi local storage'a kaydet (Ziyaretçi takibi için)
          if (newOrderId) {
            let myOrders = [];
            try { myOrders = JSON.parse(localStorage.getItem('laflaf_my_orders') || '[]'); } catch(e){}
            if (!myOrders.includes(newOrderId)) {
              myOrders.push(newOrderId);
              localStorage.setItem('laflaf_my_orders', JSON.stringify(myOrders));
            }
          }
        </script>
      </div>
    ) : (
      <>
        <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
          <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white">Güvenli Ödeme</h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">Ziyaretçi olarak veya giriş yaparak siparişinizi tamamlayabilirsiniz.</p>
        </div>

        {hata && (
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-xl"></i>
            <span>{hata}</span>
          </div>
        )}

        <form method="POST" id="checkoutForm" class="flex flex-col lg:flex-row gap-8">
          <input type="hidden" name="cart_data" id="cartDataInput" value="" />
          <input type="hidden" name="payment_method" id="paymentMethodInput" value="havale" />
          <input type="hidden" name="coupon_code" id="couponCodeInput" value="" />
          
          <!-- Sol: Form Alanları -->
          <div class="lg:w-2/3 space-y-8">
            
            <!-- Kişisel Bilgiler -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center text-sm">1</span>
                Kişisel Bilgiler (Ziyaretçi)
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="md:col-span-2">
                  <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Ad Soyad *</label>
                  <input type="text" name="customer_name" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" placeholder="Örn: Ahmet Yılmaz" />
                </div>
                <div>
                  <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">E-Posta Adresi *</label>
                  <input type="email" name="customer_email" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" placeholder="Örn: ahmet@example.com" />
                </div>
                <div>
                  <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Telefon</label>
                  <input type="tel" name="customer_phone" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" placeholder="Örn: 0555 123 4567" />
                </div>
              </div>
            </div>

            <!-- Teslimat Adresi -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center text-sm">2</span>
                Teslimat Adresi
              </h2>
              <div>
                <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Açık Adres *</label>
                <textarea name="shipping_address" required rows="3" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" placeholder="Mahalle, Sokak, Apartman No, İlçe, İl"></textarea>
              </div>
            </div>

            <!-- Ödeme Yöntemi -->
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                <span class="w-8 h-8 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center text-sm">3</span>
                Ödeme Yöntemi
              </h2>
              
              <!-- Tab Headers -->
              <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-6 border-b border-gray-200 dark:border-gray-700 pb-2">
                <button type="button" class="pay-tab-btn px-4 py-3 text-sm font-bold border-b-2 border-orange-500 text-orange-600 transition" data-target="havale">
                  <i class="fas fa-university mb-1 block text-lg"></i> Havale / EFT
                </button>
                <button type="button" class="pay-tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 dark:hover:text-white transition" data-target="kapida">
                  <i class="fas fa-box mb-1 block text-lg"></i> Kapıda Ödeme
                </button>
                <button type="button" class="pay-tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 dark:hover:text-white transition" data-target="kredi_karti">
                  <i class="fas fa-credit-card mb-1 block text-lg"></i> Kredi Kartı
                </button>
                <button type="button" class="pay-tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 dark:hover:text-white transition" data-target="banka_kredisi">
                  <i class="fas fa-hand-holding-usd mb-1 block text-lg"></i> Banka Kredisi
                </button>
              </div>

              <!-- Tab Contents -->
              <div id="tab-havale" class="pay-tab-content block">
                <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-4 rounded-lg text-sm text-blue-800 dark:text-blue-300">
                  <p class="font-bold mb-2">Banka Hesap Bilgilerimiz:</p>
                  <p><strong>Banka:</strong> Örnek Bankası A.Ş.</p>
                  <p><strong>IBAN:</strong> TR00 0000 0000 0000 0000 0000 00</p>
                  <p><strong>Alıcı:</strong> Laflaf Bilişim ve Tic. Ltd. Şti.</p>
                  <p class="mt-2 text-xs italic">Lütfen açıklama kısmına sipariş kodunuzu yazmayı unutmayın. Siparişiniz ödeme onayından sonra kargoya verilecektir.</p>
                </div>
              </div>

              <div id="tab-kapida" class="pay-tab-content hidden">
                <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 p-4 rounded-lg text-sm text-orange-800 dark:text-orange-300 flex items-start gap-3">
                  <i class="fas fa-truck text-2xl mt-1"></i>
                  <div>
                    <p class="font-bold mb-1">Kapıda Nakit / Kredi Kartı ile Ödeme</p>
                    <p>Siparişinizi teslim alırken kargo görevlisine nakit veya kredi kartı ile ödeme yapabilirsiniz. Kapıda ödeme hizmet bedeli yansıtılmamaktadır.</p>
                  </div>
                </div>
              </div>

              <div id="tab-kredi_karti" class="pay-tab-content hidden relative">
                <div class="absolute inset-0 bg-white/60 dark:bg-gray-800/60 backdrop-blur-[2px] z-10 flex items-center justify-center rounded-lg">
                  <div class="bg-gray-900 text-white px-4 py-2 rounded-lg font-bold shadow-lg flex items-center gap-2">
                    <i class="fas fa-lock"></i> Aktif Etmek İçin Yöneticiye Başvurun
                  </div>
                </div>
                <div class="opacity-30 pointer-events-none">
                  <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                      <label class="block text-xs font-semibold mb-1">Kart Numarası</label>
                      <input type="text" class="w-full border border-gray-300 rounded px-3 py-2 bg-gray-50" placeholder="0000 0000 0000 0000" disabled>
                    </div>
                    <div>
                      <label class="block text-xs font-semibold mb-1">Son Kullanma (AA/YY)</label>
                      <input type="text" class="w-full border border-gray-300 rounded px-3 py-2 bg-gray-50" placeholder="12/25" disabled>
                    </div>
                    <div>
                      <label class="block text-xs font-semibold mb-1">CVC</label>
                      <input type="text" class="w-full border border-gray-300 rounded px-3 py-2 bg-gray-50" placeholder="123" disabled>
                    </div>
                  </div>
                </div>
              </div>

              <div id="tab-banka_kredisi" class="pay-tab-content hidden relative">
                <div class="absolute inset-0 bg-white/60 dark:bg-gray-800/60 backdrop-blur-[2px] z-10 flex items-center justify-center rounded-lg">
                  <div class="bg-gray-900 text-white px-4 py-2 rounded-lg font-bold shadow-lg flex items-center gap-2">
                    <i class="fas fa-lock"></i> Aktif Etmek İçin Yöneticiye Başvurun
                  </div>
                </div>
                <div class="opacity-30 pointer-events-none p-4 border border-gray-300 rounded-lg">
                  <div class="flex justify-between items-center mb-4">
                    <h3 class="font-bold">Anında Alışveriş Kredisi</h3>
                    <i class="fas fa-university text-2xl text-gray-400"></i>
                  </div>
                  <p class="text-sm mb-4">36 aya varan vade seçenekleriyle banka kredisi kullanarak alışverişinizi hemen tamamlayabilirsiniz.</p>
                  <button type="button" class="w-full bg-blue-600 text-white font-bold py-2 rounded" disabled>Krediye Başvur</button>
                </div>
              </div>

            </div>
          </div>

          <!-- Sağ: Sipariş Özeti -->
          <div class="lg:w-1/3">
            <div class="bg-gray-50 dark:bg-gray-800/80 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 sticky top-24">
              <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Sipariş Özeti</h2>
              
              <div id="checkoutSummaryItems" class="space-y-4 mb-6 border-b border-gray-200 dark:border-gray-700 pb-6 max-h-60 overflow-y-auto pr-2">
                <!-- JS tarafından doldurulacak -->
              </div>
              
              <div class="space-y-3 mb-6 text-sm text-gray-600 dark:text-gray-300">
                <div class="flex justify-between">
                  <span>Ara Toplam</span>
                  <span id="coSubtotal" class="font-medium text-gray-900 dark:text-white">0,00 ₺</span>
                </div>
                <div id="coDiscountRow" class="flex justify-between hidden text-green-600">
                  <span>İndirim (<span id="coCouponDisplay"></span>)</span>
                  <span id="coDiscount" class="font-medium">-0,00 ₺</span>
                </div>
                <div class="flex justify-between">
                  <span>Kargo Ücreti</span>
                  <span class="font-medium text-green-600">Ücretsiz</span>
                </div>
              </div>
              
              <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mb-8">
                <div class="flex justify-between items-center">
                  <span class="text-lg font-bold text-gray-900 dark:text-white">Toplam</span>
                  <span id="coTotal" class="text-2xl font-extrabold text-orange-600">0,00 ₺</span>
                </div>
              </div>
              
              <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white text-center font-bold py-4 px-6 rounded-xl shadow-lg transition-transform hover:-translate-y-0.5 text-lg flex items-center justify-center gap-2">
                <i class="fas fa-lock"></i> Siparişi Onayla
              </button>
              
              <p class="text-xs text-gray-500 text-center mt-4">
                Siparişi onaylayarak <strong>Mesafeli Satış Sözleşmesi</strong> ve <strong>Ön Bilgilendirme Formu</strong>'nu kabul etmiş olursunuz.
              </p>
            </div>
          </div>
        </form>
      </>
    )}
  </div>

  {!basari && (
    <script is:inline>
      const formatMoney = (amount) => {
        return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
      };

      // Load cart data
      let cart = [];
      try {
        cart = JSON.parse(localStorage.getItem('laflaf_cart') || '[]');
      } catch(e) {}

      // If cart empty, redirect
      if (cart.length === 0) {
        window.location.href = '/sepet';
      }

      // Populate hidden input
      document.getElementById('cartDataInput').value = JSON.stringify(cart);

      // Render Summary
      const summaryItemsContainer = document.getElementById('checkoutSummaryItems');
      let subtotal = 0;
      
      cart.forEach(item => {
        const itemTotal = item.qty * item.price;
        subtotal += itemTotal;
        
        const div = document.createElement('div');
        div.className = 'flex gap-3 text-sm';
        
        const imgHtml = item.image 
          ? `<img src="${item.image}" class="w-12 h-12 object-cover rounded border border-gray-200 dark:border-gray-600" />`
          : `<div class="w-12 h-12 bg-gray-200 dark:bg-gray-700 rounded border border-gray-300 dark:border-gray-600 flex items-center justify-center text-gray-400"><i class="fas fa-image"></i></div>`;
        
        div.innerHTML = `
          ${imgHtml}
          <div class="flex-1">
            <div class="font-bold text-gray-900 dark:text-white line-clamp-1">${item.name}</div>
            <div class="text-xs text-gray-500">${item.variant_name ? item.variant_name + ' | ' : ''}${item.qty} Adet</div>
          </div>
          <div class="font-bold text-gray-900 dark:text-white">
            ${formatMoney(itemTotal)}
          </div>
        `;
        summaryItemsContainer.appendChild(div);
      });

      document.getElementById('coSubtotal').textContent = formatMoney(subtotal);
      
      let discountAmount = 0;
      let appliedCoupon = null;
      try { appliedCoupon = JSON.parse(localStorage.getItem('laflaf_coupon')); } catch(e){}

      if (appliedCoupon) {
        if (appliedCoupon.type === 'percentage') {
          discountAmount = subtotal * (appliedCoupon.value / 100);
        } else {
          discountAmount = appliedCoupon.value;
        }
        if (discountAmount > subtotal) discountAmount = subtotal;
        
        document.getElementById('coDiscountRow').classList.remove('hidden');
        document.getElementById('coCouponDisplay').textContent = appliedCoupon.code;
        document.getElementById('coDiscount').textContent = '-' + formatMoney(discountAmount);
        document.getElementById('couponCodeInput').value = appliedCoupon.code;
      }

      const total = subtotal - discountAmount;
      document.getElementById('coTotal').textContent = formatMoney(total > 0 ? total : 0);

      // Tabs Logic
      const tabBtns = document.querySelectorAll('.pay-tab-btn');
      const tabContents = document.querySelectorAll('.pay-tab-content');
      const paymentMethodInput = document.getElementById('paymentMethodInput');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          // Reset styles
          tabBtns.forEach(b => {
            b.classList.remove('border-orange-500', 'text-orange-600', 'font-bold');
            b.classList.add('border-transparent', 'text-gray-500', 'font-medium');
          });
          
          // Hide all contents
          tabContents.forEach(c => c.classList.add('hidden'));
          tabContents.forEach(c => c.classList.remove('block'));

          // Activate clicked
          const target = e.currentTarget;
          target.classList.remove('border-transparent', 'text-gray-500', 'font-medium');
          target.classList.add('border-orange-500', 'text-orange-600', 'font-bold');
          
          const targetId = target.getAttribute('data-target');
          document.getElementById('tab-' + targetId).classList.remove('hidden');
          document.getElementById('tab-' + targetId).classList.add('block');
          
          paymentMethodInput.value = targetId;
        });
      });

      // Prevent submit if restricted method
      document.getElementById('checkoutForm').addEventListener('submit', (e) => {
        const method = paymentMethodInput.value;
        if (method === 'kredi_karti' || method === 'banka_kredisi') {
          e.preventDefault();
          alert('Bu ödeme yöntemi henüz aktif değildir. Lütfen Yöneticiye başvurun veya başka bir yöntem seçin.');
        }
      });
    </script>
  )}
</BaseLayout>
