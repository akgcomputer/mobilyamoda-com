---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Güvenli Ödeme | Laflaf E-Ticaret">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12 bg-gray-50 dark:bg-gray-950 min-h-screen">
    
    <div class="text-center mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Güvenli Ödeme</h1>
      <p class="text-gray-500 mt-2">Siparişinizi tamamlamak için bilgilerinizi girin.</p>
    </div>

    <!-- Hata ve Bilgi Mesajları -->
    <div id="alertMessage" class="hidden max-w-4xl mx-auto mb-6 p-4 rounded-xl text-center font-bold"></div>

    <form id="checkoutForm" class="flex flex-col lg:flex-row gap-8 max-w-6xl mx-auto">
      
      <!-- Sol: İletişim ve Adres -->
      <div class="lg:w-2/3 space-y-8">
        
        <!-- 1. İletişim Bilgileri -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
            <span class="bg-orange-100 text-orange-600 dark:bg-orange-900 dark:text-orange-400 w-8 h-8 rounded-full flex items-center justify-center text-sm">1</span> 
            İletişim Bilgileri
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Ad Soyad <span class="text-red-500">*</span></label>
              <input type="text" id="customer_name" name="customer_name" required class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none dark:text-white" placeholder="Örn: Ahmet Yılmaz">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Telefon Numarası <span class="text-red-500">*</span></label>
              <input type="tel" id="customer_phone" name="customer_phone" required class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none dark:text-white" placeholder="05XX XXX XX XX">
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">E-Posta Adresi <span class="text-red-500">*</span></label>
              <input type="email" id="customer_email" name="customer_email" required class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none dark:text-white" placeholder="Siparişinizin faturası bu adrese gönderilecektir.">
            </div>
          </div>
        </div>

        <!-- 2. Teslimat Adresi -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
            <span class="bg-orange-100 text-orange-600 dark:bg-orange-900 dark:text-orange-400 w-8 h-8 rounded-full flex items-center justify-center text-sm">2</span> 
            Teslimat Adresi
          </h2>
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Açık Adres <span class="text-red-500">*</span></label>
              <textarea id="shipping_address" name="shipping_address" rows="3" required class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none dark:text-white resize-none" placeholder="Mahalle, sokak, apartman ve daire numarası..."></textarea>
            </div>
            <div class="flex items-center gap-3">
              <input type="checkbox" id="same_as_shipping" checked class="w-5 h-5 text-orange-600 rounded focus:ring-orange-500 dark:bg-gray-700 dark:border-gray-600">
              <label for="same_as_shipping" class="text-sm text-gray-700 dark:text-gray-300 cursor-pointer">Fatura adresim teslimat adresim ile aynı olsun.</label>
            </div>
            <div id="billing_address_container" class="hidden">
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Fatura Adresi</label>
              <textarea id="billing_address" name="billing_address" rows="3" class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition outline-none dark:text-white resize-none" placeholder="Fatura adresi ve varsa V.D. / V.No..."></textarea>
            </div>
          </div>
        </div>

        <!-- 3. Ödeme Yöntemi -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
            <span class="bg-orange-100 text-orange-600 dark:bg-orange-900 dark:text-orange-400 w-8 h-8 rounded-full flex items-center justify-center text-sm">3</span> 
            Ödeme Yöntemi
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <label class="relative flex flex-col p-4 cursor-pointer border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition payment-method-card has-checked">
              <input type="radio" name="payment_method" value="havale" class="peer sr-only" checked>
              <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-orange-500 pointer-events-none transition"></div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                  <i class="fas fa-university text-orange-500"></i> Havale / EFT
                </span>
                <i class="fas fa-check-circle text-orange-500 opacity-0 peer-checked:opacity-100 transition"></i>
              </div>
              <span class="text-xs text-gray-500 mt-auto">Banka hesaplarımıza ödeme yapabilirsiniz.</span>
            </label>

            <label class="relative flex flex-col p-4 cursor-pointer border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition payment-method-card">
              <input type="radio" name="payment_method" value="kapida" class="peer sr-only">
              <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-orange-500 pointer-events-none transition"></div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                  <i class="fas fa-truck text-orange-500"></i> Kapıda Ödeme
                </span>
                <i class="fas fa-check-circle text-orange-500 opacity-0 peer-checked:opacity-100 transition"></i>
              </div>
              <span class="text-xs text-gray-500 mt-auto">Ürün teslimatında kuryeye ödeme yapabilirsiniz.</span>
            </label>

            <label class="relative flex flex-col p-4 cursor-pointer border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition payment-method-card">
              <input type="radio" name="payment_method" value="kredi_karti" class="peer sr-only">
              <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-orange-500 pointer-events-none transition"></div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                  <i class="fas fa-credit-card text-orange-500"></i> Kredi Kartı
                </span>
                <i class="fas fa-check-circle text-orange-500 opacity-0 peer-checked:opacity-100 transition"></i>
              </div>
              <span class="text-xs text-gray-500 mt-auto">Sanal POS ile 3D güvenli ödeme.</span>
            </label>

            <label class="relative flex flex-col p-4 cursor-pointer border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition payment-method-card">
              <input type="radio" name="payment_method" value="banka_kredisi" class="peer sr-only">
              <div class="absolute inset-0 rounded-xl border-2 border-transparent peer-checked:border-orange-500 pointer-events-none transition"></div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                  <i class="fas fa-hand-holding-usd text-orange-500"></i> Banka Kredisi
                </span>
                <i class="fas fa-check-circle text-orange-500 opacity-0 peer-checked:opacity-100 transition"></i>
              </div>
              <span class="text-xs text-gray-500 mt-auto">Anlaşmalı bankalar aracılığıyla alışveriş kredisi.</span>
            </label>

          </div>
        </div>

      </div>

      <!-- Sağ: Sipariş Özeti -->
      <div class="lg:w-1/3">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 sticky top-24">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6 border-b border-gray-200 dark:border-gray-700 pb-4">Sipariş Özeti</h3>
          
          <ul id="summaryList" class="space-y-4 mb-6 max-h-60 overflow-y-auto pr-2 divide-y divide-gray-100 dark:divide-gray-800">
            <!-- JS ile doldurulacak -->
          </ul>
          
          <div class="space-y-3 text-sm border-t border-gray-200 dark:border-gray-700 pt-4 mb-6">
            <div class="flex justify-between items-center text-gray-600 dark:text-gray-400">
              <span>Ara Toplam</span>
              <span id="summarySubTotal" class="font-medium text-gray-900 dark:text-white">0,00 ₺</span>
            </div>
            <div class="flex justify-between items-center text-green-600">
              <span>Kargo Ücreti</span>
              <span>Ücretsiz</span>
            </div>
          </div>
          
          <div class="border-t border-gray-200 dark:border-gray-700 pt-4 mb-8">
            <div class="flex justify-between items-center">
              <span class="text-lg font-bold text-gray-900 dark:text-white">Genel Toplam</span>
              <span id="summaryTotal" class="text-2xl font-extrabold text-orange-600">0,00 ₺</span>
            </div>
          </div>
          
          <button type="submit" id="submitBtn" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 px-6 rounded-xl shadow-lg hover:shadow-orange-500/30 transition flex justify-center items-center gap-2">
            <span>Siparişi Tamamla</span>
            <i class="fas fa-lock"></i>
          </button>
          
          <div class="mt-4 text-center text-xs text-gray-500">
            Siparişi tamamlayarak <a href="#" class="text-orange-500 hover:underline">Mesafeli Satış Sözleşmesi</a>'ni okuduğumu ve kabul ettiğimi onaylıyorum.
          </div>
        </div>
      </div>
      
    </form>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Adres check box mantığı
      const sameAsShipping = document.getElementById('same_as_shipping');
      const billingContainer = document.getElementById('billing_address_container');
      const billingInput = document.getElementById('billing_address');

      sameAsShipping.addEventListener('change', (e) => {
        if (e.target.checked) {
          billingContainer.classList.add('hidden');
          billingInput.removeAttribute('required');
        } else {
          billingContainer.classList.remove('hidden');
          billingInput.setAttribute('required', 'true');
        }
      });

      // Sepet Verilerini Okuma ve Özet Çıkarma
      let cart = [];
      try { cart = JSON.parse(localStorage.getItem('laflaf_cart') || '[]'); } catch(e) {}

      if (cart.length === 0) {
        window.location.href = '/sepet';
        return;
      }

      const summaryList = document.getElementById('summaryList');
      const summarySubTotal = document.getElementById('summarySubTotal');
      const summaryTotal = document.getElementById('summaryTotal');

      const formatMoney = (amount) => {
        return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
      };

      let total = 0;
      let html = '';

      cart.forEach(item => {
        const itemTotal = item.price * item.qty;
        total += itemTotal;
        const variantText = item.variant_name ? `<span class="text-xs text-gray-500 block">${item.variant_name}</span>` : '';
        
        html += `
          <li class="py-2 flex justify-between gap-4">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 dark:text-white truncate">${item.name}</p>
              ${variantText}
              <p class="text-xs text-gray-500">${item.qty} ${item.unit} x ${formatMoney(item.price)}</p>
            </div>
            <div class="text-sm font-bold text-gray-900 dark:text-white whitespace-nowrap">
              ${formatMoney(itemTotal)}
            </div>
          </li>
        `;
      });

      summaryList.innerHTML = html;
      summarySubTotal.textContent = formatMoney(total);
      summaryTotal.textContent = formatMoney(total); // Şimdilik kargo bedava

      // Form Submit
      const form = document.getElementById('checkoutForm');
      const submitBtn = document.getElementById('submitBtn');
      const alertMessage = document.getElementById('alertMessage');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.cart = cart;

        // Görsel geri bildirim
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> İşleniyor...';
        alertMessage.classList.add('hidden');

        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if (res.ok) {
            // Başarılı
            localStorage.removeItem('laflaf_cart');
            window.dispatchEvent(new Event('cart_updated')); // Sepet ikonunu temizle
            window.location.href = `/checkout/success?order_id=${result.order_id}`;
          } else {
            // Hata
            alertMessage.textContent = result.error || 'Bir hata oluştu.';
            alertMessage.classList.remove('hidden', 'bg-green-100', 'text-green-800');
            alertMessage.classList.add('bg-red-100', 'text-red-800', 'dark:bg-red-900/50', 'dark:text-red-200');
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<span>Siparişi Tamamla</span> <i class="fas fa-lock"></i>';
          }
        } catch (err) {
          alertMessage.textContent = 'Bağlantı hatası oluştu. Lütfen tekrar deneyin.';
          alertMessage.classList.remove('hidden');
          alertMessage.classList.add('bg-red-100', 'text-red-800');
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<span>Siparişi Tamamla</span> <i class="fas fa-lock"></i>';
        }
      });
    });
  </script>
</BaseLayout>
