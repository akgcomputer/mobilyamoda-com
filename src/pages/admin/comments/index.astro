---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getComments, updateCommentStatus, deleteComment, getPosts } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let mesaj = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const islem = formData.get('islem');
  const id = parseInt(formData.get('id') as string);
  
  if (islem === 'onayla') {
    await updateCommentStatus(id, 'approved', dbBinding);
    mesaj = 'Yorum onaylandı';
  } else if (islem === 'spam') {
    await updateCommentStatus(id, 'spam', dbBinding);
    mesaj = 'Yorum spam olarak işaretlendi';
  } else if (islem === 'sil') {
    await deleteComment(id, dbBinding);
    mesaj = 'Yorum silindi';
  } else if (islem === 'topluIslem') {
    const ids = formData.getAll('secili');
    const topluIslem = formData.get('topluIslem');
    for (const idStr of ids) {
      const parsedId = parseInt(idStr as string);
      if (topluIslem === 'onayla') await updateCommentStatus(parsedId, 'approved', dbBinding);
      else if (topluIslem === 'spam') await updateCommentStatus(parsedId, 'spam', dbBinding);
      else if (topluIslem === 'sil') await deleteComment(parsedId, dbBinding);
    }
    mesaj = 'Toplu işlem tamamlandı';
  }
}

// Fetch comments and posts
const rawComments = await getComments(dbBinding);
const allPosts = await getPosts(dbBinding);

const yorumlar = rawComments.map(c => {
  const post = allPosts.find(p => p.id === c.post_id);
  return {
    id: c.id,
    yazar: c.author_name,
    icerik: c.content,
    postBaslik: post ? post.title : 'Bilinmeyen Yazı',
    postSlug: post ? `${post.category?.slug || 'genel'}/${post.slug}` : '',
    tarih: new Date(c.createdAt).toLocaleDateString('tr-TR'),
    durum: c.status === 'approved' ? 'onayli' : c.status === 'pending' ? 'beklemede' : 'spam',
    begeni: 0
  };
});
---

<BaseLayout title="Yorumlar" isAdmin={true}>
  <div class="p-6">
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold">Yorumlar</h1>
        <p class="text-sm text-gray-500">Yorumları yönetin, onaylayın veya spam olarak işaretleyin</p>
      </div>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded mb-4">{mesaj}</div>}

    <!-- Filtreler -->
    <div class="flex flex-wrap gap-2 mb-4">
      <button onclick="filtrele('hepsi')" class="px-3 py-1 rounded-full text-sm bg-gray-200 dark:bg-gray-700">Tümü</button>
      <button onclick="filtrele('beklemede')" class="px-3 py-1 rounded-full text-sm bg-yellow-100 text-yellow-700">Bekleyen</button>
      <button onclick="filtrele('onayli')" class="px-3 py-1 rounded-full text-sm bg-green-100 text-green-700">Onaylı</button>
      <button onclick="filtrele('spam')" class="px-3 py-1 rounded-full text-sm bg-red-100 text-red-700">Spam</button>
    </div>

    <!-- Toplu İşlem -->
    <form method="POST" id="topluForm" class="mb-4 flex gap-3 items-center">
      <input type="hidden" name="islem" value="topluIslem" />
      <select name="topluIslem" class="px-3 py-2 border rounded dark:bg-gray-800">
        <option value="">Toplu işlem seç</option>
        <option value="onayla">Onayla</option>
        <option value="spam">Spam olarak işaretle</option>
        <option value="sil">Sil</option>
      </select>
      <button type="submit" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">Uygula</button>
    </form>

    <!-- Yorumlar Tablosu -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="w-10 px-4 py-3"><input type="checkbox" id="selectAll" class="w-4 h-4" /></th>
            <th class="px-4 py-3 text-left">Yazar / Yorum</th>
            <th class="px-4 py-3 text-left">İçerik</th>
            <th class="px-4 py-3 text-left">Durum</th>
            <th class="px-4 py-3 text-left">Tarih</th>
            <th class="px-4 py-3 text-center">İşlem</th>
          </tr>
        </thead>
        <tbody id="yorumTablo">
          {yorumlar.map(y => (
            <tr class="yorum-satiri border-t dark:border-gray-700" data-durum={y.durum}>
              <td class="px-4 py-3"><input type="checkbox" name="secili" value={y.id} form="topluForm" class="yorum-checkbox w-4 h-4" /></td>
              <td class="px-4 py-3">
                <div class="font-medium">{y.yazar}</div>
                <div class="text-xs text-gray-500">{y.postBaslik}</div>
              </td>
              <td class="px-4 py-3 max-w-md">
                <p class="text-sm line-clamp-2">{y.icerik}</p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs text-gray-500">❤️ {y.begeni}</span>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class={`text-xs px-2 py-1 rounded-full ${
                  y.durum === 'onayli' ? 'bg-green-100 text-green-700' :
                  y.durum === 'beklemede' ? 'bg-yellow-100 text-yellow-700' :
                  'bg-red-100 text-red-700'
                }`}>
                  {y.durum === 'onayli' ? 'Onaylı' : y.durum === 'beklemede' ? 'Bekliyor' : 'Spam'}
                </span>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500">{y.tarih}</td>
              <td class="px-4 py-3 text-center">
                <div class="flex justify-center gap-2">
                  {y.durum === 'beklemede' && (
                    <form method="POST" class="inline">
                      <input type="hidden" name="islem" value="onayla" />
                      <input type="hidden" name="id" value={y.id} />
                      <button type="submit" class="text-green-600 hover:text-green-800" title="Onayla">✅</button>
                    </form>
                  )}
                  <form method="POST" class="inline">
                    <input type="hidden" name="islem" value="spam" />
                    <input type="hidden" name="id" value={y.id} />
                    <button type="submit" class="text-red-600 hover:text-red-800" title="Spam">🚫</button>
                  </form>
                  <form method="POST" class="inline" onsubmit="return confirm('Yorum silinecek, emin misiniz?')">
                    <input type="hidden" name="islem" value="sil" />
                    <input type="hidden" name="id" value={y.id} />
                    <button type="submit" class="text-gray-600 hover:text-gray-800" title="Sil">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    // Tümünü seç
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.yorum-checkbox');
    
    selectAll?.addEventListener('change', (e) => {
      checkboxes.forEach(cb => cb.checked = e.target.checked);
    });
    
    // Filtreleme
    function filtrele(durum) {
      const satirlar = document.querySelectorAll('.yorum-satiri');
      satirlar.forEach(satir => {
        if (durum === 'hepsi') {
          satir.style.display = '';
        } else {
          satir.style.display = satir.dataset.durum === durum ? '' : 'none';
        }
      });
    }
  </script>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</BaseLayout>
