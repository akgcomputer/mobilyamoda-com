// src/pages/admin/comments/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { 
  getComments, updateCommentStatus, deleteComment, getPosts,
  getAllReviews, updateReviewStatus, deleteReview, getProducts,
  getAllQA, answerQuestion, deleteQuestion
} from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let mesaj = '';
let hata = '';

// Persistent active tab selector
const aktifSekme = Astro.url.searchParams.get('tab') || 'blog';
const q = Astro.url.searchParams.get('q') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1') || 1;
const limit = 50;
const offset = (page - 1) * limit;

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    const id = parseInt(formData.get('id') as string);

    // 1. Blog Comment Actions
    if (action === 'approve_blog') {
      await updateCommentStatus(id, 'approved', dbBinding);
      mesaj = 'Blog yorumu başarıyla onaylandı.';
    } else if (action === 'spam_blog') {
      await updateCommentStatus(id, 'spam', dbBinding);
      mesaj = 'Blog yorumu spam olarak işaretlendi.';
    } else if (action === 'delete_blog') {
      await deleteComment(id, dbBinding);
      mesaj = 'Blog yorumu silindi.';
    }

    // 2. Product Review Actions
    else if (action === 'approve_review') {
      await updateReviewStatus(id, 'approved', dbBinding);
      mesaj = 'Ürün değerlendirmesi başarıyla onaylandı.';
    } else if (action === 'spam_review') {
      await updateReviewStatus(id, 'spam', dbBinding);
      mesaj = 'Ürün değerlendirmesi spam olarak işaretlendi.';
    } else if (action === 'delete_review') {
      await deleteReview(id, dbBinding);
      mesaj = 'Ürün değerlendirmesi silindi.';
    }

    // 3. Product Q&A Actions
    else if (action === 'answer_qa') {
      const answer = formData.get('answer') as string;
      if (!answer || answer.trim() === '') {
        throw new Error('Soruya verilecek cevap boş olamaz.');
      }
      await answerQuestion(id, answer, dbBinding);
      mesaj = 'Soru yanıtlandı ve yayınlandı.';
    } else if (action === 'delete_qa') {
      await deleteQuestion(id, dbBinding);
      mesaj = 'Soru silindi.';
    }
  } catch (err: any) {
    hata = err.message || 'İşlem sırasında bir hata oluştu.';
  }
}

// Fetch all necessary data
const allPosts = await getPosts(dbBinding);
const allProducts = await getProducts(dbBinding);

// Fetch and map Blog Comments
const blogComments = await getComments(dbBinding);
const mappedBlogComments = blogComments.map(c => {
  const post = allPosts.find(p => p.id === c.post_id);
  return {
    id: c.id,
    yazar: c.author_name,
    email: c.author_email || 'Ziyaretçi',
    icerik: c.content,
    postBaslik: post ? post.title : 'Bilinmeyen Yazı',
    tarih: new Date(c.createdAt).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' }),
    status: c.status
  };
});

// Fetch and map E-commerce Reviews
const productReviews = await getAllReviews(dbBinding);
const mappedReviews = productReviews.map(r => {
  const product = allProducts.find(p => p.id === r.product_id);
  return {
    id: r.id,
    yazar: r.user_name,
    rating: r.rating,
    comment: r.comment || 'Yorumsuz değerlendirme',
    productName: product ? product.name : 'Bilinmeyen Ürün',
    tarih: new Date(r.createdAt).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' }),
    status: r.status
  };
});

// Fetch and map E-commerce Q&As
const productQAs = await getAllQA(dbBinding);
const mappedQAs = productQAs.map(q => {
  const product = allProducts.find(p => p.id === q.product_id);
  return {
    id: q.id,
    yazar: q.user_name,
    question: q.question,
    answer: q.answer,
    productName: product ? product.name : 'Bilinmeyen Ürün',
    tarih: new Date(q.createdAt).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' }),
    status: q.status
  };
});

// --- Arama (Search) Filtreleme ---
const searchLower = q.toLowerCase().trim();

const filteredBlogComments = searchLower 
  ? mappedBlogComments.filter(c => 
      c.yazar.toLowerCase().includes(searchLower) ||
      c.email.toLowerCase().includes(searchLower) ||
      c.icerik.toLowerCase().includes(searchLower) ||
      c.postBaslik.toLowerCase().includes(searchLower)
    )
  : mappedBlogComments;

const filteredReviews = searchLower
  ? mappedReviews.filter(r =>
      r.yazar.toLowerCase().includes(searchLower) ||
      r.comment.toLowerCase().includes(searchLower) ||
      r.productName.toLowerCase().includes(searchLower)
    )
  : mappedReviews;

const filteredQAs = searchLower
  ? mappedQAs.filter(qa =>
      qa.yazar.toLowerCase().includes(searchLower) ||
      qa.question.toLowerCase().includes(searchLower) ||
      (qa.answer && qa.answer.toLowerCase().includes(searchLower)) ||
      qa.productName.toLowerCase().includes(searchLower)
    )
  : mappedQAs;

// --- Sayfalama (Pagination) Hesaplama ---
let activeFilteredList = [];
if (aktifSekme === 'blog') {
  activeFilteredList = filteredBlogComments;
} else if (aktifSekme === 'qa') {
  activeFilteredList = filteredQAs;
} else if (aktifSekme === 'reviews') {
  activeFilteredList = filteredReviews;
}

const totalItems = activeFilteredList.length;
const totalPages = Math.ceil(totalItems / limit) || 1;
const paginatedList = activeFilteredList.slice(offset, offset + limit);

// HTML içinde görüntülenecek nihai listeler
const paginatedBlogComments = aktifSekme === 'blog' ? paginatedList : filteredBlogComments.slice(0, limit);
const paginatedQAs = aktifSekme === 'qa' ? paginatedList : filteredQAs.slice(0, limit);
const paginatedReviews = aktifSekme === 'reviews' ? paginatedList : filteredReviews.slice(0, limit);

// --- Sayfa Numaraları Listesi Hazırlama (Frontmatter'da) ---
const pageList = [];
let lastPushedPage = 0;
for (let p = 1; p <= totalPages; p++) {
  const isNear = Math.abs(p - page) <= 2 || p === 1 || p === totalPages;
  if (isNear) {
    if (p - lastPushedPage > 1) {
      pageList.push({ type: 'dots' });
    }
    pageList.push({ type: 'page', page: p });
    lastPushedPage = p;
  }
}
---

<BaseLayout title="Yorum ve Değerlendirme Yönetimi" isAdmin={true}>
  
  <div class="max-w-6xl mx-auto p-6">
    
    <!-- Header -->
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-comments text-orange-600 dark:text-orange-400"></i>
        </div>
        Yorum & Değerlendirme Yönetimi
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 ml-15">Blog yorumlarını, müşteri soru-cevaplarını ve ürün değerlendirmelerini buradan yönetin.</p>
    </div>

    <!-- Alert Messages -->
    {mesaj && (
      <div class="p-4 mb-6 text-sm text-green-800 rounded-xl bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200">
        {mesaj}
      </div>
    )}
    {hata && (
      <div class="p-4 mb-6 text-sm text-red-800 rounded-xl bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200">
        {hata}
      </div>
    )}

    <!-- Search Form -->
    <div class="mb-6 bg-white dark:bg-gray-800 p-4 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700">
      <form method="GET" class="flex gap-3">
        <input type="hidden" name="tab" value={aktifSekme} />
        <div class="relative flex-1">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-gray-400">
            <i class="fas fa-search"></i>
          </span>
          <input 
            type="text" 
            name="q" 
            value={q} 
            placeholder="Yazar adı, e-posta, yorum içeriği veya başlık ile ara..." 
            class="w-full text-sm pl-10 pr-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
          />
        </div>
        <button 
          type="submit" 
          class="bg-orange-600 hover:bg-orange-700 text-white font-bold px-6 py-2.5 rounded-xl text-sm transition flex items-center gap-2 shadow-sm"
        >
          <i class="fas fa-search"></i> Ara
        </button>
        {q && (
          <a 
            href={`?tab=${aktifSekme}`} 
            class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 font-bold px-4 py-2.5 rounded-xl text-sm transition flex items-center gap-1"
          >
            Temizle
          </a>
        )}
      </form>
    </div>

    <!-- Tabs Navigation -->
    <div class="flex flex-wrap border-b border-gray-200 dark:border-gray-700 gap-1 mb-8">
      <a 
        href={`?tab=blog${q ? '&q=' + encodeURIComponent(q) : ''}`} 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'blog' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fas fa-blog"></i> 1. Blog Yorumları ({filteredBlogComments.length})
      </a>
      <a 
        href={`?tab=qa${q ? '&q=' + encodeURIComponent(q) : ''}`} 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'qa' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fas fa-question-circle"></i> 2. E-Ticaret Soru & Cevap ({filteredQAs.length})
      </a>
      <a 
        href={`?tab=reviews${q ? '&q=' + encodeURIComponent(q) : ''}`} 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'reviews' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fas fa-star"></i> 3. E-Ticaret Ürün Değerlendirmeleri ({filteredReviews.length})
      </a>
    </div>

    <!-- TAB 1: Blog Comments -->
    {aktifSekme === 'blog' && (
      <div class="space-y-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <i class="fas fa-blog text-orange-500"></i> Blog Yorumları
        </h2>
        {filteredBlogComments.length === 0 ? (
          <div class="py-16 text-center bg-gray-50 dark:bg-gray-800 rounded-3xl border dark:border-gray-700">
            <p class="text-gray-500 italic">{q ? 'Arama kriterlerinize uygun blog yorumu bulunamadı.' : 'Henüz hiç blog yorumu bulunmamaktadır.'}</p>
          </div>
        ) : (
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-bold uppercase text-xs border-b dark:border-gray-700">
                  <tr>
                    <th class="px-6 py-4">Yazar</th>
                    <th class="px-6 py-4">Yorum Yapılan Yazı</th>
                    <th class="px-6 py-4">Yorum İçeriği</th>
                    <th class="px-6 py-4">Durum</th>
                    <th class="px-6 py-4">Tarih</th>
                    <th class="px-6 py-4 text-center">İşlem</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                  {paginatedBlogComments.map(c => (
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/20 transition">
                      <td class="px-6 py-4 font-semibold text-gray-900 dark:text-white">
                        <div>{c.yazar}</div>
                        <div class="text-[10px] text-gray-400 font-light font-mono">{c.email}</div>
                      </td>
                      <td class="px-6 py-4 text-gray-500 dark:text-gray-400 font-medium max-w-xs truncate">{c.postBaslik}</td>
                      <td class="px-6 py-4 max-w-md">
                        <p class="text-gray-700 dark:text-gray-300 leading-relaxed break-words">{c.icerik}</p>
                      </td>
                      <td class="px-6 py-4">
                        <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${
                          c.status === 'approved' ? 'bg-green-100 text-green-700 dark:bg-green-950/20 dark:text-green-400' :
                          c.status === 'pending' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-950/20 dark:text-yellow-400' :
                          'bg-red-100 text-red-700 dark:bg-red-950/20 dark:text-red-400'
                        }`}>
                          {c.status === 'approved' ? 'Onaylı' : c.status === 'pending' ? 'Bekliyor' : 'Spam'}
                        </span>
                      </td>
                      <td class="px-6 py-4 text-gray-400 dark:text-gray-500 text-xs">{c.tarih}</td>
                      <td class="px-6 py-4 text-center">
                        <div class="flex items-center justify-center gap-2.5">
                          {c.status === 'pending' && (
                            <form method="POST" class="inline">
                              <input type="hidden" name="action" value="approve_blog" />
                              <input type="hidden" name="id" value={c.id} />
                              <button type="submit" class="bg-green-500 hover:bg-green-600 text-white font-bold p-2 rounded-lg text-xs transition" title="Onayla">
                                <i class="fas fa-check"></i> Onayla
                              </button>
                            </form>
                          )}
                          {c.status !== 'spam' && (
                            <form method="POST" class="inline">
                              <input type="hidden" name="action" value="spam_blog" />
                              <input type="hidden" name="id" value={c.id} />
                              <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold p-2 rounded-lg text-xs transition" title="Spam">
                                <i class="fas fa-ban"></i> Spam
                              </button>
                            </form>
                          )}
                          <form method="POST" class="inline" onsubmit="return confirm('Blog yorumu silinecektir, emin misiniz?')">
                            <input type="hidden" name="action" value="delete_blog" />
                            <input type="hidden" name="id" value={c.id} />
                            <button type="submit" class="bg-red-600 hover:bg-red-750 text-white font-bold p-2 rounded-lg text-xs transition" title="Sil">
                              <i class="fas fa-trash"></i> Sil
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <!-- Pagination Navigation for Blog Comments -->
        {aktifSekme === 'blog' && totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-gray-200 dark:border-gray-700 px-4 py-3 sm:px-6 mt-6 bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              {page > 1 ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Önceki
                </a>
              ) : (
                <span class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-750 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Önceki
                </span>
              )}
              {page < totalPages ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Sonraki
                </a>
              ) : (
                <span class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-750 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Sonraki
                </span>
              )}
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-sm text-gray-700 dark:text-gray-300">
                  Toplam <span class="font-bold text-orange-600">{totalItems}</span> kayıttan <span class="font-medium">{offset + 1}</span> ile <span class="font-medium">{Math.min(offset + limit, totalItems)}</span> arası gösteriliyor.
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-xl shadow-sm bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-750 p-1 gap-1" aria-label="Pagination">
                  {page > 1 ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Önceki Sayfa"
                    >
                      <span class="sr-only">Önceki</span>
                      <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-left text-xs"></i>
                    </span>
                  )}

                  {pageList.map(item => {
                    if (item.type === 'dots') {
                      return <span class="relative inline-flex items-center px-3 py-1.5 text-sm text-gray-500 dark:text-gray-450">...</span>;
                    }
                    return (
                      <a
                        href={`?tab=${aktifSekme}&page=${item.page}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                        class={`relative inline-flex items-center rounded-lg px-3.5 py-1.5 text-sm font-bold transition ${
                          item.page === page
                            ? "bg-orange-600 text-white shadow-md shadow-orange-600/20"
                            : "text-gray-650 dark:text-gray-300 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600"
                        }`}
                      >
                        {item.page}
                      </a>
                    );
                  })}

                  {page < totalPages ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Sonraki Sayfa"
                    >
                      <span class="sr-only">Sonraki</span>
                      <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-right text-xs"></i>
                    </span>
                  )}
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- TAB 2: Product Q&A -->
    {aktifSekme === 'qa' && (
      <div class="space-y-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <i class="fas fa-question-circle text-orange-500"></i> E-Ticaret Ürün Soru & Cevapları
        </h2>
        {filteredQAs.length === 0 ? (
          <div class="py-16 text-center bg-gray-50 dark:bg-gray-800 rounded-3xl border dark:border-gray-700">
            <p class="text-gray-500 italic">{q ? 'Arama kriterlerinize uygun soru-cevap bulunamadı.' : 'Henüz müşteriler tarafından sorulmuş ürün sorusu bulunmamaktadır.'}</p>
          </div>
        ) : (
          <div class="space-y-4">
            {paginatedQAs.map(q => (
              <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-6 transition hover:shadow-md">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-4 pb-2 border-b dark:border-gray-700">
                  <div>
                    <span class="text-xs text-gray-400 font-mono block">Ürün</span>
                    <span class="font-bold text-orange-600">{q.productName}</span>
                  </div>
                  <div class="text-right">
                    <span class="text-xs text-gray-400 block">Soran Müşteri: <strong class="text-gray-800 dark:text-gray-200">{q.yazar}</strong></span>
                    <span class="text-[10px] text-gray-400">{q.tarih}</span>
                  </div>
                </div>
                
                <div class="space-y-4">
                  <div class="bg-blue-50 dark:bg-blue-950/20 border border-blue-100 dark:border-blue-900/50 p-4 rounded-xl">
                    <span class="inline-block bg-blue-100 text-blue-800 text-[10px] px-2 py-0.5 rounded font-extrabold mr-2 uppercase tracking-wide">Müşteri Sorusu</span>
                    <p class="text-sm text-gray-700 dark:text-gray-300 mt-2 font-medium break-words">{q.question}</p>
                  </div>

                  {q.answer ? (
                    <div class="bg-green-50 dark:bg-green-950/20 border border-green-150 dark:border-green-900/50 p-4 rounded-xl relative group">
                      <span class="inline-block bg-green-100 text-green-800 text-[10px] px-2 py-0.5 rounded font-extrabold mr-2 uppercase tracking-wide">Mağaza Cevabı</span>
                      <p class="text-sm text-gray-700 dark:text-gray-300 mt-2 break-words">{q.answer}</p>
                    </div>
                  ) : (
                    <form method="POST" class="bg-gray-50 dark:bg-gray-900/50 p-4 rounded-xl border border-gray-200 dark:border-gray-700 space-y-3">
                      <input type="hidden" name="action" value="answer_qa" />
                      <input type="hidden" name="id" value={q.id} />
                      <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider">Cevabınızı Yazın</label>
                      <textarea name="answer" rows="2.5" required placeholder="Müşterinizin sorusunu açıklayıcı bir şekilde yanıtlayın..." class="w-full text-sm border border-gray-300 dark:border-gray-700 rounded-lg p-2 bg-white dark:bg-gray-800 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"></textarea>
                      <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-6 rounded-lg text-xs transition flex items-center gap-1">
                        <i class="fas fa-paper-plane"></i> Cevabı Gönder ve Yayınla
                      </button>
                    </form>
                  )}
                </div>

                <div class="flex justify-end gap-2 mt-4 pt-2 border-t border-gray-50 dark:border-gray-700">
                  <form method="POST" onsubmit="return confirm('Bu soruyu silmek istediğinize emin misiniz?')">
                    <input type="hidden" name="action" value="delete_qa" />
                    <input type="hidden" name="id" value={q.id} />
                    <button type="submit" class="bg-red-50 hover:bg-red-100 dark:bg-red-950/20 text-red-600 hover:text-red-700 py-1.5 px-4 rounded-lg text-xs font-bold transition flex items-center gap-1">
                      <i class="fas fa-trash-alt"></i> Soruyu Tamamen Sil
                    </button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        )}

        <!-- Pagination Navigation for Product Q&As -->
        {aktifSekme === 'qa' && totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-gray-200 dark:border-gray-700 px-4 py-3 sm:px-6 mt-6 bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              {page > 1 ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Önceki
                </a>
              ) : (
                <span class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-750 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Önceki
                </span>
              )}
              {page < totalPages ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Sonraki
                </a>
              ) : (
                <span class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-750 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Sonraki
                </span>
              )}
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-sm text-gray-700 dark:text-gray-300">
                  Toplam <span class="font-bold text-orange-600">{totalItems}</span> kayıttan <span class="font-medium">{offset + 1}</span> ile <span class="font-medium">{Math.min(offset + limit, totalItems)}</span> arası gösteriliyor.
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-xl shadow-sm bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-750 p-1 gap-1" aria-label="Pagination">
                  {page > 1 ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Önceki Sayfa"
                    >
                      <span class="sr-only">Önceki</span>
                      <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-left text-xs"></i>
                    </span>
                  )}

                  {pageList.map(item => {
                    if (item.type === 'dots') {
                      return <span class="relative inline-flex items-center px-3 py-1.5 text-sm text-gray-500 dark:text-gray-450">...</span>;
                    }
                    return (
                      <a
                        href={`?tab=${aktifSekme}&page=${item.page}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                        class={`relative inline-flex items-center rounded-lg px-3.5 py-1.5 text-sm font-bold transition ${
                          item.page === page
                            ? "bg-orange-600 text-white shadow-md shadow-orange-600/20"
                            : "text-gray-650 dark:text-gray-300 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600"
                        }`}
                      >
                        {item.page}
                      </a>
                    );
                  })}

                  {page < totalPages ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Sonraki Sayfa"
                    >
                      <span class="sr-only">Sonraki</span>
                      <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-right text-xs"></i>
                    </span>
                  )}
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- TAB 3: Product Reviews -->
    {aktifSekme === 'reviews' && (
      <div class="space-y-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <i class="fas fa-star text-orange-500"></i> E-Ticaret Ürün Değerlendirmeleri
        </h2>
        {filteredReviews.length === 0 ? (
          <div class="py-16 text-center bg-gray-50 dark:bg-gray-800 rounded-3xl border dark:border-gray-700">
            <p class="text-gray-500 italic">{q ? 'Arama kriterlerinize uygun ürün değerlendirmesi bulunamadı.' : 'Henüz müşteriler tarafından girilmiş ürün değerlendirmesi bulunmamaktadır.'}</p>
          </div>
        ) : (
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left">
                <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-bold uppercase text-xs border-b dark:border-gray-700">
                  <tr>
                    <th class="px-6 py-4">Müşteri</th>
                    <th class="px-6 py-4">Ürün</th>
                    <th class="px-6 py-4">Puan / Yıldız</th>
                    <th class="px-6 py-4">Yorum</th>
                    <th class="px-6 py-4">Durum</th>
                    <th class="px-6 py-4">Tarih</th>
                    <th class="px-6 py-4 text-center">İşlem</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                  {paginatedReviews.map(r => (
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/20 transition">
                      <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">{r.yazar}</td>
                      <td class="px-6 py-4 text-gray-500 dark:text-gray-400 font-semibold max-w-xs truncate">{r.productName}</td>
                      <td class="px-6 py-4">
                        <div class="flex text-yellow-400 tracking-widest text-xs">
                          {Array.from({ length: 5 }).map((_, i) => (
                            <i class={i < r.rating ? "fas fa-star" : "far fa-star"}></i>
                          ))}
                        </div>
                      </td>
                      <td class="px-6 py-4 max-w-sm">
                        <p class="text-gray-700 dark:text-gray-300 break-words leading-relaxed">{r.comment}</p>
                      </td>
                      <td class="px-6 py-4">
                        <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${
                          r.status === 'approved' ? 'bg-green-100 text-green-700 dark:bg-green-950/20 dark:text-green-400' :
                          r.status === 'pending' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-950/20 dark:text-yellow-400' :
                          'bg-red-100 text-red-700 dark:bg-red-950/20 dark:text-red-400'
                        }`}>
                          {r.status === 'approved' ? 'Onaylı' : r.status === 'pending' ? 'Bekliyor' : 'Spam'}
                        </span>
                      </td>
                      <td class="px-6 py-4 text-gray-400 dark:text-gray-550 text-xs">{r.tarih}</td>
                      <td class="px-6 py-4 text-center">
                        <div class="flex items-center justify-center gap-2">
                          {r.status === 'pending' && (
                            <form method="POST" class="inline">
                              <input type="hidden" name="action" value="approve_review" />
                              <input type="hidden" name="id" value={r.id} />
                              <button type="submit" class="bg-green-500 hover:bg-green-600 text-white font-bold p-2 rounded-lg text-xs transition" title="Onayla">
                                <i class="fas fa-check"></i> Onayla
                              </button>
                            </form>
                          )}
                          {r.status !== 'spam' && (
                            <form method="POST" class="inline">
                              <input type="hidden" name="action" value="spam_review" />
                              <input type="hidden" name="id" value={r.id} />
                              <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold p-2 rounded-lg text-xs transition" title="Spam">
                                <i class="fas fa-ban"></i> Spam
                              </button>
                            </form>
                          )}
                          <form method="POST" class="inline" onsubmit="return confirm('Bu değerlendirmeyi tamamen silmek istediğinize emin misiniz?')">
                            <input type="hidden" name="action" value="delete_review" />
                            <input type="hidden" name="id" value={r.id} />
                            <button type="submit" class="bg-red-600 hover:bg-red-750 text-white font-bold p-2 rounded-lg text-xs transition" title="Sil">
                              <i class="fas fa-trash"></i> Sil
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <!-- Pagination Navigation for Product Reviews -->
        {aktifSekme === 'reviews' && totalPages > 1 && (
          <div class="flex items-center justify-between border-t border-gray-200 dark:border-gray-700 px-4 py-3 sm:px-6 mt-6 bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 shadow-sm">
            <div class="flex flex-1 justify-between sm:hidden">
              {page > 1 ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Önceki
                </a>
              ) : (
                <span class="relative inline-flex items-center rounded-md border border-gray-300 dark:border-gray-750 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Önceki
                </span>
              )}
              {page < totalPages ? (
                <a
                  href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                  class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700"
                >
                  Sonraki
                </a>
              ) : (
                <span class="relative ml-3 inline-flex items-center rounded-md border border-gray-300 dark:border-gray-755 bg-gray-50 dark:bg-gray-800/50 px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 cursor-not-allowed">
                  Sonraki
                </span>
              )}
            </div>
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
              <div>
                <p class="text-sm text-gray-700 dark:text-gray-300">
                  Toplam <span class="font-bold text-orange-600">{totalItems}</span> kayıttan <span class="font-medium">{offset + 1}</span> ile <span class="font-medium">{Math.min(offset + limit, totalItems)}</span> arası gösteriliyor.
                </p>
              </div>
              <div>
                <nav class="isolate inline-flex -space-x-px rounded-xl shadow-sm bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-750 p-1 gap-1" aria-label="Pagination">
                  {page > 1 ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page - 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Önceki Sayfa"
                    >
                      <span class="sr-only">Önceki</span>
                      <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-left text-xs"></i>
                    </span>
                  )}

                  {pageList.map(item => {
                    if (item.type === 'dots') {
                      return <span class="relative inline-flex items-center px-3 py-1.5 text-sm text-gray-500 dark:text-gray-455">...</span>;
                    }
                    return (
                      <a
                        href={`?tab=${aktifSekme}&page=${item.page}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                        class={`relative inline-flex items-center rounded-lg px-3.5 py-1.5 text-sm font-bold transition ${
                          item.page === page
                            ? "bg-orange-600 text-white shadow-md shadow-orange-600/20"
                            : "text-gray-650 dark:text-gray-300 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600"
                        }`}
                      >
                        {item.page}
                      </a>
                    );
                  })}

                  {page < totalPages ? (
                    <a
                      href={`?tab=${aktifSekme}&page=${page + 1}${q ? '&q=' + encodeURIComponent(q) : ''}`}
                      class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-500 dark:text-gray-400 hover:bg-orange-50 dark:hover:bg-orange-950/20 hover:text-orange-600 transition"
                      title="Sonraki Sayfa"
                    >
                      <span class="sr-only">Sonraki</span>
                      <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                  ) : (
                    <span class="relative inline-flex items-center rounded-lg px-2.5 py-1.5 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                      <i class="fas fa-chevron-right text-xs"></i>
                    </span>
                  )}
                </nav>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

  </div>

</BaseLayout>
