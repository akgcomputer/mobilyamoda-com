---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getProductById, updateProduct, getCategories, getBrands } from '../../../../lib/db';
import MediaPicker from '../../../../components/admin/MediaPicker.astro';

const dbBinding = Astro.locals.runtime?.env?.DB;

const { id } = Astro.params;
const productId = parseInt(id as string);

if (isNaN(productId)) {
  return Astro.redirect('/admin/ecommerce/products');
}

const product = await getProductById(productId, dbBinding);

if (!product) {
  return Astro.redirect('/admin/ecommerce/products');
}

let hata = '';
let basari = '';

function slugify(text: string): string {
  const trMap: Record<string, string> = {
    'ç': 'c', 'Ç': 'C', 'ğ': 'g', 'Ğ': 'G', 'ı': 'i', 'İ': 'I',
    'ö': 'o', 'Ö': 'O', 'ş': 's', 'Ş': 'S', 'ü': 'u', 'Ü': 'U'
  };
  return text
    .replace(/[çÇğĞıİöÖşŞüÜ]/g, match => trMap[match])
    .toLowerCase()
    .replace(/[^a-z0-9 -]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .trim();
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const name = formData.get('name') as string;
    let slug = formData.get('slug') as string;
    if (!slug) slug = slugify(name);
    
    const category_id = parseInt(formData.get('category_id') as string) || null;
    const brand_id = parseInt(formData.get('brand_id') as string) || null;
    const excerpt = formData.get('excerpt') as string;
    const description = formData.get('description') as string;
    const price = parseFloat(formData.get('price') as string) || 0;
    const compare_at_price = formData.get('compare_at_price') ? parseFloat(formData.get('compare_at_price') as string) : null;
    const image_url = formData.get('image_url') as string;
    const badge_top_left = formData.get('badge_top_left') as string;
    const badge_top_right = formData.get('badge_top_right') as string;
    const status = formData.get('status') as string || 'aktif';

    if (!name || !price) {
      hata = 'Ürün adı ve fiyat zorunludur.';
    } else {
      await updateProduct(productId, {
        category_id, brand_id, name, slug, excerpt, description,
        price, compare_at_price, image_url, badge_top_left, badge_top_right,
        status
      }, dbBinding);
      basari = 'Ürün başarıyla güncellendi.';
      Object.assign(product, {
        category_id, brand_id, name, slug, excerpt, description,
        price, compare_at_price, image_url, badge_top_left, badge_top_right,
        status
      });
    }
  } catch (err) {
    console.error('Update product error:', err);
    hata = 'Ürün güncellenirken bir hata oluştu. Slug benzersiz olmayabilir.';
  }
}

const categories = await getCategories(dbBinding, 'product');
const brands = await getBrands(dbBinding);
---

<BaseLayout title={`${product.name} Düzenle - Admin`} isAdmin={true}>
  <!-- Quill Tema CSS -->
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />

  <div class="p-6">
    <div class="mb-6 flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Ürünü Düzenle</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">#{product.id} ID'li ürünü güncelliyorsunuz</p>
      </div>
      <div class="flex gap-2">
        <a href={`/urunler/${product.slug}`} target="_blank" class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 px-4 py-2 rounded-lg transition text-sm font-medium flex items-center">
          <i class="fas fa-eye mr-2"></i> Görüntüle
        </a>
        <a href="/admin/ecommerce/products" class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 px-4 py-2 rounded-lg transition text-sm font-medium flex items-center">
          <i class="fas fa-arrow-left mr-2"></i> Geri
        </a>
      </div>
    </div>

    {hata && (
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
        <span class="block sm:inline">{hata}</span>
      </div>
    )}

    {basari && (
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6" role="alert">
        <span class="block sm:inline">{basari}</span>
        <button onclick="this.parentElement.remove()" class="absolute top-0 bottom-0 right-0 px-4 py-3 text-green-700">✕</button>
      </div>
    )}

    <form method="POST" id="productForm" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Sol Kolon (Ana İçerik) -->
      <div class="lg:col-span-2 space-y-6">
        
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6">
          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Ürün Adı *</label>
            <input type="text" name="name" value={product.name} required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none transition" />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Kısa Açıklama (Excerpt)</label>
            <textarea name="excerpt" rows="2" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-3 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none transition">{product.excerpt || ''}</textarea>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Detaylı Açıklama (HTML)</label>
            <input type="hidden" name="description" id="description" value={product.description || ''} />
            <div id="editor-container" class="h-64 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-b-lg border-gray-300 dark:border-gray-600"></div>
          </div>
        </div>

        <!-- Görsel ve Rozetler -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-lg font-bold mb-4 text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Görsel ve 4-Köşe Rozetleri</h2>
          
          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Ana Görsel (Dik Format Önerilir)</label>
            <div class="flex gap-2 mb-2">
              <input type="text" id="image_url" name="image_url" value={product.image_url || ''} class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none" />
              <MediaPicker inputId="image_url" />
            </div>
            {product.image_url && (
              <div class="mt-2 w-24 h-32 rounded border border-gray-200 dark:border-gray-700 overflow-hidden bg-gray-50 dark:bg-gray-900">
                <img src={product.image_url} alt={product.name} class="w-full h-full object-cover" />
              </div>
            )}
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-gray-50 dark:bg-gray-900/50 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-xs font-semibold mb-1 text-gray-500 uppercase">Sol Üst Rozet</label>
              <input type="text" name="badge_top_left" value={product.badge_top_left || ''} class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
            </div>
            <div>
              <label class="block text-xs font-semibold mb-1 text-gray-500 uppercase">Sağ Üst Rozet</label>
              <input type="text" name="badge_top_right" value={product.badge_top_right || ''} class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
            </div>
          </div>
        </div>
      </div>

      <!-- Sağ Kolon (Ayarlar) -->
      <div class="space-y-6">
        
        <!-- Fiyatlandırma -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-base font-bold mb-4 text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Fiyatlandırma</h2>
          
          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Satış Fiyatı (₺) *</label>
            <input type="number" step="0.01" name="price" value={product.price} required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 font-mono text-lg" />
          </div>
          <div class="mb-2">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">İndirimsiz Fiyat (₺)</label>
            <input type="number" step="0.01" name="compare_at_price" value={product.compare_at_price || ''} class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400 focus:ring-2 focus:ring-orange-500 font-mono line-through" />
          </div>
        </div>

        <!-- Kategori ve Marka -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-base font-bold mb-4 text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Organizasyon</h2>
          
          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Kategori</label>
            <select name="category_id" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">
              <option value="">Seçiniz</option>
              {categories.map(c => (
                <option value={c.id} selected={product.category_id === c.id}>{c.parent_id ? '— ' : ''}{c.name}</option>
              ))}
            </select>
          </div>

          <div class="mb-2">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Marka</label>
            <select name="brand_id" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">
              <option value="">Seçiniz</option>
              {brands.map(b => (
                <option value={b.id} selected={product.brand_id === b.id}>{b.name}</option>
              ))}
            </select>
          </div>
        </div>

        <!-- Yayın Ayarları -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-base font-bold mb-4 text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">Yayın</h2>
          
          <div class="mb-4">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Özel URL (Slug)</label>
            <input type="text" name="slug" value={product.slug} class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm" />
          </div>

          <div class="mb-6">
            <label class="block text-sm font-semibold mb-2 text-gray-700 dark:text-gray-300">Durum</label>
            <select name="status" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2.5 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">
              <option value="aktif" selected={product.status === 'aktif'}>Aktif (Yayında)</option>
              <option value="pasif" selected={product.status === 'pasif'}>Pasif (Gizli)</option>
              <option value="taslak" selected={product.status === 'taslak'}>Taslak</option>
            </select>
          </div>

          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-xl shadow-lg transition-transform transform hover:-translate-y-0.5">
            <i class="fas fa-save mr-2"></i> Değişiklikleri Kaydet
          </button>
        </div>

      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js" is:inline></script>
  <script is:inline>
    // Quill ayarları
    const Link = Quill.import('formats/link');
    class MyLink extends Link {
      static create(value) {
        let node = super.create(value);
        if (typeof value === 'string') {
          value = this.sanitize(value);
          if (!value.startsWith('http://') && !value.startsWith('https://')) {
            value = 'https://' + value;
          }
          node.setAttribute('href', value);
        }
        node.setAttribute('target', '_blank');
        return node;
      }
    }
    Quill.register(MyLink, true);

    const ColorStyle = Quill.import('attributors/style/color');
    const BackgroundStyle = Quill.import('attributors/style/background');
    Quill.register(ColorStyle, true);
    Quill.register(BackgroundStyle, true);

    const quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'color': [] }, { 'background': [] }],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link', 'image', 'video'],
          ['clean']
        ]
      }
    });

    // Var olan içeriği yükle
    const descInput = document.getElementById('description');
    if (descInput && descInput.value) {
      quill.clipboard.dangerouslyPasteHTML(descInput.value);
    }

    const form = document.getElementById('productForm');
    form.addEventListener('submit', function() {
      if (quill.getText().trim().length > 0) {
        descInput.value = quill.root.innerHTML;
      } else {
        descInput.value = '';
      }
    });
  </script>
</BaseLayout>
