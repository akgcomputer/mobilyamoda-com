---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getProducts, deleteProduct, getCategories, getBrands } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const id = parseInt(formData.get('id') as string);
    if (id) {
      await deleteProduct(id, dbBinding);
      mesaj = 'Ürün başarıyla silindi.';
    }
  } catch (err) {
    console.error('Delete product error:', err);
    mesaj = 'Silme işlemi sırasında bir hata oluştu.';
  }
}

const products = await getProducts(dbBinding);
const categories = await getCategories(dbBinding, 'product');
const brands = await getBrands(dbBinding);

// Helper functions for names
function getCategoryName(id: number) {
  return categories.find(c => c.id === id)?.name || '-';
}
function getBrandName(id: number) {
  return brands.find(b => b.id === id)?.name || '-';
}
---

<BaseLayout title="Ürünler - Admin" isAdmin={true}>
  <div class="p-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Ürün Yönetimi</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">E-ticaret sisteminizdeki ürünleri ekleyin ve düzenleyin</p>
      </div>
      <div class="flex gap-2">
        <button class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 px-4 py-2.5 rounded-lg transition font-medium shadow-sm flex items-center gap-2 text-sm" onclick="alert('Toplu Excel/XML aktarımı Adım 2.1\'de aktif edilecek.')">
          <i class="fas fa-file-excel"></i> Dışa/İçe Aktar
        </button>
        <a href="/admin/ecommerce/products/new" class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-lg transition font-medium shadow-md flex items-center gap-2">
          <i class="fas fa-plus"></i>
          Yeni Ürün Ekle
        </a>
      </div>
    </div>

    {mesaj && (
      <div class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-4 rounded-xl border border-green-200 dark:border-green-800 mb-6 flex justify-between items-center">
        <span>✅ {mesaj}</span>
        <button onclick="this.parentElement.remove()" class="text-green-700 dark:text-green-300">✕</button>
      </div>
    )}

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
            <tr>
              <th class="w-16 px-4 py-3 text-left">Görsel</th>
              <th class="px-6 py-4 text-left">Ürün Adı</th>
              <th class="px-6 py-4 text-left">Fiyat</th>
              <th class="px-6 py-4 text-left hidden md:table-cell">Kategori / Marka</th>
              <th class="px-6 py-4 text-left hidden lg:table-cell">Rozetler</th>
              <th class="px-6 py-4 text-left">Durum</th>
              <th class="px-6 py-4 text-center">İşlem</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700 text-gray-700 dark:text-gray-200">
            {products.map(product => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                <td class="px-4 py-4 text-sm font-semibold text-gray-500 dark:text-gray-400">
                  {product.image_url ? <img src={product.image_url} class="w-10 h-14 object-cover rounded shadow-sm" /> : <div class="w-10 h-14 bg-gray-200 dark:bg-gray-700 rounded flex items-center justify-center"><i class="fas fa-image text-gray-400"></i></div>}
                </td>
                <td class="px-6 py-4">
                  <div class="font-medium text-gray-900 dark:text-white line-clamp-1">{product.name}</div>
                  <div class="text-xs text-gray-500 mt-0.5">/{product.slug}</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="font-bold text-gray-900 dark:text-white">{product.price.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })}</div>
                  {product.compare_at_price && product.compare_at_price > product.price && (
                    <div class="text-xs text-gray-500 line-through">{product.compare_at_price.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })}</div>
                  )}
                </td>
                <td class="px-6 py-4 hidden md:table-cell text-sm text-gray-500 dark:text-gray-400">
                  <div>{getCategoryName(product.category_id || 0)}</div>
                  <div class="text-xs mt-1 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded inline-block">{getBrandName(product.brand_id || 0)}</div>
                </td>
                <td class="px-6 py-4 hidden lg:table-cell text-xs text-gray-500">
                  {product.badge_top_left && <div class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded mb-1 w-max dark:bg-blue-900/40 dark:text-blue-300">Sol: {product.badge_top_left}</div>}
                  {product.badge_top_right && <div class="bg-red-100 text-red-800 px-2 py-0.5 rounded w-max dark:bg-red-900/40 dark:text-red-300">Sağ: {product.badge_top_right}</div>}
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class={`px-2.5 py-1 text-xs font-medium rounded-full ${product.status === 'aktif' ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'}`}>
                    {product.status === 'aktif' ? 'Aktif' : 'Pasif'}
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                  <div class="flex items-center justify-center gap-2">
                    <a href={`/urunler/detay/${product.slug}`} target="_blank" class="text-gray-500 hover:text-orange-600 dark:text-gray-400 dark:hover:text-orange-400 transition" title="Görüntüle">
                      <i class="fas fa-external-link-alt"></i>
                    </a>
                    <a href={`/admin/ecommerce/products/${product.id}`} class="text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/30 p-2 rounded-lg transition" title="Düzenle">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form method="POST" class="inline" onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?')">
                      <input type="hidden" name="id" value={product.id} />
                      <button type="submit" class="text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-900/30 p-2 rounded-lg transition" title="Sil">
                        <i class="fas fa-trash-alt"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
            
            {products.length === 0 && (
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                  <div class="text-4xl mb-4">📦</div>
                  <p class="text-lg">Henüz hiç ürün eklenmemiş.</p>
                  <a href="/admin/ecommerce/products/new" class="text-orange-600 hover:underline mt-2 inline-block">İlk ürününüzü ekleyin</a>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>