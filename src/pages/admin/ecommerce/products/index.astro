---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getProducts, deleteProduct, duplicateProduct, getCategories, getBrands, getAllReviews, getAllQA, getBadges, updateProduct } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    const id = parseInt(formData.get('id') as string);
    if (id) {
      if (action === 'delete') {
        await deleteProduct(id, dbBinding);
        mesaj = 'Ürün başarıyla silindi.';
      } else if (action === 'duplicate') {
        await duplicateProduct(id, dbBinding);
        mesaj = 'Ürün başarıyla kopyalandı.';
      } else if (action === 'toggle_backorder') {
        const product = await getProducts(dbBinding).then(res => res.find(p => p.id === id));
        if (product) {
          const newStatus = product.allow_backorder === 1 ? 0 : 1;
          await updateProduct(id, { allow_backorder: newStatus }, dbBinding);
          mesaj = 'Stoksuz sat durumu güncellendi.';
        }
      }
    }
  } catch (err) {
    console.error('Action error:', err);
    mesaj = 'İşlem sırasında bir hata oluştu.';
  }
}

const products = await getProducts(dbBinding);
const categories = await getCategories(dbBinding, 'product');
const brands = await getBrands(dbBinding);
const allReviews = await getAllReviews(dbBinding);
const allQA = await getAllQA(dbBinding);
const allBadges = await getBadges(dbBinding);

// Helper functions
function getCategoryName(id: number) {
  return categories.find(c => c.id === id)?.name || '-';
}
function getBrandName(id: number) {
  return brands.find(b => b.id === id)?.name || '-';
}
function getBadgeNames(badgesJson: string | null) {
  if (!badgesJson) return [];
  try {
    const parsed = JSON.parse(badgesJson);
    return parsed.map((p: any) => {
      const b = allBadges.find(x => x.id === p.badge_id);
      return b ? b.name : null;
    }).filter(Boolean);
  } catch(e) { return []; }
}
---

<BaseLayout title="Ürünler - Admin" isAdmin={true}>
  <div class="p-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Ürün Yönetimi</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">E-ticaret sisteminizdeki ürünleri ekleyin ve düzenleyin</p>
      </div>
      <div class="flex gap-2">
        <button type="button" onclick="document.getElementById('importModal').classList.remove('hidden')" class="bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 px-4 py-2.5 rounded-lg transition font-medium shadow-sm flex items-center gap-2 text-sm">
          <i class="fas fa-file-excel"></i> Dışa/İçe Aktar
        </button>
        <a href="/admin/ecommerce/products/new" class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-lg transition font-medium shadow-md flex items-center gap-2">
          <i class="fas fa-plus"></i>
          Yeni Ürün Ekle
        </a>
      </div>
    </div>

    {mesaj && (
      <div class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-4 rounded-xl border border-green-200 dark:border-green-800 mb-6 flex justify-between items-center">
        <span>✅ {mesaj}</span>
        <button onclick="this.parentElement.remove()" class="text-green-700 dark:text-green-300">✕</button>
      </div>
    )}

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
            <tr>
              <th class="px-3 py-3 text-left">Görsel</th>
              <th class="px-3 py-4 text-left">Ürün Adı</th>
              <th class="px-3 py-4 text-left">Fiyat</th>
              <th class="px-3 py-4 text-left hidden md:table-cell">Kategori/Marka</th>
              <th class="px-3 py-4 text-left">Stok / Varyant</th>
              <th class="px-3 py-4 text-center">Stoksuz Sat</th>
              <th class="px-3 py-4 text-left hidden lg:table-cell">Rozetler</th>
              <th class="px-3 py-4 text-left">Puan/Soru/Beğeni</th>
              <th class="px-3 py-4 text-left">Durum</th>
              <th class="px-3 py-4 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700 text-gray-700 dark:text-gray-200 text-sm">
            {products.map(product => {
              const pReviews = allReviews.filter(r => r.product_id === product.id && r.status === 'approved');
              const thumbsUp = pReviews.filter(r => r.rating >= 2).length;
              const thumbsDown = pReviews.filter(r => r.rating === 1).length;
              const pQA = allQA.filter(q => q.product_id === product.id && q.status === 'answered');
              const bNames = getBadgeNames(product.badges);
              
              return (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                <td class="px-3 py-4 text-sm font-semibold text-gray-500 dark:text-gray-400">
                  {product.image_url ? <img src={product.image_url} class="w-10 h-14 object-cover rounded shadow-sm" /> : <div class="w-10 h-14 bg-gray-200 dark:bg-gray-700 rounded flex items-center justify-center"><i class="fas fa-image text-gray-400"></i></div>}
                </td>
                <td class="px-3 py-4">
                  <div class="font-medium text-gray-900 dark:text-white line-clamp-1">{product.name}</div>
                  <div class="text-xs text-gray-500 mt-0.5">/{product.slug}</div>
                </td>
                <td class="px-3 py-4 whitespace-nowrap">
                  <div class="font-bold text-gray-900 dark:text-white">{product.price.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' })}</div>
                </td>
                <td class="px-3 py-4 hidden md:table-cell text-sm text-gray-500 dark:text-gray-400">
                  <div class="line-clamp-1">{getCategoryName(product.category_id || 0)}</div>
                  <div class="text-xs mt-1 bg-gray-100 dark:bg-gray-700 px-2 py-0.5 rounded inline-block">{getBrandName(product.brand_id || 0)}</div>
                </td>
                <td class="px-3 py-4">
                  {product.variants && product.variants.length > 0 ? (
                    <div class="text-xs">
                      {product.variants.map(v => (
                        <div class="mb-0.5"><span class="text-gray-500">{v.name}:</span> <span class="font-semibold">{v.stock}</span></div>
                      ))}
                    </div>
                  ) : (
                    <div class="font-semibold">{product.stock || 0} Adet</div>
                  )}
                </td>
                <td class="px-3 py-4 text-center">
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="toggle_backorder" />
                    <input type="hidden" name="id" value={product.id} />
                    <button type="submit" class={`px-3 py-1 rounded-full text-xs font-bold transition ${product.allow_backorder === 1 ? 'bg-orange-100 text-orange-700 dark:bg-orange-900/50 dark:text-orange-400' : 'bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400'}`}>
                      {product.allow_backorder === 1 ? 'Açık' : 'Kapalı'}
                    </button>
                  </form>
                </td>
                <td class="px-3 py-4 hidden lg:table-cell text-xs text-gray-500">
                  <div class="flex flex-wrap gap-1 w-24">
                    {bNames.map((n: string) => <span class="bg-blue-50 text-blue-600 border border-blue-100 px-1 rounded dark:bg-blue-900/30 dark:border-blue-800 dark:text-blue-300">{n}</span>)}
                  </div>
                </td>
                <td class="px-3 py-4 text-xs whitespace-nowrap">
                  <div class="text-yellow-500">{product.rating} ⭐</div>
                  <div class="mt-1">{thumbsUp} 👍 | {thumbsDown} 👎</div>
                  <div class="mt-1">💬 {pQA.length} | ❤️ {product.likes || 0}</div>
                </td>
                <td class="px-3 py-4 whitespace-nowrap">
                  <span class={`px-2.5 py-1 text-xs font-medium rounded-full ${product.status === 'aktif' ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'}`}>
                    {product.status === 'aktif' ? 'Aktif' : 'Pasif'}
                  </span>
                </td>
                <td class="px-3 py-4 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <a href={`/urunler/${product.slug}`} target="_blank" title="Görüntüle" class="p-1.5 text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/50 rounded transition">
                      <i class="fas fa-external-link-alt"></i>
                    </a>
                    <form method="POST" class="inline" onsubmit="return confirm('Bu ürünü kopyalamak istiyor musunuz?');">
                      <input type="hidden" name="action" value="duplicate" />
                      <input type="hidden" name="id" value={product.id} />
                      <button type="submit" title="Kopyala/Çoğalt" class="p-1.5 text-green-600 hover:bg-green-50 dark:hover:bg-green-900/50 rounded transition">
                        <i class="fas fa-copy"></i>
                      </button>
                    </form>
                    <a href={`/admin/ecommerce/products/${product.id}`} title="Düzenle" class="p-1.5 text-gray-500 hover:text-orange-600 hover:bg-orange-50 dark:hover:bg-gray-700 rounded transition">
                      <i class="fas fa-edit"></i>
                    </a>
                    <form method="POST" class="inline" onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={product.id} />
                      <button type="submit" title="Sil" class="p-1.5 text-gray-500 hover:text-red-600 hover:bg-red-50 dark:hover:bg-gray-700 rounded transition">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              )}
            )}
            
            {products.length === 0 && (
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                  <div class="text-4xl mb-4">📦</div>
                  <p class="text-lg">Henüz hiç ürün eklenmemiş.</p>
                  <a href="/admin/ecommerce/products/new" class="text-orange-600 hover:underline mt-2 inline-block">İlk ürününüzü ekleyin</a>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- İçe / Dışa Aktar Modal -->
  <div id="importModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl max-w-lg w-full overflow-hidden border border-gray-100 dark:border-gray-700">
      <div class="flex justify-between items-center p-6 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <i class="fas fa-file-excel text-green-600"></i> Toplu Ürün İçe/Dışa Aktar
        </h3>
        <button type="button" onclick="document.getElementById('importModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
          <i class="fas fa-times text-lg"></i>
        </button>
      </div>
      <div class="p-6 space-y-6">
        
        <!-- Örnek Şablon -->
        <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 p-4 rounded-xl flex items-start gap-3">
          <i class="fas fa-info-circle text-blue-500 mt-1"></i>
          <div>
            <h4 class="font-bold text-blue-800 dark:text-blue-300 mb-1">Örnek Şablonu İndirin</h4>
            <p class="text-sm text-blue-600 dark:text-blue-400 mb-3">Sisteme ürün yükleyebilmek için lütfen aşağıdaki örnek CSV şablonunu kullanın. Tüm gerekli sütunlar şablonda mevcuttur.</p>
            <a href="/downloads/ornek-urun-sablonu.csv" download class="inline-flex items-center gap-2 bg-white dark:bg-gray-800 text-blue-600 border border-blue-200 dark:border-blue-700 px-4 py-2 rounded shadow-sm text-sm font-medium hover:bg-blue-50 dark:hover:bg-gray-700 transition">
              <i class="fas fa-download"></i> Şablonu İndir (.csv)
            </a>
          </div>
        </div>

        <!-- İçe Aktar (Dosya Yükleme) -->
        <form method="POST" enctype="multipart/form-data" onsubmit="event.preventDefault(); alert('Toplu içe aktarma altyapısı (Adım 2.1) henüz aktif edilmedi. Şablon üzerinden hazırlık yapabilirsiniz.'); document.getElementById('importModal').classList.add('hidden');">
          <h4 class="font-bold text-gray-800 dark:text-gray-200 mb-3">Sisteme Yükle</h4>
          <div class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-8 text-center hover:bg-gray-50 dark:hover:bg-gray-700/50 transition cursor-pointer" onclick="document.getElementById('fileUpload').click()">
            <i class="fas fa-cloud-upload-alt text-4xl text-gray-400 mb-3"></i>
            <p class="text-gray-600 dark:text-gray-400 mb-1">CSV/Excel dosyasını seçin</p>
            <input type="file" name="file" accept=".xlsx, .xls, .csv" class="hidden" id="fileUpload" onchange="document.getElementById('fileName').textContent = this.files[0].name" />
            <button type="button" class="mt-4 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-4 py-2 rounded text-sm font-medium hover:bg-gray-300 dark:hover:bg-gray-600 transition">
              Dosya Seç
            </button>
            <p id="fileName" class="mt-3 text-sm font-bold text-orange-600"></p>
          </div>
          
          <button type="submit" class="w-full mt-4 bg-green-600 hover:bg-green-700 text-white py-3 rounded-xl font-bold shadow-md transition flex items-center justify-center gap-2">
            <i class="fas fa-check"></i> Ürünleri İçe Aktar
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
