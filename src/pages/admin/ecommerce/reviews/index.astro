---
// src/pages/admin/ecommerce/reviews/index.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getAllReviews, updateReviewStatus, deleteReview } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let basari = '';
let hata = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    const id = parseInt(formData.get('id') as string);

    if (action === 'approve') {
      await updateReviewStatus(id, 'approved', dbBinding);
      basari = 'Yorum onaylandı ve yayına alındı.';
    } else if (action === 'delete') {
      await deleteReview(id, dbBinding);
      basari = 'Yorum silindi.';
    }
  } catch (err: any) {
    hata = err.message || 'Bir hata oluştu.';
  }
}

const reviews = await getAllReviews(dbBinding);
---

<BaseLayout title="Ürün Yorumları | Laflaf Admin">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Ürün Değerlendirmeleri</h1>
  </div>

  {basari && (
    <div class="p-4 mb-6 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200">
      {basari}
    </div>
  )}
  {hata && (
    <div class="p-4 mb-6 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200">
      {hata}
    </div>
  )}

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-300">
        <tr>
          <th scope="col" class="px-6 py-3">Ürün ID</th>
          <th scope="col" class="px-6 py-3">Müşteri & Puan</th>
          <th scope="col" class="px-6 py-3 w-1/3">Yorum</th>
          <th scope="col" class="px-6 py-3">Durum</th>
          <th scope="col" class="px-6 py-3 text-right">İşlem</th>
        </tr>
      </thead>
      <tbody>
        {reviews.length === 0 ? (
          <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Henüz değerlendirme bulunmuyor.</td></tr>
        ) : (
          reviews.map(review => (
            <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4 font-bold">
                <a href={`/urunler/detay/${review.product_id}`} target="_blank" class="text-blue-600 hover:underline">#{review.product_id}</a>
              </td>
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900 dark:text-white">{review.user_name}</div>
                <div class="text-yellow-400 text-xs mt-1">
                  {[...Array(5)].map((_, i) => (
                    <i class={i < review.rating ? "fas fa-star" : "far fa-star"}></i>
                  ))}
                </div>
              </td>
              <td class="px-6 py-4 whitespace-pre-wrap">
                {review.comment || '-'}
              </td>
              <td class="px-6 py-4">
                {review.status === 'pending' ? (
                  <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2 py-0.5 rounded border border-yellow-200">Onay Bekliyor</span>
                ) : (
                  <span class="bg-green-100 text-green-800 text-xs font-medium px-2 py-0.5 rounded border border-green-200">Yayında</span>
                )}
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                {review.status === 'pending' && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="approve" />
                    <input type="hidden" name="id" value={review.id} />
                    <button type="submit" class="text-green-600 hover:text-green-900 dark:text-green-400 font-medium">Onayla</button>
                  </form>
                )}
                <form method="POST" class="inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={review.id} />
                  <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400 font-medium ml-2">Sil</button>
                </form>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</BaseLayout>
