---
// src/pages/admin/ecommerce/shipping.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSettings, updateSetting } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';
let settings = await getSettings(dbBinding);
let returnShippingInfo = settings.return_shipping_info || '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const info = formData.get('return_shipping_info') as string;
  await updateSetting('return_shipping_info', info, dbBinding);
  returnShippingInfo = info;
  mesaj = 'Sabit İade ve Kargo metni başarıyla kaydedildi.';
}
---

<BaseLayout title="İade & Kargo Ayarları - Admin" isAdmin={true}>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
  
  <div class="p-6 max-w-6xl mx-auto space-y-12">
    <!-- Header -->
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <div class="flex items-center gap-3">
        <a href="/admin/ecommerce" class="w-10 h-10 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors" title="E-Ticaret Paneline Dön">
          <i class="fas fa-chevron-left"></i>
        </a>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
            <i class="fas fa-shipping-fast text-indigo-600 dark:text-indigo-400"></i>
          </div>
          İade & Kargo Ayarları
        </h1>
      </div>
      <p class="text-gray-500 dark:text-gray-400 mt-2 ml-14">Sabit iade bilgilendirme metinlerini düzenleyin ve kullanıcıların iade/değişim taleplerini yönetin.</p>
    </div>

    {mesaj && (
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl relative shadow-sm flex items-center gap-2 animate-fade-in">
        <i class="fas fa-check-circle"></i>
        <span class="block sm:inline font-semibold">{mesaj}</span>
        <button onclick="this.parentElement.remove()" class="absolute top-0 bottom-0 right-0 px-4 py-3 text-green-700">✕</button>
      </div>
    )}

    <!-- Üst Kısım: Sabit Metin Belirleme Editörü -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
          <i class="fas fa-edit text-indigo-600 dark:text-indigo-400"></i>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Sabit Bilgilendirme Metni</h2>
          <p class="text-xs text-gray-500">Tüm ürünlerin "İade ve Kargo" sekmesinde sabit olarak görünecek metni belirleyin.</p>
        </div>
      </div>
      
      <form method="POST" id="shippingInfoForm">
        <input type="hidden" name="return_shipping_info" id="returnShippingInput" value={returnShippingInfo} />
        
        <div class="mb-6">
          <div id="editor-container" class="h-64 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-b-lg border-gray-300 dark:border-gray-600"></div>
        </div>
        
        <button type="submit" onclick="document.getElementById('returnShippingInput').value = window.quill.root.innerHTML;" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3.5 px-8 rounded-xl shadow-md transition-all hover:-translate-y-0.5 flex items-center gap-2">
          <i class="fas fa-save"></i> Değişiklikleri Kaydet
        </button>
      </form>
    </div>

    <!-- Alt Kısım: İade ve Değişim Talepleri Listesi -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-tasks text-orange-600 dark:text-orange-400"></i>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Müşteri İade ve Değişim Talepleri</h2>
          <p class="text-xs text-gray-500">Kullanıcılar tarafından profil sayfasından başlatılmış aktif talepler.</p>
        </div>
      </div>

      <!-- Talepler Tablosu / Listesi -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="returnsTable">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              <th class="py-4 px-6">Tarih</th>
              <th class="py-4 px-6">Sipariş</th>
              <th class="py-4 px-6">Ürün</th>
              <th class="py-4 px-6">Miktar</th>
              <th class="py-4 px-6">Tür</th>
              <th class="py-4 px-6">Durum</th>
              <th class="py-4 px-6 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody id="returnsTableBody" class="divide-y divide-gray-150 dark:divide-gray-750 text-sm">
            <!-- Dinamik Doldurulacak -->
          </tbody>
        </table>
      </div>

      <!-- Boş Durum Görünümü -->
      <div id="noReturnsView" class="hidden text-center py-16 bg-gray-50 dark:bg-gray-800/40 rounded-2xl border-2 border-dashed border-gray-200 dark:border-gray-750">
        <i class="fas fa-box-open text-5xl text-gray-300 dark:text-gray-600 mb-4 block"></i>
        <h3 class="font-bold text-gray-800 dark:text-gray-300 mb-1">Aktif Talep Bulunmuyor</h3>
        <p class="text-xs text-gray-500">Şu anda onay veya ret bekleyen herhangi bir iade veya değişim talebi bulunmamaktadır.</p>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js" is:inline></script>
  <script is:inline>
    // --- Quill Editor Setup ---
    function initReturnShippingEditor() {
      if (!document.getElementById('editor-container') || document.querySelector('.ql-toolbar')) return;
      if (typeof Quill === 'undefined') {
        setTimeout(initReturnShippingEditor, 100);
        return;
      }
      
      window.quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: 'İade ve kargo koşullarınızı buraya yazabilirsiniz...',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote'],
            [{ 'header': 1 }, { 'header': 2 }],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'align': [] }],
            ['link', 'clean']
          ]
        }
      });
      
      const existingContent = document.getElementById('returnShippingInput').value;
      if (existingContent) {
        window.quill.root.innerHTML = existingContent;
      }
    }

    // --- Returns Management Setup ---
    function initReturnsManager() {
      const table = document.getElementById('returnsTable');
      const tableBody = document.getElementById('returnsTableBody');
      const emptyView = document.getElementById('noReturnsView');
      
      if (!table || !tableBody || !emptyView) return;

      const getReturns = () => {
        try {
          return JSON.parse(localStorage.getItem('laflaf_profile_returns') || '[]');
        } catch(e) {
          return [];
        }
      };

      const saveReturns = (list) => {
        localStorage.setItem('laflaf_profile_returns', JSON.stringify(list));
      };

      const updateReturnStatus = (createdAt, newStatus) => {
        const list = getReturns();
        const found = list.find(r => r.createdAt === createdAt);
        if (found) {
          found.status = newStatus;
          saveReturns(list);
          renderReturns();
          
          // Show feedback message
          const feedback = document.createElement('div');
          feedback.className = 'fixed bottom-5 right-5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-bold px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-2 border border-gray-700/50 z-50 animate-bounce text-xs';
          feedback.innerHTML = `<i class="fas fa-check text-green-500"></i> Talep başarıyla ${newStatus === 'onaylandı' ? 'onaylandı!' : 'reddedildi!'}`;
          document.body.appendChild(feedback);
          setTimeout(() => feedback.remove(), 2500);
        }
      };

      const renderReturns = () => {
        const rawList = getReturns();
        const list = Array.isArray(rawList) ? rawList : [];
        
        if (list.length === 0) {
          table.classList.add('hidden');
          emptyView.classList.remove('hidden');
          return;
        }

        table.classList.remove('hidden');
        emptyView.classList.add('hidden');
        tableBody.innerHTML = '';

        // Sort returns descending by date
        const sortedList = [...list].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

        sortedList.forEach(r => {
          const tr = document.createElement('tr');
          tr.className = 'hover:bg-gray-50 dark:hover:bg-gray-800/40 transition-colors border-b border-gray-100 dark:border-gray-800/50';
          
          const dateStr = new Date(r.createdAt).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' });
          
          let statusBadgeClass = 'bg-orange-100 text-orange-700 dark:bg-orange-950/20 dark:text-orange-400 border border-orange-200/50';
          let statusText = 'Bekliyor';
          if (r.status === 'onaylandı') {
            statusBadgeClass = 'bg-green-100 text-green-700 dark:bg-green-950/20 dark:text-green-400 border border-green-200/50';
            statusText = 'Onaylandı';
          } else if (r.status === 'reddedildi') {
            statusBadgeClass = 'bg-red-100 text-red-700 dark:bg-red-950/20 dark:text-red-400 border border-red-200/50';
            statusText = 'Reddedildi';
          }

          let actionButtons = '';
          if (r.status === 'başlatıldı') {
            actionButtons = `
              <div class="flex items-center justify-end gap-2">
                <button type="button" class="btn-approve px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white rounded-lg text-xs font-bold transition shadow-sm flex items-center gap-1 active:scale-95" data-id="${r.createdAt}">
                  <i class="fas fa-check"></i> Onayla
                </button>
                <button type="button" class="btn-reject px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white rounded-lg text-xs font-bold transition shadow-sm flex items-center gap-1 active:scale-95" data-id="${r.createdAt}">
                  <i class="fas fa-times"></i> Reddet
                </button>
              </div>
            `;
          } else {
            actionButtons = `
              <span class="text-xs text-gray-400 dark:text-gray-500 italic font-medium"><i class="fas fa-check-double mr-1"></i> İşlem Tamamlandı</span>
            `;
          }

          tr.innerHTML = `
            <td class="py-4 px-6 text-xs text-gray-500 font-mono">${dateStr}</td>
            <td class="py-4 px-6 font-bold text-indigo-600 dark:text-indigo-400">#LAF${r.order_id}</td>
            <td class="py-4 px-6 font-semibold text-gray-800 dark:text-gray-200">${r.product_name}</td>
            <td class="py-4 px-6 font-extrabold text-gray-900 dark:text-white">${r.qty}</td>
            <td class="py-4 px-6 font-medium text-xs text-gray-600 dark:text-gray-400">${r.type === 'iade' ? 'Ürün İadesi' : 'Beden/Renk Değişimi'}</td>
            <td class="py-4 px-6">
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-extrabold uppercase tracking-wider ${statusBadgeClass}">
                ${statusText}
              </span>
            </td>
            <td class="py-4 px-6 text-right">${actionButtons}</td>
          `;

          tableBody.appendChild(tr);
        });
      };

      // Table Action Listeners
      tableBody.addEventListener('click', (e) => {
        const btn = e.target.closest('button');
        if (!btn) return;

        const id = btn.getAttribute('data-id');
        if (btn.classList.contains('btn-approve')) {
          if (confirm('Bu iade/değişim talebini onaylamak istediğinize emin misiniz?')) {
            updateReturnStatus(id, 'onaylandı');
          }
        } else if (btn.classList.contains('btn-reject')) {
          if (confirm('Bu iade/değişim talebini reddetmek istediğinize emin misiniz?')) {
            updateReturnStatus(id, 'reddedildi');
          }
        }
      });

      renderReturns();
    }

    // Run all features securely
    function runAllShippingAdminLogic() {
      try {
        initReturnShippingEditor();
      } catch (e) {
        console.error("Quill editor init failed:", e);
      }
      try {
        initReturnsManager();
      } catch (e) {
        console.error("Returns manager init failed:", e);
      }
    }

    document.addEventListener('astro:page-load', runAllShippingAdminLogic);
    
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(runAllShippingAdminLogic, 100);
    } else {
      document.addEventListener('DOMContentLoaded', runAllShippingAdminLogic);
    }
  </script>
</BaseLayout>
