---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSettings, updateSetting } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';
let settings = await getSettings(dbBinding);
let returnShippingInfo = settings.return_shipping_info || '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const info = formData.get('return_shipping_info') as string;
  await updateSetting('return_shipping_info', info, dbBinding);
  returnShippingInfo = info;
  mesaj = 'İade ve Kargo bilgileri başarıyla kaydedildi.';
}

const cards = [
  { title: 'Manşet (Slider)', icon: 'fas fa-images', color: 'text-purple-600', bg: 'bg-purple-100', link: '/admin/ecommerce/sliders' },
  { title: 'Siparişler', icon: 'fas fa-shopping-cart', color: 'text-orange-600', bg: 'bg-orange-100', link: '/admin/ecommerce/orders' },
  { title: 'Ürünler', icon: 'fas fa-box', color: 'text-blue-600', bg: 'bg-blue-100', link: '/admin/ecommerce/products' },
  { title: 'Ürün Kategorileri', icon: 'fas fa-tags', color: 'text-green-600', bg: 'bg-green-100', link: '/admin/ecommerce/categories' },
  { title: 'Markalar', icon: 'fas fa-copyright', color: 'text-yellow-600', bg: 'bg-yellow-100', link: '/admin/ecommerce/brands' },
  { title: 'Kupon & Kampanyalar', icon: 'fas fa-ticket-alt', color: 'text-rose-600', bg: 'bg-rose-100', link: '/admin/ecommerce/campaigns' },
  { title: 'Ödeme Yöntemleri', icon: 'fas fa-credit-card', color: 'text-teal-600', bg: 'bg-teal-100', link: '/admin/ecommerce/settings/payment' },
];
---

<BaseLayout title="E-Ticaret Yönetimi - Admin" isAdmin={true}>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
  
  <div class="p-6 max-w-6xl mx-auto">
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-shopping-basket text-orange-600 dark:text-orange-400"></i>
        </div>
        E-Ticaret Yönetimi
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 ml-14">Mağazanızın tüm sipariş, ürün ve kategori ayarlarını buradan yönetebilirsiniz.</p>
    </div>

    {mesaj && (
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6">
        <span class="block sm:inline">{mesaj}</span>
        <button onclick="this.parentElement.remove()" class="absolute top-0 bottom-0 right-0 px-4 py-3 text-green-700">✕</button>
      </div>
    )}

    <!-- Navigation Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {cards.map(card => (
        <a href={card.link} class="bg-white dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-4">
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center ${card.bg} ${card.color} group-hover:scale-110 transition-transform duration-300`}>
              <i class={`${card.icon} text-2xl`}></i>
            </div>
            <div>
              <h3 class="font-bold text-lg text-gray-900 dark:text-white group-hover:text-orange-600 transition-colors">{card.title}</h3>
            </div>
            <i class="fas fa-chevron-right ml-auto text-gray-300 dark:text-gray-600 group-hover:text-orange-500 transition-colors"></i>
          </div>
        </a>
      ))}
    </div>

    <!-- İade ve Kargo Bilgilendirmesi Formu -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center">
          <i class="fas fa-truck text-indigo-600 dark:text-indigo-400"></i>
        </div>
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">İade ve Kargo Bilgilendirmesi</h2>
          <p class="text-sm text-gray-500">Tüm ürünlerin "İade ve Kargo" sekmesinde sabit olarak görünecek metni belirleyin.</p>
        </div>
      </div>
      
      <form method="POST">
        <input type="hidden" name="return_shipping_info" id="returnShippingInput" value={returnShippingInfo} />
        
        <div class="mb-6">
          <div id="editor-container" class="h-64 bg-white dark:bg-gray-800 text-gray-900 dark:text-white rounded-b-lg border-gray-300 dark:border-gray-600"></div>
        </div>
        
        <button type="submit" onclick="document.getElementById('returnShippingInput').value = window.quill.root.innerHTML;" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-xl shadow-md transition-colors flex items-center gap-2">
          <i class="fas fa-save"></i> Bilgileri Kaydet
        </button>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js" is:inline></script>
  <script is:inline>
    function initReturnShippingEditor() {
      if (!document.getElementById('editor-container') || document.querySelector('.ql-toolbar')) return;
      if (typeof Quill === 'undefined') {
        setTimeout(initReturnShippingEditor, 100);
        return;
      }
      
      window.quill = new Quill('#editor-container', {
        theme: 'snow',
        placeholder: 'İade ve kargo koşullarınızı buraya yazabilirsiniz...',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote'],
            [{ 'header': 1 }, { 'header': 2 }],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'align': [] }],
            ['link', 'clean']
          ]
        }
      });
      
      const existingContent = document.getElementById('returnShippingInput').value;
      if (existingContent) {
        window.quill.root.innerHTML = existingContent;
      }
    }

    document.addEventListener('astro:page-load', initReturnShippingEditor);
    
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      setTimeout(initReturnShippingEditor, 100);
    } else {
      document.addEventListener('DOMContentLoaded', initReturnShippingEditor);
    }
  </script>
</BaseLayout>
