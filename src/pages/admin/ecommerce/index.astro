---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSettings, updateSetting, getOrders, getProducts } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';
let settings = await getSettings(dbBinding);
let returnShippingInfo = settings.return_shipping_info || '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const info = formData.get('return_shipping_info') as string;
  await updateSetting('return_shipping_info', info, dbBinding);
  returnShippingInfo = info;
  mesaj = 'İade ve Kargo bilgileri başarıyla kaydedildi.';
}

// Sipariş ve Ürün verilerini gerçek zamanlı çekelim
const allOrders = await getOrders(dbBinding);
const allProducts = await getProducts(dbBinding);

// Tarih sınırlarını tanımlayalım
const now = new Date();
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const oneMonthAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
const threeMonthsAgo = new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000);

const getOrdersInTimeframe = (list: any[], status: string, dateLimit: Date) => {
  return list.filter(o => {
    const oDate = new Date(o.createdAt);
    return oDate >= dateLimit && o.status === status;
  });
};

const getSalesInTimeframe = (list: any[], dateLimit: Date) => {
  return list
    .filter(o => {
      const oDate = new Date(o.createdAt);
      return oDate >= dateLimit && o.status !== 'iptal';
    })
    .reduce((sum, o) => sum + (parseFloat(o.total_amount) || 0), 0);
};

// Bekleyen Siparişler
const pending7d = getOrdersInTimeframe(allOrders, 'bekliyor', sevenDaysAgo).length;
const pending30d = getOrdersInTimeframe(allOrders, 'bekliyor', oneMonthAgo).length;
const pending90d = getOrdersInTimeframe(allOrders, 'bekliyor', threeMonthsAgo).length;

// Teslim Edilen Siparişler (Tamamlandı)
const delivered7d = getOrdersInTimeframe(allOrders, 'tamamlandi', sevenDaysAgo).length;
const delivered30d = getOrdersInTimeframe(allOrders, 'tamamlandi', oneMonthAgo).length;
const delivered90d = getOrdersInTimeframe(allOrders, 'tamamlandi', threeMonthsAgo).length;

// Toplam Satış Cirosu
const sales7d = getSalesInTimeframe(allOrders, sevenDaysAgo);
const sales30d = getSalesInTimeframe(allOrders, oneMonthAgo);
const sales90d = getSalesInTimeframe(allOrders, threeMonthsAgo);

// Toplam Ürün Adeti
const totalProductsCount = allProducts.length;

const cards = [
  { title: 'Manşet (Slider)', icon: 'fas fa-images', color: 'text-purple-600', bg: 'bg-purple-100', link: '/admin/ecommerce/sliders' },
  { title: 'Siparişler', icon: 'fas fa-shopping-cart', color: 'text-orange-600', bg: 'bg-orange-100', link: '/admin/ecommerce/orders' },
  { title: 'Ürünler', icon: 'fas fa-box', color: 'text-blue-600', bg: 'bg-blue-100', link: '/admin/ecommerce/products' },
  { title: 'Ürün Kategorileri', icon: 'fas fa-tags', color: 'text-green-600', bg: 'bg-green-100', link: '/admin/ecommerce/categories' },
  { title: 'Markalar', icon: 'fas fa-copyright', color: 'text-yellow-600', bg: 'bg-yellow-100', link: '/admin/ecommerce/brands' },
  { title: 'Kupon & Kampanyalar', icon: 'fas fa-ticket-alt', color: 'text-rose-600', bg: 'bg-rose-100', link: '/admin/ecommerce/campaigns' },
  { title: 'Ödeme Yöntemleri', icon: 'fas fa-credit-card', color: 'text-teal-600', bg: 'bg-teal-100', link: '/admin/ecommerce/settings/payment' },
  { title: 'İade & Kargo Ayarları', icon: 'fas fa-shipping-fast', color: 'text-indigo-600', bg: 'bg-indigo-100', link: '/admin/ecommerce/shipping' },
];
---

<BaseLayout title="E-Ticaret Yönetimi - Admin" isAdmin={true}>
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
  
  <div class="p-6 max-w-6xl mx-auto">
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-shopping-basket text-orange-600 dark:text-orange-400"></i>
        </div>
        E-Ticaret Yönetimi
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 ml-14">Mağazanızın tüm sipariş, ürün ve kategori ayarlarını buradan yönetebilirsiniz.</p>
    </div>

    {mesaj && (
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-6">
        <span class="block sm:inline">{mesaj}</span>
        <button onclick="this.parentElement.remove()" class="absolute top-0 bottom-0 right-0 px-4 py-3 text-green-700">✕</button>
      </div>
    )}

    <!-- Gerçek Verilerden Oluşan İstatistik Kartları -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
      
      <!-- Bekleyen Siparişler -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4 border-b dark:border-gray-700 pb-3">
          <div>
            <h3 class="text-xs font-extrabold text-gray-450 dark:text-gray-400 uppercase tracking-wider">Bekleyen Siparişler</h3>
            <p class="text-2xl font-black text-yellow-600 font-outfit mt-1">{pending90d} Adet</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-yellow-50 dark:bg-yellow-950/20 text-yellow-600 flex items-center justify-center text-xl">
            <i class="fas fa-clock"></i>
          </div>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1.5 font-medium">
          <div class="flex justify-between"><span>Son 7 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{pending7d} Adet</strong></div>
          <div class="flex justify-between"><span>Son 30 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{pending30d} Adet</strong></div>
          <div class="flex justify-between"><span>Son 90 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{pending90d} Adet</strong></div>
        </div>
      </div>

      <!-- Teslim Edilen Siparişler -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4 border-b dark:border-gray-700 pb-3">
          <div>
            <h3 class="text-xs font-extrabold text-gray-450 dark:text-gray-400 uppercase tracking-wider">Teslim Edilenler</h3>
            <p class="text-2xl font-black text-green-600 font-outfit mt-1">{delivered90d} Adet</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-green-50 dark:bg-green-950/20 text-green-600 flex items-center justify-center text-xl">
            <i class="fas fa-check-circle"></i>
          </div>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1.5 font-medium">
          <div class="flex justify-between"><span>Son 7 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{delivered7d} Adet</strong></div>
          <div class="flex justify-between"><span>Son 30 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{delivered30d} Adet</strong></div>
          <div class="flex justify-between"><span>Son 90 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{delivered90d} Adet</strong></div>
        </div>
      </div>

      <!-- Toplam Satış -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between mb-4 border-b dark:border-gray-700 pb-3">
          <div>
            <h3 class="text-xs font-extrabold text-gray-450 dark:text-gray-400 uppercase tracking-wider">Toplam Ciro</h3>
            <p class="text-2xl font-black text-indigo-600 font-outfit mt-1">{sales90d.toLocaleString('tr-TR')} ₺</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-indigo-50 dark:bg-indigo-950/20 text-indigo-600 flex items-center justify-center text-xl">
            <i class="fas fa-lira-sign"></i>
          </div>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 space-y-1.5 font-medium">
          <div class="flex justify-between"><span>Son 7 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{sales7d.toLocaleString('tr-TR')} ₺</strong></div>
          <div class="flex justify-between"><span>Son 30 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{sales30d.toLocaleString('tr-TR')} ₺</strong></div>
          <div class="flex justify-between"><span>Son 90 Gün:</span><strong class="text-gray-750 dark:text-gray-250">{sales90d.toLocaleString('tr-TR')} ₺</strong></div>
        </div>
      </div>

      <!-- Toplam Ürün Adeti -->
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between">
        <div class="flex items-center justify-between mb-4 border-b dark:border-gray-700 pb-3">
          <div>
            <h3 class="text-xs font-extrabold text-gray-450 dark:text-gray-400 uppercase tracking-wider">Aktif Ürünler</h3>
            <p class="text-2xl font-black text-orange-600 font-outfit mt-1">{totalProductsCount} Ürün</p>
          </div>
          <div class="w-12 h-12 rounded-xl bg-orange-50 dark:bg-orange-950/20 text-orange-600 flex items-center justify-center text-xl">
            <i class="fas fa-box-open"></i>
          </div>
        </div>
        <div class="text-xs text-gray-500 dark:text-gray-400 font-medium">
          <span class="block">Katalogda yer alan aktif satışa açık ürün çeşitliliğiniz.</span>
          <a href="/admin/ecommerce/products" class="text-orange-650 hover:underline font-bold mt-2 block flex items-center gap-1">
            Tümünü Yönet <i class="fas fa-chevron-right text-[10px]"></i>
          </a>
        </div>
      </div>

    </div>

    <!-- Navigation Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {cards.map(card => (
        <a href={card.link} class="bg-white dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 group">
          <div class="flex items-center gap-4">
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center ${card.bg} ${card.color} group-hover:scale-110 transition-transform duration-300`}>
              <i class={`${card.icon} text-2xl`}></i>
            </div>
            <div>
              <h3 class="font-bold text-lg text-gray-900 dark:text-white group-hover:text-orange-600 transition-colors">{card.title}</h3>
            </div>
            <i class="fas fa-chevron-right ml-auto text-gray-300 dark:text-gray-600 group-hover:text-orange-500 transition-colors"></i>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
