---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getOrderById, updateOrderStatus } from '../../../../lib/db';

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
  return Astro.redirect('/login');
}

const { id } = Astro.params;
const db = Astro.locals.runtime?.env?.DB;

let errorMessage = '';
let successMessage = '';

// Handle Status Update
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const status = formData.get('status')?.toString();
    const notes = formData.get('notes')?.toString();
    
    if (status) {
      const success = await updateOrderStatus(Number(id), status, notes, db);
      if (success) {
        successMessage = 'Sipariş durumu başarıyla güncellendi.';
      } else {
        errorMessage = 'Sipariş güncellenirken bir hata oluştu.';
      }
    }
  } catch(e:any) {
    errorMessage = 'Hata: ' + e.message;
  }
}

const order = await getOrderById(Number(id), db);

if (!order) {
  return Astro.redirect('/admin/ecommerce/orders');
}

const formatMoney = (amount: number) => {
  return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('tr-TR') + ' ' + d.toLocaleTimeString('tr-TR');
};

const getStatusBadge = (status: string) => {
  switch(status) {
    case 'bekliyor': return '<span class="bg-yellow-100 text-yellow-800 text-sm font-bold px-3 py-1 rounded-full">Bekliyor</span>';
    case 'onaylandi': return '<span class="bg-blue-100 text-blue-800 text-sm font-bold px-3 py-1 rounded-full">Onaylandı</span>';
    case 'kargolandi': return '<span class="bg-purple-100 text-purple-800 text-sm font-bold px-3 py-1 rounded-full">Kargolandı</span>';
    case 'tamamlandi': return '<span class="bg-green-100 text-green-800 text-sm font-bold px-3 py-1 rounded-full">Tamamlandı</span>';
    case 'iptal': return '<span class="bg-red-100 text-red-800 text-sm font-bold px-3 py-1 rounded-full">İptal Edildi</span>';
    default: return `<span class="bg-gray-100 text-gray-800 text-sm font-bold px-3 py-1 rounded-full">${status}</span>`;
  }
};
---

<BaseLayout title={`Sipariş #${order.id} | Admin Paneli`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin/ecommerce/orders" class="w-10 h-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 rounded-xl flex items-center justify-center hover:bg-gray-50 transition">
        <i class="fas fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
          Sipariş #{order.id}
          <Fragment set:html={getStatusBadge(order.status)} />
        </h1>
        <p class="text-sm text-gray-500 mt-1">{formatDate(order.createdAt)} tarihinde verildi.</p>
      </div>
    </div>

    {successMessage && (
      <div class="mb-6 p-4 bg-green-100 text-green-800 rounded-xl font-medium flex items-center gap-2">
        <i class="fas fa-check-circle"></i> {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="mb-6 p-4 bg-red-100 text-red-800 rounded-xl font-medium flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i> {errorMessage}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Sol: Sipariş Detayları & Ürünler -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Ürünler Tablosu -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
            <h2 class="font-bold text-gray-900 dark:text-white text-lg">Sipariş Edilen Ürünler</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
              <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700/50 dark:text-gray-300">
                <tr>
                  <th class="px-6 py-3">Ürün</th>
                  <th class="px-6 py-3 text-center">Birim Fiyat</th>
                  <th class="px-6 py-3 text-center">Adet</th>
                  <th class="px-6 py-3 text-right">Toplam</th>
                </tr>
              </thead>
              <tbody>
                {order.items && order.items.map(item => (
                  <tr class="border-b dark:border-gray-700 last:border-0">
                    <td class="px-6 py-4">
                      <div class="font-medium text-gray-900 dark:text-white">{item.product_name}</div>
                      {item.variant_name && <div class="text-xs text-gray-500">{item.variant_name}</div>}
                    </td>
                    <td class="px-6 py-4 text-center">{formatMoney(item.unit_price)}</td>
                    <td class="px-6 py-4 text-center font-bold">{item.quantity}</td>
                    <td class="px-6 py-4 text-right font-medium text-gray-900 dark:text-white">{formatMoney(item.total_price)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="p-6 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-700">
            <div class="flex justify-end">
              <div class="w-full sm:w-1/2 space-y-3">
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">Ara Toplam:</span>
                  <span class="font-medium dark:text-white">{formatMoney(order.subtotal)}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">Kargo Ücreti:</span>
                  <span class="font-medium text-green-600">{order.shipping_fee === 0 ? 'Ücretsiz' : formatMoney(order.shipping_fee)}</span>
                </div>
                <div class="flex justify-between text-lg font-bold border-t border-gray-200 dark:border-gray-700 pt-3 mt-3">
                  <span class="text-gray-900 dark:text-white">Genel Toplam:</span>
                  <span class="text-orange-600">{formatMoney(order.total_amount)}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Sağ: Müşteri & Durum Güncelleme -->
      <div class="space-y-8">
        
        <!-- Durum Güncelleme -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="font-bold text-gray-900 dark:text-white mb-4">Sipariş Durumu</h2>
          <form method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Durum</label>
              <select name="status" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">
                <option value="bekliyor" selected={order.status === 'bekliyor'}>Bekliyor</option>
                <option value="onaylandi" selected={order.status === 'onaylandi'}>Onaylandı</option>
                <option value="kargolandi" selected={order.status === 'kargolandi'}>Kargolandı</option>
                <option value="tamamlandi" selected={order.status === 'tamamlandi'}>Tamamlandı</option>
                <option value="iptal" selected={order.status === 'iptal'}>İptal Edildi</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Yönetici Notu (Opsiyonel)</label>
              <textarea name="notes" rows="2" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">{order.notes || ''}</textarea>
            </div>
            <button type="submit" class="w-full bg-gray-900 hover:bg-gray-800 dark:bg-orange-600 dark:hover:bg-orange-700 text-white font-bold py-2.5 px-4 rounded-xl transition">
              Durumu Güncelle
            </button>
          </form>
        </div>

        <!-- Müşteri Bilgileri -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="font-bold text-gray-900 dark:text-white mb-4">Müşteri Bilgileri</h2>
          <div class="space-y-4">
            <div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Müşteri Adı</div>
              <div class="font-medium text-gray-900 dark:text-white">{order.customer_name}</div>
            </div>
            <div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">İletişim</div>
              <div class="text-sm text-gray-900 dark:text-white">
                <a href={`mailto:${order.customer_email}`} class="hover:text-orange-500"><i class="fas fa-envelope w-5"></i> {order.customer_email}</a><br>
                <a href={`tel:${order.customer_phone}`} class="hover:text-orange-500 mt-1 inline-block"><i class="fas fa-phone w-5"></i> {order.customer_phone}</a>
              </div>
            </div>
            <div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Ödeme Yöntemi</div>
              <div class="font-medium text-gray-900 dark:text-white capitalize bg-gray-100 dark:bg-gray-700 inline-block px-3 py-1 rounded-lg">
                {order.payment_method.replace('_', ' ')}
              </div>
            </div>
          </div>
        </div>

        <!-- Adresler -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="font-bold text-gray-900 dark:text-white mb-4">Adres Bilgileri</h2>
          <div class="space-y-4">
            <div>
              <div class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Teslimat Adresi</div>
              <p class="text-sm text-gray-900 dark:text-white whitespace-pre-line bg-gray-50 dark:bg-gray-900 p-3 rounded-lg border border-gray-100 dark:border-gray-700">{order.shipping_address}</p>
            </div>
            {order.billing_address && order.billing_address !== order.shipping_address && (
              <div>
                <div class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Fatura Adresi</div>
                <p class="text-sm text-gray-900 dark:text-white whitespace-pre-line bg-gray-50 dark:bg-gray-900 p-3 rounded-lg border border-gray-100 dark:border-gray-700">{order.billing_address}</p>
              </div>
            )}
          </div>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>
