---
// src/pages/admin/ecommerce/orders/index.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getOrders, updateOrderStatus, deleteOrder } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

// Handle Delete or Status update via POST
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;
  const orderId = parseInt(formData.get('order_id') as string);

  if (action === 'delete' && orderId) {
    await deleteOrder(orderId, dbBinding);
  } else if (action === 'update_status' && orderId) {
    const status = formData.get('status') as string;
    if (status) {
      await updateOrderStatus(orderId, status, undefined, dbBinding);
    }
  }
}

const orders = await getOrders(dbBinding);

// Helper for status styling
const getStatusBadge = (status: string) => {
  switch (status) {
    case 'bekliyor': return '<span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2.5 py-0.5 rounded border border-yellow-200">Bekliyor</span>';
    case 'onaylandi': return '<span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded border border-blue-200">Onaylandı</span>';
    case 'kargolandi': return '<span class="bg-indigo-100 text-indigo-800 text-xs font-medium px-2.5 py-0.5 rounded border border-indigo-200">Kargolandı</span>';
    case 'tamamlandi': return '<span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded border border-green-200">Tamamlandı</span>';
    case 'iptal': return '<span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded border border-red-200">İptal Edildi</span>';
    default: return `<span class="bg-gray-100 text-gray-800 text-xs font-medium px-2.5 py-0.5 rounded border border-gray-200">${status}</span>`;
  }
};

const getPaymentMethod = (method: string) => {
  switch (method) {
    case 'havale': return 'Havale/EFT';
    case 'kapida': return 'Kapıda Ödeme';
    case 'kredi_karti': return 'Kredi Kartı';
    case 'banka_kredisi': return 'Banka Kredisi';
    default: return method;
  }
};
---

<BaseLayout title="Siparişler | Laflaf Admin">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Sipariş Yönetimi</h1>
    <a href="/admin/ecommerce/settings/payment" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg flex items-center gap-2">
      <i class="fas fa-credit-card"></i> Ödeme Yöntemlerini Yönet
    </a>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
        <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-300">
          <tr>
            <th scope="col" class="px-6 py-3">Sipariş No</th>
            <th scope="col" class="px-6 py-3">Müşteri</th>
            <th scope="col" class="px-6 py-3">Tarih</th>
            <th scope="col" class="px-6 py-3">Tutar</th>
            <th scope="col" class="px-6 py-3">Ödeme</th>
            <th scope="col" class="px-6 py-3">Durum</th>
            <th scope="col" class="px-6 py-3 text-right">İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {orders.length === 0 ? (
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                Henüz sipariş bulunmuyor.
              </td>
            </tr>
          ) : (
            orders.map(order => (
              <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                  #LAF{order.id}
                </td>
                <td class="px-6 py-4">
                  <div class="font-medium text-gray-900 dark:text-white">{order.customer_name}</div>
                  <div class="text-xs text-gray-500">{order.customer_email}</div>
                  {order.user_id ? (
                    <span class="inline-block mt-1 px-1.5 py-0.5 bg-blue-100 text-blue-800 text-[10px] rounded">Kayıtlı</span>
                  ) : (
                    <span class="inline-block mt-1 px-1.5 py-0.5 bg-gray-100 text-gray-800 text-[10px] rounded">Ziyaretçi</span>
                  )}
                </td>
                <td class="px-6 py-4">
                  {new Date(order.createdAt).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
                </td>
                <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                  {order.total_amount.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 })} ₺
                </td>
                <td class="px-6 py-4">
                  {getPaymentMethod(order.payment_method)}
                </td>
                <td class="px-6 py-4" set:html={getStatusBadge(order.status)}>
                </td>
                <td class="px-6 py-4 text-right">
                  <a href={`/admin/ecommerce/orders/${order.id}`} class="text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 font-medium mr-3">İncele</a>
                  <form method="POST" class="inline" onsubmit="return confirm('Bu siparişi silmek istediğinize emin misiniz?');">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="order_id" value={order.id} />
                    <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 font-medium">Sil</button>
                  </form>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
