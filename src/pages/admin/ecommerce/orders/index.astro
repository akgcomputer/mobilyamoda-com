---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getOrders } from '../../../../lib/db';

// Yalnızca admin erişebilir
if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
  return Astro.redirect('/login');
}

const db = Astro.locals.runtime?.env?.DB;
const orders = await getOrders(db);

const formatMoney = (amount: number) => {
  return new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount);
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('tr-TR') + ' ' + d.toLocaleTimeString('tr-TR', {hour: '2-digit', minute:'2-digit'});
};

const getStatusBadge = (status: string) => {
  switch(status) {
    case 'bekliyor': return '<span class="bg-yellow-100 text-yellow-800 dark:bg-yellow-900/50 dark:text-yellow-300 text-xs font-medium px-2.5 py-0.5 rounded">Bekliyor</span>';
    case 'onaylandi': return '<span class="bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300 text-xs font-medium px-2.5 py-0.5 rounded">Onaylandı</span>';
    case 'kargolandi': return '<span class="bg-purple-100 text-purple-800 dark:bg-purple-900/50 dark:text-purple-300 text-xs font-medium px-2.5 py-0.5 rounded">Kargolandı</span>';
    case 'tamamlandi': return '<span class="bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300 text-xs font-medium px-2.5 py-0.5 rounded">Tamamlandı</span>';
    case 'iptal': return '<span class="bg-red-100 text-red-800 dark:bg-red-900/50 dark:text-red-300 text-xs font-medium px-2.5 py-0.5 rounded">İptal Edildi</span>';
    default: return `<span class="bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300 text-xs font-medium px-2.5 py-0.5 rounded">${status}</span>`;
  }
};
---

<BaseLayout title="Siparişler | Admin Paneli">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Siparişler</h1>
        <p class="text-sm text-gray-500 mt-1">E-ticaret sitenizden gelen tüm siparişleri yönetin.</p>
      </div>
    </div>

    <!-- Filtreler / İstatistik (Opsiyonel) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-500">Toplam Sipariş</h3>
        <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">{orders.length}</p>
      </div>
      <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-500">Bekleyen</h3>
        <p class="text-2xl font-bold text-yellow-600 mt-1">{orders.filter(o => o.status === 'bekliyor').length}</p>
      </div>
      <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-500">Tamamlanan</h3>
        <p class="text-2xl font-bold text-green-600 mt-1">{orders.filter(o => o.status === 'tamamlandi').length}</p>
      </div>
      <div class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <h3 class="text-sm font-medium text-gray-500">Toplam Ciro (Başarılı)</h3>
        <p class="text-2xl font-bold text-blue-600 mt-1">{formatMoney(orders.filter(o => o.status === 'tamamlandi').reduce((sum, o) => sum + o.total_amount, 0))}</p>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700/50 dark:text-gray-300">
            <tr>
              <th scope="col" class="px-6 py-4">Sipariş No</th>
              <th scope="col" class="px-6 py-4">Müşteri</th>
              <th scope="col" class="px-6 py-4">Tarih</th>
              <th scope="col" class="px-6 py-4">Tutar</th>
              <th scope="col" class="px-6 py-4">Ödeme</th>
              <th scope="col" class="px-6 py-4">Durum</th>
              <th scope="col" class="px-6 py-4 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody>
            {orders.length === 0 ? (
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                  <div class="flex flex-col items-center">
                    <i class="fas fa-box-open text-4xl mb-3 text-gray-300"></i>
                    <p>Henüz hiç sipariş alınmamış.</p>
                  </div>
                </td>
              </tr>
            ) : (
              orders.map(order => (
                <tr class="bg-white dark:bg-gray-800 border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
                  <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                    #{order.id}
                  </td>
                  <td class="px-6 py-4">
                    <div class="font-medium text-gray-900 dark:text-white">{order.customer_name}</div>
                    <div class="text-xs text-gray-500">{order.customer_email}</div>
                  </td>
                  <td class="px-6 py-4">
                    {formatDate(order.createdAt)}
                  </td>
                  <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">
                    {formatMoney(order.total_amount)}
                  </td>
                  <td class="px-6 py-4 capitalize">
                    {order.payment_method.replace('_', ' ')}
                  </td>
                  <td class="px-6 py-4" set:html={getStatusBadge(order.status)}></td>
                  <td class="px-6 py-4 text-right">
                    <a href={`/admin/ecommerce/orders/${order.id}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg transition text-xs font-medium">
                      <i class="fas fa-eye"></i> İncele
                    </a>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>
