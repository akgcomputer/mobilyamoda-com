---
// src/pages/admin/ecommerce/coupons/index.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCoupons, createCoupon, deleteCoupon } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let basari = '';
let hata = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;

    if (action === 'create') {
      const code = formData.get('code') as string;
      const discount_type = formData.get('discount_type') as string;
      const discount_value = parseFloat(formData.get('discount_value') as string);
      const min_cart_amount = parseFloat(formData.get('min_cart_amount') as string) || 0;
      
      if (!code || isNaN(discount_value)) {
        throw new Error("Lütfen zorunlu alanları doldurun.");
      }
      
      await createCoupon({ code, discount_type, discount_value, min_cart_amount }, dbBinding);
      basari = 'Kupon başarıyla oluşturuldu.';
    } else if (action === 'delete') {
      const id = parseInt(formData.get('id') as string);
      await deleteCoupon(id, dbBinding);
      basari = 'Kupon silindi.';
    }
  } catch (err: any) {
    hata = err.message || 'Bir hata oluştu.';
  }
}

const coupons = await getCoupons(dbBinding);
---

<BaseLayout title="İndirim Kuponları | Laflaf Admin">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">İndirim Kuponları</h1>
  </div>

  {basari && (
    <div class="p-4 mb-6 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200">
      {basari}
    </div>
  )}
  {hata && (
    <div class="p-4 mb-6 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200">
      {hata}
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Sol Kolon: Yeni Kupon Ekle -->
    <div class="lg:col-span-1">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Yeni Kupon Oluştur</h2>
        
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="create" />
          
          <div>
            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Kupon Kodu *</label>
            <input type="text" name="code" required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Örn: LAFLAF10" />
            <p class="text-xs text-gray-500 mt-1">Müşterilerin sepette gireceği kod.</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">İndirim Türü</label>
            <select name="discount_type" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
              <option value="percentage">Yüzde (%) İndirimi</option>
              <option value="fixed">Sabit Tutar (₺) İndirimi</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">İndirim Değeri *</label>
            <input type="number" step="0.01" name="discount_value" required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Örn: 10" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Minimum Sepet Tutarı (₺)</label>
            <input type="number" step="0.01" name="min_cart_amount" value="0" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
            <p class="text-xs text-gray-500 mt-1">Sıfır bırakılırsa limitsiz geçerli olur.</p>
          </div>

          <button type="submit" class="w-full text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none">
            Kuponu Kaydet
          </button>
        </form>
      </div>
    </div>

    <!-- Sağ Kolon: Kupon Listesi -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-300">
            <tr>
              <th scope="col" class="px-6 py-3">Kupon Kodu</th>
              <th scope="col" class="px-6 py-3">Tür & Değer</th>
              <th scope="col" class="px-6 py-3">Min. Tutar</th>
              <th scope="col" class="px-6 py-3 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody>
            {coupons.length === 0 ? (
              <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">Henüz kupon oluşturulmamış.</td></tr>
            ) : (
              coupons.map(coupon => (
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                  <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                    <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded font-mono border border-gray-200">{coupon.code}</span>
                  </td>
                  <td class="px-6 py-4 font-medium">
                    {coupon.discount_type === 'percentage' ? `%${coupon.discount_value} İndirim` : `${coupon.discount_value} ₺ İndirim`}
                  </td>
                  <td class="px-6 py-4">
                    {coupon.min_cart_amount > 0 ? `${coupon.min_cart_amount} ₺` : 'Limitsiz'}
                  </td>
                  <td class="px-6 py-4 text-right">
                    <form method="POST" class="inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="id" value={coupon.id} />
                      <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 font-medium">Sil</button>
                    </form>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>
