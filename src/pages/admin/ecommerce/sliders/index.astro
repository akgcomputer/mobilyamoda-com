---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getSliders, createSlider, deleteSlider } from '../../../../lib/db';
import { uploadFile } from '../../../../lib/storage';

const dbBinding = Astro.locals.runtime?.env?.DB;
const mediaBinding = Astro.locals.runtime?.env?.MEDIA_BUCKET;

let mesaj = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create') {
    try {
      const file = formData.get('image_file');
      let finalImageUrl = formData.get('image_url') as string;

      if (file && file instanceof File && file.size > 0) {
        const uploadedUrl = await uploadFile(file, mediaBinding, 'sliders');
        if (uploadedUrl) {
          finalImageUrl = uploadedUrl;
        }
      }

      if (!finalImageUrl) {
        throw new Error('Lütfen bir görsel seçin veya URL girin.');
      }

      const newSlider = {
        image_url: finalImageUrl,
        title: formData.get('title') as string,
        subtitle: formData.get('subtitle') as string,
        button_text: formData.get('button_text') as string,
        link_url: formData.get('link_url') as string,
        status: formData.get('status') as string || 'aktif',
        sort_order: parseInt(formData.get('sort_order') as string) || 0
      };

      await createSlider(newSlider, dbBinding);
      mesaj = 'Yeni manşet başarıyla eklendi!';
    } catch (e: any) {
      errorMessage = 'Hata: ' + e.message;
    }
  } else if (action === 'delete') {
    const deleteId = parseInt(formData.get('delete_id') as string);
    if (deleteId) {
      await deleteSlider(deleteId, dbBinding);
      mesaj = 'Manşet başarıyla silindi.';
    }
  }
}

const sliders = await getSliders(dbBinding);
---

<BaseLayout title="Slider (Manşet) Yönetimi" isAdmin={true}>
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Slider (Manşet) Yönetimi</h1>
      <p class="text-sm text-gray-500">Ana sayfadaki büyük kayan görselleri buradan yönetin.</p>
    </div>
  </div>

  {mesaj && <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{mesaj}</div>}
  {errorMessage && <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{errorMessage}</div>}

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- Yeni Ekleme Formu -->
    <div class="lg:col-span-1 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-lg font-bold mb-4 border-b pb-2 dark:text-white">Yeni Manşet Ekle</h2>
      <form method="POST" enctype="multipart/form-data" class="space-y-4" data-astro-reload>
        <input type="hidden" name="action" value="create" />
        
        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Arkaplan Görseli *</label>
          <input type="file" name="image_file" accept="image/*" class="w-full text-sm mb-2 dark:text-gray-300" />
          <div class="text-xs text-gray-500 mb-1">Veya Görsel URL'si:</div>
          <input type="text" name="image_url" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="https://..." />
          <p class="text-xs text-gray-500 mt-1">Önerilen: 1920x800px veya 16:9 yatay yüksek çözünürlüklü görsel.</p>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Başlık (Opsiyonel)</label>
          <input type="text" name="title" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Kış İndirimleri Başladı" />
        </div>

        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Alt Başlık (Opsiyonel)</label>
          <input type="text" name="subtitle" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="%50'ye varan fırsatları kaçırmayın" />
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1 dark:text-gray-300">Buton Yazısı</label>
            <input type="text" name="button_text" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Alışverişe Başla" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1 dark:text-gray-300">Buton Linki</label>
            <input type="text" name="link_url" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="/urunler" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1 dark:text-gray-300">Sıra (0 = En Başta)</label>
            <input type="number" name="sort_order" value="0" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1 dark:text-gray-300">Durum</label>
            <select name="status" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
              <option value="aktif">Aktif</option>
              <option value="pasif">Pasif</option>
            </select>
          </div>
        </div>

        <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded-lg transition mt-4">
          Ekle
        </button>
      </form>
    </div>

    <!-- Mevcut Manşetler -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        {sliders.length === 0 ? (
          <div class="p-8 text-center text-gray-500">
            <i class="fas fa-images text-4xl mb-3"></i>
            <p>Henüz hiç manşet eklenmemiş. Soldaki formu kullanarak ilk manşetinizi ekleyin.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-900">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Görsel</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Metinler</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Durum & Sıra</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">İşlemler</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                {sliders.map(slider => (
                  <tr class="hover:bg-gray-50 dark:hover:bg-gray-750 transition">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="w-32 h-16 rounded overflow-hidden border border-gray-200 dark:border-gray-700">
                        <img src={slider.image_url} alt="Slider" class="w-full h-full object-cover" />
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <div class="text-sm font-bold text-gray-900 dark:text-white truncate max-w-[200px]">{slider.title || '-'}</div>
                      <div class="text-xs text-gray-500 truncate max-w-[200px]">{slider.subtitle || '-'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${slider.status === 'aktif' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                        {slider.status === 'aktif' ? 'Aktif' : 'Pasif'}
                      </span>
                      <div class="text-xs text-gray-500 mt-1">Sıra: {slider.sort_order}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <div class="flex items-center justify-end gap-2">
                        <a href={`/admin/ecommerce/sliders/${slider.id}`} class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded transition" title="Düzenle">
                          <i class="fas fa-edit"></i>
                        </a>
                        <form method="POST" class="inline" onsubmit="return confirm('Bu manşeti silmek istediğinize emin misiniz?');" data-astro-reload>
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="delete_id" value={slider.id} />
                          <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded transition" title="Sil">
                            <i class="fas fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>

  </div>
</BaseLayout>
