---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getSliderById, updateSlider } from '../../../../lib/db';
import { uploadFile } from '../../../../lib/storage';

const { id } = Astro.params;
const sliderId = parseInt(id as string);
if (isNaN(sliderId)) {
  return Astro.redirect('/admin/ecommerce/sliders');
}

const dbBinding = Astro.locals.runtime?.env?.DB;
const mediaBinding = Astro.locals.runtime?.env?.MEDIA_BUCKET;

let slider = await getSliderById(sliderId, dbBinding);
if (!slider) {
  return Astro.redirect('/admin/ecommerce/sliders');
}

let mesaj = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    let finalImageUrl = formData.get('image_url') as string || slider.image_url;
    const file = formData.get('image_file');

    if (file && file instanceof File && file.size > 0) {
      const uploadedUrl = await uploadFile(file, mediaBinding, 'sliders');
      if (uploadedUrl) {
        finalImageUrl = uploadedUrl;
      }
    }

    const updatedData = {
      image_url: finalImageUrl,
      title: formData.get('title') as string,
      subtitle: formData.get('subtitle') as string,
      button_text: formData.get('button_text') as string,
      link_url: formData.get('link_url') as string,
      status: formData.get('status') as string,
      sort_order: parseInt(formData.get('sort_order') as string) || 0
    };

    const updated = await updateSlider(sliderId, updatedData, dbBinding);
    if (updated) {
      slider = updated;
      mesaj = 'Manşet başarıyla güncellendi!';
    }
  } catch (e: any) {
    errorMessage = 'Hata: ' + e.message;
  }
}
---

<BaseLayout title="Manşet Düzenle" isAdmin={true}>
  <div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/admin/ecommerce/sliders" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
        <i class="fas fa-arrow-left text-xl"></i>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Manşet Düzenle</h1>
        <p class="text-sm text-gray-500">#{slider.id} numaralı manşeti güncelliyorsunuz.</p>
      </div>
    </div>
  </div>

  {mesaj && <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{mesaj}</div>}
  {errorMessage && <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{errorMessage}</div>}

  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 max-w-2xl">
    
    <div class="mb-6 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-900 aspect-[21/9] relative">
      <img src={slider.image_url} alt="Slider Preview" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40 flex flex-col justify-center items-center text-center p-6 text-white">
        {slider.title && <h2 class="text-3xl font-bold mb-2">{slider.title}</h2>}
        {slider.subtitle && <p class="text-lg mb-4">{slider.subtitle}</p>}
        {slider.button_text && <span class="bg-orange-600 px-6 py-2 rounded-full font-bold">{slider.button_text}</span>}
      </div>
    </div>

    <form method="POST" enctype="multipart/form-data" class="space-y-6" data-astro-reload>
      
      <div>
        <label class="block text-sm font-medium mb-1 dark:text-gray-300">Yeni Arkaplan Görseli Yükle (Değiştirmek isterseniz)</label>
        <input type="file" name="image_file" accept="image/*" class="w-full text-sm mb-2 dark:text-gray-300" />
        <div class="text-xs text-gray-500 mb-1">Veya Mevcut URL:</div>
        <input type="text" name="image_url" value={slider.image_url} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1 dark:text-gray-300">Başlık (Opsiyonel)</label>
        <input type="text" name="title" value={slider.title || ''} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1 dark:text-gray-300">Alt Başlık (Opsiyonel)</label>
        <input type="text" name="subtitle" value={slider.subtitle || ''} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Buton Yazısı</label>
          <input type="text" name="button_text" value={slider.button_text || ''} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Buton Linki</label>
          <input type="text" name="link_url" value={slider.link_url || ''} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Sıra (0 = En Başta)</label>
          <input type="number" name="sort_order" value={slider.sort_order} class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1 dark:text-gray-300">Durum</label>
          <select name="status" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white">
            <option value="aktif" selected={slider.status === 'aktif'}>Aktif</option>
            <option value="pasif" selected={slider.status === 'pasif'}>Pasif</option>
          </select>
        </div>
      </div>

      <div class="pt-4 border-t border-gray-200 dark:border-gray-700 flex gap-3">
        <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition">
          Değişiklikleri Kaydet
        </button>
        <a href="/admin/ecommerce/sliders" class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-white font-bold py-2 px-6 rounded-lg transition text-center">
          İptal
        </a>
      </div>
    </form>

  </div>
</BaseLayout>
