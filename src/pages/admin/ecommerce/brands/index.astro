---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getBrands, createBrand, updateBrand, deleteBrand } from '../../../../lib/db';
import MediaPicker from '../../../../components/admin/MediaPicker.astro';

const dbBinding = Astro.locals.runtime?.env?.DB;

let mesaj = '';

function slugify(text: string): string {
  const trMap: Record<string, string> = {
    'ç': 'c', 'Ç': 'C', 'ğ': 'g', 'Ğ': 'G', 'ı': 'i', 'İ': 'I',
    'ö': 'o', 'Ö': 'O', 'ş': 's', 'Ş': 'S', 'ü': 'u', 'Ü': 'U'
  };
  return text
    .replace(/[çÇğĞıİöÖşŞüÜ]/g, match => trMap[match])
    .toLowerCase()
    .replace(/[^a-z0-9 -]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .trim();
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const islem = formData.get('islem') as string;
    
    if (islem === 'ekle') {
      const name = formData.get('ad') as string;
      const logo_url = formData.get('logo_url') as string;
      const is_popular = formData.get('is_popular') === 'on';
      if (name) {
        const slug = slugify(name);
        await createBrand({ name, slug, logo_url, is_popular }, dbBinding);
        mesaj = 'Marka başarıyla eklendi.';
      }
    } else if (islem === 'sil') {
      const id = parseInt(formData.get('id') as string);
      await deleteBrand(id, dbBinding);
      mesaj = 'Marka silindi.';
    } else if (islem === 'guncelle') {
      const id = parseInt(formData.get('id') as string);
      const name = formData.get('ad') as string;
      const logo_url = formData.get('logo_url') as string;
      const is_popular = formData.get('is_popular') === 'on';
      if (name) {
        const slug = slugify(name);
        await updateBrand(id, { name, slug, logo_url, is_popular }, dbBinding);
        mesaj = 'Marka başarıyla güncellendi.';
      }
    }
  } catch (err) {
    console.error('Brand action error:', err);
    mesaj = 'Bir hata oluştu.';
  }
}

const markalar = await getBrands(dbBinding);
---

<BaseLayout title="Markalar - Admin" isAdmin={true}>
  <div class="p-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Markalar</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">E-ticaret sistemindeki markaları yönetin</p>
    </div>

    {mesaj && (
      <div class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-4 rounded-xl border border-green-200 dark:border-green-800 mb-6 flex justify-between items-center">
        <span>✅ {mesaj}</span>
        <button onclick="this.parentElement.remove()" class="text-green-700 dark:text-green-300">✕</button>
      </div>
    )}

    <!-- Marka Ekleme Formu -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Yeni Marka Ekle</h2>
      <form method="POST" class="flex flex-col md:flex-row gap-3 items-start md:items-center">
        <input type="hidden" name="islem" value="ekle" />
        <input 
          type="text" 
          name="ad" 
          placeholder="Marka adı" 
          required 
          class="flex-1 min-w-[200px] w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500"
        />
        <div class="flex gap-2 w-full md:w-auto">
          <input type="text" id="add_logo_url" name="logo_url" placeholder="Logo URL" class="px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" />
          <MediaPicker inputId="add_logo_url" />
        </div>
        <label class="flex items-center gap-2 cursor-pointer whitespace-nowrap">
          <input type="checkbox" name="is_popular" class="w-5 h-5 rounded border-gray-300 text-orange-600 focus:ring-orange-500" />
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Popüler Marka</span>
        </label>
        <button type="submit" class="w-full md:w-auto bg-orange-600 hover:bg-orange-700 text-white px-6 py-2.5 rounded-lg transition font-medium shadow-md">Kaydet</button>
      </form>
    </div>

    <!-- Marka Listesi -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow border border-gray-200 dark:border-gray-700 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
          <tr>
            <th class="w-16 px-4 py-3 text-left">Logo</th>
            <th class="px-6 py-4 text-left">Marka Adı</th>
            <th class="px-6 py-4 text-left">URL (Slug)</th>
            <th class="px-6 py-4 text-left">Popüler</th>
            <th class="px-6 py-4 text-center">İşlem</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700 text-gray-700 dark:text-gray-200">
          {markalar.map(marka => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
              <td class="px-4 py-4 text-sm font-semibold text-gray-500 dark:text-gray-400">
                {marka.logo_url ? <img src={marka.logo_url} class="w-12 h-12 object-contain bg-white rounded p-1" /> : <div class="w-12 h-12 rounded bg-gray-200 dark:bg-gray-600 flex items-center justify-center"><i class="fas fa-copyright text-gray-400"></i></div>}
              </td>
              <td class="px-6 py-3.5 font-semibold text-gray-900 dark:text-white">
                {marka.name}
              </td>
              <td class="px-6 py-3.5 text-gray-500 text-sm">/{marka.slug}</td>
              <td class="px-6 py-3.5">
                {marka.is_popular === 1 ? <span class="bg-orange-100 text-orange-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-orange-900 dark:text-orange-300">Evet</span> : <span class="text-gray-400 text-xs">-</span>}
              </td>
              <td class="px-6 py-3.5 text-center">
                <div class="flex items-center justify-center gap-3">
                  <button 
                    class="edit-brand-btn text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 p-2 rounded-lg transition" 
                    data-id={marka.id} 
                    data-ad={marka.name}
                    data-logo={marka.logo_url || ''}
                    data-popular={marka.is_popular}
                    title="Düzenle"
                  >
                    ✏️
                  </button>
                  <form method="POST" class="inline" onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                    <input type="hidden" name="islem" value="sil" />
                    <input type="hidden" name="id" value={marka.id} />
                    <button type="submit" class="text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 p-2 rounded-lg transition" title="Sil">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
          {markalar.length === 0 && (
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">Henüz hiç marka eklenmemiş.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Düzenleme Modalı -->
  <div id="editModal" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-50 backdrop-blur-sm">
    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 w-full max-w-md border border-gray-200 dark:border-gray-700 shadow-2xl">
      <h2 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Marka Düzenle</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="islem" value="guncelle" />
        <input type="hidden" name="id" id="editId" />
        <div>
          <label class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300">Marka Adı</label>
          <input type="text" name="ad" id="editAd" required class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5 text-gray-700 dark:text-gray-300">Logo URL</label>
          <div class="flex gap-2">
            <input type="text" name="logo_url" id="editLogo" class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" />
            <MediaPicker inputId="editLogo" />
          </div>
        </div>
        <div>
          <label class="flex items-center gap-2 cursor-pointer mt-2">
            <input type="checkbox" name="is_popular" id="editPopular" class="w-5 h-5 rounded border-gray-300 text-orange-600 focus:ring-orange-500" />
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Popüler Marka (Ana sayfada göster)</span>
          </label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="bg-orange-600 text-white px-4 py-2.5 rounded-lg hover:bg-orange-700 flex-1 font-semibold transition">Kaydet</button>
          <button type="button" id="closeModalBtn" class="bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-200 px-4 py-2.5 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600 flex-1 font-semibold transition">İptal</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.querySelectorAll('.edit-brand-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const ad = btn.getAttribute('data-ad');
        const logo = btn.getAttribute('data-logo');
        const pop = btn.getAttribute('data-popular') === '1';
        
        const inputId = document.getElementById('editId') as HTMLInputElement;
        const inputAd = document.getElementById('editAd') as HTMLInputElement;
        const inputLogo = document.getElementById('editLogo') as HTMLInputElement;
        const inputPop = document.getElementById('editPopular') as HTMLInputElement;
        const modal = document.getElementById('editModal');
        
        if (inputId && inputAd && modal) {
          inputId.value = id || '';
          inputAd.value = ad || '';
          if (inputLogo) inputLogo.value = logo || '';
          if (inputPop) inputPop.checked = pop;
          modal.classList.remove('hidden');
        }
      });
    });

    document.getElementById('closeModalBtn')?.addEventListener('click', () => {
      document.getElementById('editModal')?.classList.add('hidden');
    });

    document.getElementById('editModal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        document.getElementById('editModal')?.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
