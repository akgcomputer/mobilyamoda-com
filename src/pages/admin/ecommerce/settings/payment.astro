---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
  return Astro.redirect('/login');
}
---

<BaseLayout title="Ödeme Yöntemleri | Admin Paneli">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Ödeme Yöntemleri</h1>
      <p class="text-sm text-gray-500 mt-1">E-ticaret sitenizde müşterilerinize sunacağınız ödeme seçeneklerini yönetin.</p>
    </div>

    <div class="space-y-6">
      
      <!-- Havale / EFT -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-green-200 dark:border-green-900 p-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">Aktif</div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center shrink-0">
            <i class="fas fa-university text-2xl"></i>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Havale / EFT</h3>
            <p class="text-sm text-gray-500 mt-1 mb-4">Müşteriler siparişi tamamladıktan sonra banka hesaplarınıza ödeme gönderir.</p>
            
            <div class="bg-gray-50 dark:bg-gray-900 p-4 rounded-xl border border-gray-200 dark:border-gray-700">
              <label class="block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Banka Hesap Bilgileriniz (Ödeme Sayfasında Görünür)</label>
              <textarea rows="3" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white outline-none focus:border-orange-500">TR00 0000 0000 0000 0000 0000 00
Laflaf Teknoloji A.Ş.
Garanti Bankası - Merkez Şube</textarea>
              <div class="mt-3 text-right">
                <button type="button" class="bg-gray-900 dark:bg-gray-700 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-gray-800 transition">Kaydet</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Kapıda Ödeme -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-green-200 dark:border-green-900 p-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">Aktif</div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-green-100 dark:bg-green-900/30 text-green-600 flex items-center justify-center shrink-0">
            <i class="fas fa-truck text-2xl"></i>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Kapıda Ödeme</h3>
            <p class="text-sm text-gray-500 mt-1">Müşteriler ürün teslimatında kuryeye ödeme yapar.</p>
          </div>
        </div>
      </div>

      <!-- Sanal POS -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden opacity-75">
        <div class="absolute top-0 right-0 bg-gray-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">Kurulum Gerekiyor</div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gray-100 dark:bg-gray-700 text-gray-500 flex items-center justify-center shrink-0">
            <i class="fas fa-credit-card text-2xl"></i>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Kredi Kartı / Sanal POS</h3>
            <p class="text-sm text-gray-500 mt-1 mb-4">Müşterilerin 3D Secure ile güvenli kredi kartı ödemesi yapabilmesi için sanal POS entegrasyonu gereklidir (iyzico, PayTR vb.).</p>
            
            <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 p-4 rounded-xl font-medium flex items-center gap-3">
              <i class="fas fa-info-circle text-xl"></i>
              <span>Bu ödeme yöntemini tam olarak aktif etmek ve entegrasyonu tamamlamak için <strong>yöneticiye başvurun</strong>.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Banka Kredisi -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden opacity-75">
        <div class="absolute top-0 right-0 bg-gray-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">Kurulum Gerekiyor</div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-gray-100 dark:bg-gray-700 text-gray-500 flex items-center justify-center shrink-0">
            <i class="fas fa-hand-holding-usd text-2xl"></i>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Banka Kredisi ile Ödeme</h3>
            <p class="text-sm text-gray-500 mt-1 mb-4">Anlaşmalı bankalar aracılığıyla alışveriş kredisi kullandırma seçeneği.</p>
            
            <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 p-4 rounded-xl font-medium flex items-center gap-3">
              <i class="fas fa-info-circle text-xl"></i>
              <span>Bu ödeme yöntemini aktif etmek ve banka API'lerini bağlamak için <strong>yöneticiye başvurun</strong>.</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
