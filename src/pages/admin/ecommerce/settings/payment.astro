---
// src/pages/admin/ecommerce/settings/payment.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getSettings, updateSetting } from '../../../../lib/db';

const sessionData = Astro.cookies.has('user_session') ? Astro.cookies.get('user_session')?.json() : null;

if (!sessionData || sessionData.role !== 'admin') {
  return Astro.redirect('/profil');
}

const dbBinding = Astro.locals.runtime?.env?.DB;

let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Read states
    const havaleActive = formData.get('havale_active') === 'on' ? '1' : '0';
    const havaleIbanName = formData.get('havale_iban_name') as string || '';
    const havaleIbanNo = formData.get('havale_iban_no') as string || '';
    
    const kapidaNakitActive = formData.get('kapida_nakit_active') === 'on' ? '1' : '0';
    const kapidaPosActive = formData.get('kapida_pos_active') === 'on' ? '1' : '0';
    
    const krediKartiActive = formData.get('kredi_karti_active') === 'on' ? '1' : '0';
    const krediKrediActive = formData.get('kredi_kredi_active') === 'on' ? '1' : '0';
    
    // Save to settings
    await updateSetting('payment_havale_active', havaleActive, dbBinding);
    await updateSetting('payment_havale_iban_name', havaleIbanName, dbBinding);
    await updateSetting('payment_havale_iban_no', havaleIbanNo, dbBinding);
    
    await updateSetting('payment_kapida_nakit_active', kapidaNakitActive, dbBinding);
    await updateSetting('payment_kapida_pos_active', kapidaPosActive, dbBinding);
    
    await updateSetting('payment_kredi_karti_active', krediKartiActive, dbBinding);
    await updateSetting('payment_kredi_kredi_active', krediKrediActive, dbBinding);
    
    successMsg = 'Ödeme yöntemleri ayarları başarıyla güncellendi.';
  } catch (err: any) {
    errorMsg = err.message || 'Ayarlar kaydedilirken bir hata oluştu.';
  }
}

// Load settings
const settings = await getSettings(dbBinding);
const havaleActive = settings.payment_havale_active === '1';
const havaleIbanName = settings.payment_havale_iban_name || '';
const havaleIbanNo = settings.payment_havale_iban_no || '';

const kapidaNakitActive = settings.payment_kapida_nakit_active === '1';
const kapidaPosActive = settings.payment_kapida_pos_active === '1';

const krediKartiActive = settings.payment_kredi_karti_active === '1';
const krediKrediActive = settings.payment_kredi_kredi_active === '1';
---

<BaseLayout title="Ödeme Yöntemleri | Admin Paneli" isAdmin={true}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <div class="mb-8 flex justify-between items-center border-b border-gray-200 dark:border-gray-700 pb-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
            <i class="fas fa-credit-card text-teal-600 dark:text-teal-400"></i>
          </div>
          Ödeme Yöntemleri Yönetimi
        </h1>
        <p class="text-sm text-gray-500 mt-2 ml-14">Sitenizde müşterilerinize sunacağınız tüm ödeme seçeneklerini buradan aktif-pasif yapıp düzenleyebilirsiniz.</p>
      </div>
      <a href="/admin/ecommerce" class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 px-4 py-2 rounded-lg transition text-sm font-medium flex items-center">
        <i class="fas fa-arrow-left mr-2"></i> Geri Dön
      </a>
    </div>

    {successMsg && (
      <div class="mb-6 p-4 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 rounded-xl border border-green-200 dark:border-green-800 flex justify-between items-center">
        <span class="font-semibold">{successMsg}</span>
        <button onclick="this.parentElement.remove()" class="text-green-700 dark:text-green-300 hover:scale-110 font-bold">✕</button>
      </div>
    )}

    {errorMsg && (
      <div class="mb-6 p-4 bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 rounded-xl border border-red-200 dark:border-red-800 flex justify-between items-center">
        <span class="font-semibold">{errorMsg}</span>
        <button onclick="this.parentElement.remove()" class="text-red-700 dark:text-red-300 hover:scale-110 font-bold">✕</button>
      </div>
    )}

    <form method="POST" class="space-y-6">
      
      <!-- Havale / EFT -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden transition-all duration-300">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center shrink-0">
              <i class="fas fa-university text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">Banka Havalesi / EFT</h3>
              <p class="text-sm text-gray-500 mt-1">Müşteriler siparişi tamamladıktan sonra banka hesaplarınıza ödeme gönderir.</p>
            </div>
          </div>
          
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="havale_active" class="sr-only peer" checked={havaleActive} />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
          </label>
        </div>
        
        <!-- Banka Hesap Bilgileri Alanı -->
        <div class="mt-6 bg-gray-50 dark:bg-gray-900/40 p-5 rounded-xl border border-gray-200 dark:border-gray-700 space-y-4">
          <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Banka Hesap Detayları</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 mb-1">İban Sahibi (İsim Soyisim / Ünvan)</label>
              <input type="text" name="havale_iban_name" value={havaleIbanName} class="w-full px-3 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white outline-none focus:border-orange-500" placeholder="Örn: Laflaf Teknoloji A.Ş." />
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 mb-1">IBAN Numarası</label>
              <input type="text" name="havale_iban_no" value={havaleIbanNo} class="w-full px-3 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white outline-none focus:border-orange-500" placeholder="Örn: TR00 0000 0000 0000 0000 0000 00" />
            </div>
          </div>
        </div>
      </div>

      <!-- Kapıda Ödeme Seçenekleri -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden transition-all duration-300">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 rounded-xl bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 flex items-center justify-center shrink-0">
            <i class="fas fa-truck text-2xl"></i>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Kapıda Ödeme Ayarları</h3>
            <p class="text-sm text-gray-500 mt-1">Teslimat sırasında kurye aracılığıyla ödeme alınması seçenekleri.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-gray-100 dark:border-gray-700">
          
          <!-- Kapıda Ödeme Nakit ile -->
          <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700">
            <div class="flex items-center gap-3">
              <i class="fas fa-money-bill-wave text-green-500 text-xl"></i>
              <div>
                <span class="font-bold text-gray-800 dark:text-gray-200 block text-sm">Kapıda Ödeme Nakit ile</span>
                <span class="text-xs text-gray-400 font-medium">Nakit ödeme kabul edilir</span>
              </div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" name="kapida_nakit_active" class="sr-only peer" checked={kapidaNakitActive} />
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
            </label>
          </div>

          <!-- Kapıda Ödeme POS ile -->
          <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 dark:bg-gray-900/40 border border-gray-200 dark:border-gray-700">
            <div class="flex items-center gap-3">
              <i class="fas fa-credit-card text-purple-500 text-xl"></i>
              <div>
                <span class="font-bold text-gray-800 dark:text-gray-200 block text-sm">Kapıda Ödeme POS ile</span>
                <span class="text-xs text-gray-400 font-medium">Kuryede kartla ödeme kabul edilir</span>
              </div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" name="kapida_pos_active" class="sr-only peer" checked={kapidaPosActive} />
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
            </label>
          </div>
          
        </div>
      </div>

      <!-- Kredi Kartı ile Ödeme (Sanal POS) -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden transition-all duration-300">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 flex items-center justify-center shrink-0">
              <i class="fas fa-credit-card text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">Kredi Kartı ile Ödeme (Sanal POS)</h3>
              <p class="text-sm text-gray-500 mt-1">Müşteriler sipariş aşamasında kredi/banka kartı bilgilerini girerek anında ödeme yapar.</p>
            </div>
          </div>
          
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="kredi_karti_active" class="sr-only peer" checked={krediKartiActive} />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
          </label>
        </div>
        
        <div class="mt-4 p-4 bg-purple-50 dark:bg-purple-950/20 text-purple-700 dark:text-purple-400 rounded-xl font-medium flex items-center gap-3 text-sm border border-purple-200/50">
          <i class="fas fa-lock"></i>
          <span>Entegrasyon tamamlandığında siparişler anında tahsil edilip otomatik onaylanır.</span>
        </div>
      </div>

      <!-- Alışveriş Kredisi ile Ödeme -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 relative overflow-hidden transition-all duration-300">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-teal-100 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 flex items-center justify-center shrink-0">
              <i class="fas fa-hand-holding-usd text-2xl"></i>
            </div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white">Alışveriş Kredisi ile Ödeme</h3>
              <p class="text-sm text-gray-500 mt-1">Müşterilerin bankalar aracılığıyla 36 aya varan vadelerle kredi kullanarak alışveriş yapmasını sağlar.</p>
            </div>
          </div>
          
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="kredi_kredi_active" class="sr-only peer" checked={krediKrediActive} />
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-orange-500"></div>
          </label>
        </div>
      </div>

      <!-- Submit button -->
      <div class="text-right">
        <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-4 px-10 rounded-xl shadow-lg transition-transform hover:-translate-y-0.5 text-base flex items-center gap-2 ml-auto">
          <i class="fas fa-save"></i> Tüm Ayarları Kaydet
        </button>
      </div>

    </form>
  </div>
</BaseLayout>
