---
// src/pages/admin/ecommerce/campaigns/index.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getSettings, updateSetting, getCoupons, createCoupon, deleteCoupon } from '../../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let basari = '';
let hata = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;

    if (action === 'save_campaign') {
      const active = formData.get('campaign_active') === 'on';
      const name = formData.get('campaign_name') as string || '';
      const type = formData.get('campaign_type') as string;
      const value = parseFloat(formData.get('campaign_value') as string) || 0;
      const bogo_buy_qty = parseInt(formData.get('campaign_bogo_buy_qty') as string) || 3;
      const bogo_get_qty = parseInt(formData.get('campaign_bogo_get_qty') as string) || 1;

      const campaignSettings = {
        active,
        name,
        type,
        value,
        bogo_buy_qty,
        bogo_get_qty
      };

      await updateSetting('campaign_settings', JSON.stringify(campaignSettings), dbBinding);
      basari = 'Site geneli kampanya ayarları başarıyla kaydedildi.';
    } else if (action === 'create_coupon') {
      const code = (formData.get('code') as string || '').toUpperCase().trim();
      const discount_type = formData.get('discount_type') as string;
      const discount_value = parseFloat(formData.get('discount_value') as string);
      const min_cart_amount = parseFloat(formData.get('min_cart_amount') as string) || 0;
      const max_uses = formData.get('max_uses') as string || '';
      const valid_until = formData.get('valid_until') as string || '';

      if (!code || isNaN(discount_value)) {
        throw new Error("Lütfen zorunlu alanları (Kupon Kodu ve İndirim Değeri) doldurunuz.");
      }

      await createCoupon({ 
        code, 
        discount_type, 
        discount_value, 
        min_cart_amount,
        max_uses,
        valid_until
      }, dbBinding);
      basari = 'İndirim kuponu başarıyla tanımlandı.';
    } else if (action === 'delete_coupon') {
      const id = parseInt(formData.get('id') as string);
      await deleteCoupon(id, dbBinding);
      basari = 'İndirim kuponu silindi.';
    }
  } catch (err: any) {
    hata = err.message || 'Bir hata oluştu.';
  }
}

// Fetch current values
const settings = await getSettings(dbBinding);
let campaign = {
  active: false,
  name: '',
  type: 'percentage',
  value: 0,
  bogo_buy_qty: 3,
  bogo_get_qty: 1
};

if (settings.campaign_settings) {
  try {
    campaign = JSON.parse(settings.campaign_settings);
  } catch (e) {}
}

const coupons = await getCoupons(dbBinding);
---

<BaseLayout title="Kupon & Kampanya Yönetimi | Laflaf Admin" isAdmin={true}>
  <div class="p-6 max-w-6xl mx-auto">
    
    <!-- Header -->
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4 flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center">
            <i class="fas fa-ticket-alt text-rose-600 dark:text-rose-400"></i>
          </div>
          Kupon & Kampanya Yönetimi
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2 ml-15">Site geneli indirim kampanyalarını ve müşteri hediye kuponlarını buradan yönetin.</p>
      </div>
      <a href="/admin/ecommerce" class="text-sm font-semibold text-gray-600 dark:text-gray-400 hover:text-orange-600 flex items-center gap-1.5 transition">
        <i class="fas fa-arrow-left"></i> E-Ticaret Paneli
      </a>
    </div>

    <!-- Alert Messages -->
    {basari && (
      <div class="p-4 mb-6 text-sm text-green-800 rounded-xl bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200 flex items-center gap-2">
        <i class="fas fa-check-circle text-lg"></i>
        <span>{basari}</span>
      </div>
    )}
    {hata && (
      <div class="p-4 mb-6 text-sm text-red-800 rounded-xl bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200 flex items-center gap-2">
        <i class="fas fa-exclamation-circle text-lg"></i>
        <span>{hata}</span>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- 1. Site Geneli Kampanya Tanımlama -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
            <i class="fas fa-bullhorn text-orange-500"></i> Site Geneli Kampanya Tanımlama
          </h2>
          
          <form method="POST" id="campaignForm" class="space-y-5">
            <input type="hidden" name="action" value="save_campaign" />
            
            <!-- Aktiflik Durumu -->
            <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-900/50 rounded-xl border border-gray-200 dark:border-gray-700">
              <input type="checkbox" name="campaign_active" id="campaign_active" checked={campaign.active} class="w-5 h-5 text-orange-600 border-gray-300 rounded focus:ring-orange-500 dark:bg-gray-700 dark:border-gray-600" />
              <label for="campaign_active" class="text-sm font-bold text-gray-900 dark:text-white cursor-pointer select-none">Kampanyayı Sitede Aktifleştir</label>
            </div>

            <!-- Kampanya Adı -->
            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Kampanya Adı *</label>
              <input type="text" name="campaign_name" value={campaign.name} required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-orange-500" placeholder="Örn: 3 Al 2 Öde Fırsatı!" />
            </div>

            <!-- Kampanya Türü -->
            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Kampanya Türü</label>
              <select name="campaign_type" id="campaign_type" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-orange-500">
                <option value="percentage" selected={campaign.type === 'percentage'}>Site Geneli Yüzde (%) İndirim</option>
                <option value="fixed" selected={campaign.type === 'fixed'}>Site Geneli Parasal (₺) İndirim</option>
                <option value="bogo" selected={campaign.type === 'bogo'}>X Adet Alana Y Adet Bedava (En Ucuzu Bedava)</option>
              </select>
            </div>

            <!-- İndirim Tutarı (Percentage / Fixed için) -->
            <div id="discountValueGroup" class={campaign.type === 'bogo' ? 'hidden' : 'block'}>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">İndirim Değeri (Yüzde veya ₺ Miktarı) *</label>
              <input type="number" step="0.01" name="campaign_value" value={campaign.value} class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-orange-500" placeholder="Örn: 15" />
            </div>

            <!-- BOGO (Buy X Get Y Free) ayarları -->
            <div id="bogoSettingsGroup" class={`grid grid-cols-2 gap-4 ${campaign.type === 'bogo' ? 'block' : 'hidden'}`}>
              <div>
                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Satın Alınacak Miktar (X) *</label>
                <input type="number" name="campaign_bogo_buy_qty" value={campaign.bogo_buy_qty} class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-orange-500" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Hediye Adedi (Y) *</label>
                <input type="number" name="campaign_bogo_get_qty" value={campaign.bogo_get_qty} class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-orange-500" />
              </div>
              <p class="col-span-2 text-xs text-gray-500 italic"><i class="fas fa-info-circle"></i> Kampanyalı alışverişlerde sepetteki en ucuz / uygun fiyatlı ürün otomatik olarak bedava sayılacaktır.</p>
            </div>
            
            <button type="submit" class="w-full text-white bg-rose-600 hover:bg-rose-700 font-bold rounded-lg text-sm px-5 py-3 shadow-md transition hover:-translate-y-0.5 mt-4">
              Kampanya Ayarlarını Kaydet
            </button>
          </form>
        </div>
      </div>

      <!-- 2. Kupon Tanımlama -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
          <i class="fas fa-tags text-rose-500"></i> Kupon Tanımlama
        </h2>
        
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="create_coupon" />
          
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Kupon Adı / Kodu *</label>
              <input type="text" name="code" required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500 uppercase" placeholder="Örn: BAHAR20" />
              <p class="text-xs text-gray-500 mt-1">Müşterinin sepette indirim uygulamak için yazacağı kod.</p>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">İndirim Türü</label>
              <select name="discount_type" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500">
                <option value="percentage">Yüzde (%) İndirim</option>
                <option value="fixed">Sabit Tutar (₺) İndirim</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">İndirim Miktarı *</label>
              <input type="number" step="0.01" name="discount_value" required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500" placeholder="Örn: 20" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Min. Sepet Tutarı (₺)</label>
              <input type="number" step="0.01" name="min_cart_amount" value="0" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Kullanım Limiti (Kaç Defa)</label>
              <input type="number" name="max_uses" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500" placeholder="Sınırsız için boş bırakın" />
            </div>

            <div class="col-span-2">
              <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-1.5">Geçerlilik Son Tarihi</label>
              <input type="date" name="valid_until" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-rose-500" />
              <p class="text-xs text-gray-500 mt-1">Belirtilen tarihten sonra kupon geçersiz sayılır.</p>
            </div>
          </div>

          <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 font-bold rounded-lg text-sm px-5 py-3 shadow-md transition hover:-translate-y-0.5 mt-2">
            Kuponu Kaydet
          </button>
        </form>
      </div>

    </div>

    <!-- Tanımlı Kuponlar Listesi -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden mt-8">
      <div class="p-6 border-b border-gray-250 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <i class="fas fa-list text-gray-500"></i> Tanımlı İndirim Kuponları ({coupons.length})
        </h2>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-100 dark:bg-gray-700 dark:text-gray-300">
            <tr>
              <th scope="col" class="px-6 py-3.5">Kupon Kodu</th>
              <th scope="col" class="px-6 py-3.5">İndirim Değeri</th>
              <th scope="col" class="px-6 py-3.5">Min. Sepet Tutarı</th>
              <th scope="col" class="px-6 py-3.5">Kullanım / Limit</th>
              <th scope="col" class="px-6 py-3.5">Son Kullanma</th>
              <th scope="col" class="px-6 py-3.5 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody>
            {coupons.length === 0 ? (
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-gray-500 italic">Henüz indirim kuponu tanımlanmamış.</td>
              </tr>
            ) : (
              coupons.map(coupon => (
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td class="px-6 py-4 font-bold text-gray-900 dark:text-white font-mono">
                    <span class="bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-2.5 py-1 rounded border border-gray-250 dark:border-gray-600">{coupon.code}</span>
                  </td>
                  <td class="px-6 py-4 font-semibold text-gray-900 dark:text-white">
                    {coupon.discount_type === 'percentage' ? `%${coupon.discount_value}` : `${coupon.discount_value} ₺`}
                  </td>
                  <td class="px-6 py-4">
                    {coupon.min_cart_amount > 0 ? `${coupon.min_cart_amount} ₺` : 'Limitsiz'}
                  </td>
                  <td class="px-6 py-4">
                    <span class="font-medium text-gray-800 dark:text-gray-200">{coupon.used_count || 0}</span> / 
                    <span class="text-gray-500">{coupon.max_uses !== null && coupon.max_uses !== undefined ? coupon.max_uses : '∞'}</span>
                  </td>
                  <td class="px-6 py-4 text-xs font-semibold">
                    {coupon.valid_until ? (
                      <span class={new Date(coupon.valid_until) < new Date() ? 'text-red-500' : 'text-green-600'}>
                        {new Date(coupon.valid_until).toLocaleDateString('tr-TR')}
                      </span>
                    ) : (
                      <span class="text-gray-400">Süresiz</span>
                    )}
                  </td>
                  <td class="px-6 py-4 text-right">
                    <form method="POST" class="inline" onsubmit="return confirm('Bu kuponu silmek istediğinize emin misiniz?');">
                      <input type="hidden" name="action" value="delete_coupon" />
                      <input type="hidden" name="id" value={coupon.id} />
                      <button type="submit" class="text-red-600 hover:text-red-950 font-bold transition">Sil</button>
                    </form>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Dynamic Fields UI Javascript -->
  <script is:inline>
    function handleCampaignTypeChange() {
      const typeSelect = document.getElementById('campaign_type');
      const discountValueGroup = document.getElementById('discountValueGroup');
      const bogoSettingsGroup = document.getElementById('bogoSettingsGroup');
      
      if (!typeSelect || !discountValueGroup || !bogoSettingsGroup) return;

      if (typeSelect.value === 'bogo') {
        discountValueGroup.classList.add('hidden');
        discountValueGroup.classList.remove('block');
        bogoSettingsGroup.classList.remove('hidden');
        bogoSettingsGroup.classList.add('block');
      } else {
        discountValueGroup.classList.remove('hidden');
        discountValueGroup.classList.add('block');
        bogoSettingsGroup.classList.add('hidden');
        bogoSettingsGroup.classList.remove('block');
      }
    }

    document.addEventListener('astro:page-load', () => {
      const typeSelect = document.getElementById('campaign_type');
      if (typeSelect) {
        typeSelect.addEventListener('change', handleCampaignTypeChange);
      }
      handleCampaignTypeChange();
    });

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      handleCampaignTypeChange();
    } else {
      document.addEventListener('DOMContentLoaded', handleCampaignTypeChange);
    }
  </script>
</BaseLayout>
