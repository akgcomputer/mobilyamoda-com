---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPages, deletePage } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;

let successMsg = '';
let errorMsg = '';

// Handle Delete
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  
  if (action === 'delete') {
    const pageId = parseInt(formData.get('page_id') as string);
    if (pageId) {
      const success = await deletePage(pageId, dbBinding);
      if (success) {
        successMsg = 'Sayfa başarıyla silindi.';
      } else {
        errorMsg = 'Sayfa silinirken bir hata oluştu.';
      }
    }
  }
}

const pages = await getPages(dbBinding);
---

<BaseLayout title="Sabit Sayfalar - Admin" isAdmin={true}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Sabit Sayfalar</h1>
        <p class="text-sm text-gray-500">Özel tasarımlı kurumsal ve statik sayfalarınızı yönetin.</p>
      </div>
      <a href="/admin/pages/new" class="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-lg font-medium transition shadow-lg flex items-center gap-2">
        <i class="fas fa-plus"></i> Yeni Sayfa
      </a>
    </div>

    {successMsg && <div class="bg-green-100 text-green-700 p-4 rounded-lg">✅ {successMsg}</div>}
    {errorMsg && <div class="bg-red-100 text-red-700 p-4 rounded-lg">❌ {errorMsg}</div>}

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-700/50 border-b dark:border-gray-700">
            <th class="p-4 font-semibold text-sm text-gray-600 dark:text-gray-300">Başlık</th>
            <th class="p-4 font-semibold text-sm text-gray-600 dark:text-gray-300">URL / Slug</th>
            <th class="p-4 font-semibold text-sm text-gray-600 dark:text-gray-300">Tarih</th>
            <th class="p-4 font-semibold text-sm text-gray-600 dark:text-gray-300 text-right">İşlemler</th>
          </tr>
        </thead>
        <tbody>
          {pages.length === 0 ? (
            <tr>
              <td colspan="4" class="p-8 text-center text-gray-500">Henüz hiç sabit sayfa oluşturulmamış.</td>
            </tr>
          ) : (
            pages.map(page => (
              <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700/20 transition">
                <td class="p-4 font-medium text-gray-900 dark:text-white">
                  {page.title || 'Başlıksız Sayfa'}
                </td>
                <td class="p-4 text-sm text-gray-500">
                  <a href={`/${page.slug}`} target="_blank" class="hover:text-orange-500 hover:underline">/{page.slug}</a>
                </td>
                <td class="p-4 text-sm text-gray-500">
                  {new Date(page.createdAt).toLocaleDateString('tr-TR')}
                </td>
                <td class="p-4 text-right space-x-2">
                  <a href={`/${page.slug}`} target="_blank" class="text-blue-500 hover:text-blue-700 p-2" title="Görüntüle">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href={`/admin/pages/edit/${page.id}`} class="text-orange-500 hover:text-orange-700 p-2" title="Düzenle">
                    <i class="fas fa-edit"></i>
                  </a>
                  <form method="POST" class="inline" onsubmit="return confirm('Bu sayfayı silmek istediğinize emin misiniz?');">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="page_id" value={page.id} />
                    <button type="submit" class="text-red-500 hover:text-red-700 p-2" title="Sil">
                      <i class="fas fa-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
