---
// src/pages/admin/ads/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPosts, updatePost, getSettings, updateSetting } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let mesaj = '';
let hata = '';
let aktifSekme = Astro.url.searchParams.get('tab') || 'sponsorlu';

// Form işleme
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const islem = formData.get('islem') as string;
    const tip = formData.get('tip') as string;
    
    if (tip === 'sponsorlu') {
      const postId = parseInt(formData.get('postId') as string);
      if (islem === 'ekle') {
        if (!postId) throw new Error('Lütfen sponsor yapılacak bir içerik seçin.');
        await updatePost(postId, { isSponsored: true }, dbBinding);
        mesaj = 'İçerik başarıyla sponsorlu olarak işaretlendi.';
      } else if (islem === 'sil') {
        await updatePost(postId, { isSponsored: false }, dbBinding);
        mesaj = 'İçerik sponsorluktan çıkarıldı.';
      } else if (islem === 'toggle') {
        const posts = await getAllPosts(dbBinding);
        const post = posts.find(p => p.id === postId);
        if (post) {
          await updatePost(postId, { isSponsored: !post.isSponsored }, dbBinding);
          mesaj = 'Sponsorluk durumu güncellendi.';
        }
      }
    } else if (tip === 'reklam') {
      const keys = [
        'ad_left_top_image', 'ad_left_top_link', 'ad_left_top_status',
        'ad_left_bottom_image', 'ad_left_bottom_link', 'ad_left_bottom_status',
        'ad_right_top_image', 'ad_right_top_link', 'ad_right_top_status',
        'ad_right_bottom_image', 'ad_right_bottom_link', 'ad_right_bottom_status'
      ];
      for (const key of keys) {
        const val = formData.get(key) as string || '';
        await updateSetting(key, val, dbBinding);
      }
      mesaj = 'Reklam alanları başarıyla güncellendi.';
    } else if (tip === 'google') {
      const keys = ['google_pub_id', 'google_home_banner', 'google_content_ad', 'google_sidebar_ad'];
      for (const key of keys) {
        const val = formData.get(key) as string || '';
        await updateSetting(key, val, dbBinding);
      }
      mesaj = 'Google Ads ayarları başarıyla kaydedildi.';
    }
  } catch (err: any) {
    hata = err.message || 'İşlem sırasında bir hata oluştu.';
  }
}

// Tüm verileri güncel olarak çekelim
const allPosts = await getAllPosts(dbBinding);
const settings = await getSettings(dbBinding);

// Sponsorlu ve normal içerikleri ayır
const sponsorluIcerikler = allPosts.filter(p => p.isSponsored);
const normalIcerikler = allPosts.filter(p => !p.isSponsored && p.status === 'published');
---

<BaseLayout title="Reklam ve Sponsorlu İçerik Yönetimi" isAdmin={true}>
  
  <div class="max-w-6xl mx-auto p-6">
    
    <!-- Header -->
    <div class="mb-8 border-b border-gray-200 dark:border-gray-700 pb-4">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <i class="fas fa-ad text-orange-600 dark:text-orange-400"></i>
        </div>
        Reklam & Sponsor Yönetimi
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2 ml-15">Sponsorlu blog içeriklerini, görsel reklam alanlarını ve Google AdSense kodlarını buradan yönetin.</p>
    </div>

    <!-- Alert Messages -->
    {mesaj && (
      <div class="p-4 mb-6 text-sm text-green-800 rounded-xl bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200">
        {mesaj}
      </div>
    )}
    {hata && (
      <div class="p-4 mb-6 text-sm text-red-800 rounded-xl bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200">
        {hata}
      </div>
    )}

    <!-- Tabs Navigation -->
    <div class="flex flex-wrap border-b border-gray-200 dark:border-gray-700 gap-1 mb-8">
      <a 
        href="?tab=sponsorlu" 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'sponsorlu' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fas fa-award"></i> 1. Sponsorlu İçerikler ({sponsorluIcerikler.length})
      </a>
      <a 
        href="?tab=reklam" 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'reklam' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fas fa-image"></i> 2. Reklam Alanları (4 Slot)
      </a>
      <a 
        href="?tab=google" 
        class={`px-5 py-3 text-sm font-bold rounded-t-xl transition-all flex items-center gap-2 border-b-2 ${aktifSekme === 'google' ? 'bg-orange-50 dark:bg-orange-950/20 text-orange-600 border-orange-500' : 'text-gray-500 hover:text-gray-750 dark:hover:text-gray-200 border-transparent'}`}
      >
        <i class="fab fa-google"></i> 3. Google AdSense
      </a>
    </div>

    <!-- TAB 1: Sponsorlu İçerikler -->
    {aktifSekme === 'sponsorlu' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-150 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Yeni Sponsorlu İçerik Ekle</h2>
          <form method="POST" class="flex flex-wrap gap-3 items-end">
            <input type="hidden" name="tip" value="sponsorlu" />
            <input type="hidden" name="islem" value="ekle" />
            <div class="flex-1 min-w-[250px]">
              <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 mb-1 uppercase">İçerik Seçin</label>
              <select name="postId" required class="w-full text-sm px-3 py-2.5 border rounded-xl bg-white dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none">
                <option value="">-- Sponsor Yapılacak Yazı Seçin --</option>
                {normalIcerikler.map(post => (
                  <option value={post.id}>{post.title} ({post.category?.name || 'Genel'})</option>
                ))}
              </select>
            </div>
            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold px-6 py-2.5 rounded-xl text-sm transition shadow-sm">
              <i class="fas fa-plus mr-1"></i> Sponsor Ekle
            </button>
          </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
              <thead class="bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-200 font-bold uppercase text-xs border-b dark:border-gray-700">
                <tr>
                  <th class="px-6 py-4">İçerik Başlığı</th>
                  <th class="px-6 py-4">Görüntülenme</th>
                  <th class="px-6 py-4">Beğeni</th>
                  <th class="px-6 py-4">Eklenme Tarihi</th>
                  <th class="px-6 py-4 text-center">Durum</th>
                  <th class="px-6 py-4 text-center">İşlem</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                {sponsorluIcerikler.length === 0 ? (
                  <tr>
                    <td colspan="6" class="py-16 text-center text-gray-500 italic">Henüz hiçbir sponsorlu içerik bulunmamaktadır.</td>
                  </tr>
                ) : (
                  sponsorluIcerikler.map(item => (
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/20 transition">
                      <td class="px-6 py-4 font-semibold text-gray-900 dark:text-white">
                        <a href={`/${item.category?.slug || 'genel'}/${item.slug}`} target="_blank" class="text-orange-600 hover:underline">{item.title}</a>
                      </td>
                      <td class="px-6 py-4 text-gray-500 dark:text-gray-400 font-semibold">{item.views.toLocaleString()}</td>
                      <td class="px-6 py-4 text-gray-500 dark:text-gray-400 font-semibold">{item.likes.toLocaleString()}</td>
                      <td class="px-6 py-4 text-gray-400 dark:text-gray-500 text-xs">{new Date(item.createdAt).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' })}</td>
                      <td class="px-6 py-4 text-center">
                        <span class={`px-2.5 py-1 text-xs rounded-full font-bold ${item.isSponsored ? 'bg-green-100 text-green-700 dark:bg-green-950/20 dark:text-green-400' : 'bg-gray-100 text-gray-750'}`}>
                          {item.isSponsored ? 'Aktif' : 'Pasif'}
                        </span>
                      </td>
                      <td class="px-6 py-4 text-center">
                        <div class="flex justify-center gap-2">
                          <form method="POST" class="inline">
                            <input type="hidden" name="tip" value="sponsorlu" />
                            <input type="hidden" name="islem" value="toggle" />
                            <input type="hidden" name="postId" value={item.id} />
                            <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white font-bold p-2 rounded-lg text-xs transition" title="Durum Değiştir">
                              <i class="fas fa-sync-alt"></i> Durum
                            </button>
                          </form>
                          <form method="POST" class="inline" onsubmit="return confirm('Sponsorlu içerik durumunu kaldırmak istediğinize emin misiniz?')">
                            <input type="hidden" name="tip" value="sponsorlu" />
                            <input type="hidden" name="islem" value="sil" />
                            <input type="hidden" name="postId" value={item.id} />
                            <button type="submit" class="bg-red-600 hover:bg-red-750 text-white font-bold p-2 rounded-lg text-xs transition" title="Kaldır">
                              <i class="fas fa-trash-alt"></i> Kaldır
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}

    <!-- TAB 2: Reklam Alanları Sekmesi -->
    {aktifSekme === 'reklam' && (
      <form method="POST" class="space-y-6">
        <input type="hidden" name="tip" value="reklam" />
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          
          <!-- SLOT 1: Sol Üst Banner -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-5 space-y-4">
            <div class="flex justify-between items-center border-b dark:border-gray-700 pb-2">
              <h3 class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <i class="fas fa-columns text-orange-500"></i> Sol Sidebar - Üst (Dikdörtgen / Dik)
              </h3>
              <select name="ad_left_top_status" class="text-xs px-2.5 py-1.5 rounded-lg border dark:bg-gray-700 dark:text-white outline-none font-bold">
                <option value="active" selected={settings['ad_left_top_status'] === 'active'}>Aktif</option>
                <option value="inactive" selected={settings['ad_left_top_status'] === 'inactive' || !settings['ad_left_top_status']}>Pasif</option>
              </select>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">REKLAM GÖRSELİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_left_top_image" 
                  value={settings['ad_left_top_image'] || ''} 
                  placeholder="https://site.com/reklam-gorseli.jpg" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">HARİCİ YÖNLENDİRME LİNKİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_left_top_link" 
                  value={settings['ad_left_top_link'] || ''} 
                  placeholder="https://partner-linki.com" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              {settings['ad_left_top_image'] && (
                <div class="pt-2">
                  <span class="block text-xs font-bold text-gray-400 mb-1">Önizleme:</span>
                  <div class="w-full h-32 rounded-lg overflow-hidden border bg-gray-50 dark:bg-gray-900 flex items-center justify-center">
                    <img src={settings['ad_left_top_image']} class="max-h-full max-w-full object-contain" />
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- SLOT 2: Sol Alt Banner -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-5 space-y-4">
            <div class="flex justify-between items-center border-b dark:border-gray-700 pb-2">
              <h3 class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <i class="fas fa-columns text-orange-500"></i> Sol Sidebar - Alt (Kare)
              </h3>
              <select name="ad_left_bottom_status" class="text-xs px-2.5 py-1.5 rounded-lg border dark:bg-gray-700 dark:text-white outline-none font-bold">
                <option value="active" selected={settings['ad_left_bottom_status'] === 'active'}>Aktif</option>
                <option value="inactive" selected={settings['ad_left_bottom_status'] === 'inactive' || !settings['ad_left_bottom_status']}>Pasif</option>
              </select>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">REKLAM GÖRSELİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_left_bottom_image" 
                  value={settings['ad_left_bottom_image'] || ''} 
                  placeholder="https://site.com/reklam-gorseli.jpg" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">HARİCİ YÖNLENDİRME LİNKİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_left_bottom_link" 
                  value={settings['ad_left_bottom_link'] || ''} 
                  placeholder="https://partner-linki.com" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              {settings['ad_left_bottom_image'] && (
                <div class="pt-2">
                  <span class="block text-xs font-bold text-gray-400 mb-1">Önizleme:</span>
                  <div class="w-full h-32 rounded-lg overflow-hidden border bg-gray-50 dark:bg-gray-900 flex items-center justify-center">
                    <img src={settings['ad_left_bottom_image']} class="max-h-full max-w-full object-contain" />
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- SLOT 3: Sağ Üst Banner -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-5 space-y-4">
            <div class="flex justify-between items-center border-b dark:border-gray-700 pb-2">
              <h3 class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <i class="fas fa-columns text-orange-500"></i> Sağ Sidebar - Üst (Dikdörtgen / Dik)
              </h3>
              <select name="ad_right_top_status" class="text-xs px-2.5 py-1.5 rounded-lg border dark:bg-gray-700 dark:text-white outline-none font-bold">
                <option value="active" selected={settings['ad_right_top_status'] === 'active'}>Aktif</option>
                <option value="inactive" selected={settings['ad_right_top_status'] === 'inactive' || !settings['ad_right_top_status']}>Pasif</option>
              </select>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">REKLAM GÖRSELİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_right_top_image" 
                  value={settings['ad_right_top_image'] || ''} 
                  placeholder="https://site.com/reklam-gorseli.jpg" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">HARİCİ YÖNLENDİRME LİNKİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_right_top_link" 
                  value={settings['ad_right_top_link'] || ''} 
                  placeholder="https://partner-linki.com" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              {settings['ad_right_top_image'] && (
                <div class="pt-2">
                  <span class="block text-xs font-bold text-gray-400 mb-1">Önizleme:</span>
                  <div class="w-full h-32 rounded-lg overflow-hidden border bg-gray-50 dark:bg-gray-900 flex items-center justify-center">
                    <img src={settings['ad_right_top_image']} class="max-h-full max-w-full object-contain" />
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- SLOT 4: Sağ Alt Banner -->
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-5 space-y-4">
            <div class="flex justify-between items-center border-b dark:border-gray-700 pb-2">
              <h3 class="font-bold text-gray-900 dark:text-white flex items-center gap-2">
                <i class="fas fa-columns text-orange-500"></i> Sağ Sidebar - Alt (Kare)
              </h3>
              <select name="ad_right_bottom_status" class="text-xs px-2.5 py-1.5 rounded-lg border dark:bg-gray-700 dark:text-white outline-none font-bold">
                <option value="active" selected={settings['ad_right_bottom_status'] === 'active'}>Aktif</option>
                <option value="inactive" selected={settings['ad_right_bottom_status'] === 'inactive' || !settings['ad_right_bottom_status']}>Pasif</option>
              </select>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">REKLAM GÖRSELİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_right_bottom_image" 
                  value={settings['ad_right_bottom_image'] || ''} 
                  placeholder="https://site.com/reklam-gorseli.jpg" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">HARİCİ YÖNLENDİRME LİNKİ (URL)</label>
                <input 
                  type="text" 
                  name="ad_right_bottom_link" 
                  value={settings['ad_right_bottom_link'] || ''} 
                  placeholder="https://partner-linki.com" 
                  class="w-full text-sm px-3 py-2 border rounded-xl bg-white dark:bg-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 outline-none"
                />
              </div>
              {settings['ad_right_bottom_image'] && (
                <div class="pt-2">
                  <span class="block text-xs font-bold text-gray-400 mb-1">Önizleme:</span>
                  <div class="w-full h-32 rounded-lg overflow-hidden border bg-gray-50 dark:bg-gray-900 flex items-center justify-center">
                    <img src={settings['ad_right_bottom_image']} class="max-h-full max-w-full object-contain" />
                  </div>
                </div>
              )}
            </div>
          </div>

        </div>

        <div class="flex justify-end pt-4">
          <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3.5 px-8 rounded-xl text-sm transition flex items-center gap-2 shadow-md">
            <i class="fas fa-save"></i> Tüm Reklam Alanı Değişikliklerini Kaydet
          </button>
        </div>
      </form>
    )}

    <!-- TAB 3: Google Ads Sekmesi -->
    {aktifSekme === 'google' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-150 dark:border-gray-700 p-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white flex items-center gap-2">
            <i class="fab fa-google text-orange-500"></i> Google AdSense Ayarları
          </h2>
          <p class="text-sm text-gray-500 mb-6">Google AdSense kodlarınızı aşağıdaki alanlara girerek tüm sitede entegre edebilirsiniz.</p>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tip" value="google" />
            
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Publisher ID (pub-xxx)</label>
              <input 
                type="text" 
                name="google_pub_id" 
                value={settings['google_pub_id'] || ''} 
                placeholder="pub-1234567890" 
                class="w-full px-4 py-2.5 border rounded-xl bg-white dark:bg-gray-900 dark:text-white dark:border-gray-700 focus:ring-2 focus:ring-orange-500 outline-none" 
              />
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Ana Sayfa Banner Kodu</label>
              <textarea 
                name="google_home_banner" 
                rows="4" 
                placeholder='<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-xxx"></script>' 
                class="w-full px-4 py-2.5 border rounded-xl font-mono text-sm bg-white dark:bg-gray-900 dark:text-white dark:border-gray-700 focus:ring-2 focus:ring-orange-500 outline-none"
              >{settings['google_home_banner'] || ''}</textarea>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">İçerik İçi Reklam Kodu</label>
              <textarea 
                name="google_content_ad" 
                rows="4" 
                class="w-full px-4 py-2.5 border rounded-xl font-mono text-sm bg-white dark:bg-gray-900 dark:text-white dark:border-gray-700 focus:ring-2 focus:ring-orange-500 outline-none"
              >{settings['google_content_ad'] || ''}</textarea>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Sidebar Reklam Kodu</label>
              <textarea 
                name="google_sidebar_ad" 
                rows="4" 
                class="w-full px-4 py-2.5 border rounded-xl font-mono text-sm bg-white dark:bg-gray-900 dark:text-white dark:border-gray-700 focus:ring-2 focus:ring-orange-500 outline-none"
              >{settings['google_sidebar_ad'] || ''}</textarea>
            </div>
            <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-xl text-sm transition flex items-center gap-2 shadow-md">
              <i class="fas fa-save"></i> Google Reklam Ayarlarını Kaydet
            </button>
          </form>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
