---
import BaseLayout from '../../../layouts/BaseLayout.astro';

let categories = [
  { id: 1, name: 'Teknoloji', slug: 'teknoloji', description: 'Yapay zeka, yazılım, donanım ve teknoloji haberleri', postCount: 12, color: '#3b82f6', icon: '💻', status: 'active', createdAt: '2026-05-01' },
  { id: 2, name: 'Seyahat', slug: 'seyahat', description: 'Gezi rehberleri, rotalar ve tatil önerileri', postCount: 8, color: '#10b981', icon: '✈️', status: 'active', createdAt: '2026-05-02' },
  { id: 3, name: 'Yemek', slug: 'yemek', description: 'Tarifler, mutfak önerileri ve lezzet durakları', postCount: 15, color: '#f59e0b', icon: '🍜', status: 'active', createdAt: '2026-05-03' },
];

let mesaj = '';
let hata = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const islem = data.get('islem');
  
  if (islem === 'ekle') {
    const yeniId = categories.length + 1;
    categories.push({
      id: yeniId,
      name: data.get('name'),
      slug: data.get('slug'),
      description: data.get('description') || '',
      postCount: 0,
      color: data.get('color') || '#6b7280',
      icon: data.get('icon') || '📁',
      status: 'active',
      createdAt: new Date().toISOString().split('T')[0]
    });
    mesaj = 'Kategori eklendi';
  } else if (islem === 'sil') {
    const id = parseInt(data.get('id'));
    categories = categories.filter(c => c.id !== id);
    mesaj = 'Kategori silindi';
  } else if (islem === 'guncelle') {
    const id = parseInt(data.get('id'));
    const index = categories.findIndex(c => c.id === id);
    if (index !== -1) {
      categories[index] = {
        ...categories[index],
        name: data.get('name'),
        slug: data.get('slug'),
        description: data.get('description') || '',
        color: data.get('color') || '#6b7280',
        icon: data.get('icon') || '📁',
        status: data.get('status')
      };
      mesaj = 'Kategori güncellendi';
    }
  }
}
---

<BaseLayout title="Kategoriler" isAdmin={true}>
  <div class="p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Kategoriler</h1>
      <button onclick="document.getElementById('modal').classList.remove('hidden')" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">+ Yeni Kategori</button>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded mb-4">{mesaj}</div>}
    {hata && <div class="bg-red-100 text-red-700 p-3 rounded mb-4">{hata}</div>}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.filter(c => c.status === 'active').map(cat => (
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 border">
          <div class="flex justify-between items-start">
            <div class="flex items-center gap-3">
              <div class="text-3xl">{cat.icon}</div>
              <div>
                <h3 class="font-bold text-lg">{cat.name}</h3>
                <p class="text-xs text-gray-500">/{cat.slug}</p>
                <p class="text-sm text-gray-600 mt-1">{cat.description}</p>
                <div class="flex items-center gap-2 mt-2">
                  <div class="w-3 h-3 rounded-full" style={{ backgroundColor: cat.color }}></div>
                  <span class="text-xs text-gray-500">{cat.postCount} içerik</span>
                </div>
              </div>
            </div>
            <div class="flex gap-2">
              <button onclick="duzenleModal({id: ${cat.id}, name: '${cat.name}', slug: '${cat.slug}', desc: '${cat.description.replace(/'/g, "\\'")}', color: '${cat.color}', icon: '${cat.icon}', status: '${cat.status}'})" class="text-blue-600 hover:text-blue-800">✏️</button>
              <form method="POST" onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                <input type="hidden" name="islem" value="sil" />
                <input type="hidden" name="id" value={cat.id} />
                <button type="submit" class="text-red-600 hover:text-red-800">🗑️</button>
              </form>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md">
      <h2 id="modalBaslik" class="text-xl font-bold mb-4">Yeni Kategori</h2>
      <form method="POST" id="kategoriForm">
        <input type="hidden" name="islem" id="islem" value="ekle" />
        <input type="hidden" name="id" id="kategoriId" />
        
        <div class="mb-3">
          <label class="block text-sm font-medium mb-1">Kategori Adı</label>
          <input type="text" name="name" id="kategoriAd" required class="w-full border rounded px-3 py-2 dark:bg-gray-700" />
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium mb-1">Slug</label>
          <input type="text" name="slug" id="kategoriSlug" required class="w-full border rounded px-3 py-2 dark:bg-gray-700" />
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium mb-1">Açıklama</label>
          <textarea name="description" id="kategoriDesc" rows="2" class="w-full border rounded px-3 py-2 dark:bg-gray-700"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-sm font-medium mb-1">Renk</label>
            <input type="color" name="color" id="kategoriRenk" value="#3b82f6" class="w-full h-10 border rounded" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">İkon (emoji)</label>
            <input type="text" name="icon" id="kategoriIkon" placeholder="📁" class="w-full border rounded px-3 py-2 dark:bg-gray-700" />
          </div>
        </div>
        <div class="mb-4" id="durumAlan" style="display: none;">
          <label class="block text-sm font-medium mb-1">Durum</label>
          <select name="status" id="kategoriDurum" class="w-full border rounded px-3 py-2 dark:bg-gray-700">
            <option value="active">Aktif</option>
            <option value="inactive">Pasif</option>
          </select>
        </div>
        <div class="flex gap-3">
          <button type="submit" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700 flex-1">Kaydet</button>
          <button type="button" onclick="document.getElementById('modal').classList.add('hidden')" class="bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400">İptal</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function duzenleModal(veri) {
      document.getElementById('islem').value = 'guncelle';
      document.getElementById('modalBaslik').innerText = 'Kategori Düzenle';
      document.getElementById('durumAlan').style.display = 'block';
      document.getElementById('kategoriId').value = veri.id;
      document.getElementById('kategoriAd').value = veri.name;
      document.getElementById('kategoriSlug').value = veri.slug;
      document.getElementById('kategoriDesc').value = veri.desc;
      document.getElementById('kategoriRenk').value = veri.color;
      document.getElementById('kategoriIkon').value = veri.icon;
      document.getElementById('kategoriDurum').value = veri.status;
      document.getElementById('modal').classList.remove('hidden');
    }
    
    // Yeni kategori için modalı temizle
    const modal = document.getElementById('modal');
    const modalBaslik = document.getElementById('modalBaslik');
    const islem = document.getElementById('islem');
    const durumAlan = document.getElementById('durumAlan');
    const kategoriId = document.getElementById('kategoriId');
    const kategoriAd = document.getElementById('kategoriAd');
    const kategoriSlug = document.getElementById('kategoriSlug');
    const kategoriDesc = document.getElementById('kategoriDesc');
    const kategoriRenk = document.getElementById('kategoriRenk');
    const kategoriIkon = document.getElementById('kategoriIkon');
    
    // Yeni kategori butonu için özel işlem
    const yeniButon = document.querySelector('button[onclick*="modal"]');
    if (yeniButon) {
      yeniButon.onclick = () => {
        islem.value = 'ekle';
        modalBaslik.innerText = 'Yeni Kategori';
        durumAlan.style.display = 'none';
        kategoriId.value = '';
        kategoriAd.value = '';
        kategoriSlug.value = '';
        kategoriDesc.value = '';
        kategoriRenk.value = '#3b82f6';
        kategoriIkon.value = '';
        modal.classList.remove('hidden');
      };
    }
    
    // Modal dışına tıklayınca kapat
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.classList.add('hidden');
    });
  </script>
</BaseLayout>