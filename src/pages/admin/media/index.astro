---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const mediaBinding = Astro.locals.runtime?.env?.MEDIA_BUCKET;
let mediaFiles: any[] = [];
let mesaj = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    
    if (action === 'delete' && mediaBinding) {
      const fileName = formData.get('name') as string;
      if (fileName) {
        await mediaBinding.delete(fileName);
        mesaj = 'Dosya başarıyla silindi.';
      }
    } else if (action === 'bulk_delete' && mediaBinding) {
      const fileNames = formData.getAll('names[]');
      if (fileNames && fileNames.length > 0) {
        for (const name of fileNames) {
          await mediaBinding.delete(name.toString());
        }
        mesaj = `${fileNames.length} dosya başarıyla silindi.`;
      }
    }
  } catch (e) {
    console.error('İşlem sırasında hata:', e);
    mesaj = 'İşlem sırasında hata oluştu.';
  }
}

if (mediaBinding) {
  try {
    const listed = await mediaBinding.list();
    mediaFiles = listed.objects.map((obj: any, index: number) => {
      return {
        id: index + 1,
        name: obj.key,
        url: `/api/media/${obj.key}`,
        size: (obj.size / 1024).toFixed(1) + ' KB',
        date: obj.uploaded ? new Date(obj.uploaded).toISOString().split('T')[0] : ''
      };
    });
    // En yeniler en üstte
    mediaFiles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
  } catch (e) {
    console.error('Medya dosyaları okunamadı:', e);
  }
}
---

<BaseLayout title="Medya Kütüphanesi" isAdmin={true}>
  <div class="p-6">
    <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
      <h1 class="text-2xl font-bold">Medya Kütüphanesi</h1>
      
      <div class="flex items-center gap-3">
        <!-- Arama -->
        <input 
          type="text" 
          id="arama" 
          placeholder="Dosya adında ara..." 
          class="w-full md:w-64 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white"
        />
        
        <!-- Yükle -->
        <label class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 cursor-pointer flex items-center gap-2 whitespace-nowrap font-medium transition shadow-sm">
          <i class="fas fa-upload" id="uploadIcon"></i> <span id="uploadText">Cihazdan Yükle</span>
          <input type="file" id="mediaUploadInput" class="hidden" accept="image/*" multiple />
        </label>
      </div>
    </div>

    {mesaj && <div class="bg-green-100 border border-green-400 text-green-700 p-3 rounded-lg mb-6 shadow-sm">{mesaj}</div>}
    
    <!-- Toplu İşlemler ve Seçim -->
    <div class="mb-4 flex items-center gap-4 bg-gray-50 dark:bg-gray-800 p-3 rounded-lg border border-gray-200 dark:border-gray-700">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="selectAllCheckbox" class="w-5 h-5 rounded text-orange-500 focus:ring-orange-500" />
        <span class="text-sm font-bold text-gray-700 dark:text-gray-300">Tümünü Seç</span>
      </label>
      
      <button type="button" id="bulkDeleteBtn" class="hidden px-4 py-1.5 bg-red-600 text-white rounded hover:bg-red-700 text-sm font-bold flex items-center gap-2 transition shadow-sm">
        <i class="fas fa-trash"></i> <span id="bulkDeleteText">Seçilenleri Sil</span>
      </button>
      
      <form id="bulkDeleteForm" method="POST" class="hidden">
        <input type="hidden" name="action" value="bulk_delete" />
        <div id="bulkDeleteInputs"></div>
      </form>
    </div>

    <!-- Resim Grid -->
    <div id="mediaGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {mediaFiles.map(file => (
        <div class="media-item relative bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden group hover:shadow-md transition" data-name={file.name.toLowerCase()}>
          <!-- Checkbox -->
          <div class="absolute top-2 left-2 z-10">
            <input type="checkbox" value={file.name} class="media-checkbox w-5 h-5 rounded text-orange-500 focus:ring-orange-500 cursor-pointer shadow" />
          </div>
          
          <div class="aspect-square bg-gray-100 dark:bg-gray-900 relative">
            <img src={file.url} alt={file.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-3">
            <p class="text-xs text-gray-700 dark:text-gray-300 truncate font-medium" title={file.name}>{file.name}</p>
            <div class="flex justify-between items-center mt-2">
              <span class="text-xs text-gray-500 font-semibold">{file.size}</span>
              <div class="flex gap-2">
                <button type="button" onclick={`navigator.clipboard.writeText(window.location.origin + '${file.url}').then(()=>alert('Kopyalandı!'))`} class="text-indigo-500 hover:text-indigo-700 bg-indigo-50 dark:bg-indigo-900/30 p-1.5 rounded" title="URL Kopyala"><i class="fas fa-link"></i></button>
                <form method="POST" onsubmit="return confirm('Silmek istediğinize emin misiniz?')" class="m-0 p-0">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="name" value={file.name} />
                  <button type="submit" class="text-red-600 hover:text-red-800 bg-red-50 dark:bg-red-900/30 p-1.5 rounded" title="Sil"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {mediaFiles.length === 0 && (
      <div class="text-center py-12 text-gray-500">Henüz medya dosyası yok</div>
    )}
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      // --- Yükleme (Upload) ---
      const uploadInput = document.getElementById('mediaUploadInput');
      if (uploadInput && !uploadInput.dataset.bound) {
        uploadInput.dataset.bound = 'true';
        uploadInput.addEventListener('change', async (e) => {
          const files = e.target.files;
          if (!files || files.length === 0) return;
          
          const icon = document.getElementById('uploadIcon');
          const text = document.getElementById('uploadText');
          const origIcon = icon.className;
          const origText = text.innerText;
          
          icon.className = 'fas fa-spinner fa-spin';
          text.innerText = 'Yüklendi: 0/' + files.length;
          
          try {
            let basarili = 0;
            for(let i = 0; i < files.length; i++) {
              const file = files[i];
              const res = await fetch('/api/media/upload.json', {
                method: 'POST',
                headers: {
                  'Content-Type': file.type || 'application/octet-stream',
                  'X-File-Name': encodeURIComponent(file.name)
                },
                body: file
              });
              if(res.ok) {
                basarili++;
                text.innerText = 'Yüklendi: ' + basarili + '/' + files.length;
              }
            }
            window.location.reload();
          } catch (err) {
            console.error(err);
            alert('Yükleme sırasında hata oluştu');
            icon.className = origIcon;
            text.innerText = origText;
            uploadInput.value = '';
          }
        });
      }

      // --- Arama (Filtreleme) ---
      const aramaInput = document.getElementById('arama');
      if (aramaInput && !aramaInput.dataset.bound) {
        aramaInput.dataset.bound = 'true';
        aramaInput.addEventListener('input', (e) => {
          const aranan = e.target.value.toLowerCase().trim();
          document.querySelectorAll('.media-item').forEach(item => {
            const name = item.getAttribute('data-name') || '';
            if (name.includes(aranan)) {
              item.style.display = '';
            } else {
              item.style.display = 'none';
              // Gizlenen item'ların seçimini kaldır
              const cb = item.querySelector('.media-checkbox');
              if (cb) cb.checked = false;
            }
          });
          updateBulkBtn();
        });
      }

      // --- Toplu Seçim ve Silme ---
      const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
      const bulkDeleteText = document.getElementById('bulkDeleteText');
      const bulkDeleteForm = document.getElementById('bulkDeleteForm');
      const selectAllCheckbox = document.getElementById('selectAllCheckbox');
      const itemCheckboxes = document.querySelectorAll('.media-checkbox');

      const updateBulkBtn = () => {
        const checkedCount = document.querySelectorAll('.media-checkbox:checked').length;
        if (bulkDeleteBtn && bulkDeleteText) {
          if (checkedCount > 0) {
            bulkDeleteBtn.classList.remove('hidden');
            bulkDeleteText.innerText = `${checkedCount} Dosyayı Sil`;
          } else {
            bulkDeleteBtn.classList.add('hidden');
          }
        }
      };

      if (selectAllCheckbox && !selectAllCheckbox.dataset.bound) {
        selectAllCheckbox.dataset.bound = 'true';
        selectAllCheckbox.addEventListener('change', (e) => {
          itemCheckboxes.forEach(cb => {
            // Sadece görünür olanları seç
            if(cb.closest('.media-item').style.display !== 'none') {
              cb.checked = e.target.checked;
            }
          });
          updateBulkBtn();
        });
      }

      itemCheckboxes.forEach(cb => {
        if (!cb.dataset.bound) {
          cb.dataset.bound = 'true';
          cb.addEventListener('change', () => {
            updateBulkBtn();
            // Hepsi seçiliyse tümünü seç i işaretle
            const visibleCount = Array.from(document.querySelectorAll('.media-item')).filter(i => i.style.display !== 'none').length;
            const checkedCount = document.querySelectorAll('.media-checkbox:checked').length;
            if (selectAllCheckbox) {
              selectAllCheckbox.checked = (visibleCount > 0 && visibleCount === checkedCount);
            }
          });
        }
      });

      if (bulkDeleteBtn && !bulkDeleteBtn.dataset.bound) {
        bulkDeleteBtn.dataset.bound = 'true';
        bulkDeleteBtn.addEventListener('click', () => {
          if (confirm('Seçili dosyaları kalıcı olarak silmek istediğinize emin misiniz?')) {
            const checked = document.querySelectorAll('.media-checkbox:checked');
            const container = document.getElementById('bulkDeleteInputs');
            if (container && bulkDeleteForm) {
              container.innerHTML = '';
              checked.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'names[]';
                input.value = cb.value;
                container.appendChild(input);
              });
              bulkDeleteForm.submit();
            }
          }
        });
      }
    });
  </script>
</BaseLayout>
