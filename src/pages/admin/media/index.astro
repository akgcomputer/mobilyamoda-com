---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const mediaBinding = Astro.locals.runtime?.env?.MEDIA_BUCKET;
let mediaFiles: any[] = [];
let mesaj = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const fileName = formData.get('name') as string;
    const action = formData.get('action') as string;
    
    if (action === 'delete' && fileName && mediaBinding) {
      await mediaBinding.delete(fileName);
      mesaj = 'Dosya başarıyla silindi.';
    }
  } catch (e) {
    console.error('Dosya silinirken hata:', e);
    mesaj = 'Dosya silinirken hata oluştu.';
  }
}

if (mediaBinding) {
  try {
    const listed = await mediaBinding.list();
    mediaFiles = listed.objects.map((obj: any, index: number) => {
      return {
        id: index + 1,
        name: obj.key,
        url: `/api/media/${obj.key}`,
        size: (obj.size / 1024).toFixed(1) + ' KB',
        date: obj.uploaded ? new Date(obj.uploaded).toISOString().split('T')[0] : ''
      };
    });
    // En yeniler en üstte
    mediaFiles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
  } catch (e) {
    console.error('Medya dosyaları okunamadı:', e);
  }
}
---

<BaseLayout title="Medya Kütüphanesi" isAdmin={true}>
  <div class="p-6">
    <div class="mb-6">
      <h1 class="text-2xl font-bold mb-2">Medya Kütüphanesi</h1>
      
      <!-- Arama -->
      <input 
        type="text" 
        id="arama" 
        placeholder="Dosya adında ara..." 
        class="w-full md:w-96 px-4 py-2 border rounded-lg dark:bg-gray-800"
      />
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded mb-4">{mesaj}</div>}

    <!-- Resim Grid -->
    <div id="mediaGrid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3">
      {mediaFiles.map(file => (
        <div class="media-item bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden group" data-name={file.name.toLowerCase()}>
          <div class="aspect-square bg-gray-100 dark:bg-gray-700">
            <img src={file.url} alt={file.name} class="w-full h-full object-cover" />
          </div>
          <div class="p-2">
            <p class="text-xs truncate">{file.name}</p>
            <div class="flex justify-between items-center mt-1">
              <span class="text-xs text-gray-500">{file.size}</span>
              <form method="POST" onsubmit="return confirm('Silmek istediğinize emin misiniz?')">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="name" value={file.name} />
                <button type="submit" class="text-red-600 hover:text-red-800 text-xs">🗑️</button>
              </form>
            </div>
          </div>
        </div>
      ))}
    </div>

    {mediaFiles.length === 0 && (
      <div class="text-center py-12 text-gray-500">Henüz medya dosyası yok</div>
    )}
  </div>

  <script>
    const arama = document.getElementById('arama');
    const mediaItems = document.querySelectorAll('.media-item');
    
    arama.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      mediaItems.forEach(item => {
        const name = item.dataset.name;
        if (name.includes(term)) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  </script>
</BaseLayout>