---
import BaseLayout from '../../../layouts/BaseLayout.astro';

let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title');
    const content = formData.get('content');
    const status = formData.get('status');
    const category = formData.get('category');
    const tags = formData.get('tags');
    const featuredImageUrl = formData.get('featured_image_url');
    
    if (!title || !content) {
      error = 'Başlık ve içerik gerekli';
    } else {
      success = true;
    }
  } catch (err) {
    error = 'Bir hata oluştu';
  }
}

const categories = ['Teknoloji', 'Seyahat', 'Yemek', 'Moda', 'Spor', 'Eğitim'];
---

<BaseLayout title="Yeni İçerik - Admin" isAdmin={true}>
  <div class="max-w-4xl mx-auto px-4 py-8 pb-24">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/admin" class="hover:text-orange-500 transition">Dashboard</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <a href="/admin/posts" class="hover:text-orange-500 transition">İçerikler</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <span class="text-gray-700 dark:text-gray-300 font-medium">İçerik Ekle</span>
    </div>

    <!-- Geri Butonu -->
    <a href="/admin/posts" class="inline-flex items-center gap-2 text-gray-600 hover:text-orange-500 transition mb-6">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Geri
    </a>

    <!-- Alt sabit çubuk -->
    <div class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-900 border-t shadow-lg p-4 z-50">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <div class="text-sm text-gray-500">
          📝 <span id="wordCount">0</span> kelime
        </div>
        <div class="flex gap-3">
          <button type="submit" form="postForm" name="status" value="draft" class="px-6 py-3 bg-gray-600 hover:bg-gray-700 text-white rounded-lg transition font-medium">
            Taslak Kaydet
          </button>
          <button type="submit" form="postForm" name="status" value="published" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white rounded-lg transition font-medium shadow-lg">
            Yayınla
          </button>
        </div>
      </div>
    </div>

    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 p-4 rounded-lg mb-6">
        ✅ İçerik başarıyla kaydedildi!
      </div>
    )}

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg mb-6">
        ❌ {error}
      </div>
    )}

    <form id="postForm" method="POST" class="space-y-8">
      <!-- Başlık -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Başlık *</label>
        <input 
          type="text" 
          name="title" 
          required 
          class="w-full px-4 py-3 text-2xl font-bold border-0 border-b-2 border-gray-200 dark:border-gray-700 focus:border-orange-500 focus:ring-0 bg-transparent dark:bg-transparent transition"
          placeholder="İçerik başlığını girin..."
        />
      </div>

      <!-- Zengin Metin Editörü - Tasarımı düzeltilmiş -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide p-6 pb-0">İçerik *</label>
        
        <!-- Toolbar - Görünür butonlar -->
        <div class="border-b border-gray-200 dark:border-gray-700 p-3 flex flex-wrap gap-1 bg-gray-50 dark:bg-gray-900">
          <button type="button" data-cmd="bold" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded font-bold text-gray-700 dark:text-gray-300" title="Kalın (Ctrl+B)">B</button>
          <button type="button" data-cmd="italic" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded italic text-gray-700 dark:text-gray-300" title="İtalik (Ctrl+I)">I</button>
          <button type="button" data-cmd="underline" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded underline text-gray-700 dark:text-gray-300" title="Altı Çizili (Ctrl+U)">U</button>
          <span class="w-px h-6 bg-gray-300 dark:bg-gray-600 mx-1"></span>
          <button type="button" data-cmd="insertUnorderedList" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded text-gray-700 dark:text-gray-300" title="Madde İşareti">• Liste</button>
          <button type="button" data-cmd="insertOrderedList" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded text-gray-700 dark:text-gray-300" title="Numaralı Liste">1. Liste</button>
          <span class="w-px h-6 bg-gray-300 dark:bg-gray-600 mx-1"></span>
          <button type="button" data-cmd="createLink" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded text-gray-700 dark:text-gray-300" title="Link Ekle">🔗 Link</button>
          <button type="button" data-cmd="insertImage" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded text-gray-700 dark:text-gray-300" title="Görsel Ekle">🖼️ Resim</button>
          <span class="w-px h-6 bg-gray-300 dark:bg-gray-600 mx-1"></span>
          <select data-cmd="formatBlock" class="p-2 text-sm border rounded bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300">
            <option value="">Normal</option>
            <option value="H1">Başlık 1</option>
            <option value="H2">Başlık 2</option>
            <option value="H3">Başlık 3</option>
          </select>
          <input type="color" data-cmd="foreColor" class="w-8 h-8 p-1 border rounded cursor-pointer bg-white dark:bg-gray-800" title="Yazı Rengi" value="#000000" />
          <button type="button" data-cmd="removeFormat" class="p-2 hover:bg-gray-200 dark:hover:bg-gray-700 rounded text-gray-700 dark:text-gray-300" title="Temizle">✖️ Temizle</button>
        </div>
        
        <!-- Editor alanı - Beyaz zemin, siyah yazı -->
        <div id="editor" contenteditable="true" class="min-h-[500px] p-6 focus:outline-none bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" style="line-height: 1.8; font-size: 16px;"></div>
        <input type="hidden" name="content" id="content" />
        <div class="border-t border-gray-200 dark:border-gray-700 p-4 bg-gray-50 dark:bg-gray-900">
          <div class="text-sm text-gray-500">
            💡 İpucu: Metin seçip renk butonuna tıklayarak renk değiştirebilirsiniz.
          </div>
        </div>
      </div>

      <!-- Kategori ve Etiket -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Kategori</label>
          <select name="category" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500 focus:border-transparent">
            <option value="">Seçiniz</option>
            {categories.map(cat => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Etiketler</label>
          <input 
            type="text" 
            name="tags" 
            placeholder="teknoloji, yapay-zeka, yazılım"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500 focus:border-transparent"
          />
          <p class="text-xs text-gray-500 mt-2">Virgül ile ayırın</p>
        </div>
      </div>

      <!-- Görseller -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Ana Görsel - Dosya ve URL -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Ana Görsel</label>
          <div class="space-y-3">
            <div id="featuredArea" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-4 text-center hover:border-orange-500 hover:bg-orange-50 dark:hover:bg-gray-700 cursor-pointer transition">
              <svg class="w-10 h-10 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm text-gray-500">Dosyadan seçin veya sürükleyin</p>
              <img id="featuredPreview" class="hidden mt-4 max-h-32 mx-auto rounded shadow" />
              <input type="file" id="featuredInput" accept="image/*" class="hidden" />
            </div>
            <div>
              <input type="url" name="featured_image_url" placeholder="veya görsel URL'si girin" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500" />
            </div>
          </div>
        </div>
        
        <!-- Galeri - Dosya ve URL -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Galeri</label>
          <div class="space-y-3">
            <div id="galleryArea" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-4 text-center hover:border-orange-500 hover:bg-orange-50 dark:hover:bg-gray-700 cursor-pointer transition">
              <svg class="w-10 h-10 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm text-gray-500">Birden fazla görsel seçin</p>
              <div id="galleryPreview" class="flex flex-wrap gap-2 mt-4 justify-center"></div>
              <input type="file" id="galleryInput" multiple accept="image/*" class="hidden" />
            </div>
            <div>
              <input type="text" name="gallery_urls" placeholder="veya görsel URL'lerini virgülle girin" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500" />
            </div>
          </div>
        </div>
      </div>

      <!-- SEO -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4 uppercase tracking-wide">🔍 SEO Ayarları</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Meta Başlık</label>
            <input type="text" name="meta_title" maxlength="60" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500" />
            <div class="text-xs text-gray-500 mt-1"><span id="metaTitleCount">0</span>/60</div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Meta Açıklama</label>
            <textarea name="meta_description" rows="2" maxlength="160" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500"></textarea>
            <div class="text-xs text-gray-500 mt-1"><span id="metaDescCount">0</span>/160</div>
          </div>
        </div>
      </div>

      <!-- Yayın Tarihi -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Yayın Tarihi</label>
        <input type="datetime-local" name="publish_date" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 focus:ring-2 focus:ring-orange-500" />
      </div>
    </form>
  </div>

  <script>
    const editor = document.getElementById('editor');
    const contentInput = document.getElementById('content');
    const wordCountSpan = document.getElementById('wordCount');

    function updateWordCount() {
      const text = editor.innerText || '';
      const words = text.trim().split(/\s+/).filter(w => w.length > 0 && w !== editor.dataset.placeholder);
      wordCountSpan.textContent = words.length;
    }

    function exec(cmd, val = null) {
      document.execCommand(cmd, false, val);
      editor.focus();
      updateWordCount();
    }

    // Renk seçimi için özel işlem
    document.querySelectorAll('[data-cmd="foreColor"]').forEach(btn => {
      btn.addEventListener('change', (e) => {
        const color = e.target.value;
        exec('foreColor', color);
      });
    });

    document.querySelectorAll('[data-cmd]').forEach(btn => {
      const cmd = btn.dataset.cmd;
      if (cmd === 'foreColor') return; // Yukarıda işledik
      
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        if (cmd === 'createLink') {
          const url = prompt('Link URL:', 'https://');
          if (url) exec(cmd, url);
        } else if (cmd === 'insertImage') {
          const url = prompt('Görsel URL:', 'https://');
          if (url) exec(cmd, url);
        } else if (cmd === 'formatBlock') {
          const val = btn.value;
          if (val) exec(cmd, val);
        } else {
          exec(cmd);
        }
      });
    });

    // Placeholder
    const placeholder = "İçerik en az 500 kelime olmalı ve özgün olmasına önem verin...";
    editor.innerText = placeholder;
    editor.style.color = '#9ca3af';
    editor.addEventListener('focus', () => {
      if (editor.innerText === placeholder) {
        editor.innerText = '';
        editor.style.color = '';
      }
    });
    editor.addEventListener('blur', () => {
      if (editor.innerText.trim() === '') {
        editor.innerText = placeholder;
        editor.style.color = '#9ca3af';
      }
    });
    editor.addEventListener('input', updateWordCount);
    editor.addEventListener('keyup', updateWordCount);

    document.getElementById('postForm').addEventListener('submit', () => {
      document.getElementById('content').value = editor.innerHTML;
    });

    // Featured image - dosya
    const featInput = document.getElementById('featuredInput');
    const featArea = document.getElementById('featuredArea');
    const featPreview = document.getElementById('featuredPreview');
    featArea.addEventListener('click', () => featInput.click());
    featInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (ev) => {
          featPreview.src = ev.target.result;
          featPreview.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      }
    });

    // Gallery - dosya
    const galInput = document.getElementById('galleryInput');
    const galArea = document.getElementById('galleryArea');
    const galPreview = document.getElementById('galleryPreview');
    galArea.addEventListener('click', () => galInput.click());
    galInput.addEventListener('change', (e) => {
      const files = Array.from(e.target.files);
      galPreview.innerHTML = '';
      files.forEach(file => {
        const reader = new FileReader();
        reader.onload = (ev) => {
          const img = document.createElement('img');
          img.src = ev.target.result;
          img.className = 'w-16 h-16 object-cover rounded border shadow';
          galPreview.appendChild(img);
        };
        reader.readAsDataURL(file);
      });
    });

    // Meta counters
    const mt = document.querySelector('input[name="meta_title"]');
    const md = document.querySelector('textarea[name="meta_description"]');
    mt?.addEventListener('input', () => document.getElementById('metaTitleCount').innerText = mt.value.length);
    md?.addEventListener('input', () => document.getElementById('metaDescCount').innerText = md.value.length);

    updateWordCount();
  </script>
</BaseLayout>