---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCategories, getAllPosts, updatePost } from '../../../lib/db';
import { uploadFile } from '../../../lib/storage';
import MediaPicker from '../../../components/admin/MediaPicker.astro';

const dbBinding = Astro.locals.runtime?.env?.DB;
const mediaBinding = Astro.locals.runtime?.env?.MEDIA_BUCKET;
const { id } = Astro.params;

const sessionData = Astro.cookies.has('user_session') ? Astro.cookies.get('user_session')?.json() : null;
const userRole = sessionData?.role || 'misafir';
const userId = sessionData?.id;

let success = false;
let error = '';

// Get Post
const posts = userRole === 'yazar' ? await getAllPosts(dbBinding, userId) : await getAllPosts(dbBinding);
const post = posts.find(p => p.id === parseInt(id as string));

if (!post) {
  return Astro.redirect('/admin/posts');
}

// Fetch categories from DB
const categories = await getCategories(dbBinding);

// Turkish Slugification Helper
function slugify(text: string): string {
  const trMap: Record<string, string> = {
    'ç': 'c', 'Ç': 'C', 'ğ': 'g', 'Ğ': 'G', 'ı': 'i', 'İ': 'I',
    'ö': 'o', 'Ö': 'O', 'ş': 's', 'Ş': 'S', 'ü': 'u', 'Ü': 'U'
  };
  return text
    .replace(/[çÇğĞıİöÖşŞüÜ]/g, match => trMap[match])
    .toLowerCase()
    .replace(/[^a-z0-9 -]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .trim();
}

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title') as string;
    const content = formData.get('content') as string;
    const status = (formData.get('status') as string) || 'draft';
    const category_id = formData.get('category_id') ? parseInt(formData.get('category_id') as string) : null;
    const tags = formData.get('tags') as string;
    const isSponsored = formData.get('isSponsored') === 'on' ? 1 : 0;
    
    // SEO Meta
    const metaTitle = formData.get('meta_title') as string;
    const metaDescription = formData.get('meta_description') as string;

    let imageUrl = formData.get('featured_image_url') as string || post.imageUrl;

    // Handle Image Upload
    const featuredImageFile = formData.get('featured_image');
    if (featuredImageFile && featuredImageFile instanceof File && featuredImageFile.size > 0) {
      const uploadedPath = await uploadFile(featuredImageFile, mediaBinding, 'post');
      if (uploadedPath) {
        imageUrl = uploadedPath;
      }
    }

    if (!title || !content || content === '<p><br></p>') {
      error = 'Başlık ve içerik doldurulması zorunludur.';
    } else {
      let slug = post.slug;
      if (title !== post.title) {
        slug = slugify(title);
      }
      
      const wordCount = content.replace(/<[^>]*>/g, '').trim().split(/\s+/).filter(w => w.length > 0).length;
      const readTime = Math.max(1, Math.ceil(wordCount / 200));

      await updatePost(post.id, {
        title,
        slug,
        content,
        excerpt: content.replace(/<[^>]*>/g, '').slice(0, 150) + '...',
        status,
        isSponsored,
        category_id,
        readTime,
        imageUrl,
        tags,
        metaTitle,
        metaDescription
      }, dbBinding);

      // Güncellenmiş post'u tekrar çekelim ki arayüzde doğru görünsün
      post.title = title;
      post.content = content;
      post.status = status;
      post.category_id = category_id;
      post.tags = tags;
      post.metaTitle = metaTitle;
      post.metaDescription = metaDescription;
      post.imageUrl = imageUrl;
      post.isSponsored = isSponsored;

      success = true;
    }
  } catch (err) {
    console.error('Edit post save error:', err);
    error = 'İçerik güncellenirken bir hata oluştu.';
  }
}
---

<BaseLayout title="İçerik Düzenle - Admin" isAdmin={true}>
  <div class="max-w-4xl mx-auto px-4 py-8 pb-24">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/admin" class="hover:text-orange-500 transition">Dashboard</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <a href="/admin/posts" class="hover:text-orange-500 transition">İçerikler</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      <span class="text-gray-700 dark:text-gray-300 font-medium">İçerik Düzenle</span>
    </div>

    <!-- Geri Butonu -->
    <a href="/admin/posts" class="inline-flex items-center gap-2 text-gray-600 hover:text-orange-500 transition mb-6">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Geri
    </a>

    {success && (
        <div class="bg-green-100 border border-green-200 text-green-700 p-4 rounded-lg mb-6 flex justify-between items-center">
          <span>✅ İçerik başarıyla güncellendi!</span>
          <a href="/admin/posts" class="text-green-800 underline font-semibold text-sm">İçeriklere Dön</a>
        </div>
      )}

    {error && (
      <div class="bg-red-100 border border-red-200 text-red-700 p-4 rounded-lg mb-6">
        ❌ {error}
      </div>
    )}

    <form id="postForm" method="POST" enctype="multipart/form-data" class="space-y-8">
      <!-- Başlık -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Başlık *</label>
        <input 
          type="text" 
          name="title" 
          value={post.title}
          required 
          class="w-full px-4 py-3 text-2xl font-bold border-0 border-b-2 border-gray-200 dark:border-gray-700 focus:border-orange-500 focus:ring-0 bg-transparent dark:bg-transparent text-gray-900 dark:text-white transition"
          placeholder="İçerik başlığını girin..."
        />
      </div>

      <!-- Zengin Metin Editörü -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide p-6 pb-0">İçerik *</label>
        
        <!-- Editor alanı -->
        <div class="p-6 bg-white dark:bg-gray-800 text-gray-900 dark:text-white">
          <div id="editor-container" class="min-h-[400px] bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-b-lg text-gray-900 dark:text-gray-100" set:html={post.content}></div>
          <input type="hidden" name="content" id="hiddenContent" value={post.content}>
        </div>
      </div>

      <!-- Kategori ve Etiket -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Kategori</label>
          <select name="category_id" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent">
            <option value="">Seçiniz</option>
            {categories.map(cat => (
              <option value={cat.id} selected={cat.id === post.category_id}>{cat.name}</option>
            ))}
          </select>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Etiketler</label>
          <input 
            type="text" 
            name="tags" 
            value={post.tags}
            placeholder="teknoloji, yapay-zeka, yazılım"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent"
          />
          <p class="text-xs text-gray-500 mt-2">Virgül ile ayırın</p>
        </div>
      </div>

      <!-- Sponsorlu İçerik -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="isSponsored" class="w-6 h-6 text-orange-500 rounded border-gray-300 focus:ring-orange-500" checked={post.isSponsored} />
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wide">Bu bir Sponsorlu İçeriktir</span>
        </label>
        <p class="text-xs text-gray-500 mt-2">İşaretlendiğinde, bu içerik ana sayfada her zaman kalıcı olarak ve özel bir rozet ile gösterilir.</p>
      </div>

      <!-- Görseller -->
      <div class="grid grid-cols-1 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2 uppercase tracking-wide">Ana Görsel</label>
          <div class="space-y-3">
            <div id="featuredArea" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-4 text-center hover:border-orange-500 hover:bg-orange-50 dark:hover:bg-gray-700 cursor-pointer transition">
              <svg class="w-10 h-10 mx-auto text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm text-gray-500">Dosyadan seçin veya sürükleyin</p>
              <img id="featuredPreview" src={post.imageUrl || ''} class={`mt-4 max-h-32 mx-auto rounded shadow ${!post.imageUrl ? 'hidden' : ''}`} />
              <input type="file" id="featuredInput" name="featured_image" accept="image/*" class="hidden" />
            </div>
            <div class="flex gap-2">
              <input type="text" id="featured_image_url" name="featured_image_url" value="" placeholder="veya yeni görsel URL'si girin" class="flex-1 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" />
              <MediaPicker inputId="featured_image_url" />
            </div>
          </div>
        </div>
      </div>

      <!-- SEO -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4 uppercase tracking-wide">🔍 SEO Ayarları</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Meta Başlık</label>
            <input type="text" name="meta_title" value={post.metaTitle} maxlength="60" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500" />
            <div class="text-xs text-gray-500 mt-1"><span id="metaTitleCount">{post.metaTitle?.length || 0}</span>/60</div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Meta Açıklama</label>
            <textarea name="meta_description" rows="2" maxlength="160" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-orange-500">{post.metaDescription}</textarea>
            <div class="text-xs text-gray-500 mt-1"><span id="metaDescCount">{post.metaDescription?.length || 0}</span>/160</div>
          </div>
        </div>
      </div>

      <!-- Alt sabit çubuk -->
      <div class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-900 border-t dark:border-gray-800 shadow-lg p-4 z-50">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
          <div class="text-sm text-gray-500">
            📝 <span id="wordCount">0</span> kelime
          </div>
          <div class="flex gap-3">
            <button type="submit" name="status" value="draft" class={`px-6 py-3 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg transition font-medium ${post.status === 'draft' ? 'ring-2 ring-orange-500' : ''}`}>
              Taslak Yap
            </button>
            <button type="submit" name="status" value="published" class={`px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white rounded-lg transition font-medium shadow-lg ${post.status === 'published' ? 'ring-2 ring-offset-2 ring-orange-500' : ''}`}>
              Değişiklikleri Kaydet
            </button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" is:inline>
  <script src="https://cdn.quilljs.com/1.3.7/quill.min.js" is:inline></script>
  <style is:global>
    .ql-toolbar {
      @apply bg-gray-50 dark:bg-gray-700 dark:border-gray-600 rounded-t-lg;
    }
    .ql-container {
      @apply text-base font-sans;
    }
    .ql-editor {
      @apply min-h-[400px] text-gray-900 dark:text-gray-100;
    }
    .dark .ql-snow .ql-stroke {
      stroke: #d1d5db;
    }
    .dark .ql-snow .ql-fill {
      fill: #d1d5db;
    }
    .dark .ql-snow .ql-picker {
      color: #d1d5db;
    }
  </style>
  <script src="https://cdn.tailwindcss.com"></script>
  <script is:inline>
    const wordCountSpan = document.getElementById('wordCount');
    const form = document.getElementById('postForm');

    // Quill Customizations
    const Link = Quill.import('formats/link');
    class MyLink extends Link {
      static create(value) {
        if (value && typeof value === 'string') {
          if (!value.startsWith('http://') && !value.startsWith('https://') && !value.startsWith('mailto:') && !value.startsWith('tel:') && !value.startsWith('/')) {
            value = 'https://' + value;
          }
        }
        return super.create(value);
      }
    }
    Quill.register(MyLink, true);

    const ColorStyle = Quill.import('attributors/style/color');
    const BackgroundStyle = Quill.import('attributors/style/background');
    Quill.register(ColorStyle, true);
    Quill.register(BackgroundStyle, true);

    // Quill Initialization
    const quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['link', 'image', 'video'],
          [{ 'color': [] }, { 'background': [] }],
          ['clean']
        ]
      },
      placeholder: 'İçeriğinizi buraya yazın...'
    });

    // İlk kelime sayımı
    function updateWordCount() {
      const text = quill.getText();
      const words = text.trim().split(/\s+/).filter(w => w.length > 0).length;
      if (wordCountSpan) wordCountSpan.innerText = text.trim().length > 0 ? words : 0;
    }

    quill.on('text-change', function() {
      updateWordCount();
      document.getElementById('hiddenContent').value = quill.root.innerHTML;
    });

    form?.addEventListener('submit', function() {
      document.getElementById('hiddenContent').value = quill.root.innerHTML;
    });

    // Featured image - dosya
    const featInput = document.getElementById('featuredInput');
    const featArea = document.getElementById('featuredArea');
    const featPreview = document.getElementById('featuredPreview');
    featArea.addEventListener('click', () => featInput.click());
    featInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (ev) => {
          featPreview.src = ev.target.result;
          featPreview.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      }
    });

    // Meta counters
    const mt = document.querySelector('input[name="meta_title"]');
    const md = document.querySelector('textarea[name="meta_description"]');
    mt?.addEventListener('input', () => document.getElementById('metaTitleCount').innerText = mt.value.length);
    md?.addEventListener('input', () => document.getElementById('metaDescCount').innerText = md.value.length);

    updateWordCount();
  </script>
</BaseLayout>
