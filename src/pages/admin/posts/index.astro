---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const auth = Astro.cookies.get('admin_auth');
if (!auth || auth.value !== 'true') {
  return Astro.redirect('/admin/login');
}

// Mock içerikler (geçici - sonra D1'den gelecek)
const posts = [
  { id: 1, title: 'Meraklı İçerik 1', slug: 'icerik-1', status: 'published', date: '2024-01-01' },
  { id: 2, title: 'Meraklı İçerik 2', slug: 'icerik-2', status: 'draft', date: '2024-01-02' },
  { id: 3, title: 'Meraklı İçerik 3', slug: 'icerik-3', status: 'published', date: '2024-01-03' },
];
---

<BaseLayout title="İçerikler - Admin">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">İçerikler</h1>
      <a href="/admin/posts/new" class="bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition">
        + Yeni İçerik
      </a>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">Başlık</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">Durum</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">Tarih</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">İşlemler</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          {posts.map(post => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-6 py-4 text-gray-900 dark:text-white">{post.title}</td>
              <td class="px-6 py-4">
                <span class={`px-2 py-1 text-xs rounded-full ${
                  post.status === 'published' 
                    ? 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300'
                    : 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'
                }`}>
                  {post.status === 'published' ? 'Yayında' : 'Taslak'}
                </span>
              </td>
              <td class="px-6 py-4 text-gray-500 dark:text-gray-400">{post.date}</td>
              <td class="px-6 py-4">
                <a href={`/admin/posts/${post.id}`} class="text-orange-500 hover:text-orange-600">Düzenle</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>