---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Mock veriler
const allPosts = [
  { id: 1, title: 'Yapay Zeka ile İçerik Üretimi', slug: 'yapay-zeka-icerik', status: 'published', isSponsored: true, category: 'Teknoloji', tags: ['AI', 'Yapay Zeka'], viewCount: 1250, likeCount: 89, createdAt: '2026-05-20T10:30:00', publishedAt: '2026-05-20T10:30:00', image: null },
  { id: 2, title: 'Seyahat Rehberi: Sapanca', slug: 'sapanca-rehberi', status: 'draft', isSponsored: false, category: 'Seyahat', tags: ['Sapanca', 'Tatil'], viewCount: 0, likeCount: 0, createdAt: '2026-05-21T14:20:00', publishedAt: null, image: null },
  { id: 3, title: 'En İyi 10 Yazılım Aracı', slug: 'yazilim-araclari', status: 'published', isSponsored: false, category: 'Teknoloji', tags: ['Yazılım', 'Araçlar'], viewCount: 3420, likeCount: 156, createdAt: '2026-05-19T09:15:00', publishedAt: '2026-05-19T09:15:00', image: null },
  { id: 4, title: 'Sağlıklı Beslenme Tüyoları', slug: 'saglikli-beslenme', status: 'scheduled', isSponsored: true, category: 'Sağlık', tags: ['Beslenme', 'Sağlık'], viewCount: 0, likeCount: 0, createdAt: '2026-05-22T08:00:00', publishedAt: '2026-05-25T08:00:00', image: null },
  { id: 5, title: 'Minimalist Yaşam Önerileri', slug: 'minimalist-yasam', status: 'archived', isSponsored: false, category: 'Yaşam', tags: ['Minimalist'], viewCount: 890, likeCount: 45, createdAt: '2026-05-15T11:00:00', publishedAt: '2026-05-16T11:00:00', image: null },
];

// Status renkleri
const statusColors = {
  published: 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300',
  draft: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300',
  scheduled: 'bg-pink-100 text-pink-700 dark:bg-pink-900 dark:text-pink-300',
  archived: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
};

const statusLabels = {
  published: 'Yayında',
  draft: 'Taslak',
  scheduled: 'Planlanmış',
  archived: 'Arşiv'
};
---

<BaseLayout title="İçerikler - Admin">
  <div class="max-w-full mx-auto px-4 py-6">
    <!-- Header -->
    <!-- Header -->
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">İçerikler</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Tüm içeriklerinizi yönetin</p>
  </div>
  <a href="/admin/posts/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-orange-600 hover:bg-orange-700 text-white rounded-lg transition shadow-md">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
    <span>Yeni İçerik</span>
  </a>
</div>

    <!-- Arama ve Filtreler -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-6">
      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Arama -->
        <div class="flex-1">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input type="text" id="searchInput" placeholder="İçerik ara (en az 2 karakter)..." class="w-full pl-10 pr-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-transparent bg-white dark:bg-gray-900">
          </div>
          <div id="searchResults" class="mt-2 text-sm text-gray-500 hidden">Sonuçlar gösteriliyor</div>
        </div>
        
        <!-- Filtre Butonu -->
        <div class="relative">
          <button id="filterToggle" class="w-full lg:w-auto px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
            Filtrele
            <span id="activeFilterCount" class="bg-orange-500 text-white text-xs rounded-full px-2 py-0.5">0</span>
          </button>
          
          <!-- Filtre Panel -->
          <div id="filterPanel" class="hidden absolute right-0 top-full mt-2 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 z-50 p-4">
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium mb-2">Durum</label>
                <div class="flex flex-wrap gap-2">
                  {Object.entries(statusLabels).map(([value, label]) => (
                    <label class="flex items-center gap-1">
                      <input type="checkbox" value={value} class="status-filter w-4 h-4 rounded border-gray-300" /> {label}
                    </label>
                  ))}
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Kategori</label>
                <select id="categoryFilter" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700">
                  <option value="">Tümü</option>
                  <option value="Teknoloji">Teknoloji</option>
                  <option value="Seyahat">Seyahat</option>
                  <option value="Sağlık">Sağlık</option>
                  <option value="Yaşam">Yaşam</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium mb-2">Sponsorlu</label>
                <select id="sponsoredFilter" class="w-full px-3 py-2 border rounded-lg dark:bg-gray-700">
                  <option value="">Tümü</option>
                  <option value="true">Sponsorlu</option>
                  <option value="false">Sponsorsuz</option>
                </select>
              </div>
              <div class="flex gap-2 pt-2">
                <button id="clearFilters" class="flex-1 px-3 py-2 border rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700">Temizle</button>
                <button id="applyFilters" class="flex-1 px-3 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700">Uygula</button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Sıralama -->
        <select id="sortSelect" class="w-full lg:w-48 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800">
          <option value="date_desc">Tarih (Yeni→Eski)</option>
          <option value="date_asc">Tarih (Eski→Yeni)</option>
          <option value="title_asc">Başlık (A→Z)</option>
          <option value="title_desc">Başlık (Z→A)</option>
          <option value="popular">Popülerlik</option>
        </select>
      </div>
    </div>

    <!-- Seçili Post Sayısı -->
    <div id="selectionBar" class="hidden fixed bottom-20 sm:bottom-24 left-1/2 transform -translate-x-1/2 bg-gray-900 text-white rounded-full shadow-xl px-4 py-2 z-50 flex items-center gap-3">
      <span id="selectedCount">0</span> içerik seçili
      <button id="bulkDelete" class="px-3 py-1 bg-red-600 rounded-lg hover:bg-red-700">Sil</button>
      <select id="bulkStatus" class="px-3 py-1 bg-gray-700 rounded-lg text-sm">
        <option value="">Durum Değiştir</option>
        <option value="published">Yayında</option>
        <option value="draft">Taslak</option>
        <option value="archived">Arşiv</option>
      </select>
      <button id="closeSelection" class="w-6 h-6 bg-gray-700 rounded-full flex items-center justify-center">✕</button>
    </div>

    <!-- Posts Grid/Table -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
            <tr>
              <th class="w-10 px-4 py-3"><input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-gray-300"></th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">İçerik</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Durum</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Kategori</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">İstatistik</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Yayın Tarihi</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">İşlemler</th>
            </tr>
          </thead>
          <tbody id="postsTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <!-- JS ile doldurulacak -->
          </tbody>
        </table>
      </div>
    </div>

    <!-- Sonsuz Kaydırma Yükleniyor -->
    <div id="loadingMore" class="text-center py-8 hidden">
      <div class="inline-block w-8 h-8 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm text-gray-500 mt-2">Daha fazla içerik yükleniyor...</p>
    </div>
  </div>

  <script>
    let allPosts = JSON.parse(`<script type="application/json">${JSON.stringify(allPosts)}<\/script>`);
    let filteredPosts = [...allPosts];
    let currentOffset = 0;
    const limit = 10;
    let isLoading = false;
    let selectedPosts = new Set();

    // Durum rozeti HTML
    function getStatusBadge(status, isSponsored) {
      const colors = {
        published: 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300',
        draft: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300',
        scheduled: 'bg-pink-100 text-pink-700 dark:bg-pink-900 dark:text-pink-300',
        archived: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
      };
      const labels = {
        published: 'Yayında',
        draft: 'Taslak',
        scheduled: 'Planlanmış',
        archived: 'Arşiv'
      };
      return `
        <div class="flex flex-wrap gap-1">
          ${isSponsored ? '<span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300">Sponsorlu</span>' : ''}
          <span class="px-2 py-1 text-xs rounded-full ${colors[status]}">${labels[status]}</span>
        </div>
      `;
    }

    // Tarih formatı
    function formatDate(dateStr) {
      if (!dateStr) return '-';
      const date = new Date(dateStr);
      const now = new Date();
      const diff = now - date;
      const hours = diff / (1000 * 60 * 60);
      if (hours < 24) {
        const h = Math.floor(hours);
        return `${h} saat önce`;
      }
      return date.toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    // Etiket özeti
    function getTagsSummary(tags) {
      if (!tags || tags.length === 0) return '-';
      const visible = tags.slice(0, 2);
      const remaining = tags.length - 2;
      return visible.join(', ') + (remaining > 0 ? ` +${remaining}` : '');
    }

    // Satır oluştur
    function createRow(post) {
      return `
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition" data-post-id="${post.id}">
          <td class="px-4 py-4"><input type="checkbox" class="post-checkbox w-4 h-4 rounded border-gray-300" data-id="${post.id}"></td>
          <td class="px-4 py-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center flex-shrink-0">
                ${post.image ? `<img src="${post.image}" class="w-full h-full object-cover rounded-lg">` : '<svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>'}
              </div>
              <div>
                <h3 class="font-medium text-gray-900 dark:text-white editable-title" data-id="${post.id}" data-title="${post.title.replace(/"/g, '&quot;')}">${post.title}</h3>
                <div class="flex flex-wrap gap-1 mt-1">
                  ${post.tags.slice(0, 2).map(t => `<span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-700 rounded-full">${t}</span>`).join('')}
                  ${post.tags.length > 2 ? `<span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-700 rounded-full">+${post.tags.length - 2}</span>` : ''}
                </div>
              </div>
            </div>
          </td>
          <td class="px-4 py-4">${getStatusBadge(post.status, post.isSponsored)}</td>
          <td class="px-4 py-4"><span class="text-sm">${post.category}</span></td>
          <td class="px-4 py-4">
            <div class="text-sm">
              <div>👁️ ${post.viewCount.toLocaleString()}</div>
              <div>❤️ ${post.likeCount.toLocaleString()}</div>
            </div>
          </td>
          <td class="px-4 py-4 text-sm text-gray-500">${formatDate(post.publishedAt || post.createdAt)}</td>
          <td class="px-4 py-4 text-right">
            <div class="flex items-center justify-end gap-2">
              <button onclick="quickEdit(${post.id})" class="p-2 text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900 rounded-lg transition" title="Hızlı Düzenle">✏️</button>
              <a href="/admin/posts/${post.id}" class="p-2 text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition" title="Düzenle">📝</a>
              <button onclick="duplicatePost(${post.id})" class="p-2 text-purple-600 hover:bg-purple-50 dark:hover:bg-purple-900 rounded-lg transition" title="Kopyala">📋</button>
              <button onclick="archivePost(${post.id})" class="p-2 text-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition" title="Arşivle">📦</button>
              <button onclick="deletePost(${post.id})" class="p-2 text-red-600 hover:bg-red-50 dark:hover:bg-red-900 rounded-lg transition" title="Sil">🗑️</button>
            </div>
          </td>
        </tr>
      `;
    }

    // Tabloyu render et
    function renderTable() {
      const tbody = document.getElementById('postsTableBody');
      const toShow = filteredPosts.slice(0, currentOffset + limit);
      tbody.innerHTML = toShow.map(post => createRow(post)).join('');
      
      // Seçili checkbox'ları geri yükle
      document.querySelectorAll('.post-checkbox').forEach(cb => {
        if (selectedPosts.has(parseInt(cb.dataset.id))) cb.checked = true;
        cb.addEventListener('change', updateSelection);
      });
      
      // Sonsuz scroll kontrol
      if (toShow.length >= filteredPosts.length) {
        document.getElementById('loadingMore')?.classList.add('hidden');
      }
    }

    // Filtreleme
    function applyFilters() {
      const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
      const statusFilters = Array.from(document.querySelectorAll('.status-filter:checked')).map(cb => cb.value);
      const categoryFilter = document.getElementById('categoryFilter')?.value;
      const sponsoredFilter = document.getElementById('sponsoredFilter')?.value;
      
      filteredPosts = allPosts.filter(post => {
        if (searchTerm.length >= 2 && !post.title.toLowerCase().includes(searchTerm)) return false;
        if (statusFilters.length > 0 && !statusFilters.includes(post.status)) return false;
        if (categoryFilter && post.category !== categoryFilter) return false;
        if (sponsoredFilter === 'true' && !post.isSponsored) return false;
        if (sponsoredFilter === 'false' && post.isSponsored) return false;
        return true;
      });
      
      // Sıralama
      const sortBy = document.getElementById('sortSelect')?.value;
      if (sortBy === 'date_desc') filteredPosts.sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt));
      else if (sortBy === 'date_asc') filteredPosts.sort((a,b) => new Date(a.createdAt) - new Date(b.createdAt));
      else if (sortBy === 'title_asc') filteredPosts.sort((a,b) => a.title.localeCompare(b.title));
      else if (sortBy === 'title_desc') filteredPosts.sort((a,b) => b.title.localeCompare(a.title));
      else if (sortBy === 'popular') filteredPosts.sort((a,b) => (b.viewCount + b.likeCount) - (a.viewCount + a.likeCount));
      
      currentOffset = limit;
      renderTable();
      
      // Filtre sayacı
      const activeCount = (searchTerm.length >= 2 ? 1 : 0) + statusFilters.length + (categoryFilter ? 1 : 0) + (sponsoredFilter ? 1 : 0);
      document.getElementById('activeFilterCount').innerText = activeCount;
    }

    // Sonsuz kaydırma
    function handleScroll() {
      if (isLoading) return;
      const scrollPosition = window.innerHeight + window.scrollY;
      const threshold = document.body.offsetHeight - 500;
      if (scrollPosition >= threshold && currentOffset + limit < filteredPosts.length) {
        isLoading = true;
        document.getElementById('loadingMore')?.classList.remove('hidden');
        setTimeout(() => {
          currentOffset += limit;
          renderTable();
          isLoading = false;
          document.getElementById('loadingMore')?.classList.add('hidden');
        }, 500);
      }
    }

    // Seçim yönetimi
    function updateSelection() {
      document.querySelectorAll('.post-checkbox:checked').forEach(cb => {
        selectedPosts.add(parseInt(cb.dataset.id));
      });
      document.querySelectorAll('.post-checkbox:not(:checked)').forEach(cb => {
        selectedPosts.delete(parseInt(cb.dataset.id));
      });
      
      const count = selectedPosts.size;
      const selectionBar = document.getElementById('selectionBar');
      if (count > 0) {
        selectionBar.classList.remove('hidden');
        document.getElementById('selectedCount').innerText = count;
      } else {
        selectionBar.classList.add('hidden');
      }
    }

    // Hızlı düzenleme
    window.quickEdit = (id) => {
      const row = document.querySelector(`tr[data-post-id="${id}"]`);
      const titleSpan = row.querySelector('.editable-title');
      const oldTitle = titleSpan.dataset.title;
      const input = document.createElement('input');
      input.value = oldTitle;
      input.className = 'w-full px-2 py-1 border rounded';
      input.addEventListener('blur', () => {
        const newTitle = input.value;
        if (newTitle && newTitle !== oldTitle) {
          const post = allPosts.find(p => p.id === id);
          if (post) post.title = newTitle;
          titleSpan.dataset.title = newTitle;
          titleSpan.innerText = newTitle;
        }
        titleSpan.style.display = '';
        input.remove();
      });
      titleSpan.style.display = 'none';
      titleSpan.parentNode.insertBefore(input, titleSpan);
      input.focus();
    };

    window.duplicatePost = (id) => {
      const original = allPosts.find(p => p.id === id);
      if (original) {
        const newPost = { ...original, id: Date.now(), title: `${original.title} (Kopya)`, createdAt: new Date().toISOString() };
        allPosts.push(newPost);
        applyFilters();
      }
    };

    window.archivePost = (id) => {
      const post = allPosts.find(p => p.id === id);
      if (post) post.status = 'archived';
      applyFilters();
    };

    window.deletePost = (id) => {
      if (confirm('Bu içeriği silmek istediğinize emin misiniz?')) {
        allPosts = allPosts.filter(p => p.id !== id);
        applyFilters();
      }
    };

    // Event Listeners
    document.getElementById('searchInput')?.addEventListener('input', (e) => {
      if (e.target.value.length >= 2 || e.target.value.length === 0) applyFilters();
    });
    document.getElementById('sortSelect')?.addEventListener('change', applyFilters);
    document.getElementById('applyFilters')?.addEventListener('click', () => {
      document.getElementById('filterPanel')?.classList.add('hidden');
      applyFilters();
    });
    document.getElementById('clearFilters')?.addEventListener('click', () => {
      document.querySelectorAll('.status-filter').forEach(cb => cb.checked = false);
      document.getElementById('categoryFilter').value = '';
      document.getElementById('sponsoredFilter').value = '';
      applyFilters();
    });
    document.getElementById('filterToggle')?.addEventListener('click', () => {
      document.getElementById('filterPanel')?.classList.toggle('hidden');
    });
    document.getElementById('selectAll')?.addEventListener('change', (e) => {
      document.querySelectorAll('.post-checkbox').forEach(cb => {
        cb.checked = e.target.checked;
        if (e.target.checked) selectedPosts.add(parseInt(cb.dataset.id));
        else selectedPosts.delete(parseInt(cb.dataset.id));
      });
      updateSelection();
    });
    document.getElementById('bulkDelete')?.addEventListener('click', () => {
      if (confirm(`${selectedPosts.size} içerik silinecek. Devam?`)) {
        allPosts = allPosts.filter(p => !selectedPosts.has(p.id));
        selectedPosts.clear();
        applyFilters();
        updateSelection();
      }
    });
    document.getElementById('bulkStatus')?.addEventListener('change', (e) => {
      if (e.target.value) {
        allPosts.forEach(p => {
          if (selectedPosts.has(p.id)) p.status = e.target.value;
        });
        applyFilters();
        updateSelection();
      }
    });
    document.getElementById('closeSelection')?.addEventListener('click', () => {
      document.querySelectorAll('.post-checkbox').forEach(cb => cb.checked = false);
      selectedPosts.clear();
      updateSelection();
    });
    
    window.addEventListener('scroll', handleScroll);
    
    applyFilters();
    
    // Filtreleri localStorage'dan hatırla
    const savedFilters = localStorage.getItem('postFilters');
    if (savedFilters) {
      try {
        const filters = JSON.parse(savedFilters);
        if (filters.search) document.getElementById('searchInput').value = filters.search;
        if (filters.sort) document.getElementById('sortSelect').value = filters.sort;
        // Diğer filtreler...
      } catch(e) {}
    }
    
    window.addEventListener('beforeunload', () => {
      const filters = {
        search: document.getElementById('searchInput')?.value,
        sort: document.getElementById('sortSelect')?.value,
      };
      localStorage.setItem('postFilters', JSON.stringify(filters));
    });
  </script>
</BaseLayout>