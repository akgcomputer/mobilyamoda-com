---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getUsers, createUser, updateUser, deleteUser } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let mesaj = '';
let hata = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const islem = formData.get('islem');
  
  if (islem === 'ekle') {
    const email = formData.get('email') as string;
    const sifre = formData.get('sifre') as string;
    const sifreTekrar = formData.get('sifre_tekrar') as string;
    const ad = formData.get('ad') as string;
    const telefon = formData.get('telefon') as string;
    const rol = formData.get('rol') as string || 'abone';
    
    const existingUsers = await getUsers(dbBinding);
    
    if (!email || !ad) {
      hata = 'E-posta ve ad soyad gerekli';
    } else if (sifre !== sifreTekrar) {
      hata = 'Şifreler eşleşmiyor';
    } else if (existingUsers.some(k => k.email === email)) {
      hata = 'Bu e-posta zaten kayıtlı';
    } else {
      await createUser({
        name: ad, email, password: sifre, phone: telefon, role: rol, status: 'aktif'
      }, dbBinding);
      mesaj = 'Kullanıcı eklendi';
    }
  } else if (islem === 'sil') {
    const id = parseInt(formData.get('id') as string);
    await deleteUser(id, dbBinding);
    mesaj = 'Kullanıcı silindi';
  } else if (islem === 'rolGuncelle') {
    const id = parseInt(formData.get('id') as string);
    const yeniRol = formData.get('rol');
    await updateUser(id, { role: yeniRol }, dbBinding);
    mesaj = 'Rol güncellendi';
  } else if (islem === 'durumGuncelle') {
    const id = parseInt(formData.get('id') as string);
    const existingUsers = await getUsers(dbBinding);
    const user = existingUsers.find(u => u.id === id);
    if (user) {
      await updateUser(id, { status: user.status === 'aktif' ? 'pasif' : 'aktif' }, dbBinding);
      mesaj = 'Durum güncellendi';
    }
  }
}

const rawKullanicilar = await getUsers(dbBinding);
const kullanicilar = rawKullanicilar.map(k => {
  let role = k.role || 'abone';
  role = role.toLowerCase();
  if (role === 'editör') role = 'editor';
  return {
    ...k,
    role
  };
});
---

<BaseLayout title="Kullanıcılar" isAdmin={true}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Kullanıcılar</h1>
      <p class="text-sm text-gray-500">Kullanıcıları yönetin, roller atayın</p>
    </div>

    <!-- Yeni Kullanıcı Ekleme Formu -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">Yeni Kullanıcı Ekle</h2>
      <form method="POST" class="space-y-4">
        <input type="hidden" name="islem" value="ekle" />
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">E-posta *</label>
            <input type="email" name="email" required class="w-full px-3 py-2 border rounded dark:bg-gray-700" placeholder="ornek@eposta.com" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Şifre</label>
            <input type="password" name="sifre" class="w-full px-3 py-2 border rounded dark:bg-gray-700" placeholder="••••••••" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Şifre Tekrar</label>
            <input type="password" name="sifre_tekrar" class="w-full px-3 py-2 border rounded dark:bg-gray-700" placeholder="••••••••" />
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1">Ad Soyad *</label>
            <input type="text" name="ad" required class="w-full px-3 py-2 border rounded dark:bg-gray-700" placeholder="Ahmet Yılmaz" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Telefon Numarası</label>
            <input type="tel" name="telefon" class="w-full px-3 py-2 border rounded dark:bg-gray-700" placeholder="5XX XXX XX XX" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Rol</label>
            <select name="rol" class="w-full px-3 py-2 border rounded dark:bg-gray-700">
              <option value="abone">Abone</option>
              <option value="yazar">Yazar</option>
              <option value="editor">Editör</option>
              <option value="admin">Admin</option>
            </select>
          </div>
        </div>
        
        <button type="submit" class="bg-orange-600 text-white px-6 py-2 rounded hover:bg-orange-700">Kaydet</button>
      </form>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded">{mesaj}</div>}
    {hata && <div class="bg-red-100 text-red-700 p-3 rounded">{hata}</div>}

    <!-- Rol Kılavuzu -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-blue-50 dark:bg-blue-900/20 p-3 rounded-lg border-l-4 border-blue-500">
        <p class="font-semibold text-blue-700">Admin</p>
        <p class="text-xs text-gray-500">Tüm yetkiler</p>
      </div>
      <div class="bg-green-50 dark:bg-green-900/20 p-3 rounded-lg border-l-4 border-green-500">
        <p class="font-semibold text-green-700">Editör</p>
        <p class="text-xs text-gray-500">İçerik yönetimi</p>
      </div>
      <div class="bg-yellow-50 dark:bg-yellow-900/20 p-3 rounded-lg border-l-4 border-yellow-500">
        <p class="font-semibold text-yellow-700">Yazar</p>
        <p class="text-xs text-gray-500">Kendi içerikleri</p>
      </div>
      <div class="bg-gray-50 dark:bg-gray-700 p-3 rounded-lg border-l-4 border-gray-500">
        <p class="font-semibold">Abone</p>
        <p class="text-xs text-gray-500">Yorum ve beğeni</p>
      </div>
    </div>

    <!-- Kullanıcı Tablosu -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-4 py-3 text-left">Kullanıcı</th>
              <th class="px-4 py-3 text-left">İletişim</th>
              <th class="px-4 py-3 text-left">Rol</th>
              <th class="px-4 py-3 text-left">Durum</th>
              <th class="px-4 py-3 text-left">Kayıt</th>
              <th class="px-4 py-3 text-center">İşlem</th>
            </tr>
          </thead>
          <tbody>
            {kullanicilar.map(k => (
              <tr class="border-t dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900 rounded-full flex items-center justify-center text-orange-600 font-bold uppercase">
                      {k.name.charAt(0)}
                    </div>
                    <div>
                      <p class="font-medium">{k.name}</p>
                      <p class="text-xs text-gray-500">@{k.email.split('@')[0]}</p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <p class="text-sm">{k.email}</p>
                  <p class="text-xs text-gray-500">{k.phone}</p>
                </td>
                <td class="px-4 py-3">
                  <form method="POST" class="inline">
                    <input type="hidden" name="islem" value="rolGuncelle" />
                    <input type="hidden" name="id" value={k.id} />
                    <select name="rol" onchange="this.form.submit()" class="px-2 py-1 border rounded text-sm dark:bg-gray-700">
                      <option value="admin" selected={k.role === 'admin'}>Admin</option>
                      <option value="editor" selected={k.role === 'editor'}>Editör</option>
                      <option value="yazar" selected={k.role === 'yazar'}>Yazar</option>
                      <option value="abone" selected={k.role === 'abone'}>Abone</option>
                    </select>
                  </form>
                </td>
                <td class="px-4 py-3">
                  <form method="POST" class="inline">
                    <input type="hidden" name="islem" value="durumGuncelle" />
                    <input type="hidden" name="id" value={k.id} />
                    <button type="submit" class={`px-2 py-1 text-xs rounded-full ${k.status === 'aktif' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      {k.status === 'aktif' ? 'Aktif' : 'Pasif'}
                    </button>
                  </form>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">{k.createdAt}</td>
                <td class="px-4 py-3 text-center">
                  <div class="flex justify-center gap-2">
                    <button onclick={`profilModal({id: ${k.id}, ad: '${k.name.replace(/'/g, "\\'")}', email: '${k.email}', telefon: '${k.phone || '-'}', ip: '${k.ip || '-'}', rol: '${k.role}'})`} class="text-blue-600 hover:text-blue-800" title="Profil">👤</button>
                    <form method="POST" class="inline" onsubmit="return confirm('Kullanıcıyı silmek istediğinize emin misiniz?')">
                      <input type="hidden" name="islem" value="sil" />
                      <input type="hidden" name="id" value={k.id} />
                      <button type="submit" class="text-red-600 hover:text-red-800" title="Sil">🗑️</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Profil Modal -->
  <div id="profilModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md">
      <h2 class="text-xl font-bold mb-4">Kullanıcı Profili</h2>
      <div class="space-y-3">
        <div>
          <p class="text-sm text-gray-500">Ad Soyad</p>
          <p id="profilAd" class="font-medium"></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">E-posta</p>
          <p id="profilEmail" class="font-medium"></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Telefon</p>
          <p id="profilTel" class="font-medium"></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Rol</p>
          <p id="profilRol" class="font-medium"></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Son IP</p>
          <p id="profilIp" class="font-mono text-sm"></p>
        </div>
        <div class="pt-4">
          <button onclick="kapatProfilModal()" class="w-full bg-gray-600 text-white py-2 rounded hover:bg-gray-700">Kapat</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function profilModal(data) {
      document.getElementById('profilAd').innerText = data.ad;
      document.getElementById('profilEmail').innerText = data.email;
      document.getElementById('profilTel').innerText = data.telefon || '-';
      document.getElementById('profilRol').innerText = data.rol;
      document.getElementById('profilIp').innerText = data.ip;
      document.getElementById('profilModal').classList.remove('hidden');
    }
    function kapatProfilModal() {
      document.getElementById('profilModal').classList.add('hidden');
    }
    
    const profilModalDiv = document.getElementById('profilModal');
    profilModalDiv?.addEventListener('click', (e) => {
      if (e.target === profilModalDiv) kapatProfilModal();
    });
  </script>
</BaseLayout>
