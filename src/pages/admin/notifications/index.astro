---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Bildirimler (mock)
let bildirimler = [
  { id: 1, tip: 'yorum', mesaj: 'Ahmet Yılmaz yeni bir yorum yazdı', icerik: 'Harika bir yazı olmuş, teşekkürler!', link: '/admin/comments', okundu: false, tarih: '2026-05-23 14:30:00' },
  { id: 2, tip: 'kullanici', mesaj: 'Yeni kullanıcı kaydoldu', icerik: 'Mehmet Demir sisteme kaydoldu', link: '/admin/users', okundu: false, tarih: '2026-05-23 10:15:00' },
  { id: 3, tip: 'hata', mesaj: 'Sistem hatası rapor edildi', icerik: '404 hatası: /olmayan-sayfa', link: '/admin/logs', okundu: true, tarih: '2026-05-22 23:45:00' },
  { id: 4, tip: 'sistem', mesaj: 'Yedekleme tamamlandı', icerik: 'Veritabanı yedeği başarıyla alındı', link: '/admin/backup', okundu: true, tarih: '2026-05-22 03:00:00' },
  { id: 5, tip: 'sponsor', mesaj: 'Sponsorluk süresi doluyor', icerik: '"Seyahat Rehberi" içeriğinin sponsorluk süresi 3 gün içinde dolacak', link: '/admin/ads', okundu: false, tarih: '2026-05-21 09:00:00' },
];

// İletişim formu mesajları
let iletisimMesajlari = [
  { id: 1, ad: 'Ali Veli', email: 'ali@example.com', konu: 'Site Hakkında', mesaj: 'Siteniz çok başarılı, tebrik ederim.', tarih: '2026-05-22', durum: 'okunmadi' },
  { id: 2, ad: 'Ayşe Kaya', email: 'ayse@example.com', konu: 'Reklam', mesaj: 'Sitenizde reklam vermek istiyorum, iletişime geçer misiniz?', tarih: '2026-05-21', durum: 'okundu' },
];

let aktifSekme = 'bildirimler';
let mesaj = '';

// URL'den aktif sekmeyi al
const urlParams = Astro.url.searchParams;
if (urlParams.has('tab')) {
  aktifSekme = urlParams.get('tab');
}

// Bildirim işlemleri
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const islem = formData.get('islem');
  
  if (islem === 'bildirim_oku') {
    const id = parseInt(formData.get('id'));
    const index = bildirimler.findIndex(b => b.id === id);
    if (index !== -1) {
      bildirimler[index].okundu = true;
      mesaj = 'Bildirim okundu olarak işaretlendi';
    }
  } else if (islem === 'bildirim_sil') {
    const id = parseInt(formData.get('id'));
    bildirimler = bildirimler.filter(b => b.id !== id);
    mesaj = 'Bildirim silindi';
  } else if (islem === 'tumunu_oku') {
    bildirimler = bildirimler.map(b => ({ ...b, okundu: true }));
    mesaj = 'Tüm bildirimler okundu olarak işaretlendi';
  } else if (islem === 'iletisim_oku') {
    const id = parseInt(formData.get('id'));
    const index = iletisimMesajlari.findIndex(m => m.id === id);
    if (index !== -1) {
      iletisimMesajlari[index].durum = 'okundu';
      mesaj = 'Mesaj okundu olarak işaretlendi';
    }
  } else if (islem === 'iletisim_sil') {
    const id = parseInt(formData.get('id'));
    iletisimMesajlari = iletisimMesajlari.filter(m => m.id !== id);
    mesaj = 'Mesaj silindi';
  }
}

const okunmamisSayisi = bildirimler.filter(b => !b.okundu).length;
const okunmamisIletisim = iletisimMesajlari.filter(m => m.durum === 'okunmadi').length;
---

<BaseLayout title="Bildirimler" isAdmin={true}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Bildirimler</h1>
      <p class="text-sm text-gray-500">Sistem bildirimlerini ve iletişim formu mesajlarını yönetin</p>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded">{mesaj}</div>}

    <!-- Sekmeler -->
    <div class="flex flex-wrap border-b border-gray-200 dark:border-gray-700 gap-1">
      <a href="/admin/notifications?tab=bildirimler" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition flex items-center gap-2 ${aktifSekme === 'bildirimler' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        🔔 Bildirimler
        {okunmamisSayisi > 0 && <span class="bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">{okunmamisSayisi}</span>}
      </a>
      <a href="/admin/notifications?tab=iletisim" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition flex items-center gap-2 ${aktifSekme === 'iletisim' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        📧 İletişim Formu
        {okunmamisIletisim > 0 && <span class="bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">{okunmamisIletisim}</span>}
      </a>
      <a href="/admin/notifications?tab=ayarlar" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'ayarlar' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        ⚙️ Bildirim Ayarları
      </a>
    </div>

    <!-- Bildirimler Sekmesi -->
    {aktifSekme === 'bildirimler' && (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <h2 class="font-semibold">Tüm Bildirimler</h2>
          <form method="POST">
            <input type="hidden" name="islem" value="tumunu_oku" />
            <button type="submit" class="text-sm text-orange-600 hover:text-orange-700">Tümünü Okundu İşaretle</button>
          </form>
        </div>
        
        {bildirimler.length === 0 ? (
          <div class="p-8 text-center text-gray-500">Henüz bildirim yok</div>
        ) : (
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            {bildirimler.map(b => (
              <div class={`p-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition ${!b.okundu ? 'bg-orange-50 dark:bg-orange-900/10' : ''}`}>
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <span class={`text-xs px-2 py-0.5 rounded-full ${
                        b.tip === 'yorum' ? 'bg-blue-100 text-blue-700' :
                        b.tip === 'kullanici' ? 'bg-green-100 text-green-700' :
                        b.tip === 'hata' ? 'bg-red-100 text-red-700' :
                        b.tip === 'sponsor' ? 'bg-yellow-100 text-yellow-700' :
                        'bg-gray-100 text-gray-700'
                      }`}>
                        {b.tip === 'yorum' ? 'Yorum' : b.tip === 'kullanici' ? 'Kullanıcı' : b.tip === 'hata' ? 'Hata' : b.tip === 'sponsor' ? 'Sponsor' : 'Sistem'}
                      </span>
                      {!b.okundu && <span class="w-2 h-2 bg-red-500 rounded-full"></span>}
                    </div>
                    <a href={b.link} class="font-medium text-gray-900 dark:text-white hover:text-orange-600">{b.mesaj}</a>
                    <p class="text-sm text-gray-500 mt-1">{b.icerik}</p>
                    <p class="text-xs text-gray-400 mt-2">{b.tarih}</p>
                  </div>
                  <div class="flex gap-2">
                    {!b.okundu && (
                      <form method="POST">
                        <input type="hidden" name="islem" value="bildirim_oku" />
                        <input type="hidden" name="id" value={b.id} />
                        <button type="submit" class="text-blue-600 hover:text-blue-800" title="Okundu İşaretle">✓</button>
                      </form>
                    )}
                    <form method="POST" onsubmit="return confirm('Sil?')">
                      <input type="hidden" name="islem" value="bildirim_sil" />
                      <input type="hidden" name="id" value={b.id} />
                      <button type="submit" class="text-red-600 hover:text-red-800" title="Sil">🗑️</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- İletişim Formu Sekmesi -->
    {aktifSekme === 'iletisim' && (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700">
          <h2 class="font-semibold">İletişim Formu Mesajları</h2>
        </div>
        
        {iletisimMesajlari.length === 0 ? (
          <div class="p-8 text-center text-gray-500">Henüz mesaj yok</div>
        ) : (
          <div class="divide-y divide-gray-200 dark:divide-gray-700">
            {iletisimMesajlari.map(m => (
              <div class={`p-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition ${m.durum === 'okunmadi' ? 'bg-orange-50 dark:bg-orange-900/10' : ''}`}>
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="font-medium">{m.ad}</span>
                      <span class="text-xs text-gray-500">{m.email}</span>
                      {m.durum === 'okunmadi' && <span class="w-2 h-2 bg-red-500 rounded-full"></span>}
                    </div>
                    <p class="text-sm font-medium text-gray-700 dark:text-gray-300">{m.konu}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{m.mesaj}</p>
                    <p class="text-xs text-gray-400 mt-2">{m.tarih}</p>
                  </div>
                  <div class="flex gap-2">
                    {m.durum === 'okunmadi' && (
                      <form method="POST">
                        <input type="hidden" name="islem" value="iletisim_oku" />
                        <input type="hidden" name="id" value={m.id} />
                        <button type="submit" class="text-blue-600 hover:text-blue-800" title="Okundu İşaretle">✓</button>
                      </form>
                    )}
                    <form method="POST" onsubmit="return confirm('Sil?')">
                      <input type="hidden" name="islem" value="iletisim_sil" />
                      <input type="hidden" name="id" value={m.id} />
                      <button type="submit" class="text-red-600 hover:text-red-800" title="Sil">🗑️</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Bildirim Ayarları Sekmesi -->
    {aktifSekme === 'ayarlar' && (
      <form method="POST" class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 space-y-4">
        <input type="hidden" name="islem" value="ayarlar" />
        
        <h2 class="font-semibold text-lg mb-4">Bildirim Tercihleri</h2>
        
        <div class="space-y-3">
          <label class="flex items-center justify-between cursor-pointer">
            <span>Yeni yorum bildirimleri</span>
            <div class="relative">
              <input type="checkbox" class="sr-only peer" checked />
              <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-orange-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
            </div>
          </label>
          <label class="flex items-center justify-between cursor-pointer">
            <span>Yeni kullanıcı kaydı bildirimleri</span>
            <div class="relative">
              <input type="checkbox" class="sr-only peer" checked />
              <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-orange-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
            </div>
          </label>
          <label class="flex items-center justify-between cursor-pointer">
            <span>Sponsorluk süresi dolum bildirimleri</span>
            <div class="relative">
              <input type="checkbox" class="sr-only peer" checked />
              <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-orange-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
            </div>
          </label>
          <label class="flex items-center justify-between cursor-pointer">
            <span>Sistem hata bildirimleri</span>
            <div class="relative">
              <input type="checkbox" class="sr-only peer" />
              <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-checked:bg-orange-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
            </div>
          </label>
        </div>
        
        <div class="pt-4">
          <label class="block text-sm font-medium mb-2">Bildirim E-posta Adresi</label>
          <input type="email" value="admin@laflaf.net" class="w-full px-3 py-2 border rounded dark:bg-gray-700" />
          <p class="text-xs text-gray-500 mt-1">Bu adrese bildirimler e-posta olarak da gönderilecektir.</p>
        </div>
        
        <button type="submit" class="bg-orange-600 text-white px-6 py-2 rounded hover:bg-orange-700">Ayarları Kaydet</button>
      </form>
    )}
  </div>
</BaseLayout>