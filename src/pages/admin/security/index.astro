---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getUsers, updateUser } from '../../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
const sessionData = Astro.cookies.get('user_session')?.json();
const userRole = sessionData?.role || 'misafir';
const currentUserId = sessionData?.id;

// Aktivite logları (mock)
let activityLogs = [
  { id: 1, kullanici: 'Ahmet Yılmaz', islem: 'Giriş yaptı', ip: '192.168.1.1', tarih: '2026-05-23 14:30:00', durum: 'başarılı' },
  { id: 2, kullanici: 'Mehmet Demir', islem: 'İçerik ekledi', ip: '192.168.1.2', tarih: '2026-05-23 10:15:00', durum: 'başarılı' },
  { id: 3, kullanici: 'Bilinmeyen', islem: 'Başarısız giriş denemesi', ip: '45.67.89.10', tarih: '2026-05-23 03:45:00', durum: 'başarısız' },
  { id: 4, kullanici: 'Ayşe Kaya', islem: 'Şifre değiştirdi', ip: '192.168.1.3', tarih: '2026-05-22 16:20:00', durum: 'başarılı' },
  { id: 5, kullanici: 'Bilinmeyen', islem: 'Başarısız giriş denemesi', ip: '45.67.89.10', tarih: '2026-05-22 02:30:00', durum: 'başarısız' },
  { id: 6, kullanici: 'Zeynep Şahin', islem: 'Çıkış yaptı', ip: '192.168.1.4', tarih: '2026-05-21 23:00:00', durum: 'başarılı' },
];

// Bloklanmış IP'ler (mock)
let blockedIps = [
  { id: 1, ip: '45.67.89.10', sebep: 'Çoklu başarısız giriş', tarih: '2026-05-23' },
  { id: 2, ip: '203.0.113.0', sebep: 'Spam', tarih: '2026-05-22' },
];

let mesaj = '';
let hata = '';
let aktifSekme = 'oturum';

// Kullanıcıları getir (admin için)
let users: any[] = [];
if (userRole === 'admin') {
  users = await getUsers(dbBinding);
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const islem = formData.get('islem');
  const tip = formData.get('tip');
  
  if (tip === 'oturum') {
    if (islem === 'tum_oturumlar' && userRole === 'admin') {
      mesaj = 'Tüm aktif oturumlar sonlandırıldı (Simülasyon)';
    }
  } else if (tip === 'sifre') {
    if (islem === 'sifre_degistir') {
      const targetUserIdStr = formData.get('user_id');
      const newPassword = formData.get('new_password') as string;
      
      let targetUserId = currentUserId;
      if (userRole === 'admin' && targetUserIdStr) {
        targetUserId = parseInt(targetUserIdStr as string);
      }
      
      if (newPassword && newPassword.length >= 6) {
        const success = await updateUser(targetUserId, { password: newPassword }, dbBinding);
        if (success) {
          mesaj = 'Şifre başarıyla güncellendi.';
        } else {
          hata = 'Şifre güncellenirken bir hata oluştu.';
        }
      } else {
        hata = 'Şifre en az 6 karakter olmalıdır.';
      }
    }
  } else if (tip === 'ip' && userRole === 'admin') {
    if (islem === 'ip_ekle') {
      const ip = formData.get('ip') as string;
      const sebep = formData.get('sebep') as string;
      if (ip) {
        blockedIps.push({ id: blockedIps.length + 1, ip, sebep, tarih: new Date().toISOString().split('T')[0] });
        mesaj = 'IP adresi engellendi (Simülasyon)';
      }
    } else if (islem === 'ip_sil') {
      const id = parseInt(formData.get('id') as string);
      blockedIps = blockedIps.filter(i => i.id !== id);
      mesaj = 'IP engeli kaldırıldı (Simülasyon)';
    }
  }
}

const urlParams = Astro.url.searchParams;
if (urlParams.has('tab')) {
  aktifSekme = urlParams.get('tab') as string;
  // Yetki kontrolü (admin olmayanlar log ve ip sekmelerine giremez)
  if (userRole !== 'admin' && (aktifSekme === 'log' || aktifSekme === 'ip')) {
    aktifSekme = 'oturum';
    hata = 'Bu sekmeye erişim yetkiniz yok.';
  }
}

const basarisizGiris = activityLogs.filter(l => l.islem.includes('Başarısız') && l.tarih.includes('2026-05-23')).length;
---

<BaseLayout title="Güvenlik" isAdmin={true}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Güvenlik</h1>
      <p class="text-sm text-gray-500">Oturum ve güvenlik ayarlarını yönetin</p>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded-lg">✅ {mesaj}</div>}
    {hata && <div class="bg-red-100 text-red-700 p-3 rounded-lg">❌ {hata}</div>}

    <!-- Sekmeler -->
    <div class="flex flex-wrap border-b border-gray-200 dark:border-gray-700 gap-1">
      <a href="/admin/security?tab=oturum" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'oturum' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'}`}>
        ⏱️ Oturum Yönetimi
      </a>
      <a href="/admin/security?tab=sifre" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'sifre' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'}`}>
        🔐 Şifre Değiştirme
      </a>
      {userRole === 'admin' && (
        <>
          <a href="/admin/security?tab=log" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'log' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'}`}>
            📋 Aktivite Logları
          </a>
          <a href="/admin/security?tab=ip" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'ip' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200'}`}>
            🚫 IP Engelleme
          </a>
        </>
      )}
    </div>

    <!-- Oturum Yönetimi Sekmesi -->
    {aktifSekme === 'oturum' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border border-gray-100 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-2 text-gray-900 dark:text-white">Oturum Zaman Aşımı Sistemi</h2>
          <div class="bg-blue-50 dark:bg-blue-900/20 text-blue-800 dark:text-blue-300 p-4 rounded-lg flex items-center gap-3">
            <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p><strong>Aktif:</strong> Güvenlik sebebiyle 10 dakika boyunca işlem yapılmadığında oturumlar otomatik olarak sonlandırılmaktadır.</p>
          </div>
        </div>

        {userRole === 'admin' && (
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border border-gray-100 dark:border-gray-700">
            <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Aktif Oturumlar</h2>
            <div class="mb-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg flex justify-between items-center">
              <div>
                <p class="font-medium text-gray-900 dark:text-yellow-100">3 aktif oturum</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Son 24 saatte {basarisizGiris} başarısız giriş denemesi</p>
              </div>
              <form method="POST">
                <input type="hidden" name="tip" value="oturum" />
                <input type="hidden" name="islem" value="tum_oturumlar" />
                <button type="submit" class="px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700">Tümünü Sonlandır</button>
              </form>
            </div>
            <div class="space-y-2">
              <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700/50 rounded">
                <div>
                  <p class="font-medium text-gray-900 dark:text-white">Ahmet Yılmaz</p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">IP: 192.168.1.1 | Son aktivite: 2 dakika önce</p>
                </div>
                <button class="text-red-600 hover:text-red-800 dark:hover:text-red-400 text-sm">Sonlandır</button>
              </div>
            </div>
          </div>
        )}
      </div>
    )}

    <!-- Şifre Değiştirme Sekmesi -->
    {aktifSekme === 'sifre' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border border-gray-100 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">{userRole === 'admin' ? 'Kullanıcı Şifre Değiştirme' : 'Şifre Değiştir'}</h2>
          <form method="POST" class="space-y-4 max-w-md">
            <input type="hidden" name="tip" value="sifre" />
            <input type="hidden" name="islem" value="sifre_degistir" />
            
            {userRole === 'admin' && (
              <div>
                <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Kullanıcı Seç</label>
                <select name="user_id" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white" required>
                  {users.map(u => (
                    <option value={u.id}>{u.name || u.username} ({u.email})</option>
                  ))}
                </select>
              </div>
            )}
            
            <div>
              <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">Yeni Şifre</label>
              <input type="password" name="new_password" required minlength="6" placeholder="En az 6 karakter" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" />
            </div>
            
            <button type="submit" class="bg-orange-600 text-white px-4 py-2 rounded-lg hover:bg-orange-700 transition w-full sm:w-auto font-medium shadow-sm">Şifreyi Değiştir</button>
          </form>
        </div>
      </div>
    )}

    <!-- Aktivite Logları Sekmesi (Admin Only) -->
    {aktifSekme === 'log' && userRole === 'admin' && (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-100 dark:border-gray-700">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-gray-50 dark:bg-gray-800">
          <h2 class="font-semibold text-gray-900 dark:text-white">Son Aktivite Kayıtları</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Kullanıcı</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">İşlem</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">IP Adresi</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tarih</th>
                <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Durum</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
              {activityLogs.map(log => (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/20 transition">
                  <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">{log.kullanici}</td>
                  <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{log.islem}</td>
                  <td class="px-4 py-3 text-sm font-mono text-gray-500 dark:text-gray-400">{log.ip}</td>
                  <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">{log.tarih}</td>
                  <td class="px-4 py-3 text-center">
                    <span class={`px-2 py-1 text-xs rounded-full ${log.durum === 'başarılı' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'}`}>
                      {log.durum}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- IP Engelleme Sekmesi (Admin Only) -->
    {aktifSekme === 'ip' && userRole === 'admin' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border border-gray-100 dark:border-gray-700">
          <h2 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">IP Adresi Engelle</h2>
          <form method="POST" class="flex flex-wrap gap-3">
            <input type="hidden" name="tip" value="ip" />
            <input type="hidden" name="islem" value="ip_ekle" />
            <input type="text" name="ip" placeholder="IP adresi (örn: 192.168.1.1)" required class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" />
            <input type="text" name="sebep" placeholder="Sebep (Opsiyonel)" class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" />
            <button type="submit" class="bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700 transition font-medium shadow-sm">Engelle</button>
          </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-100 dark:border-gray-700">
          <h2 class="font-semibold p-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white">Engellenen IP Adresleri</h2>
          {blockedIps.length === 0 ? (
            <div class="p-8 text-center text-gray-500 dark:text-gray-400">Engellenen IP adresi yok</div>
          ) : (
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              {blockedIps.map(ip => (
                <div class="p-4 flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-700/20 transition">
                  <div>
                    <p class="font-mono font-medium text-gray-900 dark:text-white">{ip.ip}</p>
                    <p class="text-sm text-gray-600 dark:text-gray-300">Sebep: {ip.sebep || 'Belirtilmedi'}</p>
                    <p class="text-xs text-gray-400 mt-1">{ip.tarih} tarihinde engellendi</p>
                  </div>
                  <form method="POST" onsubmit="return confirm('Bu IP engelini kaldırmak istediğinize emin misiniz?')">
                    <input type="hidden" name="tip" value="ip" />
                    <input type="hidden" name="islem" value="ip_sil" />
                    <input type="hidden" name="id" value={ip.id} />
                    <button type="submit" class="text-red-600 hover:text-red-800 dark:hover:text-red-400 text-sm font-medium px-3 py-1 rounded-md hover:bg-red-50 dark:hover:bg-red-900/20 transition">Engeli Kaldır</button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>