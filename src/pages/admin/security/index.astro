---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Aktivite logları (mock)
let activityLogs = [
  { id: 1, kullanici: 'Ahmet Yılmaz', islem: 'Giriş yaptı', ip: '192.168.1.1', tarih: '2026-05-23 14:30:00', durum: 'başarılı' },
  { id: 2, kullanici: 'Mehmet Demir', islem: 'İçerik ekledi', ip: '192.168.1.2', tarih: '2026-05-23 10:15:00', durum: 'başarılı' },
  { id: 3, kullanici: 'Bilinmeyen', islem: 'Başarısız giriş denemesi', ip: '45.67.89.10', tarih: '2026-05-23 03:45:00', durum: 'başarısız' },
  { id: 4, kullanici: 'Ayşe Kaya', islem: 'Şifre değiştirdi', ip: '192.168.1.3', tarih: '2026-05-22 16:20:00', durum: 'başarılı' },
  { id: 5, kullanici: 'Bilinmeyen', islem: 'Başarısız giriş denemesi', ip: '45.67.89.10', tarih: '2026-05-22 02:30:00', durum: 'başarısız' },
  { id: 6, kullanici: 'Zeynep Şahin', islem: 'Çıkış yaptı', ip: '192.168.1.4', tarih: '2026-05-21 23:00:00', durum: 'başarılı' },
];

// Bloklanmış IP'ler
let blockedIps = [
  { id: 1, ip: '45.67.89.10', sebep: 'Çoklu başarısız giriş', tarih: '2026-05-23' },
  { id: 2, ip: '203.0.113.0', sebep: 'Spam', tarih: '2026-05-22' },
];

let mesaj = '';
let hata = '';
let aktifSekme = 'oturum'; // oturum, log, ip

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const islem = formData.get('islem');
  const tip = formData.get('tip');
  
  if (tip === 'oturum') {
    if (islem === 'oturum_suresi') {
      const sure = formData.get('timeout');
      mesaj = `Oturum zaman aşımı ${sure} dakika olarak ayarlandı`;
    } else if (islem === 'tum_oturumlar') {
      mesaj = 'Tüm aktif oturumlar sonlandırıldı';
    }
  } else if (tip === 'sifre') {
    if (islem === 'sifre_politikasi') {
      const minLength = formData.get('min_length');
      const requireUppercase = formData.get('require_uppercase') === 'on';
      mesaj = 'Şifre politikası güncellendi';
    } else if (islem === 'sifre_sifirla') {
      const userId = formData.get('user_id');
      mesaj = `Kullanıcı ${userId} için şifre sıfırlama bağlantısı gönderildi`;
    }
  } else if (tip === 'ip') {
    if (islem === 'ip_ekle') {
      const ip = formData.get('ip');
      const sebep = formData.get('sebep');
      if (ip) {
        blockedIps.push({ id: blockedIps.length + 1, ip, sebep, tarih: new Date().toISOString().split('T')[0] });
        mesaj = 'IP adresi engellendi';
      }
    } else if (islem === 'ip_sil') {
      const id = parseInt(formData.get('id'));
      blockedIps = blockedIps.filter(i => i.id !== id);
      mesaj = 'IP engeli kaldırıldı';
    }
  }
}

// URL'den aktif sekmeyi al
const urlParams = Astro.url.searchParams;
if (urlParams.has('tab')) {
  aktifSekme = urlParams.get('tab');
}

const basarisizGiris = activityLogs.filter(l => l.islem.includes('Başarısız') && l.tarih.includes('2026-05-23')).length;
---

<BaseLayout title="Güvenlik" isAdmin={true}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Güvenlik</h1>
      <p class="text-sm text-gray-500">Oturum, şifre politikası ve güvenlik ayarlarını yönetin</p>
    </div>

    {mesaj && <div class="bg-green-100 text-green-700 p-3 rounded">{mesaj}</div>}
    {hata && <div class="bg-red-100 text-red-700 p-3 rounded">{hata}</div>}

    <!-- Sekmeler -->
    <div class="flex flex-wrap border-b border-gray-200 dark:border-gray-700 gap-1">
      <a href="/admin/security?tab=oturum" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'oturum' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        ⏱️ Oturum Yönetimi
      </a>
      <a href="/admin/security?tab=sifre" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'sifre' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        🔐 Şifre Politikası
      </a>
      <a href="/admin/security?tab=log" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'log' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        📋 Aktivite Logları
      </a>
      <a href="/admin/security?tab=ip" class={`px-4 py-2 text-sm font-medium rounded-t-lg transition ${aktifSekme === 'ip' ? 'bg-orange-50 text-orange-600 border-b-2 border-orange-500' : 'text-gray-500 hover:text-gray-700'}`}>
        🚫 IP Engelleme
      </a>
    </div>

    <!-- Oturum Yönetimi Sekmesi -->
    {aktifSekme === 'oturum' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Oturum Zaman Aşımı</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tip" value="oturum" />
            <input type="hidden" name="islem" value="oturum_suresi" />
            <div>
              <label class="block text-sm font-medium mb-2">Otomatik çıkış süresi (dakika)</label>
              <select name="timeout" class="px-3 py-2 border rounded dark:bg-gray-700">
                <option value="5">5 dakika</option>
                <option value="10" selected>10 dakika</option>
                <option value="15">15 dakika</option>
                <option value="30">30 dakika</option>
                <option value="60">60 dakika</option>
              </select>
              <p class="text-xs text-gray-500 mt-1">Belirtilen süre boyunca işlem yapılmazsa otomatik çıkış yapılır.</p>
            </div>
            <button type="submit" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">Kaydet</button>
          </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Aktif Oturumlar</h2>
          <div class="mb-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg flex justify-between items-center">
            <div>
              <p class="font-medium">3 aktif oturum</p>
              <p class="text-xs text-gray-500">Son 24 saatte {basarisizGiris} başarısız giriş denemesi</p>
            </div>
            <form method="POST">
              <input type="hidden" name="tip" value="oturum" />
              <input type="hidden" name="islem" value="tum_oturumlar" />
              <button type="submit" class="px-3 py-1 bg-red-600 text-white text-sm rounded hover:bg-red-700">Tümünü Sonlandır</button>
            </form>
          </div>
          <div class="space-y-2">
            <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded">
              <div>
                <p class="font-medium">Ahmet Yılmaz</p>
                <p class="text-xs text-gray-500">IP: 192.168.1.1 | Son aktivite: 2 dakika önce</p>
              </div>
              <button class="text-red-600 hover:text-red-800">Sonlandır</button>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded">
              <div>
                <p class="font-medium">Mehmet Demir</p>
                <p class="text-xs text-gray-500">IP: 192.168.1.2 | Son aktivite: 15 dakika önce</p>
              </div>
              <button class="text-red-600 hover:text-red-800">Sonlandır</button>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Şifre Politikası Sekmesi -->
    {aktifSekme === 'sifre' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Şifre Politikası</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tip" value="sifre" />
            <input type="hidden" name="islem" value="sifre_politikasi" />
            <div>
              <label class="block text-sm font-medium mb-2">Minimum Şifre Uzunluğu</label>
              <select name="min_length" class="px-3 py-2 border rounded dark:bg-gray-700">
                <option value="6">6 karakter</option>
                <option value="8" selected>8 karakter</option>
                <option value="10">10 karakter</option>
                <option value="12">12 karakter</option>
              </select>
            </div>
            <div>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="require_uppercase" checked class="w-4 h-4" />
                <span>En az 1 büyük harf zorunlu olsun</span>
              </label>
            </div>
            <div>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="require_number" checked class="w-4 h-4" />
                <span>En az 1 rakam zorunlu olsun</span>
              </label>
            </div>
            <div>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="require_special" class="w-4 h-4" />
                <span>En az 1 özel karakter zorunlu olsun (!@#$%^&*)</span>
              </label>
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Şifre yenileme süresi (gün)</label>
              <select name="expiry" class="px-3 py-2 border rounded dark:bg-gray-700">
                <option value="0">Hiçbir zaman</option>
                <option value="30">30 gün</option>
                <option value="60" selected>60 gün</option>
                <option value="90">90 gün</option>
              </select>
            </div>
            <button type="submit" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">Kaydet</button>
          </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">Kullanıcı Şifre Sıfırlama</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tip" value="sifre" />
            <input type="hidden" name="islem" value="sifre_sifirla" />
            <div>
              <label class="block text-sm font-medium mb-2">Kullanıcı Seç</label>
              <select name="user_id" class="w-full px-3 py-2 border rounded dark:bg-gray-700">
                <option value="1">Ahmet Yılmaz (ahmet@laflaf.net)</option>
                <option value="2">Mehmet Demir (mehmet@laflaf.net)</option>
                <option value="3">Ayşe Kaya (ayse@laflaf.net)</option>
              </select>
            </div>
            <button type="submit" class="bg-yellow-600 text-white px-4 py-2 rounded hover:bg-yellow-700">Şifre Sıfırlama Bağlantısı Gönder</button>
          </form>
        </div>
      </div>
    )}

    <!-- Aktivite Logları Sekmesi -->
    {aktifSekme === 'log' && (
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <h2 class="font-semibold">Son Aktivite Kayıtları</h2>
          <div class="flex gap-2">
            <input type="text" placeholder="Filtrele..." class="px-3 py-1 text-sm border rounded dark:bg-gray-700" />
            <button class="px-3 py-1 text-sm bg-gray-600 text-white rounded">Dışa Aktar</button>
          </div>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th class="px-4 py-3 text-left text-sm">Kullanıcı</th>
                <th class="px-4 py-3 text-left text-sm">İşlem</th>
                <th class="px-4 py-3 text-left text-sm">IP Adresi</th>
                <th class="px-4 py-3 text-left text-sm">Tarih</th>
                <th class="px-4 py-3 text-center text-sm">Durum</th>
              </tr>
            </thead>
            <tbody>
              {activityLogs.map(log => (
                <tr class="border-t dark:border-gray-700">
                  <td class="px-4 py-3 text-sm">{log.kullanici}</td>
                  <td class="px-4 py-3 text-sm">{log.islem}</td>
                  <td class="px-4 py-3 text-sm font-mono">{log.ip}</td>
                  <td class="px-4 py-3 text-sm text-gray-500">{log.tarih}</td>
                  <td class="px-4 py-3 text-center">
                    <span class={`px-2 py-1 text-xs rounded-full ${log.durum === 'başarılı' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      {log.durum}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        <div class="p-4 border-t border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <p class="text-sm text-gray-500">Toplam {activityLogs.length} kayıt</p>
          <div class="flex gap-2">
            <button class="px-3 py-1 border rounded hover:bg-gray-100">Önceki</button>
            <button class="px-3 py-1 border rounded hover:bg-gray-100">Sonraki</button>
          </div>
        </div>
      </div>
    )}

    <!-- IP Engelleme Sekmesi -->
    {aktifSekme === 'ip' && (
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4">IP Adresi Engelle</h2>
          <form method="POST" class="flex flex-wrap gap-3">
            <input type="hidden" name="tip" value="ip" />
            <input type="hidden" name="islem" value="ip_ekle" />
            <input type="text" name="ip" placeholder="IP adresi (örn: 192.168.1.1)" required class="flex-1 px-3 py-2 border rounded dark:bg-gray-700" />
            <input type="text" name="sebep" placeholder="Sebep" class="flex-1 px-3 py-2 border rounded dark:bg-gray-700" />
            <button type="submit" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700">Engelle</button>
          </form>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
          <h2 class="font-semibold p-4 border-b border-gray-200 dark:border-gray-700">Engellenen IP Adresleri</h2>
          {blockedIps.length === 0 ? (
            <div class="p-8 text-center text-gray-500">Engellenen IP adresi yok</div>
          ) : (
            <div class="divide-y divide-gray-200 dark:divide-gray-700">
              {blockedIps.map(ip => (
                <div class="p-4 flex justify-between items-center">
                  <div>
                    <p class="font-mono font-medium">{ip.ip}</p>
                    <p class="text-sm text-gray-500">Sebep: {ip.sebep}</p>
                    <p class="text-xs text-gray-400">{ip.tarih} tarihinde engellendi</p>
                  </div>
                  <form method="POST" onsubmit="return confirm('Engeli kaldırmak istediğinize emin misiniz?')">
                    <input type="hidden" name="tip" value="ip" />
                    <input type="hidden" name="islem" value="ip_sil" />
                    <input type="hidden" name="id" value={ip.id} />
                    <button type="submit" class="text-red-600 hover:text-red-800">Engeli Kaldır</button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</BaseLayout>