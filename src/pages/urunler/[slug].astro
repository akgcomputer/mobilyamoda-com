        <div class="border-b border-gray-200 dark:border-gray-700 px-8 py-5 bg-gray-50 dark:bg-gray-800/50 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center text-yellow-500 text-xl shadow-sm">
            <i class="fas fa-star"></i>
          </div>
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">Değerlendirmeler ({totalReviewCount})</h2>
        </div>
        <div class="p-8">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="md:w-1/3 border-r border-gray-200 dark:border-gray-700 pr-0 md:pr-8">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Değerlendirme Yap</h3>
              <form method="POST" class="space-y-4">
                <input type="hidden" name="action" value="review" />
                <input type="hidden" name="product_id" value={product.id} />
                <input type="hidden" name="user_name" value={user ? user.username : 'Ziyaretçi'} />
                <div>
                  <label class="block text-sm mb-1 text-gray-700 dark:text-gray-300">Puanınız *</label>
                  <select name="rating" required class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                    <option value="5">5 - Mükemmel</option>
                    <option value="4">4 - Çok İyi</option>
                    <option value="3">3 - İdare Eder</option>
                    <option value="2">2 - Kötü</option>
                    <option value="1">1 - Çok Kötü</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm mb-1 text-gray-700 dark:text-gray-300">Yorumunuz</label>
                  <textarea name="comment" rows="3" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white"></textarea>
                </div>
                <button type="submit" class="w-full text-white bg-orange-600 hover:bg-orange-700 font-medium rounded-lg text-sm px-5 py-2.5">Gönder</button>
              </form>
            </div>
            <div class="md:w-2/3">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Müşteri Yorumları</h3>
              {approvedReviews.length === 0 ? (
                <p class="text-gray-500 italic">Henüz yorum yapılmamış. İlk yorum yapan siz olun!</p>
              ) : (
                <div class="space-y-6">
                  {approvedReviews.map(r => (
                    <div class="border-b border-gray-100 dark:border-gray-700 pb-4">
                      <div class="flex items-center gap-2 mb-1">
                        <div class="text-yellow-400 text-sm">
                          {[...Array(5)].map((_, i) => <i class={i < r.rating ? "fas fa-star" : "far fa-star"}></i>)}
                        </div>
                        <span class="font-bold text-gray-900 dark:text-white ml-2">{r.user_name}</span>
                        <span class="text-xs text-gray-500 ml-auto">{new Date(r.createdAt).toLocaleDateString('tr-TR')}</span>
                      </div>
                      {r.comment && <p class="text-gray-700 dark:text-gray-300 mt-2">{r.comment}</p>}
                      <div class="flex items-center gap-4 mt-3 text-xs text-gray-500">
                        <button class="hover:text-green-600"><i class="far fa-thumbs-up"></i> {r.likes}</button>
                        <button class="hover:text-red-600"><i class="far fa-thumbs-down"></i> {r.dislikes}</button>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Soru & Cevap -->
      <div id="qa" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="border-b border-gray-200 dark:border-gray-700 px-8 py-5 bg-gray-50 dark:bg-gray-800/50 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-500 text-xl shadow-sm">
            <i class="fas fa-comments"></i>
          </div>
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">Soru & Cevap ({answeredQAs.length})</h2>
        </div>
        <div class="p-8">
          <div class="flex flex-col md:flex-row gap-8">
            <div class="md:w-1/3 border-r border-gray-200 dark:border-gray-700 pr-0 md:pr-8">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Soru Sor</h3>
              {user ? (
                <form method="POST" class="space-y-4">
                  <input type="hidden" name="action" value="qa" />
                  <input type="hidden" name="product_id" value={product.id} />
                  <input type="hidden" name="user_name" value={user.username} />
                  <p class="text-sm text-gray-600 dark:text-gray-300">Merhaba <strong>{user.username}</strong>, sorunuzu yazabilirsiniz:</p>
                  <div>
                    <textarea name="question" required rows="3" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Sipariş süreci, ürün özellikleri vb. hakkında soru sorun..."></textarea>
                  </div>
                  <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-lg text-sm px-5 py-2.5">Soruyu İlet</button>
                </form>
              ) : (
                <div>
                  <p class="text-gray-700 dark:text-gray-300 mb-4 text-sm leading-relaxed">
                    Değerli misafirimiz sorunuzu sorabilirsiniz, dilerseniz <a href="/login" class="text-orange-600 font-bold hover:underline" target="_blank">üye olarak</a> sorunuzun cevabını panelinizden takip edebilirsiniz.
                  </p>
                  <form method="POST" class="space-y-4">
                    <input type="hidden" name="action" value="qa" />
                    <input type="hidden" name="product_id" value={product.id} />
                    <div>
                      <label class="block text-sm mb-1 text-gray-700 dark:text-gray-300">İsminiz *</label>
                      <input type="text" name="user_name" required placeholder="Sitede görünecek isim" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
                    </div>
                    <div>
                      <label class="block text-sm mb-1 text-gray-700 dark:text-gray-300">Sorunuz *</label>
                      <textarea name="question" required rows="3" class="w-full bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" placeholder="Sorunuzu yazabilirsiniz..."></textarea>
                    </div>
                    <button type="submit" class="w-full text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-lg text-sm px-5 py-2.5">Soruyu İlet</button>
                  </form>
                </div>
              )}
            </div>
            <div class="md:w-2/3">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Sıkça Sorulan Sorular</h3>
              {answeredQAs.length === 0 ? (
                <p class="text-gray-500 italic">Henüz cevaplanmış soru bulunmuyor.</p>
              ) : (
                <div class="space-y-4">
                  {answeredQAs.map(q => (
                    <div class="bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-100 dark:border-gray-700">
                      <div class="mb-3">
                        <span class="inline-block bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs px-2 py-0.5 rounded font-bold mr-2">Soru</span>
                        <strong class="text-gray-900 dark:text-white">{q.user_name}:</strong> {q.question}
                      </div>
                      <div class="pl-4 border-l-2 border-orange-400">
                        <span class="inline-block bg-orange-100 text-orange-800 text-xs px-2 py-0.5 rounded font-bold mr-2">Cevap</span>
                        <span class="text-gray-700 dark:text-gray-300">{q.answer}</span>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- 3. Ürün Detayları -->
      <div id="details" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="border-b border-gray-200 dark:border-gray-700 px-8 py-5 bg-gray-50 dark:bg-gray-800/50 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 text-xl shadow-sm">
            <i class="fas fa-info-circle"></i>
          </div>
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">Ürün Detayları</h2>
        </div>
        <div class="p-8 prose dark:prose-invert max-w-none">
          {product.description ? (
            <div set:html={product.description}></div>
          ) : (
            <p class="text-gray-500 italic">Bu ürün için detaylı bir açıklama girilmemiştir.</p>
          )}

          {product.tags && (
            <div class="mt-8 flex flex-wrap gap-2">
              {product.tags.split(',').map(tag => tag.trim()).filter(Boolean).map(tag => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs rounded-full font-medium">#{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- 4. İade ve Kargo -->
      <div id="shipping" class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="border-b border-gray-200 dark:border-gray-700 px-8 py-5 bg-gray-50 dark:bg-gray-800/50 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-500 text-xl shadow-sm">
            <i class="fas fa-truck"></i>
          </div>
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">İade ve Kargo</h2>
        </div>
        <div class="p-8 prose dark:prose-invert max-w-none">
          <div set:html={shippingInfo}></div>
        </div>
      </div>

    </div>

  </div>

  <div id="product-interactive-data" 
       class="hidden" 
       data-product={productJson} 
       data-main-image={mainImageUrl} 
       data-video={videoUrl} 
       data-gallery={JSON.stringify(gallery)}>
  </div>

  <!-- Script: Dinamik Fiyat, Mini Sepet ve Carousel Galeri -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const dataEl = document.getElementById('product-interactive-data');
      if (!dataEl) return;
      
      let product = { minOrderQty: 1, price: 0, variants: [], wholesalePrices: [], currency: '₺' };
      try {
        product = JSON.parse(dataEl.getAttribute('data-product') || '{}');
      } catch (e) {
        console.error("Product JSON parse error:", e);
      }
      
      const videoUrl = dataEl.getAttribute('data-video');
      
      // Elements
      const mainImage = document.getElementById('mainImage') as any;
      const mainVideo = document.getElementById('mainVideo') as any;
      const prevMediaBtn = document.getElementById('prevMediaBtn');
      const nextMediaBtn = document.getElementById('nextMediaBtn');
      const variantModal = document.getElementById('variantModal');
      const variantModalImage = document.getElementById('variantModalImage') as any;
      const closeVariantModalBtn = document.getElementById('closeVariantModalBtn');
      
      // --- Carousel Galeri Logic ---
      let currentMediaIndex = 0;
      const mediaItems: any[] = [];
      const thumbBtns = document.querySelectorAll('.thumb-btn');
      
      thumbBtns.forEach((btn) => {
        const imgEl = btn.querySelector('img');
        if (imgEl) {
          mediaItems.push({ type: 'image', url: imgEl.src });
        } else if (btn.querySelector('.fa-play')) {
          mediaItems.push({ type: 'video', url: videoUrl });
        }
      });

      function showMedia(index: number) {
        if (mediaItems.length === 0) return;
        
        // Infinite loop navigation
        if (index < 0) index = mediaItems.length - 1;
        if (index >= mediaItems.length) index = 0;
        
        currentMediaIndex = index;
        const item = mediaItems[currentMediaIndex];
        
        if (item.type === 'image') {
          if (mainVideo) {
            mainVideo.classList.add('hidden');
            mainVideo.src = ''; // stop video playback
          }
          if (mainImage) {
            mainImage.src = item.url;
            mainImage.classList.remove('hidden');
          }
        } else if (item.type === 'video') {
          if (mainImage) {
            mainImage.classList.add('hidden');
          }
          if (mainVideo) {
            let embedUrl = item.url;
            const match = item.url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
            if (match && match[1]) {
              embedUrl = 'https://www.youtube.com/embed/' + match[1] + '?autoplay=1';
            }
            mainVideo.src = embedUrl;
            mainVideo.classList.remove('hidden');
          }
        }
        
        // Update active thumbnail border classes
        thumbBtns.forEach((btn, idx) => {
          if (idx === currentMediaIndex) {
            btn.classList.add('border-orange-500', 'border-2');
            btn.classList.remove('border-gray-200', 'dark:border-gray-700', 'opacity-70');
          } else {
            btn.classList.remove('border-orange-500', 'border-2');
            btn.classList.add('border-gray-200', 'dark:border-gray-700', 'opacity-70');
          }
        });
      }

      // Prev / Next button listeners
      prevMediaBtn?.addEventListener('click', () => {
        showMedia(currentMediaIndex - 1);
      });
      nextMediaBtn?.addEventListener('click', () => {
        showMedia(currentMediaIndex + 1);
      });

      // Thumbnail button listeners
      thumbBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.getAttribute('data-index') || '0');
          showMedia(idx);
        });
      });

      // Initialize media gallery
      showMedia(0);

      // Main image click to zoom/modal
      if (mainImage) {
        mainImage.classList.add('cursor-pointer');
        mainImage.addEventListener('click', () => {
          if (variantModal && variantModalImage) {
            variantModalImage.src = mainImage.src;
            variantModal.classList.remove('hidden');
          }
        });
      }

      // Close modal when clicking outside the modal content
      variantModal?.addEventListener('click', (e: any) => {
        if (e.target === variantModal) {
          variantModal.classList.add('hidden');
        }
      });

      // Close modal with explicit close button click
      closeVariantModalBtn?.addEventListener('click', () => {
        variantModal?.classList.add('hidden');
      });

      // Close modal with Escape key
      const handleEscape = (e: any) => {
        if (e.key === 'Escape' && variantModal) {
          variantModal.classList.add('hidden');
        }
      };
      document.addEventListener('keydown', handleEscape);
      
      document.addEventListener('astro:before-swap', () => {
        document.removeEventListener('keydown', handleEscape);
      }, { once: true });

      // Currency formatter
      const formatMoney = (amount: number) => {
        return new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount) + ' ' + (product.currency || '₺');
      };

      // --- Quantity and Cart Logic (Only if elements exist) ---
      const qtyInput = document.getElementById('qtyInput') as HTMLInputElement | null;
      const qtyMinus = document.getElementById('qtyMinus');
      const qtyPlus = document.getElementById('qtyPlus');
      const displayPrice = document.getElementById('displayPrice');
      const totalPriceEl = document.getElementById('totalPrice');
      const variantBtns = document.querySelectorAll('.variant-btn');
      const addToCartBtn = document.getElementById('addToCartBtn');
      const buyNowBtn = document.getElementById('buyNowBtn');

      if (qtyInput && qtyMinus && qtyPlus && displayPrice && totalPriceEl && addToCartBtn) {
        let currentQty = product.minOrderQty;
        let selectedVariant = product.variants.length > 0 ? product.variants.find((v: any) => v.stock > 0) : null;

        // Calculate Price
        const updatePrice = () => {
          let basePrice = product.price;
          let appliedDiscount = 0;
          
          // Check Wholesale Overrides
          if (product.wholesalePrices && product.wholesalePrices.length > 0) {
            // Sort descending by min_qty to find the highest applied tier
            const sortedWP = [...product.wholesalePrices].sort((a,b) => parseInt(b.min_qty) - parseInt(a.min_qty));
            for(let wp of sortedWP) {
              if (currentQty >= parseInt(wp.min_qty)) {
                appliedDiscount = parseFloat(wp.discount_percentage);
                break;
              }
            }
          }

          // Add Variant specific price if it overrides or adds
          let unitPriceBeforeDiscount = basePrice;
          if (selectedVariant && selectedVariant.price) {
            unitPriceBeforeDiscount = selectedVariant.price;
          }

          // Apply discount
          let finalUnitPrice = unitPriceBeforeDiscount * (1 - appliedDiscount / 100);

          // Update UI
          displayPrice.textContent = formatMoney(finalUnitPrice);
          totalPriceEl.textContent = formatMoney(finalUnitPrice * currentQty);

          const discountBadge = document.getElementById('discountBadge');
          if (discountBadge) {
            if (appliedDiscount > 0) {
              discountBadge.textContent = `%${appliedDiscount} Toptan İndirimi Uygulandı!`;
              discountBadge.classList.remove('hidden');
            } else {
              discountBadge.classList.add('hidden');
            }
          }
        };

        // Quantity Handlers
        qtyMinus.addEventListener('click', () => {
          if (currentQty > product.minOrderQty) {
            currentQty--;
            qtyInput.value = String(currentQty);
            updatePrice();
          }
        });

        qtyPlus.addEventListener('click', () => {
          // Check variant stock limit
          if (selectedVariant && currentQty >= selectedVariant.stock) {
            alert('Bu varyasyon için maksimum stok miktarına ulaştınız.');
            return;
          }
          currentQty++;
          qtyInput.value = String(currentQty);
          updatePrice();
        });

        qtyInput.addEventListener('change', (e: any) => {
          let val = parseInt(e.target.value);
          if (isNaN(val) || val < product.minOrderQty) val = product.minOrderQty;
          if (selectedVariant && val > selectedVariant.stock) {
            val = selectedVariant.stock;
            alert('Maksimum stok: ' + selectedVariant.stock);
          }
          currentQty = val;
          qtyInput.value = String(currentQty);
          updatePrice();
        });

        // Variant Selection
        variantBtns.forEach(btn => {
          btn.addEventListener('click', (e: any) => {
            // Remove active class from all
            variantBtns.forEach(b => {
              b.classList.remove('border-orange-500', 'bg-orange-50', 'text-orange-700', 'dark:bg-orange-900/30', 'dark:text-orange-400');
              b.classList.add('border-gray-300', 'dark:border-gray-600');
            });
            
            // Add active to clicked
            const target = e.currentTarget;
            target.classList.remove('border-gray-300', 'dark:border-gray-600');
            target.classList.add('border-orange-500', 'bg-orange-50', 'text-orange-700', 'dark:bg-orange-900/30', 'dark:text-orange-400');
            
            // Update selected Variant
            const vId = parseInt(target.getAttribute('data-id'));
            selectedVariant = product.variants.find((v: any) => v.id === vId);
            
            // Image change if variant has specific image
            const vImage = target.getAttribute('data-image');
            if (vImage && vImage !== 'null') {
              // Find the index of variant image in the mediaItems and slide to it
              const mediaIndex = mediaItems.findIndex((item) => item.url === vImage);
              if (mediaIndex !== -1) {
                showMedia(mediaIndex);
              } else if (mainImage) {
                // If not in gallery, set it directly on main cover
                mainImage.src = vImage;
                if (mainVideo) mainVideo.classList.add('hidden');
                mainImage.classList.remove('hidden');
              }
            }

            // Adjust qty if it exceeds new variant stock
            if (selectedVariant && currentQty > selectedVariant.stock) {
              currentQty = selectedVariant.stock;
              qtyInput.value = String(currentQty);
            }

            updatePrice();
          });
        });

        // Add to Cart Logic (Local Storage)
        const handleAddToCart = (redirect = false) => {
          let cart = [];
          try { cart = JSON.parse(localStorage.getItem('laflaf_cart') || '[]'); } catch(e) {}

          let price = product.price;
          if (selectedVariant && selectedVariant.price) { price = selectedVariant.price; }
          
          let discount = 0;
          if (product.wholesalePrices) {
            const sortedWP = [...product.wholesalePrices].sort((a,b) => parseInt(b.min_qty) - parseInt(a.min_qty));
            for(let wp of sortedWP) {
              if (currentQty >= parseInt(wp.min_qty)) { 
                discount = parseFloat(wp.discount_percentage); 
                break; 
              }
            }
          }
          let finalPrice = price * (1 - discount / 100);

          const cartItem = {
            id: product.id + (selectedVariant ? '-' + selectedVariant.id : ''),
            product_id: product.id,
            name: product.name,
            variant_name: selectedVariant ? selectedVariant.name : null,
            variant_id: selectedVariant ? selectedVariant.id : null,
            qty: currentQty,
            price: finalPrice,
            image: (selectedVariant && selectedVariant.image_url) ? selectedVariant.image_url : product.image,
            unit: product.unit
          };

          const existingIdx = cart.findIndex((item: any) => item.id === cartItem.id);
          if (existingIdx !== -1) {
            cart[existingIdx].qty += currentQty;
            // recalculate price
            let newTotalQty = cart[existingIdx].qty;
            let newBasePrice = product.price;
            if (selectedVariant && selectedVariant.price) newBasePrice = selectedVariant.price;
            let newDiscount = 0;
            if (product.wholesalePrices) {
              const sortedWP = [...product.wholesalePrices].sort((a,b) => parseInt(b.min_qty) - parseInt(a.min_qty));
              for(let wp of sortedWP) {
                if (newTotalQty >= parseInt(wp.min_qty)) { 
                  newDiscount = parseFloat(wp.discount_percentage); 
                  break; 
                }
              }
            }
            cart[existingIdx].price = newBasePrice * (1 - newDiscount / 100);
          } else {
            cart.push(cartItem);
          }

          localStorage.setItem('laflaf_cart', JSON.stringify(cart));
          window.dispatchEvent(new Event('cart_updated'));

          if (redirect) {
            window.location.href = '/checkout';
          } else {
            const originalText = addToCartBtn.innerHTML;
            addToCartBtn.innerHTML = '<i class="fas fa-check"></i> Eklendi!';
            addToCartBtn.classList.replace('border-orange-500', 'bg-green-600');
            addToCartBtn.classList.replace('text-orange-600', 'text-white');
            
            setTimeout(() => {
              addToCartBtn.innerHTML = originalText;
              addToCartBtn.classList.replace('bg-green-600', 'border-orange-500');
              addToCartBtn.classList.replace('text-white', 'text-orange-600');
            }, 2000);
          }
        };

        addToCartBtn.addEventListener('click', () => handleAddToCart(false));
        buyNowBtn?.addEventListener('click', () => handleAddToCart(true));

        // Initial price calculation
        updatePrice();
      }

      // Favorites Logic
      const favBtn = document.getElementById('favBtn');
      const updateFavIcon = () => {
        if (!favBtn) return;
        let favs: any[] = [];
        try { favs = JSON.parse(localStorage.getItem('laflaf_favs') || '[]'); } catch(e){}
        if (favs.includes(product.id)) {
          favBtn.innerHTML = '<i class="fas fa-heart text-xl"></i>';
        } else {
          favBtn.innerHTML = '<i class="far fa-heart text-xl"></i>';
        }
      };
      updateFavIcon();

      if (favBtn) {
        favBtn.addEventListener('click', () => {
          let favs: any[] = [];
          try { favs = JSON.parse(localStorage.getItem('laflaf_favs') || '[]'); } catch(e){}
          
          const countSpan = document.getElementById('likeCountDisplay');
          
          if (favs.includes(product.id)) {
            favs = favs.filter(id => id !== product.id);
            if (countSpan) countSpan.innerText = String(Math.max(0, parseInt(countSpan.innerText) - 1));
          } else {
            favs.push(product.id);
            if (countSpan) countSpan.innerText = String(parseInt(countSpan.innerText) + 1);
          }
          localStorage.setItem('laflaf_favs', JSON.stringify(favs));
          updateFavIcon();
        });
      }
    });
  </script>
</BaseLayout>
