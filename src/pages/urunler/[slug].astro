---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProductBySlug, getBrands, getProductReviews, getProductQA, createProductReview, createProductQuestion, getBadges } from '../../lib/db';

const { slug } = Astro.params;
const dbBinding = Astro.locals.runtime?.env?.DB;

let basari = '';
let hata = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;
    const product_id = parseInt(formData.get('product_id') as string);
    const user_name = formData.get('user_name') as string;

    if (action === 'review') {
      const rating = parseInt(formData.get('rating') as string);
      const comment = formData.get('comment') as string;
      if (!user_name || !rating) throw new Error("İsim ve Puan zorunludur.");
      await createProductReview({ product_id, user_name, rating, comment }, dbBinding);
      basari = 'Değerlendirmeniz alındı. Onaylandıktan sonra yayınlanacaktır.';
    } else if (action === 'qa') {
      const question = formData.get('question') as string;
      if (!user_name || !question) throw new Error("İsim ve Soru zorunludur.");
      await createProductQuestion({ product_id, user_name, question }, dbBinding);
      basari = 'Sorunuz alındı. Mağaza yanıtladıktan sonra yayınlanacaktır.';
    }
  } catch (err: any) {
    hata = err.message || 'Bir hata oluştu.';
  }
}

const product = await getProductBySlug(slug as string, dbBinding);

if (!product) {
  return Astro.redirect('/404');
}

const brands = await getBrands(dbBinding);
const brand = product.brand_id ? brands.find((b: any) => b.id === product.brand_id) : null;

// JSON Serialize for Client-Side JS
const productJson = JSON.stringify({
  id: product.id,
  name: product.name,
  price: product.price,
  unit: product.unit || 'Adet',
  minOrderQty: product.min_order_qty || 1,
  variants: product.variants || [],
  wholesalePrices: product.wholesalePrices || [],
  image: product.image_url,
  currency: product.currency || '₺'
});

// JSON parse the new fields
const badges = product.badges ? (typeof product.badges === 'string' ? JSON.parse(product.badges) : product.badges) : [];
const features = product.features ? (typeof product.features === 'string' ? JSON.parse(product.features) : product.features) : null;
const gallery = product.gallery_images ? (typeof product.gallery_images === 'string' ? JSON.parse(product.gallery_images) : product.gallery_images) : [];
const isOutOfStock = product.allow_backorder === 1 ? false : (
  product.variants && product.variants.length > 0 
    ? product.variants.reduce((acc: number, v: any) => acc + v.stock, 0) === 0 
    : product.stock === 0
);

// Format Price
const formatPrice = (p: number) => {
  return new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(p) + ' ' + (product.currency || '₺');
};

// Yorum ve Soru Cevap Verilerini Çek
const productReviews = await getProductReviews(product.id, dbBinding);
const productQAs = await getProductQA(product.id, dbBinding);
const approvedReviews = productReviews.filter(r => r.status === 'approved');
const answeredQAs = productQAs.filter(q => q.status === 'answered');

// Calculate Stats for header
let totalReviewCount = approvedReviews.length;
let thumbsUp = approvedReviews.filter(r => r.rating >= 2).length;
let thumbsDown = approvedReviews.filter(r => r.rating === 1).length;

if (totalReviewCount === 0) {
  totalReviewCount = 100 + (product.id * 137) % 901; 
  thumbsUp = Math.floor(totalReviewCount * 0.95);
  thumbsDown = totalReviewCount - thumbsUp;
}

const avgRating = (thumbsUp * 5 + thumbsDown * 1) / totalReviewCount;
const starsCount = Math.round(avgRating) || 5;
const stars = Array(starsCount).fill('⭐').join('');

const user = Astro.cookies.has('user_session') ? Astro.cookies.get('user_session')?.json() : null;

import { getSettings } from '../../lib/db';
const siteSettings = await getSettings(dbBinding);
const shippingInfo = siteSettings.return_shipping_info || '<p>Standart iade ve kargo şartları geçerlidir. İade süreci hakkında daha detaylı bilgiyi Müşteri Hizmetleri üzerinden alabilirsiniz.</p>';
const videoUrl = product.video_url || null;
const mainImageUrl = product.image_url || null;
---

<BaseLayout title={`${product.name} | Laflaf E-Ticaret`}>
  
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    
    <!-- Breadcrumb -->
    <nav class="flex text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-orange-600 transition">Ana Sayfa</a>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-xs mx-2"></i>
            <a href="/urunler" class="hover:text-orange-600 transition">Ürünler</a>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center text-gray-800 dark:text-gray-200 font-semibold">
            <i class="fas fa-chevron-right text-xs mx-2 text-gray-500"></i>
            {product.name}
          </div>
        </li>
      </ol>
    </nav>

    {basari && (
      <div class="p-4 mb-6 text-sm text-green-800 rounded-lg bg-green-50 dark:bg-gray-800 dark:text-green-400 border border-green-200">
        {basari}
      </div>
    )}
    {hata && (
      <div class="p-4 mb-6 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400 border border-red-200">
        {hata}
      </div>
    )}

    <div class="flex flex-col lg:flex-row gap-10">
      
      <!-- Sol: Görsel (Galeri Altyapılı) -->
      <div class="lg:w-1/2">
        <div class="sticky top-24">
          <div class="bg-gray-100 dark:bg-gray-800 rounded-2xl overflow-hidden aspect-[3/4] md:aspect-[4/5] lg:aspect-square relative border border-gray-200 dark:border-gray-700 shadow-sm flex items-center justify-center group">
            
            {/* Videolu Rozeti */}
            {product.video_url && (
              <span class="absolute top-4 left-1/2 -translate-x-1/2 z-10 bg-red-600 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-md uppercase tracking-wider flex items-center gap-1 pointer-events-none">
                <i class="fas fa-play animate-pulse"></i> Videolu Ürün
              </span>
            )}

            <!-- Rozetler -->
            {product.badge_top_left && (
              <div class="absolute top-4 left-4 z-10 flex flex-col gap-2 transform -rotate-12 origin-top-left pointer-events-none">
                {product.badge_top_left.startsWith('http') || product.badge_top_left.startsWith('/') 
                  ? <img src={product.badge_top_left} class="h-10 object-contain drop-shadow-lg" />
                  : <span class="text-xs font-extrabold px-3 py-1.5 rounded-lg shadow-lg uppercase tracking-widest text-center bg-red-500 text-white">{product.badge_top_left}</span>
                }
              </div>
            )}
            
            {product.badge_top_right && (
              <div class="absolute top-4 right-4 z-10 flex flex-col gap-2 transform rotate-12 origin-top-right pointer-events-none">
                {product.badge_top_right.startsWith('http') || product.badge_top_right.startsWith('/') 
                  ? <img src={product.badge_top_right} class="h-10 object-contain drop-shadow-lg" />
                  : <span class="text-xs font-extrabold px-3 py-1.5 rounded-lg shadow-lg uppercase tracking-widest text-center bg-red-500 text-white">{product.badge_top_right}</span>
                }
              </div>
            )}
            
            {badges.find((b:any) => b.position === 'bottom-left') && (
              <div class="absolute bottom-4 left-4 z-10 flex flex-col gap-2 transform rotate-12 origin-bottom-left pointer-events-none">
                {(() => {
                  const bd = badges.find((b:any) => b.position === 'bottom-left');
                  return bd.type === 'image' || bd.content.startsWith('http') || bd.content.startsWith('/')
                    ? <img src={bd.content} class="h-10 object-contain drop-shadow-lg" />
                    : <span class="text-xs font-extrabold px-3 py-1.5 rounded-lg shadow-lg uppercase tracking-widest text-center bg-red-500 text-white">{bd.content}</span>
                })()}
              </div>
            )}

            {badges.find((b:any) => b.position === 'bottom-right') && (
              <div class="absolute bottom-4 right-4 z-10 flex flex-col gap-2 transform -rotate-12 origin-bottom-right pointer-events-none">
                {(() => {
                  const bd = badges.find((b:any) => b.position === 'bottom-right');
                  return bd.type === 'image' || bd.content.startsWith('http') || bd.content.startsWith('/')
                    ? <img src={bd.content} class="h-10 object-contain drop-shadow-lg" />
                    : <span class="text-xs font-extrabold px-3 py-1.5 rounded-lg shadow-lg uppercase tracking-widest text-center bg-red-500 text-white">{bd.content}</span>
                })()}
              </div>
            )}

            <!-- Left and Right navigation arrows -->
            <button type="button" id="prevMediaBtn" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/90 hover:bg-white text-gray-800 dark:bg-gray-900/90 dark:hover:bg-gray-900 dark:text-white flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Önceki Görsel">
              <i class="fas fa-chevron-left text-base"></i>
            </button>

            <button type="button" id="nextMediaBtn" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/90 hover:bg-white text-gray-800 dark:bg-gray-900/90 dark:hover:bg-gray-900 dark:text-white flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-105" aria-label="Sonraki Görsel">
              <i class="fas fa-chevron-right text-base"></i>
            </button>
            
            {product.image_url ? (
              <img id="mainImage" src={product.image_url} alt={product.name} class="w-full h-full object-cover transition-opacity duration-300" />
            ) : (
              <i class="fas fa-image text-6xl text-gray-300 dark:text-gray-600"></i>
            )}
            <iframe id="mainVideo" class="hidden w-full h-full object-cover absolute top-0 left-0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          
          <!-- Mini Galeri (Sıralama: Ana resim -> Video -> Diğer görseller) -->
          <div class="flex gap-3.5 mt-4 overflow-x-auto pb-2 scrollable-x" id="thumbnailsContainer">
            {/* Dinamik sıralı butonlar client scripti ile eşlenecek */}
            {(() => {
              let idx = 0;
              const thumbs = [];
              
              if (product.image_url) {
                thumbs.push(
                  <button type="button" class="thumb-btn w-20 h-20 rounded-lg overflow-hidden border-2 border-orange-500 flex-shrink-0 transition-all duration-200 outline-none" data-index={idx++}>
                    <img src={product.image_url} class="w-full h-full object-cover" />
                  </button>
                );
              }
              
              if (product.video_url) {
                thumbs.push(
                  <button type="button" class="thumb-btn w-20 h-20 rounded-lg border border-red-200 dark:border-red-900 bg-red-50 dark:bg-red-900/20 text-red-600 flex-shrink-0 flex items-center justify-center hover:bg-red-100 transition shadow-sm relative group overflow-hidden outline-none" data-index={idx++}>
                    <i class="fas fa-play text-2xl group-hover:scale-110 transition-transform"></i>
                    <span class="absolute bottom-1 text-[8px] uppercase tracking-wider font-extrabold bg-red-600 text-white px-1 rounded">VİDEO</span>
                  </button>
                );
              }
              
              gallery.forEach((img: string) => {
                thumbs.push(
                  <button type="button" class="thumb-btn w-20 h-20 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 flex-shrink-0 opacity-70 hover:opacity-100 transition-all duration-200 outline-none" data-index={idx++}>
                    <img src={img} class="w-full h-full object-cover" />
                  </button>
                );
              });
              
              return thumbs;
            })()}
          </div>
        </div>
      </div>

      <!-- Sağ: Ürün Bilgileri -->
      <div class="lg:w-1/2 flex flex-col">
        
        {brand && (
          <div class="text-sm font-bold text-orange-600 uppercase tracking-widest mb-2">{brand.name}</div>
        )}
        
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white leading-tight mb-4">
          {product.name}
        </h1>
        
        <!-- İstatistikler Header -->
        <div class="flex flex-wrap items-center gap-3 text-sm font-semibold text-gray-700 dark:text-gray-300 mb-6 bg-gray-50 dark:bg-gray-800/50 p-3 rounded-xl border border-gray-100 dark:border-gray-700 w-fit">
          <div class="flex items-center text-yellow-500 tracking-widest">{starsCount}{stars}</div>
          <div class="w-px h-4 bg-gray-300 dark:bg-gray-600"></div>
          <div class="flex items-center gap-2">
            <span class="text-green-600">{thumbsUp} 👍</span>
            <span class="text-red-500">{thumbsDown} 👎🏾</span>
          </div>
          <div class="w-px h-4 bg-gray-300 dark:bg-gray-600"></div>
          <a href="#qa" class="flex items-center gap-1 hover:text-orange-500 transition cursor-pointer">
            <span class="text-blue-500">💬❓</span> Soru-Cevap
          </a>
          <div class="w-px h-4 bg-gray-300 dark:bg-gray-600"></div>
          <div class="flex items-center gap-1">
            <span class="text-red-500">❤️</span> <span id="likeCountDisplay">{product.likes || 0}</span>
          </div>
        </div>
        
        <!-- Kısa Açıklama -->
        {product.excerpt && (
          <p class="text-gray-600 dark:text-gray-400 text-lg mb-8 leading-relaxed">
            {product.excerpt}
          </p>
        )}
        
        <!-- Fiyat Gösterimi -->
        <div class="mb-8">
          <div class="flex items-end gap-4">
            <div class="text-4xl font-extrabold text-gray-900 dark:text-white" id="displayPrice">
              {formatPrice(product.price)}
            </div>
            {product.compare_at_price && product.compare_at_price > product.price && (
              <div class="text-xl text-gray-500 line-through mb-1">
                {formatPrice(product.compare_at_price)}
              </div>
            )}
          </div>
          <div class="text-sm text-gray-500 mt-2 flex items-center gap-2">
            <i class="fas fa-info-circle"></i> Fiyat <span class="font-bold">{product.unit || 'Adet'}</span> bazındadır. Vergiler dahildir.
          </div>
        </div>

        <!-- Varyasyonlar -->
        {product.variants && product.variants.length > 0 && (
          <div class="mb-8">
            <h3 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Seçenekler (Varyasyon)</h3>
            <div class="flex flex-wrap gap-3" id="variantsContainer">
              {product.variants.map((v: any, index: number) => (
                <button 
                  type="button" 
                  class={`variant-btn flex flex-col items-center px-4 py-3 rounded-lg border-2 text-sm font-semibold transition ${
                    v.stock > 0 
                      ? (index === 0 ? 'border-orange-500 bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400' : 'border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:text-white')
                      : 'border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-400 cursor-not-allowed opacity-60'
                  }`}
                  data-id={v.id}
                  data-price={v.price}
                  data-stock={v.stock}
                  data-name={v.name}
                  data-image={v.image_url}
                  disabled={v.stock <= 0}
                >
                  <span class="mb-1">{v.name}</span>
                  {v.price && <span class="text-xs font-normal opacity-80 mb-1">+{formatPrice(v.price - product.price)} Fark</span>}
                  {v.image_url && (
                    <div class="mt-1 flex justify-center w-full" onclick="(function(e){ e.stopPropagation(); document.getElementById('variantModalImage').src=e.currentTarget.querySelector('img').src; document.getElementById('variantModal').classList.remove('hidden'); })(event)">
                      <img src={v.image_url} class="w-12 h-12 object-cover rounded shadow-sm hover:scale-110 transition-transform" />
                    </div>
                  )}
                  {v.stock <= 0 && <span class="text-xs text-red-500 mt-1 font-bold">Tükendi</span>}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Varyant Görsel Modalı (Zoom Modal) -->
        <div id="variantModal" class="hidden fixed inset-0 z-[100] bg-black/90 flex flex-col items-center justify-center p-4 backdrop-blur-md transition-all duration-300">
          <div class="relative max-w-5xl max-h-[90vh] flex items-center justify-center">
            <button type="button" id="closeVariantModalBtn" class="absolute -top-12 right-0 md:-right-12 text-white text-4xl hover:text-red-500 transition-colors focus:outline-none bg-black/40 hover:bg-black/80 w-12 h-12 rounded-full flex items-center justify-center shadow-lg border border-white/20 font-light" aria-label="Kapat">&times;</button>
            <img id="variantModalImage" src="" class="max-w-full max-h-[80vh] md:max-h-[90vh] rounded-xl shadow-2xl object-contain border border-gray-700 bg-gray-950 transition-all duration-350" />
          </div>
        </div>

        <!-- Toptan Fiyat Tablosu -->
        {product.wholesalePrices && product.wholesalePrices.length > 0 && (
          <div class="mb-8 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-4">
            <h3 class="text-sm font-bold text-green-800 dark:text-green-400 flex items-center gap-2 mb-3">
              <i class="fas fa-tags"></i> Toptan Alım İndirimleri
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm">
              <div class="bg-white dark:bg-gray-800 border border-green-100 dark:border-green-900 p-2 rounded text-center">
                <div class="font-bold text-gray-900 dark:text-white">1 - {(product.wholesalePrices[0].min_qty - 1)} {product.unit}</div>
                <div class="text-gray-500 font-semibold">İndirimsiz</div>
              </div>
              {product.wholesalePrices.map((wp: any, i: number, arr: any[]) => {
                const next = arr[i+1];
                const range = next ? `${wp.min_qty} - ${next.min_qty - 1}` : `${wp.min_qty}+`;
                return (
                  <div class="bg-white dark:bg-gray-800 border border-green-100 dark:border-green-900 p-2 rounded text-center shadow-sm">
                    <div class="font-bold text-gray-900 dark:text-white">{range} {product.unit}</div>
                    <div class="text-green-600 font-bold">%{(wp as any).discount_percentage} İndirim</div>
                  </div>
                )
              })}
            </div>
          </div>
        )}

        <!-- İşlem (Adet + Sepete Ekle) -->
        <div class="mt-auto bg-gray-50 dark:bg-gray-900/50 p-5 rounded-2xl border border-gray-200 dark:border-gray-700">
          {isOutOfStock ? (
            <div class="mb-4">
              <button disabled class="w-full bg-gray-300 dark:bg-gray-700 text-gray-500 dark:text-gray-400 text-base font-bold py-3 px-4 rounded-xl cursor-not-allowed uppercase tracking-widest flex items-center justify-center gap-2">
                <i class="fas fa-box-open"></i> Tükendi
              </button>
            </div>
          ) : (
            <div class="flex flex-col sm:flex-row gap-3 mb-4">
              <div class="w-full sm:w-28 flex items-center border border-gray-300 dark:border-gray-600 rounded-xl overflow-hidden bg-white dark:bg-gray-800">
                <button type="button" id="qtyMinus" class="w-8 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                  <i class="fas fa-minus text-xs"></i>
                </button>
                <input type="number" id="qtyInput" value={product.min_order_qty || 1} min={product.min_order_qty || 1} class="w-full h-10 text-center text-base font-bold border-0 bg-transparent focus:ring-0 p-0 dark:text-white" />
                <button type="button" id="qtyPlus" class="w-8 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                  <i class="fas fa-plus text-xs"></i>
                </button>
              </div>
              
              <button id="addToCartBtn" class="flex-1 bg-white border-2 border-orange-500 text-orange-600 hover:bg-orange-50 dark:bg-transparent dark:border-orange-500 dark:text-orange-500 dark:hover:bg-orange-500/10 text-sm font-bold py-2 px-3 rounded-xl transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
                <i class="fas fa-cart-plus"></i> Sepete Ekle
              </button>
              <button id="buyNowBtn" class="flex-1 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold py-2 px-3 rounded-xl shadow-md hover:shadow-orange-500/30 transition-all flex items-center justify-center gap-2 uppercase tracking-wide">
                <i class="fas fa-bolt"></i> Şimdi Al
              </button>
              <button id="favBtn" class="w-10 h-10 sm:w-11 sm:h-11 bg-red-50 hover:bg-red-100 dark:bg-red-900/20 dark:hover:bg-red-900/40 text-red-500 rounded-xl flex items-center justify-center transition flex-shrink-0" title="Favorilere Ekle" data-id={product.id}>
                <i class="far fa-heart text-lg"></i>
              </button>
            </div>
          )}
          
          <div class="flex justify-between items-center text-sm border-b border-gray-200 dark:border-gray-700 pb-4 mb-4">
            <span class="text-gray-500">Minimum Sipariş: <strong class="text-gray-700 dark:text-gray-300">{product.min_order_qty || 1} {product.unit}</strong></span>
            
            <div class="text-right flex flex-col">
              <span id="discountBadge" class="hidden text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded-full self-end mb-1 font-bold"></span>
              <div>
                <span class="text-gray-500 mr-2">Toplam:</span>
                <span id="totalPrice" class="text-xl font-extrabold text-orange-600">
                  {formatPrice(product.price * (product.min_order_qty || 1))}
                </span>
              </div>
            </div>
          </div>

          <!-- Satıcı & Kargo Bilgileri -->
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div class="flex flex-col gap-1">
              <span class="text-gray-500"><i class="fas fa-store w-4"></i> Satıcı:</span>
              <span class="font-semibold text-gray-900 dark:text-white">{product.seller_name || 'Laflaf'}</span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-gray-500"><i class="fas fa-truck w-4"></i> Kargo:</span>
              <span class="font-semibold text-gray-900 dark:text-white">{product.shipping_time || 'Standart Gönderim'}</span>
            </div>
          </div>

          {features && Object.keys(features).length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
              <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-3 uppercase tracking-wider">Öne Çıkan Özellikler</h3>
              <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                {Object.entries(features).slice(0, 6).map(([key, val]) => (
                  <div class="flex flex-col border-b border-gray-100 dark:border-gray-800 pb-1">
                    <span class="text-gray-500 text-xs">{key}</span>
                    <span class="text-gray-900 dark:text-white font-medium truncate" title={val as string}>{val as string}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

      </div>
    </div>

    <!-- İçerik Bölümleri (Sıralı Liste) -->
    <div class="mt-16 space-y-10">

      <!-- 1. Değerlendirmeler -->
