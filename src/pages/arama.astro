---
import BaseLayout from '../layouts/BaseLayout.astro';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout title={`"${query}" Arama Sonuçları | Laflaf`} description="Laflaf.net'te aradığınız her şeyi keşfedin.">
  <div class="min-h-[70vh]">
    <div class="max-w-4xl mx-auto mb-10 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">Arama Sonuçları</h1>
      
      <!-- Arama Kutusu -->
      <div class="relative max-w-2xl mx-auto">
        <input 
          type="text" 
          id="searchPageInput"
          autocomplete="off"
          value={query}
          placeholder="Yeniden arama yapın..." 
          class="w-full py-4 pl-6 pr-14 rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 focus:border-purple-500 focus:ring-2 focus:ring-purple-200 dark:focus:ring-purple-900 focus:outline-none text-gray-900 dark:text-white text-lg shadow-sm transition"
        >
        <button id="searchPageSubmit" class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center bg-purple-500 hover:bg-purple-600 text-white rounded-full transition">
          <i class="fas fa-search"></i>
        </button>
      </div>
    </div>

    <!-- Sonuçlar -->
    <div id="resultsContainer" class="masonry-grid" data-query={query}>
      <!-- AJAX ile doldurulacak -->
    </div>
    
    <!-- Yükleniyor Durumu -->
    <div id="searchLoading" class="hidden text-center py-16">
      <i class="fas fa-spinner fa-spin text-4xl text-purple-500 mb-4"></i>
      <p class="text-gray-500 dark:text-gray-400">Sonuçlar aranıyor...</p>
    </div>

    <!-- Sonuç Bulunamadı Durumu -->
    <div id="searchEmpty" class="hidden text-center py-16">
      <i class="fas fa-search text-6xl text-gray-300 dark:text-gray-700 mb-6"></i>
      <h3 class="text-2xl font-semibold mb-2">Sonuç Bulunamadı</h3>
      <p class="text-gray-500 dark:text-gray-400">Farklı anahtar kelimelerle tekrar deneyebilirsiniz.</p>
    </div>
  </div>

  <style is:global>
    .masonry-grid {
      column-count: 2;
      column-gap: 1.25rem;
    }
    @media (min-width: 768px) {
      .masonry-grid { column-count: 3; }
    }
    @media (min-width: 1024px) {
      .masonry-grid { column-count: 4; }
    }
    
    .grid-item {
      break-inside: avoid;
      margin-bottom: 1.25rem;
    }
    
    .card-hover-effect {
      position: relative;
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .card-hover-effect:hover {
      transform: scale(1.02);
      box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.4);
    }
  </style>

  <script>
  document.addEventListener('astro:page-load', () => {
    const borderColors = [
      'border-red-200 dark:border-red-800',
      'border-orange-200 dark:border-orange-800',
      'border-amber-200 dark:border-amber-800',
      'border-green-200 dark:border-green-800',
      'border-emerald-200 dark:border-emerald-800',
      'border-teal-200 dark:border-teal-800',
      'border-cyan-200 dark:border-cyan-800',
      'border-blue-200 dark:border-blue-800',
      'border-indigo-200 dark:border-indigo-800',
      'border-violet-200 dark:border-violet-800',
      'border-purple-200 dark:border-purple-800',
      'border-fuchsia-200 dark:border-fuchsia-800',
      'border-pink-200 dark:border-pink-800',
      'border-rose-200 dark:border-rose-800'
    ];

    const searchInput = document.getElementById('searchPageInput');
    const searchBtn = document.getElementById('searchPageSubmit');
    const resultsContainer = document.getElementById('resultsContainer');
    const searchLoading = document.getElementById('searchLoading');
    const searchEmpty = document.getElementById('searchEmpty');
    
    function formatNumber(num) {
      if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
      if (num >= 1000) return (num / 1000).toFixed(1) + 'k';
      return num.toString();
    }

    async function doSearch(q) {
      if (!q) {
        if (resultsContainer) resultsContainer.innerHTML = '';
        if (searchEmpty) searchEmpty.classList.remove('hidden');
        return;
      }
      
      if (resultsContainer) resultsContainer.innerHTML = '';
      if (searchEmpty) searchEmpty.classList.add('hidden');
      if (searchLoading) searchLoading.classList.remove('hidden');
      
      try {
        const res = await fetch('/api/search?q=' + encodeURIComponent(q));
        const data = await res.json();
        
        if (searchLoading) searchLoading.classList.add('hidden');
        
        if (data.length === 0) {
          if (searchEmpty) searchEmpty.classList.remove('hidden');
          return;
        }
        
        let html = '';
        data.forEach(item => {
          const catSlug = item.category ? item.category.slug : 'genel';
          const catName = item.category ? item.category.name : 'Genel';
          const randomBorder = borderColors[Math.floor(Math.random() * borderColors.length)];
          
          let imgHtml = item.imageUrl 
            ? `<img src="${item.imageUrl}" alt="${item.title}" loading="lazy" class="w-full h-auto rounded-xl object-cover" />`
            : `<div class="aspect-[4/5] flex flex-col items-center justify-center p-6 text-center rounded-xl bg-gradient-to-br from-gray-200 to-gray-300 dark:from-gray-800 dark:to-gray-900"><i class="fas fa-image text-4xl mb-3 text-gray-500"></i><p class="font-semibold text-gray-700 dark:text-gray-300 line-clamp-3">${item.title}</p></div>`;
            
          html += `
            <div class="grid-item">
              <article class="card-hover-effect group border border-solid ${randomBorder} rounded-xl p-2 bg-white dark:bg-gray-800/20">
                <a href="/${catSlug}/${item.slug}" class="block">
                  ${imgHtml}
                </a>
                <div class="mt-3 px-1">
                  <div class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-400 mb-2">
                    <span class="flex items-center gap-1 whitespace-nowrap"><i class="far fa-eye"></i> ${formatNumber(item.views || 0)}</span>
                    <span class="flex items-center gap-1 whitespace-nowrap"><i class="far fa-heart"></i> ${formatNumber(item.likes || 0)}</span>
                  </div>
                  <a href="/${catSlug}" class="text-xs text-purple-500 hover:text-purple-400">${catName}</a>
                  <a href="/${catSlug}/${item.slug}">
                    <h3 class="text-sm font-medium mt-1 line-clamp-2 hover:text-purple-400 transition text-gray-800 dark:text-gray-100">${item.title}</h3>
                  </a>
                </div>
              </article>
            </div>
          `;
        });
        
        if (resultsContainer) resultsContainer.innerHTML = html;
        
      } catch (e) {
        if (searchLoading) searchLoading.classList.add('hidden');
        if (searchEmpty) {
          searchEmpty.classList.remove('hidden');
          const h3 = searchEmpty.querySelector('h3');
          if (h3) h3.textContent = 'Bir hata oluştu';
        }
      }
    }

    const initQuery = resultsContainer?.getAttribute('data-query');
    if (initQuery) {
      doSearch(initQuery);
    }

    searchBtn?.addEventListener('click', () => {
      const q = searchInput?.value.trim();
      if (q) {
        window.history.pushState({}, '', '/arama?q=' + encodeURIComponent(q));
        doSearch(q);
      }
    });

    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = searchInput.value.trim();
        if (q) {
          window.history.pushState({}, '', '/arama?q=' + encodeURIComponent(q));
          doSearch(q);
        }
      }
    });
  });
  </script>
</BaseLayout>
