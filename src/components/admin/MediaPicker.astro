---
export interface Props {
  inputId: string; // The ID of the input field to populate with the selected image URL
}

const { inputId } = Astro.props;
---

<!-- Sistemden Ekle Butonu -->
<button type="button" onclick="openMediaPicker()" class="px-4 py-2 bg-indigo-50 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400 rounded hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition border border-indigo-200 dark:border-indigo-800 flex items-center justify-center gap-2">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
  Sistemden Seç
</button>

<!-- Media Picker Modal -->
<div id="mediaPickerModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4">
  <div class="bg-white dark:bg-gray-800 w-full max-w-4xl rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
    <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center bg-gray-50 dark:bg-gray-900">
      <h3 class="text-lg font-bold text-gray-900 dark:text-white">Medyalardan Seç</h3>
      <button type="button" onclick="closeMediaPicker()" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    
    <div class="p-4 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
      <input type="text" id="mediaPickerSearch" placeholder="Görsel ara..." class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white focus:ring-2 focus:ring-orange-500 focus:border-transparent outline-none" />
    </div>

    <div class="p-4 flex-1 overflow-y-auto">
      <div id="mediaPickerLoading" class="text-center py-8 text-gray-500">Yükleniyor...</div>
      <div id="mediaPickerGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 hidden">
        <!-- JS will populate this -->
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ inputId }}>
  let mediaFiles = [];
  const modal = document.getElementById('mediaPickerModal');
  const grid = document.getElementById('mediaPickerGrid');
  const loading = document.getElementById('mediaPickerLoading');
  const searchInput = document.getElementById('mediaPickerSearch');
  
  window.openMediaPicker = async function() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    if (mediaFiles.length === 0) {
      try {
        loading.classList.remove('hidden');
        grid.classList.add('hidden');
        
        const res = await fetch('/api/media/list.json');
        mediaFiles = await res.json();
        
        renderMedia(mediaFiles);
      } catch (err) {
        loading.innerHTML = 'Medyalar yüklenirken hata oluştu.';
      }
    }
  }
  
  window.closeMediaPicker = function() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
  
  window.selectMedia = function(url) {
    const inputField = document.getElementById(inputId);
    if (inputField) {
      inputField.value = url;
      // Eğer resim önizlemesi yapan bir kod varsa tetiklemek için change event gönder
      inputField.dispatchEvent(new Event('input', { bubbles: true }));
      inputField.dispatchEvent(new Event('change', { bubbles: true }));
    }
    closeMediaPicker();
  }
  
  function renderMedia(files) {
    loading.classList.add('hidden');
    grid.classList.remove('hidden');
    
    grid.innerHTML = files.map(file => `
      <div onclick="selectMedia('${file.url}')" class="cursor-pointer group rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-500 transition shadow-sm hover:shadow-md bg-white dark:bg-gray-800">
        <div class="aspect-square bg-gray-100 dark:bg-gray-900 relative">
          <img src="${file.url}" alt="${file.name}" class="w-full h-full object-cover group-hover:opacity-90 transition" loading="lazy" />
          <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 flex items-center justify-center transition">
            <span class="text-white font-medium text-sm px-3 py-1 bg-orange-600 rounded-full">Seç</span>
          </div>
        </div>
        <div class="p-2">
          <p class="text-xs text-gray-700 dark:text-gray-300 truncate" title="${file.name}">${file.name}</p>
        </div>
      </div>
    `).join('');
  }
  
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase().trim();
      const filtered = mediaFiles.filter(f => f.name.toLowerCase().includes(term));
      renderMedia(filtered);
    });
  }
</script>
