---
import { getCategories } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
const categories = await getCategories(dbBinding, 'product');
const anaKategoriler = categories.filter(c => !c.parent_id).slice(0, 9);
---

{anaKategoriler.length > 0 && (
  <div class="w-full py-6 overflow-hidden">
    <!-- Yatay Kaydırılabilir Alan -->
    <div class="flex gap-4 overflow-x-auto pb-4 scrollbar-hide px-4 snap-x snap-mandatory" style="scrollbar-width: none; -ms-overflow-style: none;">
      
      {anaKategoriler.map((kat) => (
        <a 
          href={`/urunler?kategori=${kat.slug}`} 
          class="flex flex-col items-center gap-2 group min-w-[80px] snap-center cursor-pointer transition-transform hover:scale-105"
        >
          <!-- Çerçeve / Yuvarlak Görsel (Story Tarzı) -->
          <div class="w-16 h-16 md:w-20 md:h-20 rounded-full border-2 border-orange-500 p-0.5 relative overflow-hidden bg-white shadow-sm group-hover:shadow-md transition-shadow">
            {kat.image_url ? (
              <img 
                src={kat.image_url} 
                alt={kat.name} 
                class="w-full h-full object-cover rounded-full"
              />
            ) : (
              <div class="w-full h-full bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center text-orange-500">
                <i class={`fas ${kat.icon || 'fa-shopping-bag'} text-xl`}></i>
              </div>
            )}
          </div>
          <!-- Kategori Adı -->
          <span class="text-xs md:text-sm font-medium text-gray-800 dark:text-gray-200 text-center line-clamp-1 max-w-[80px]">
            {kat.name}
          </span>
        </a>
      ))}
      
      <a href="/kategoriler" class="flex flex-col items-center gap-2 group min-w-[80px] snap-center cursor-pointer transition-transform hover:scale-105">
        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 flex items-center justify-center group-hover:bg-gray-100 dark:group-hover:bg-gray-700 transition-colors">
          <i class="fas fa-arrow-right text-gray-500 dark:text-gray-400 text-xl"></i>
        </div>
        <span class="text-xs md:text-sm font-medium text-gray-600 dark:text-gray-400 text-center">
          Tümü
        </span>
      </a>

    </div>
  </div>
)}

<style>
  /* Özel Kaydırma Çubuğu Gizleme Stilleri (Fallback) */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
