---
import { getSliders } from '../../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
let sliders = await getSliders(dbBinding);
sliders = sliders.filter(s => s.status === 'aktif');

// Eğer slider yoksa component hiçbir şey render etmesin
if (sliders.length === 0) {
  return;
}
---

<div class="relative w-full max-w-[1600px] mx-auto overflow-hidden group mb-8 md:mb-12" id="heroCarousel">
  
  <!-- Slider Container -->
  <div class="flex transition-transform duration-700 ease-in-out h-[400px] md:h-[500px] lg:h-[600px] w-full" id="carouselInner">
    {sliders.map((slider, index) => (
      <div class="min-w-full h-full relative flex-shrink-0">
        <!-- Arkaplan Görseli -->
        <img 
          src={slider.image_url} 
          alt={slider.title || 'Slider'} 
          class="w-full h-full object-cover"
          loading={index === 0 ? "eager" : "lazy"}
        />
        
        <!-- Karartma (Overlay) -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>
        
        <!-- İçerik -->
        <div class="absolute inset-0 flex flex-col justify-center px-8 md:px-16 lg:px-24">
          <div class="max-w-xl text-left transform transition-all duration-700 translate-y-8 opacity-0 slider-content">
            {slider.title && (
              <h2 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-4 leading-tight drop-shadow-lg">
                {slider.title}
              </h2>
            )}
            
            {slider.subtitle && (
              <p class="text-lg md:text-2xl text-gray-200 mb-8 font-light drop-shadow-md">
                {slider.subtitle}
              </p>
            )}
            
            {slider.button_text && slider.link_url && (
              <a 
                href={slider.link_url} 
                class="inline-block bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 md:py-4 px-8 md:px-10 rounded-full shadow-xl hover:shadow-orange-600/40 hover:-translate-y-1 transition-all duration-300 text-base md:text-lg"
              >
                {slider.button_text}
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Yönlendirme Okları -->
  {sliders.length > 1 && (
    <>
      <button id="carouselPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/20 hover:bg-white/40 backdrop-blur-md rounded-full flex items-center justify-center text-white transition opacity-0 group-hover:opacity-100 focus:outline-none z-10">
        <i class="fas fa-chevron-left text-xl"></i>
      </button>
      <button id="carouselNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-white/20 hover:bg-white/40 backdrop-blur-md rounded-full flex items-center justify-center text-white transition opacity-0 group-hover:opacity-100 focus:outline-none z-10">
        <i class="fas fa-chevron-right text-xl"></i>
      </button>
      
      <!-- Noktalar (Dots) -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex space-x-3 z-10">
        {sliders.map((_, idx) => (
          <button 
            class={`carousel-dot w-3 h-3 rounded-full transition-all duration-300 ${idx === 0 ? 'bg-orange-500 w-8' : 'bg-white/50 hover:bg-white/80'}`}
            data-index={idx}
            aria-label={`Go to slide ${idx + 1}`}
          ></button>
        ))}
      </div>
    </>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carouselInner = document.getElementById('carouselInner');
    const prevBtn = document.getElementById('carouselPrev');
    const nextBtn = document.getElementById('carouselNext');
    const dots = document.querySelectorAll('.carousel-dot');
    const contents = document.querySelectorAll('.slider-content');
    
    if (!carouselInner || contents.length === 0) return;

    const slideCount = contents.length;
    let currentIndex = 0;
    let autoPlayInterval;

    const animateContent = (index) => {
      // Önce hepsini gizle
      contents.forEach(el => {
        el.classList.remove('translate-y-0', 'opacity-100');
        el.classList.add('translate-y-8', 'opacity-0');
      });
      // Sadece aktif olanı göster (gecikmeli)
      setTimeout(() => {
        if (contents[index]) {
          contents[index].classList.remove('translate-y-8', 'opacity-0');
          contents[index].classList.add('translate-y-0', 'opacity-100');
        }
      }, 100);
    };

    const updateSlider = () => {
      carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      // Noktaları güncelle
      dots.forEach((dot, idx) => {
        if (idx === currentIndex) {
          dot.classList.replace('w-3', 'w-8');
          dot.classList.replace('bg-white/50', 'bg-orange-500');
          dot.classList.remove('hover:bg-white/80');
        } else {
          dot.classList.replace('w-8', 'w-3');
          dot.classList.replace('bg-orange-500', 'bg-white/50');
          dot.classList.add('hover:bg-white/80');
        }
      });

      animateContent(currentIndex);
    };

    const nextSlide = () => {
      currentIndex = (currentIndex + 1) % slideCount;
      updateSlider();
    };

    const prevSlide = () => {
      currentIndex = (currentIndex - 1 + slideCount) % slideCount;
      updateSlider();
    };

    const startAutoPlay = () => {
      autoPlayInterval = setInterval(nextSlide, 5000); // 5 saniyede bir
    };

    const stopAutoPlay = () => {
      clearInterval(autoPlayInterval);
    };

    if (nextBtn && prevBtn) {
      nextBtn.addEventListener('click', () => {
        nextSlide();
        stopAutoPlay();
        startAutoPlay();
      });

      prevBtn.addEventListener('click', () => {
        prevSlide();
        stopAutoPlay();
        startAutoPlay();
      });

      dots.forEach((dot, idx) => {
        dot.addEventListener('click', () => {
          currentIndex = idx;
          updateSlider();
          stopAutoPlay();
          startAutoPlay();
        });
      });
    }

    // İlk Animasyon
    animateContent(0);
    if (slideCount > 1) {
      startAutoPlay();
    }

    // Touch events for mobile swipe
    let touchStartX = 0;
    let touchEndX = 0;
    
    carouselInner.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
      stopAutoPlay();
    }, {passive: true});

    carouselInner.addEventListener('touchend', e => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
      if (slideCount > 1) startAutoPlay();
    }, {passive: true});

    function handleSwipe() {
      if (slideCount <= 1) return;
      if (touchEndX < touchStartX - 50) nextSlide();
      if (touchEndX > touchStartX + 50) prevSlide();
    }
  });
</script>
