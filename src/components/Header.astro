---
<header class="sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        {settings.site_logo && (settings.site_logo.startsWith('http') || settings.site_logo.startsWith('/')) ? (
          <img src={settings.site_logo} alt={settings.site_title || 'Logo'} class="h-8 w-auto object-contain" />
        ) : (
          <span class="text-2xl font-black tracking-tighter bg-gradient-to-r from-orange-500 to-purple-600 bg-clip-text text-transparent">
            {settings.site_logo || settings.site_title || 'LAF'}
          </span>
        )}
      </a>

      <!-- Sağ İkonlar (dark/light uyumlu) -->
      <div class="flex items-center gap-4">
        <!-- Arama İkonu -->
        <a href="/arama" class="text-gray-700 dark:text-white hover:text-orange-500 transition text-xl">
          <i class="fas fa-search"></i>
        </a>
        
        <!-- Kullanıcı İkonu -->
        <a href="/profil" class="text-gray-700 dark:text-white hover:text-orange-500 transition text-xl">
          <i class="far fa-user-circle"></i>
        </a>

        <!-- Sepet İkonu -->
        {settings.site_mode !== 'blog' && settings.site_mode !== 'corporate' && settings.site_mode !== 'mixed2a' ? (
          <div class="relative">
            <a href="/sepet" class="text-gray-700 dark:text-white hover:text-orange-500 transition text-xl">
              <i class="fas fa-shopping-cart"></i>
            </a>
            <span id="headerCartBadge" class="absolute -top-2 -right-2 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center opacity-0 transition-opacity pointer-events-none">0</span>
          </div>
        ) : null}
        
        <!-- Bildirim İkonu -->
        <div class="relative">
          <a href="/profil" class="text-gray-700 dark:text-white hover:text-red-500 transition text-xl">
            <i class="far fa-bell"></i>
          </a>
          <span class="absolute -top-1 -right-2 w-2 h-2 bg-red-500 rounded-full animate-pulse pointer-events-none"></span>
        </div>

        <!-- Sosyal Medya İkon Modülü -->
        {displayedSocials.length > 0 && (
          <div class="flex items-center gap-3 social-media-group">
            {displayedSocials.map((social: any) => (
              <a href={social.url} target="_blank" rel="noopener noreferrer" class={`social-icon-link social-icon-${social.id} hover:scale-110 transition-transform duration-200`} title={social.name}>
                <Fragment set:html={getSvgForPlatform(social.id)} />
              </a>
            ))}
            {showMore && (
              <a href="/social-media" class="social-icon-link social-icon-more hover:text-orange-500 hover:scale-110 transition-transform duration-200" title="Daha Fazla">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                </svg>
              </a>
            )}
          </div>
        )}
        
        <!-- Menü İkonu (sandwich) -->
        <button id="menuIconBtn" class="text-gray-700 dark:text-white hover:text-orange-500 transition text-xl">
          <i class="fas fa-bars"></i>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Off-Canvas Yan Menü -->
<div id="sideMenuOverlay" class="fixed inset-0 bg-black/50 z-[60] hidden opacity-0 transition-opacity duration-300"></div>
<div id="sideMenu" class="fixed top-0 right-0 h-full w-80 bg-white dark:bg-gray-900 shadow-2xl z-[70] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
  <div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-800">
    <span class="text-xl font-bold bg-gradient-to-r from-orange-500 to-purple-600 bg-clip-text text-transparent">Menü</span>
    <button id="closeMenuBtn" class="text-gray-500 hover:text-red-500 transition text-2xl p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800">
      <i class="fas fa-times"></i>
    </button>
  </div>
  <div class="flex-1 overflow-y-auto p-6">
    <ul class="space-y-2">
      {menuItems.map((item: any) => (
        <li>
          <a href={item.url} class="block px-4 py-3 rounded-lg text-gray-700 dark:text-gray-200 hover:bg-orange-50 dark:hover:bg-gray-800 hover:text-orange-500 transition font-medium">
            <i class="fas fa-link w-6 text-gray-400"></i> {item.title}
          </a>
        </li>
      ))}
    </ul>
  </div>
  <div class="p-6 border-t border-gray-200 dark:border-gray-800 text-center text-sm text-gray-500">
    <p>&copy; 2026 Laflaf.net</p>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    // Menü butonu ve Yan Menü İşlemleri
    const menuBtn = document.getElementById('menuIconBtn');
    const closeMenuBtn = document.getElementById('closeMenuBtn');
    const sideMenu = document.getElementById('sideMenu');
    const sideMenuOverlay = document.getElementById('sideMenuOverlay');

    function openMenu() {
      if (sideMenu && sideMenuOverlay) {
        sideMenuOverlay.classList.remove('hidden');
        // Force reflow
        void sideMenuOverlay.offsetWidth;
        sideMenuOverlay.classList.remove('opacity-0');
        sideMenu.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeMenu() {
      if (sideMenu && sideMenuOverlay) {
        sideMenu.classList.add('translate-x-full');
        sideMenuOverlay.classList.add('opacity-0');
        setTimeout(() => {
          sideMenuOverlay.classList.add('hidden');
          document.body.style.overflow = '';
        }, 300);
      }
    }

    if (menuBtn && closeMenuBtn && sideMenu && sideMenuOverlay) {
      menuBtn.addEventListener('click', openMenu);
      closeMenuBtn.addEventListener('click', closeMenu);
      sideMenuOverlay.addEventListener('click', closeMenu);
    }
    
    // Header Cart Badge Update Logic
    const headerCartBadge = document.getElementById('headerCartBadge');
    
    function updateHeaderCartBadge() {
      if (!headerCartBadge) return;
      try {
        const cartStr = localStorage.getItem('laflaf_cart');
        if (cartStr) {
          const cart = JSON.parse(cartStr);
          const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
          if (totalItems > 0) {
            headerCartBadge.textContent = totalItems.toString();
            headerCartBadge.classList.remove('opacity-0');
          } else {
            headerCartBadge.classList.add('opacity-0');
          }
        } else {
          headerCartBadge.classList.add('opacity-0');
        }
      } catch (e) {
        console.error('Error updating cart badge', e);
      }
    }

    // İlk yüklemede badge güncelle
    if (headerCartBadge) {
      updateHeaderCartBadge();
      
      // Başka sekmelerden localStorage değişirse tetiklensin
      window.addEventListener('storage', (e) => {
        if (e.key === 'laflaf_cart') {
          updateHeaderCartBadge();
        }
      });
      
      // Aynı sayfada sepete ekleme yapıldığında tetiklenmesi için custom event
      window.addEventListener('cart_updated', () => {
        updateHeaderCartBadge();
      });
    }

    // Window event listener for opening from other components if needed
    window.addEventListener('openSideMenu', openMenu);
  });
</script>

<style>
  .social-media-group {
    display: flex;
    align-items: center;
    gap: 0.75rem; /* gap-3 */
  }
  .social-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280; /* text-gray-500 */
    transition: color 0.3s ease;
  }
  :global(.dark) .social-icon-link {
    color: #9ca3af; /* text-gray-400 */
  }
  
  .social-icon-x:hover { color: #000000; }
  :global(.dark) .social-icon-x:hover { color: #ffffff; }
  .social-icon-facebook:hover { color: #1877F2; }
  .social-icon-instagram:hover { color: #E1306C; }
  .social-icon-linkedin:hover { color: #0A66C2; }
  .social-icon-pinterest:hover { color: #BD081C; }
  .social-icon-youtube:hover { color: #FF0000; }
  .social-icon-tiktok:hover { color: #010101; }
  :global(.dark) .social-icon-tiktok:hover { color: #ffffff; }
  .social-icon-medium:hover { color: #000000; }
  :global(.dark) .social-icon-medium:hover { color: #ffffff; }
  .social-icon-whatsapp:hover { color: #25D366; }
  .social-icon-telegram:hover { color: #0088cc; }
  .social-icon-phone:hover { color: #25D366; }
  .social-icon-email:hover { color: #ea4335; }
</style>