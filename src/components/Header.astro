---
import { getSettings } from '../lib/db';

const dbBinding = Astro.locals.runtime?.env?.DB;
const settings = await getSettings(dbBinding);
const menuItems = settings.menu_items ? JSON.parse(settings.menu_items) : [
  { title: 'Ana Sayfa', url: '/' },
  { title: 'Yaşam', url: '/yasam' },
  { title: 'Teknoloji', url: '/teknoloji' },
  { title: 'Kadın', url: '/kadin' },
  { title: 'Otomobil', url: '/otomobil' },
  { title: 'Anne & Bebek', url: '/anne-bebek' },
];

// Social media icons logic
let rawSocialLinks = [];
try {
  rawSocialLinks = settings.social_media_links ? JSON.parse(settings.social_media_links) : [];
} catch (e) {
  console.error("Error parsing social_media_links", e);
}

const activeSocials = rawSocialLinks.filter((item: any) => item.active && item.url);

const maxVisibleSocials = 5;
let displayedSocials = [];
let showMore = false;

if (activeSocials.length <= maxVisibleSocials) {
  displayedSocials = activeSocials;
  showMore = false;
} else {
  displayedSocials = activeSocials.slice(0, 4);
  showMore = true;
}

